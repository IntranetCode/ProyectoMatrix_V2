@{
    Layout = "_LayoutComunicados";
    ViewData["Title"] = "Streaming opc2";
}

<style>
    .stream-iframe-page {
        min-height: calc(100vh - 120px);
        padding: 1rem;
    }

    .stream-iframe-shell {
        width: 100%;
        height: calc(100vh - 170px);
        min-height: 620px;
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid #e5e7eb;
        background: #0f172a;
        box-shadow: 0 18px 40px rgba(15, 23, 42, .16);
    }

        .stream-iframe-shell iframe {
            width: 100%;
            height: 100%;
            border: 0;
            display: block;
            background: #fff;
        }

    .stream-iframe-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

        .stream-iframe-top h2 {
            margin: 0;
            font-weight: 900;
        }

    .stream-iframe-actions {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }
</style>

<div class="container-fluid stream-iframe-page">
    <div class="stream-iframe-top">
        <div>
            <h2>Streaming opc2</h2>
            <p class="text-muted mb-0">Vista alternativa con iframe.</p>
        </div>

        <div class="stream-iframe-actions">
            <a asp-controller="Streaming" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left"></i>
                Volver
            </a>
        </div>
    </div>

    <div class="stream-iframe-shell">
        <iframe src="https://www.youtube.com/embed/U5KnFdJgqJ8"
                title="Streaming opc2"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen>
        </iframe>
    </div>
</div>