@{
    ViewData["Title"] = "Directorio";
    Layout = "_LayoutComunicados";
}

<style>
    .full-width-page {
        padding: 0;
        margin: 0;
        width: 100%;
    }

    .directory-header {
        padding: 1.5rem 2rem;
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .directory-header h1 {
            color: #1a237e;
            font-weight: 800;
            border-left: 6px solid #ff6d00;
            padding-left: 15px;
            margin: 0;
            font-size: 1.5rem;
        }

    .iframe-full-container {
        width: 100%;
        height: calc(100vh - 80px); /* Ajusta restando la altura del navbar/header */
        overflow: hidden;
        background: #fff;
    }

        .iframe-full-container iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

    @@media (max-width: 768px) {
        .directory-header

    {
        padding: 1rem;
        flex-direction: column;
        gap: 10px;
        align-items: flex-start;
    }

    .iframe-full-container {
        height: calc(100vh - 120px); /* Más espacio para el header apilado */
    }

    .directory-header h1 {
        font-size: 1.2rem;
    }

    .btn-regresar {
        width: 100%;
        text-align: center;
    }

    }
</style>

<div class="full-width-page">
    <div class="directory-header">
        <h1>
            <i class="fas fa-address-book me-2"></i> Directorio
        </h1>
        <a class="btn btn-outline-secondary btn-regresar" href="javascript:history.back()">
            <i class="fas fa-arrow-left me-2"></i> Regresar al menú
        </a>
    </div>

    <div class="iframe-full-container">

        
              <iframe src="https://soporte.nsgroup.com.mx/Agenda/Integracion?token=NSGroup_Intranet_2026_Xyz"
                title="Directorio Telefónico"
                allowfullscreen>
        </iframe>

     


    </div>

</div>