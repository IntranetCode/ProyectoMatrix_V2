@model ProyectoMatrix.Models.VacacionesBandejaRHPantallaVm

@{
    ViewData["Title"] = "Bandeja RH - Vacaciones";
    Layout = "_LayoutComunicados";
    var tab = (Model?.Tab ?? "autorizadas").ToLower();
}

<style>
    .bandeja-rh-page {
        background: #f5f7fb;
        color: #26324a;
        padding-bottom: 30px;
    }

    .bandeja-rh-page h2 {
        color: #16376d;
        font-weight: 800;
        font-size: 2rem;
        padding-left: 18px;
        margin-top: 22px;
        margin-bottom: 26px;
        border-left: 6px solid #f47b20;
        letter-spacing: .2px;
        text-shadow: 0 2px 5px rgba(22, 55, 109, .08);
    }

    .bandeja-rh-page .row.g-2.mb-3 {
        margin-bottom: 24px !important;
    }

    .bandeja-rh-page .btn {
        border-radius: 10px !important;
        font-weight: 700;
        transition: all .2s ease;
    }

    .bandeja-rh-page .btn:hover {
        transform: translateY(-1px);
    }

    .bandeja-rh-page .btn-outline-primary {
        color: #173b78 !important;
        border: 1px solid #cbd8ef !important;
        background: #ffffff !important;
        padding: 12px 20px;
        box-shadow: 0 4px 12px rgba(22, 55, 109, .06);
    }

    .bandeja-rh-page .btn-outline-primary:hover {
        color: #173b78 !important;
        border-color: #f47b20 !important;
        background: #fff7f0 !important;
        box-shadow: 0 8px 18px rgba(244, 123, 32, .16);
    }

    .bandeja-rh-page .btn-primary {
        background: linear-gradient(135deg, #173b78, #234f9a) !important;
        border: none !important;
        color: #ffffff !important;
        padding: 12px 20px;
        box-shadow: 0 8px 20px rgba(22, 55, 109, .28);
        position: relative;
    }

    .bandeja-rh-page .btn-primary::after {
        content: "";
        position: absolute;
        left: 10px;
        right: 10px;
        bottom: -3px;
        height: 3px;
        border-radius: 20px;
        background: #f47b20;
    }

    .bandeja-rh-page .modal-footer {
        border-top: 1px solid #e5ebf5;
        margin-top: 12px;
        padding-top: 16px;
    }

    .bandeja-rh-page .btn-secondary {
        background: #6f7b90 !important;
        border: none !important;
        color: #ffffff !important;
        padding: 10px 18px;
        box-shadow: 0 5px 14px rgba(111, 123, 144, .20);
    }

    .bandeja-rh-page .input-group,
    .bandeja-rh-page form.row.g-2 {
        background: #ffffff;
        padding: 18px;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(22, 55, 109, .07);
        border: 1px solid #e4ebf7;
    }

    .bandeja-rh-page .form-control,
    .bandeja-rh-page .form-control-sm {
        border: 1px solid #d6e0ef;
        border-radius: 10px !important;
        background: #ffffff;
        color: #26324a;
        padding: 11px 14px;
        font-weight: 500;
    }

    .bandeja-rh-page .form-control:focus,
    .bandeja-rh-page .form-control-sm:focus {
        border-color: #f47b20;
        box-shadow: 0 0 0 .18rem rgba(244, 123, 32, .17);
    }

    .bandeja-rh-page .table-responsive {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: visible;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 10px 28px rgba(22, 55, 109, .08);
    }

    .bandeja-rh-page .table {
        background: #ffffff;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid #e2e9f5;
        margin-top: 18px;
        margin-bottom: 0;
    }

    .bandeja-rh-page .table thead th {
        background: linear-gradient(135deg, #173b78, #234f9a) !important;
        color: #ffffff !important;
        font-size: .76rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: 16px 12px;
        border: none !important;
        text-align: center;
        font-weight: 800;
    }

    .bandeja-rh-page .table tbody td {
        padding: 15px 12px;
        vertical-align: middle;
        border-bottom: 1px solid #edf2f8;
        color: #26324a;
        font-size: .92rem;
    }

    .bandeja-rh-page .table-striped tbody tr:nth-of-type(odd) {
        background-color: #fbfdff !important;
    }

    .bandeja-rh-page .table tbody tr:hover {
        background: #fff5ed !important;
        box-shadow: inset 4px 0 0 #f47b20;
    }

    .bandeja-rh-page .table td strong {
        color: #ff5f15;
        font-size: 1.04rem;
        font-weight: 900;
    }

    .bandeja-rh-page .tabla-usuarios-rh {
        width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        border-radius: 18px;
        background: #ffffff;
    }

    .bandeja-rh-page .tabla-usuarios-rh table {
        min-width: 1450px;
        margin-top: 0;
        margin-bottom: 0;
    }

    .bandeja-rh-page .tabla-usuarios-rh th,
    .bandeja-rh-page .tabla-usuarios-rh td {
        white-space: nowrap;
    }
</style>

<div class="bandeja-rh-page">

<h2>Bandeja RH - Vacaciones</h2>

@if (!string.IsNullOrEmpty(ViewBag.Error as string))
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="row g-2 mb-3">
    <div class="col-auto">
        <a asp-action="BandejaRH" asp-route-tab="autorizadas" class="btn @(tab == "autorizadas" ? "btn-primary" : "btn-outline-primary")">
            <i class="fa-solid fa-clipboard-check me-2"></i> Autorizadas
        </a>
    </div>

    <div class="col-auto">
        <a asp-action="BandejaRH" asp-route-tab="registradas" class="btn @(tab == "registradas" ? "btn-primary" : "btn-outline-primary")">
            <i class="fa-solid fa-circle-check me-2"></i> Registradas por RRHH
        </a>
    </div>

    <div class="col-auto">
        <a asp-action="BandejaRH" asp-route-tab="usuarios" class="btn @(tab == "usuarios" ? "btn-primary" : "btn-outline-primary")">
            <i class="fa-solid fa-users me-2"></i> Saldo de usuarios
        </a>
    </div>

    <div class="col-auto">
        <a asp-action="BandejaRH" asp-route-tab="vistaexcel" class="btn @(tab == "vistaexcel" ? "btn-primary" : "btn-outline-primary")">
            <i class="fa-solid fa-chart-column me-2"></i> Vista general
        </a>
    </div>
</div>


<div class="modal-footer">
    <a asp-controller="Vacaciones" asp-action="MisVacaciones" asp-route-id="1" class="btn btn-secondary">
        Volver a Mis Vacaciones
    </a>
</div>

@if (tab == "vistaexcel")
{
    <form method="get" asp-action="BandejaRH" class="row g-2 mb-3">
        <input type="hidden" name="tab" value="vistaexcel" />

        <div class="col-sm-6 col-md-4 col-lg-3">
            <input type="text" name="q" value="@ViewBag.Q"
                   class="form-control form-control-sm"
                   placeholder="Buscar por nombre o N°2..." />
        </div>

        <div class="col-auto">
            <button class="btn btn-sm btn-outline-secondary" type="submit">Buscar</button>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Q as string))
        {
            <div class="col-auto">
                <a class="btn btn-sm btn-outline-danger"
                   asp-action="BandejaRH" asp-route-tab="vistaexcel">
                    Limpiar
                </a>
            </div>
        }
    </form>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>N°</th>
                    <th>N°2</th>
                    <th>Sociedad</th>
                    <th>Nombre</th>
                    <th>Puesto</th>
                    <th>Departamento</th>
                    <th>F. de ingreso</th>
                    <th>HOY</th>
                    <th>Antigüedad (AA-MM)</th>
                    <th>Antigüedad (años)</th>
                    <th>Días correspond.</th>
                    <th>Días pendientes</th>
                    <th>Días disponibles</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.VistaExcel != null && Model.VistaExcel.Any())
                {
                    foreach (var x in Model.VistaExcel)
                    {
                        <tr>
                            <td>@x.N</td>
                            <td>@x.N2</td>
                            <td>@x.Sociedad</td>
                            <td>@x.Nombre</td>
                            <td>@x.Puesto</td>
                            <td>@x.Departamento</td>
                            <td>@x.FechaIngreso.ToString("dd/MM/yyyy")</td>
                            <td>@x.Hoy.ToString("dd/MM/yyyy")</td>
                            <td>@x.AntiguedadAniosMeses</td>
                            <td>@x.AntiguedadAnios</td>
                            <td>@x.DiasCorrespondientes</td>
                            <td>@x.DiasPendientes</td>
                            <td><strong>@x.DiasDisponibles</strong></td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="13" class="text-center text-muted">No hay datos para mostrar.</td></tr>
                }
            </tbody>
        </table>
    </div>
}
else if (tab == "usuarios")
{
    <div class="mb-3">
        <form method="get" action="@Url.Action("BandejaRH")">
            <input type="hidden" name="tab" value="usuarios" />
            <div class="input-group">
                <input type="text" name="q" class="form-control" placeholder="Buscar por nombre o # empleado..." value="@ViewBag.Q">
                <button class="btn btn-outline-secondary" type="submit">Buscar</button>
                <a href="@Url.Action("BandejaRH", new { tab = "usuarios" })" class="btn btn-outline-danger">Limpiar</a>

                <button type="button" class="btn btn-danger" onclick="abrirModalMasivo()">
                    <i class="fas fa-users-slash me-1"></i> Descuento Masivo
                </button>
            </div>
        </form>
    </div>
    <div class="table-responsive tabla-usuarios-rh">
        <table class="table table-sm table-striped align-middle w-100">
        <thead>
            <tr>
                <th>Empleado</th>
                <th>Clave nómina</th>
                <th>Nombre</th>
                <th>Puesto</th>
                <th>Año</th>
                <th>Correspond.</th>
                <th>Extra</th>
                <th>Tomados</th>
                <th>Caduc.</th>
                <th>Disponibles</th>
                <th>Anticipadas Reg.</th>
                <th>Anticipadas Por Reg.</th>
                <th style="min-width: 280px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.Usuarios != null && Model.Usuarios.Any())
            {
                foreach (var u in Model.Usuarios)
                {
                    <tr>
                        <td>@u.NumeroEmpleado</td>
                        <td>@u.ClaveEmpleadoNomina</td>
                        <td>@u.NombreCompleto</td>
                        <td>@u.Puesto</td>
                        <td>@u.Anio</td>
                        <td>@u.DiasCorrespondientes</td>
                        <td>@u.DiasExtra</td>
                        <td>@u.DiasTomados</td>
                        <td>@u.DiasCaducados</td>
                        <td><strong>@u.DiasDisponibles</strong></td>
                        <td>@u.AnticipadasRegistradas</td>
                        <td>@u.AnticipadasPorRegistrar</td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center">
                                <button class="btn btn-sm btn-outline-primary"
                                        onclick="abrirModalAjuste(@u.PersonaID, '@u.NombreCompleto')">
                                    <i class="fas fa-plus-circle me-1"></i> Historial
                                </button>

                                <button class="btn btn-sm btn-success text-white fw-semibold"
                                        onclick="abrirModalDiasExtra(@u.PersonaID, '@u.NombreCompleto')">
                                    <i class="fas fa-gift me-1"></i> Días Extra
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="13" class="text-muted text-center">No hay usuarios para mostrar.</td></tr>
            }
        </tbody>
    </table>
    </div>
}
else
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Folio</th>
                <th>Empleado</th>
                <th>Clave nómina</th>
                <th>Colaborador</th>
                <th>Periodo</th>
                <th>Días</th>
                <th>Disp.</th>
                <th>Jefe</th>
                <th>RH</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.Solicitudes != null && Model.Solicitudes.Any())
            {
                foreach (var s in Model.Solicitudes)
                {
                    <tr>
                        <td>@s.Folio</td>
                        <td>@s.NumeroEmpleado</td>
                        <td>@s.ClaveEmpleadoNomina</td>
                        <td>
                            @s.NombreCompleto
                            <div class="text-muted" style="font-size: 0.85em;">
                                @s.Puesto | Año saldo: @s.AnioSaldo
                            </div>
                        </td>
                        <td>@s.FechaInicio.ToString("dd/MM/yyyy") - @s.FechaFin.ToString("dd/MM/yyyy")</td>
                        <td>@s.DiasSolicitados</td>
                        <td><strong>@s.DiasDisponibles</strong></td>
                        <td>@s.EstadoAutorizacion</td>
                        <td>@s.EstadoRecursosHumanos</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="9" class="text-muted">No hay registros para esta pestaña.</td></tr>
            }
        </tbody>
    </table>
}

@* Modales del sistema *@

<div class="modal fade" id="modalAjusteManual" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Registrar Vacaciones (Historial)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Cargando historial para: <strong id="lblNombreEmpleado"></strong></p>
                <input type="hidden" id="txtPersonaID" />

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label">Fecha Inicio</label>
                        <input type="date" id="txtFechaInicio" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Fecha Fin</label>
                        <input type="date" id="txtFechaFin" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Días a descontar (decimales permitidos)</label>
                        <input type="number" step="0.5" id="txtDiasAjuste" class="form-control" placeholder="Ej. 2" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Observaciones (Referencia)</label>
                        <textarea id="txtObsAjuste" class="form-control" rows="2" placeholder="Ej. Vacaciones tomadas en 2024 antes del sistema"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarAjusteManual()">Guardar Registro</button>
            </div>
        </div>
    </div>
</div>

@* Interfaz para la captura de días de premio (Días Extra) *@
<div class="modal fade" id="modalDiasExtra" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-star me-2"></i>Otorgar Días Extra</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Vas a asignar días adicionales al saldo actual de: <strong id="lblNombreEmpleadoExtra"></strong></p>
                <input type="hidden" id="txtPersonaIDExtra" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Cantidad de días a otorgar:</label>
                    <input type="number" id="txtCantidadDiasExtra" class="form-control" step="0.5" min="0.5" placeholder="Ej. 1 o 2" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Motivo / Justificación:</label>
                    <textarea id="txtMotivoExtra" class="form-control" rows="3" placeholder="Ej. Por trabajar en fin de semana en migración crítica..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success text-white fw-semibold" onclick="guardarDiasExtra()">Confirmar Otorgamiento</button>
            </div>
        </div>
    </div>
</div>
</div>

<script>
    function abrirModalAjuste(personaId, nombre) {
        $('#txtPersonaID').val(personaId);
        $('#lblNombreEmpleado').text(nombre);
        $('#modalAjusteManual').modal('show');
    }

    function guardarAjusteManual() {
        const data = {
            PersonaID: $('#txtPersonaID').val(),
            FechaInicio: $('#txtFechaInicio').val(),
            FechaFin: $('#txtFechaFin').val(),
            DiasATomar: $('#txtDiasAjuste').val(),
            Observaciones: $('#txtObsAjuste').val()
        };

        if (!data.FechaInicio || !data.FechaFin || !data.DiasATomar) {
            Swal.fire('Atención', 'Por favor completa los campos de fechas y días.', 'warning');
            return;
        }

        Swal.fire({
            title: '¿Registrar ajuste?',
            text: "Esto afectará el saldo disponible del usuario de inmediato.",
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: 'Sí, registrar'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('@Url.Action("GuardarAjusteManual", "Vacaciones")', data, function (res) {
                    if (res.success) {
                        Swal.fire('Éxito', res.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                });
            }
        });
    }

    function abrirModalMasivo() {
        Swal.fire({
            title: 'Descuento Masivo de Días',
            html: `
                <input type="number" id="diasMasivo" class="swal2-input" placeholder="Cantidad de días (ej. 1)" step="0.5">
                <textarea id="motivoMasivo" class="swal2-textarea" placeholder="Motivo del descuento masivo..."></textarea>
            `,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Aplicar a TODOS',
            confirmButtonColor: '#dc3545',
            preConfirm: () => {
                const dias = document.getElementById('diasMasivo').value;
                const motivo = document.getElementById('motivoMasivo').value;
                if (!dias || !motivo) {
                    Swal.showValidationMessage('Ambos campos son obligatorios');
                }
                return { dias: dias, motivo: motivo };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('@Url.Action("AplicarDescuentoMasivo", "Vacaciones")', result.value, function(res) {
                    if (res.success) {
                        Swal.fire('Éxito', res.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                });
            }
        });
    }

    /*  Lógica para controlar la ventana emergente de Días Extra */
    function abrirModalDiasExtra(personaId, nombreCompleto) {
        $('#txtPersonaIDExtra').val(personaId);
        $('#lblNombreEmpleadoExtra').text(nombreCompleto);
        $('#txtCantidadDiasExtra').val('');
        $('#txtMotivoExtra').val('');
        $('#modalDiasExtra').modal('show');
    }
        function guardarDiasExtra() {
        const id = $('#txtPersonaIDExtra').val();
        const dias = $('#txtCantidadDiasExtra').val();
        const motivo = $('#txtMotivoExtra').val();

        if (!dias || parseFloat(dias) <= 0) {
            Swal.fire('Atención', 'Por favor ingresa una cantidad válida de días.', 'warning');
            return;
        }

        if (!motivo || motivo.trim().length < 5) {
            Swal.fire('Atención', 'Por favor ingresa una justificación descriptiva (mínimo 5 caracteres).', 'warning');
            return;
        }

        
        const token = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];

        const dataSubmit = {
            PersonaID: parseInt(id),
            DiasRegalo: parseFloat(dias),
            Motivo: motivo,
            __RequestVerificationToken: token 
        };

        $.post('@Url.Action("OtorgarDiasExtra", "Vacaciones")', dataSubmit, function (res) {
            if (res.success) {
                $('#modalDiasExtra').modal('hide');
                Swal.fire('¡Proceso Correcto!', res.message, 'success').then(() => {
                    location.reload();
                });
            } else {
                Swal.fire('Error', res.message, 'error');
            }
        }).fail(function(xhr, status, error) {
            console.error("Detalle del fallo de red:", xhr.status, xhr.responseText);
            Swal.fire('Error', 'No se pudo comunicar con el servidor. Código de estado: ' + xhr.status, 'error');
        });
    }
</script>


