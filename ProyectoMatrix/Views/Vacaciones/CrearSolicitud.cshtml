@model ProyectoMatrix.Models.CrearSolicitudVacacionesVm

@{
    ViewData["Title"] = "Solicitar vacaciones";
    Layout = "_LayoutComunicados";
}
<link href="~/css/vacaciones-modern.css" rel="stylesheet" />



<div class="vacaciones-page">
    <h2>Solicitar vacaciones</h2>

    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="vac-hero-grid">
        <section class="vac-panel">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                <div>
                    <h5 class="mt-0 mb-2">Periodo solicitado</h5>
                    <p class="text-muted mb-0">Selecciona el rango de fechas que deseas solicitar. El sistema calculará los días hábiles al guardar.</p>
                </div>
                <div class="vac-kpi">
                    <span>Días disponibles</span>
                    <strong>@Model.DiasDisponiblesActuales</strong>
                </div>
            </div>

            <form asp-action="CrearSolicitud" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FechaInicio" class="form-label">Fecha de inicio</label>
                        <input asp-for="FechaInicio" class="form-control" type="date" />
                        <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FechaFin" class="form-label">Fecha de fin</label>
                        <input asp-for="FechaFin" class="form-control" type="date" />
                        <span asp-validation-for="FechaFin" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Observaciones" class="form-label">Observaciones</label>
                        <textarea asp-for="Observaciones" class="form-control" rows="4" placeholder="Agrega un comentario opcional para tu jefe inmediato."></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-1"></i> Enviar solicitud
                    </button>
                    <a asp-action="MisVacaciones" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Regresar
                    </a>
                </div>
            </form>
        </section>

        <aside class="vac-panel vac-panel-soft">
            <h5 class="mt-0 mb-3">Flujo de aprobación</h5>
            <div class="d-grid gap-3">
                <div class="d-flex gap-3 align-items-start">
                    <span class="badge bg-warning-subtle">1</span>
                    <div>
                        <strong>Solicitud pendiente</strong>
                        <p class="text-muted mb-0 small">Tu jefe recibirá una notificación para revisar el periodo.</p>
                    </div>
                </div>
                <div class="d-flex gap-3 align-items-start">
                    <span class="badge bg-warning-subtle">2</span>
                    <div>
                        <strong>Autorización del jefe</strong>
                        <p class="text-muted mb-0 small">Mientras siga pendiente, podrás editar o cancelar tu solicitud.</p>
                    </div>
                </div>
                <div class="d-flex gap-3 align-items-start">
                    <span class="badge bg-success-subtle">3</span>
                    <div>
                        <strong>Registro de RRHH</strong>
                        <p class="text-muted mb-0 small">Al registrarse, los días se descuentan de tu saldo disponible.</p>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}