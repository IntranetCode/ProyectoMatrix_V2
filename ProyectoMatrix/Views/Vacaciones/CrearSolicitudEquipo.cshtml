@model ProyectoMatrix.Models.CrearSolicitudEquipoVm
@{
    ViewData["Title"] = "Solicitar por el equipo";
    Layout = "_LayoutComunicados";
}
<link href="~/css/vacaciones-modern.css" rel="stylesheet" />



<div class="vacaciones-page">
    <h2>Solicitar vacaciones por colaborador</h2>

    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="vac-hero-grid">
        <section class="vac-panel">
            <h5 class="mt-0 mb-2">Datos de la solicitud</h5>
            <p class="text-muted mb-4">Selecciona a un integrante de tu equipo y captura el periodo de vacaciones.</p>

            <div id="infoSaldo" class="alert alert-info d-none">
                <strong>Saldo disponible de <span id="nombreEmpleadoSel"></span>:</strong>
                <span id="valorSaldo" class="fw-bold">0</span> días.
            </div>

            <form asp-action="CrearSolicitudEquipo" method="post" id="formSolicitud">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Colaborador</label>
                        <select asp-for="PersonaID" asp-items="Model.MiEquipo" class="form-select" id="selectPersona">
                            <option value="">-- Seleccione un miembro del equipo --</option>
                        </select>
                        <span asp-validation-for="PersonaID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FechaInicio" class="form-label">Fecha de inicio</label>
                        <input asp-for="FechaInicio" class="form-control" type="date" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FechaFin" class="form-label">Fecha de fin</label>
                        <input asp-for="FechaFin" class="form-control" type="date" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Observaciones" class="form-label">Motivo / observaciones</label>
                        <textarea asp-for="Observaciones" class="form-control" rows="4" placeholder="Describe el motivo por el que se registra desde el perfil de jefe."></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <button type="submit" class="btn btn-primary" id="btnEnviar" disabled>
                        <i class="fas fa-check-circle me-1"></i> Crear solicitud oficial
                    </button>
                    <a asp-action="SolicitudesPendientesJefe" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Regresar
                    </a>
                </div>
            </form>
        </section>

        <aside class="vac-panel vac-panel-soft">
            <h5 class="mt-0 mb-3">Validación rápida</h5>
            <p class="text-muted">El botón se habilita cuando seleccionas a un colaborador y se obtiene su saldo disponible.</p>
            <div class="d-grid gap-2">
                <span class="badge bg-success-subtle text-start">Consulta de saldo en línea</span>
                <span class="badge bg-warning-subtle text-start">Registro con origen JefeDirecto</span>
                <span class="badge bg-success-subtle text-start">Bandeja de seguimiento</span>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#selectPersona').change(function () {
                const personaId = $(this).val();
                const nombre = $("#selectPersona option:selected").text();

                if (personaId) {
                    $.get('@Url.Action("ObtenerSaldoColaborador", "Vacaciones")', { personaId: personaId }, function (res) {
                        if (res.success) {
                            $('#nombreEmpleadoSel').text(nombre);
                            $('#valorSaldo').text(res.saldo);
                            $('#infoSaldo').removeClass('d-none alert-warning alert-info')
                                .addClass(res.saldo <= 0 ? 'alert-warning' : 'alert-info');
                            $('#btnEnviar').prop('disabled', false);
                        } else {
                            $('#infoSaldo').removeClass('d-none alert-info').addClass('alert-warning').text(res.message || 'No se pudo obtener el saldo.');
                            $('#btnEnviar').prop('disabled', true);
                        }
                    });
                } else {
                    $('#infoSaldo').addClass('d-none');
                    $('#btnEnviar').prop('disabled', true);
                }
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}