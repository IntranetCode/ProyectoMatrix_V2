@model ProyectoMatrix.Models.MisVacacionesVm

@{
    ViewData["Title"] = "Mis vacaciones";
    Layout = "_LayoutComunicados";

    // Datos básicos (tomados del primer registro si existe)
    var fechaIngreso = Model?.Solicitudes?.FirstOrDefault()?.FechaIngreso;

    // Estados: ajústalos si tus textos exactos son otros
    var solicitadas = Model?.Solicitudes?
        .Where(s => (s.EstadoAutorizacion ?? "").Trim().ToLower() != "rechazada"
                 && (s.EstadoRecursosHumanos ?? "").Trim().ToLower() != "rechazada"
                 && (s.EstadoAutorizacion ?? "").Trim().ToLower() != "autorizada")
        .OrderByDescending(s => s.FechaSolicitud)
        .ToList() ?? new List<ProyectoMatrix.Models.VacacionesSolicitudItemVm>();

    var autorizadas = Model?.Solicitudes?
        .Where(s => (s.EstadoAutorizacion ?? "").Trim().ToLower() == "autorizada"
                 && (s.EstadoRecursosHumanos ?? "").Trim().ToLower() == "autorizada")
        .OrderByDescending(s => s.FechaSolicitud)
        .ToList() ?? new List<ProyectoMatrix.Models.VacacionesSolicitudItemVm>();

    var rechazadas = Model?.Solicitudes?
        .Where(s => (s.EstadoAutorizacion ?? "").Trim().ToLower() == "rechazada"
                 || (s.EstadoRecursosHumanos ?? "").Trim().ToLower() == "rechazada")
        .OrderByDescending(s => s.FechaSolicitud)
        .ToList() ?? new List<ProyectoMatrix.Models.VacacionesSolicitudItemVm>();
}

<link href="~/css/stylesVacacionesMV.css" rel="stylesheet" />

<h2>Mis vacaciones</h2>

@if (TempData["MensajeVacaciones"] != null)
{
    <div class="alert alert-success">
        @TempData["MensajeVacaciones"]
    </div>
}

<div class="mb-3">
    <a asp-action="CrearSolicitud" class="btn btn-primary">Solicitar vacaciones</a>

    @if (ViewBag.EsJefeInmediato == true)
    {
        <a asp-action="SolicitudesPendientesJefe" class="btn btn-outline-secondary ms-2">
            Solicitudes de mi equipo
        </a>
    }

    @if (ViewBag.EsUsuarioRH == true)
    {
        <a asp-action="SolicitudesPendientesRH" class="btn btn-outline-warning ms-2">
            Solicitudes para registro RH
        </a>

        <a asp-action="BandejaRH" asp-route-filtro="por_registrar" class="btn btn-outline-info ms-2">
            Bandeja RH (consulta + saldo)
        </a>
    }
</div>

@if (!string.IsNullOrEmpty(ViewBag.Error as string))
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model != null)
{
    <h4>@Model.NombreCompleto (@Model.NumeroEmpleado)</h4>

    <!-- ====== TARJETA SUPERIOR: DATOS BÁSICOS ====== -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">Fecha de ingreso</div>
                    <div class="fw-semibold">
                        @(fechaIngreso.HasValue? fechaIngreso.Value.ToString("dd/MM/yyyy") : "—")
                    </div>
                </div>

                <div class="col-md-8">
                    @if (Model.ResumenActual != null)
                    {
                        <div class="row g-3">
                            <div class="col-6 col-lg-3">
                                <div class="text-muted small">Año</div>
                                <div class="fw-semibold">@Model.ResumenActual.Anio</div>
                            </div>
                            <div class="col-6 col-lg-3">
                                <div class="text-muted small">Corresponden</div>
                                <div class="fw-semibold">@Model.ResumenActual.DiasCorrespondientes</div>
                            </div>
                            <div class="col-6 col-lg-3">
                                <div class="text-muted small">Tomados</div>
                                <div class="fw-semibold">@Model.ResumenActual.DiasTomados</div>
                            </div>
                            <div class="col-6 col-lg-3">
                                <div class="text-muted small">Disponibles</div>
                                <div class="fw-semibold">@Model.ResumenActual.DiasDisponibles</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No hay resumen de saldo disponible.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ====== HISTORIAL POR SECCIONES ====== -->

    <h5 class="mt-3">Vacaciones solicitadas</h5>
    @Html.Partial("_TablaSolicitudesVacaciones", solicitadas)

    <h5 class="mt-4">Vacaciones autorizadas (historial)</h5>
    @Html.Partial("_TablaSolicitudesVacaciones", autorizadas)

    <h5 class="mt-4">Vacaciones rechazadas (historial)</h5>
    @Html.Partial("_TablaSolicitudesVacaciones", rechazadas)
}
