@model ProyectoMatrix.Models.MisVacacionesVm


@{
    ViewData["Title"] = "Mis vacaciones";
    Layout = "_LayoutComunicados";

    // Datos básicos (tomados del primer registro si existe)
    var fechaIngreso = Model?.Solicitudes?.FirstOrDefault()?.FechaIngreso;

    // Estados: ajústalos si tus textos exactos son otros
    var solicitadas = Model?.Solicitudes?
        .Where(s => (s.EstadoAutorizacion ?? "").Trim().ToLower() != "rechazada"
                 && (s.EstadoRecursosHumanos ?? "").Trim().ToLower() != "rechazada"
                 && (s.EstadoAutorizacion ?? "").Trim().ToLower() != "autorizada")
        .OrderByDescending(s => s.FechaSolicitud)
        .ToList() ?? new List<ProyectoMatrix.Models.VacacionesSolicitudItemVm>();

    var autorizadas = Model?.Solicitudes?
         .Where(s => (s.EstadoAutorizacion ?? "").Trim().ToLower() == "autorizada"
                  && ((s.EstadoRecursosHumanos ?? "").Trim().ToLower() == "autorizada"
                   || (s.EstadoRecursosHumanos ?? "").Trim().ToLower() == "registrado"))
         .OrderByDescending(s => s.FechaSolicitud)
         .ToList() ?? new List<ProyectoMatrix.Models.VacacionesSolicitudItemVm>();

    var rechazadas = Model?.Solicitudes?
        .Where(s => (s.EstadoAutorizacion ?? "").Trim().ToLower() == "rechazada"
                 || (s.EstadoRecursosHumanos ?? "").Trim().ToLower() == "rechazada"
                 || (s.EstadoRecursosHumanos ?? "").Trim().ToLower() == "cancelada")
        .OrderByDescending(s => s.FechaSolicitud)
        .ToList() ?? new List<ProyectoMatrix.Models.VacacionesSolicitudItemVm>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<link href="~/css/stylesVacacionesMV.css" rel="stylesheet" />


<h2>Mis vacaciones</h2>

@if (TempData["MensajeVacaciones"] != null)
{
    <div class="alert alert-success">
        @TempData["MensajeVacaciones"]
    </div>
}

<div class="mb-3">
    <div class="mb-3">
        @* Si tiene saldo o ya tiene permiso de adelantadas, botón normal *@
        @if (Model.ResumenActual != null && (Model.ResumenActual.DiasDisponibles > 0 || ViewBag.PermiteAdelantadas == true))
        {
            <a asp-action="CrearSolicitud" class="btn btn-primary">Solicitar vacaciones</a>
        }
        else
        {
            @* Si NO tiene saldo y NO tiene permiso, botón de excepción *@
            <button type="button" class="btn btn-warning" onclick="abrirModalExcepcion()">
                <i class="fas fa-lock-open me-1"></i> Solicitar habilitación de adelantadas
            </button>
        }


        @if (ViewBag.EsJefeInmediato == true)
        {
            <a asp-action="SolicitudesPendientesJefe" class="btn btn-outline-secondary ms-2">
                Solicitudes de mi equipo
            </a>


            <a asp-action="CrearSolicitudEquipo" class="btn btn-dark">
                <i class="fas fa-user-plus me-1"></i> Registrar Vacaciones de un Colaborador
            </a>

        }

        @if (ViewBag.EsUsuarioRH == true)
        {
            <a asp-action="SolicitudesPendientesRH" class="btn btn-outline-warning ms-2">
                Solicitudes para registro RH
            </a>

            <a asp-action="BandejaRH" asp-route-filtro="por_registrar" class="btn btn-outline-info ms-2">
                Bandeja RH (consulta + saldo)
            </a>


        }
    </div>

    @*  Modal de Justificación  *@
    <div class="modal fade" id="modalSolicitarAdelantadas" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title font-weight-bold">Justificación de Vacaciones Adelantadas</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">Explica detalladamente por qué necesitas que se te habiliten vacaciones antes de cumplir tu aniversario.</p>
                    <textarea id="txtMotivoAdelantadas" class="form-control" rows="4" placeholder="Escribe aquí tu motivo..."></textarea>
                    <input type="hidden" id="hdnUsuarioID" value="@Model.UsuarioID" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-warning" onclick="enviarSolicitudHabilitacion()">Enviar a Jefe y RH</button>
                </div>
            </div>
        </div>
    </div>

</div>

@if (!string.IsNullOrEmpty(ViewBag.Error as string))
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model != null)
{
    <h4>@Model.NombreCompleto (@Model.NumeroEmpleado)</h4>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="text-muted small">Fecha de ingreso</div>
                    <div class="fw-semibold">
                        @(fechaIngreso.HasValue? fechaIngreso.Value.ToString("dd/MM/yyyy") : "—")
                    </div>
                </div>

                <div class="col-md-9">
                    @if (Model.ResumenActual != null)
                    {
                        @* Cambiamos a row-cols-lg-6 para que quepan los 6 bloques en una sola línea en pantallas grandes *@
                        <div class="row g-3 row-cols-2 row-cols-sm-3 row-cols-lg-6 text-center">
                            <div class="col">
                                <div class="text-muted small">Año</div>
                                <div class="fw-semibold fs-5">@Model.ResumenActual.Anio</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Corresponden</div>
                                <div class="fw-semibold fs-5">@Model.ResumenActual.DiasCorrespondientes</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Tomados</div>
                                <div class="fw-semibold fs-5">@Model.ResumenActual.DiasTomados</div>
                            </div>

                            @if (Model.ResumenActual.DiasDeuda > 0)
                            {
                                <div class="col">
                                    <div class="text-danger small fw-bold">Adelantados</div>
                                    <div class="fw-semibold text-danger fs-5">@Model.ResumenActual.DiasDeuda</div>
                                </div>
                            }
                            else
                            {
                                <div class="col">
                                    <div class="text-muted small">Adelantados</div>
                                    <div class="fw-semibold fs-5">0</div>
                                </div>
                            }

                            @* Resaltamos los días extra con un tono verde corporativo suave si tiene días asignados *@
                            @if (Model.ResumenActual.DiasExtra > 0)
                            {
                                <div class="col">
                                    <div class="text-success small fw-bold">Días Extra</div>
                                    <div class="fw-semibold text-success fs-5">+@Model.ResumenActual.DiasExtra</div>
                                </div>
                            }
                            else
                            {
                                <div class="col">
                                    <div class="text-muted small">Días Extra</div>
                                    <div class="fw-semibold fs-5">0</div>
                                </div>
                            }

                            <div class="col">
                                <div class="text-muted small">Disponibles</div>
                                @* Tu estilo CSS naranja para resaltar la columna más importante *@
                                <div class="fw-bold fs-5 text-primary" style="color: #ff6d00 !important;">@Model.ResumenActual.DiasDisponibles</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No hay resumen de saldo disponible.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- HISTORIAL POR SECCIONES  -->

    <h5 class="mt-3">Vacaciones solicitadas</h5>
    @Html.Partial("_TablaSolicitudesVacaciones", solicitadas)

    <h5 class="mt-4">Vacaciones autorizadas (historial)</h5>
    @Html.Partial("_TablaSolicitudesVacaciones", autorizadas)

    <h5 class="mt-4">Vacaciones rechazadas (historial)</h5>
    @Html.Partial("_TablaSolicitudesVacaciones", rechazadas)
}

@section Scripts {
    <script>
        function abrirModalExcepcion() {
            $('#modalSolicitarAdelantadas').modal('show');
        }

                function enviarSolicitudHabilitacion() {
            const motivo = $('#txtMotivoAdelantadas').val();
            const usuarioId = $('#hdnUsuarioID').val();

            // Validación básica de cliente
            if (!motivo || motivo.trim().length < 15) {

                Swal.fire({
                    title: 'Atención',
                    text: 'Por favor ingresa un motivo más descriptivo (mínimo 15 caracteres).',
                    icon: 'warning',
                    confirmButtonColor: '#ff6d00'
                });
                return;
            }


            const idNum = parseInt(usuarioId);

            $.post('@Url.Action("SolicitarHabilitacion", "Vacaciones")', { usuarioId: idNum, motivo: motivo }, function (res) {
                if (res.success) {
                    Swal.fire('Solicitud Enviada', 'Tu jefe y RH revisarán tu motivo.', 'success').then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            }).fail(function() {
                Swal.fire('Error', 'No se pudo comunicar con el servidor.', 'error');
            });
        }
    </script>
}