@model ProyectoMatrix.Models.OperacionesGestorIndexVm
@{
    ViewData["Title"] = "Gestor de KPIs ";
    Layout = "_LayoutComunicados";
    var mensaje = TempData["Mensaje"]?.ToString();
    var tipo = TempData["Tipo"]?.ToString() ?? "info";
}

<style>

:root {
    --ops-bg-1: #eef6fc;
    --ops-bg-2: #f8fafc;
    --ops-bg-3: #e9f2f9;
    --ops-navy: #082f49;
    --ops-navy-2: #0f3d63;
    --ops-blue: #0ea5e9;
    --ops-blue-2: #0369a1;
    --ops-cyan: #7dd3fc;
    --ops-text: #0f172a;
    --ops-muted: #64748b;
    --ops-soft: #f8fafc;
    --ops-soft-2: #eef6ff;
    --ops-border: rgba(15, 23, 42, 0.11);
    --ops-border-strong: rgba(15, 23, 42, 0.18);
    --ops-white: #ffffff;
    --ops-success: #16a34a;
    --ops-warning: #f59e0b;
    --ops-danger: #dc2626;
    --ops-info: #0284c7;
    --ops-shadow-sm: 0 8px 22px rgba(15, 23, 42, 0.06);
    --ops-shadow-md: 0 14px 35px rgba(15, 23, 42, 0.10);
    --ops-shadow-lg: 0 24px 70px rgba(15, 23, 42, 0.14);
    --ops-radius-sm: 12px;
    --ops-radius-md: 18px;
    --ops-radius-lg: 24px;
    --ops-radius-xl: 30px;
}

/* ----------------------------------------------------------
   Fondo y ancho global para vistas de Operaciones
   ---------------------------------------------------------- */

body:has(.ops-shell),
body:has(.kpis-shell),
body:has(.ops-v2-page),
body:has(.kpis-v2-page) {
    background:
        radial-gradient(circle at 8% 0%, rgba(14, 165, 233, 0.18), transparent 30%),
        radial-gradient(circle at 92% 4%, rgba(8, 47, 73, 0.14), transparent 34%),
        linear-gradient(135deg, var(--ops-bg-1) 0%, var(--ops-bg-2) 44%, var(--ops-bg-3) 100%) !important;
    color: var(--ops-text) !important;
}

body:has(.ops-shell) .container,
body:has(.kpis-shell) .container,
body:has(.ops-v2-page) .container,
body:has(.kpis-v2-page) .container,
body:has(.ops-shell) .container-lg,
body:has(.kpis-shell) .container-lg,
body:has(.ops-shell) .container-xl,
body:has(.kpis-shell) .container-xl,
body:has(.ops-shell) .container-xxl,
body:has(.kpis-shell) .container-xxl {
    max-width: none !important;
    width: 100% !important;
    padding-left: 18px !important;
    padding-right: 18px !important;
}

.ops-v2-page,
.kpis-v2-page {
    min-height: calc(100vh - 72px) !important;
    padding: 18px clamp(14px, 1.6vw, 28px) 30px !important;
    background:
        radial-gradient(circle at top left, rgba(14, 165, 233, 0.16), transparent 30%),
        radial-gradient(circle at top right, rgba(8, 47, 73, 0.11), transparent 34%),
        transparent !important;
}

.ops-shell,
.kpis-shell {
    width: min(100%, 1720px) !important;
    max-width: calc(100vw - 76px) !important;
    margin: 18px auto 32px !important;
    padding: clamp(16px, 1.6vw, 26px) !important;
    border-radius: var(--ops-radius-xl) !important;
    background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.82), rgba(236, 247, 255, 0.72)) !important;
    border: 1px solid rgba(255,255,255,0.72) !important;
    box-shadow: var(--ops-shadow-lg) !important;
    backdrop-filter: blur(10px);
    position: relative;
    overflow: visible;
}

.ops-shell::before,
.kpis-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background:
        linear-gradient(90deg, rgba(14, 165, 233, 0.18), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,0.45), transparent 30%);
    opacity: .9;
    z-index: 0;
}

.ops-shell > *,
.kpis-shell > * {
    position: relative;
    z-index: 1;
}

/* ----------------------------------------------------------
   Encabezados / Hero
   ---------------------------------------------------------- */

.ops-header,
.hero-card {
    border-radius: var(--ops-radius-lg) !important;
    border: 1px solid rgba(255,255,255,0.85) !important;
    background:
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(224,242,254,0.92)) !important;
    box-shadow: var(--ops-shadow-md) !important;
}

.ops-header {
    padding: clamp(18px, 1.8vw, 28px) !important;
    margin-bottom: 18px !important;
    display: flex !important;
    justify-content: space-between !important;
    align-items: flex-start !important;
    gap: 18px !important;
}

.hero-card {
    padding: clamp(18px, 1.8vw, 28px) !important;
    margin-bottom: 18px !important;
    position: relative;
    overflow: hidden;
}

.ops-header::after,
.hero-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 7px;
    height: 100%;
    background: linear-gradient(180deg, var(--ops-blue), var(--ops-navy-2));
    border-radius: 999px;
    opacity: .95;
}

.ops-title,
.hero-title {
    font-size: clamp(2rem, 3.1vw, 3.35rem) !important;
    line-height: 0.96 !important;
    font-weight: 950 !important;
    letter-spacing: -0.055em !important;
    margin: 0 !important;
    color: var(--ops-text) !important;
    text-shadow: 0 1px 0 rgba(255,255,255,.8);
}

.ops-subtitle,
.hero-subtitle {
    color: #475569 !important;
    font-weight: 700 !important;
    line-height: 1.55 !important;
    margin: 8px 0 0 !important;
    max-width: 920px !important;
}

.ops-title-eyebrow,
.ops-pill,
.pill-badge {
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    border-radius: 999px !important;
    padding: 7px 13px !important;
    background: linear-gradient(135deg, #dff5ff, #cfeeff) !important;
    border: 1px solid rgba(14, 165, 233, 0.20) !important;
    color: #075985 !important;
    font-size: .74rem !important;
    font-weight: 950 !important;
    letter-spacing: .055em !important;
    text-transform: uppercase !important;
    box-shadow: 0 7px 16px rgba(14, 165, 233, .12) !important;
}

.ops-actions,
.hero-card .d-flex.gap-2,
.ops-header .d-flex.gap-2 {
    align-items: center !important;
}

/* ----------------------------------------------------------
   Botones
   ---------------------------------------------------------- */

.ops-btn,
.btn-soft,
.btn-outline-soft,
.btn-soft-primary,
.btn-primary-soft,
.btn-soft-danger,
.btn-danger-soft {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    min-height: 40px !important;
    padding: 10px 16px !important;
    border-radius: 999px !important;
    font-size: .82rem !important;
    font-weight: 950 !important;
    line-height: 1 !important;
    text-decoration: none !important;
    border: 1px solid rgba(15, 23, 42, 0.10) !important;
    background: rgba(255,255,255,0.94) !important;
    color: #0f172a !important;
    box-shadow: var(--ops-shadow-sm) !important;
    transition: transform .16s ease, box-shadow .16s ease, background .16s ease, color .16s ease !important;
    cursor: pointer !important;
}

.ops-btn:hover,
.btn-soft:hover,
.btn-outline-soft:hover,
.btn-soft-primary:hover,
.btn-primary-soft:hover,
.btn-soft-danger:hover,
.btn-danger-soft:hover {
    transform: translateY(-1px) !important;
    box-shadow: var(--ops-shadow-md) !important;
    color: #0f172a !important;
}

.ops-btn.primary,
.btn-soft-primary,
.btn-primary-soft,
.btn-soft.btn-primary-soft {
    background: linear-gradient(135deg, var(--ops-blue-2), var(--ops-blue)) !important;
    border-color: rgba(14, 165, 233, .22) !important;
    color: white !important;
}

.ops-btn.primary:hover,
.btn-soft-primary:hover,
.btn-primary-soft:hover,
.btn-soft.btn-primary-soft:hover {
    color: white !important;
    background: linear-gradient(135deg, #075985, #0284c7) !important;
}

.btn-soft-danger,
.btn-danger-soft,
.btn-soft.btn-danger-soft {
    background: linear-gradient(135deg, #dc2626, #f97316) !important;
    color: white !important;
    border-color: rgba(220,38,38,.20) !important;
}

.btn-soft-danger:hover,
.btn-danger-soft:hover,
.btn-soft.btn-danger-soft:hover {
    color: white !important;
    background: linear-gradient(135deg, #b91c1c, #ea580c) !important;
}

/* ----------------------------------------------------------
   Paneles / tarjetas base
   ---------------------------------------------------------- */

.ops-panel,
.ops-toolbar,
.manager-card,
.kpi-item,
.editor-card,
.hist-card,
.table-card,
.summary-card,
.kpi-card,
.empty-state,
.empty-box {
    background: rgba(255, 255, 255, 0.96) !important;
    border: 1px solid rgba(203, 213, 225, 0.82) !important;
    border-radius: var(--ops-radius-lg) !important;
    box-shadow: var(--ops-shadow-sm) !important;
}

.ops-panel,
.manager-card,
.kpi-item,
.editor-card,
.hist-card,
.table-card,
.kpi-card {
    overflow: hidden !important;
}

.ops-panel:hover,
.manager-card:hover,
.kpi-item:hover,
.hist-card:hover,
.kpi-card:hover,
.summary-card:hover {
    box-shadow: var(--ops-shadow-md) !important;
}

.manager-header,
.kpi-item-head,
.hist-head,
.kpi-card-header,
.ops-panel .ops-dashboard-head,
.ops-dashboard-head {
    padding: 16px 20px !important;
    border-bottom: 1px solid rgba(203, 213, 225, 0.75) !important;
    background:
        linear-gradient(135deg, #ffffff 0%, #eff8ff 100%) !important;
}

.manager-body,
.kpi-item-body,
.kpi-body,
.table-card > .table-responsive,
.hist-card > .p-3,
.editor-card {
    padding: clamp(16px, 1.4vw, 22px) !important;
}

/* ----------------------------------------------------------
   Dashboard Index
   ---------------------------------------------------------- */

.ops-grid {
    display: grid !important;
    grid-template-columns: minmax(250px, 300px) minmax(0, 1fr) !important;
    gap: 18px !important;
    align-items: start !important;
}

.ops-main {
    min-width: 0 !important;
}

.ops-sidebar {
    position: sticky !important;
    top: 12px !important;
    padding: 0 !important;
}

.ops-sidebar-title {
    padding: 16px 18px !important;
    margin: 0 !important;
    background: linear-gradient(135deg, var(--ops-navy), var(--ops-navy-2)) !important;
    color: white !important;
    font-weight: 950 !important;
    letter-spacing: -.02em !important;
}

.ops-depto-list {
    padding: 12px !important;
    display: grid !important;
    gap: 10px !important;
}

.ops-depto-item {
    display: block !important;
    border-radius: 16px !important;
    padding: 14px 14px !important;
    background: #ffffff !important;
    border: 1px solid rgba(203, 213, 225, .95) !important;
    box-shadow: 0 5px 14px rgba(15, 23, 42, .04) !important;
    color: var(--ops-text) !important;
    text-decoration: none !important;
    transition: transform .16s ease, border-color .16s ease, background .16s ease !important;
}

.ops-depto-item:hover,
.ops-depto-item.active,
.ops-depto-item[aria-current="true"] {
    transform: translateY(-1px) !important;
    border-color: rgba(14, 165, 233, .65) !important;
    background: linear-gradient(135deg, #ffffff, #eaf7ff) !important;
}

.ops-depto-name {
    font-size: .86rem !important;
    font-weight: 950 !important;
    color: var(--ops-text) !important;
}

.ops-depto-meta {
    margin-top: 4px !important;
    color: var(--ops-muted) !important;
    font-weight: 800 !important;
    font-size: .74rem !important;
}

.ops-filters {
    padding: 14px !important;
    margin-bottom: 16px !important;
}

.ops-filter-grid {
    display: grid !important;
    grid-template-columns: repeat(6, minmax(0, 1fr)) !important;
    gap: 12px !important;
    align-items: end !important;
}

.ops-field label,
.form-label-mini,
.form-label {
    font-size: .70rem !important;
    line-height: 1.1 !important;
    text-transform: uppercase !important;
    letter-spacing: .065em !important;
    color: #53667d !important;
    font-weight: 950 !important;
    margin-bottom: 7px !important;
}

.ops-kpi-summary,
.summary-grid {
    display: grid !important;
    grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
    gap: 14px !important;
    margin-bottom: 16px !important;
}

.ops-summary-card,
.summary-card {
    padding: 18px !important;
    min-height: 130px !important;
    position: relative !important;
    overflow: hidden !important;
}

.ops-summary-card::before,
.summary-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: var(--ops-blue);
    opacity: .9;
}

.ops-summary-card.state-success::before { background: var(--ops-success); }
.ops-summary-card.state-warning::before { background: var(--ops-warning); }
.ops-summary-card.state-danger::before { background: var(--ops-danger); }

.ops-summary-top {
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
    margin-bottom: 12px !important;
}

.ops-summary-icon {
    width: 38px !important;
    height: 38px !important;
    border-radius: 14px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: #e0f2fe !important;
    color: var(--ops-blue-2) !important;
}

.ops-summary-title,
.summary-label {
    color: #53667d !important;
    font-size: .76rem !important;
    font-weight: 950 !important;
    line-height: 1.15 !important;
}

.ops-summary-value,
.summary-value {
    font-size: clamp(1.45rem, 2.1vw, 2rem) !important;
    font-weight: 950 !important;
    line-height: 1 !important;
    color: var(--ops-text) !important;
}

.ops-summary-subtitle {
    margin-top: 8px !important;
    color: #64748b !important;
    font-size: .78rem !important;
    font-weight: 800 !important;
}

.ops-global-chart {
    height: clamp(340px, 42vh, 560px) !important;
    width: 100% !important;
}

.ops-kpi-grid,
.kpi-grid {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    gap: 18px !important;
}

.ops-kpi-card.size-Grande,
.ops-kpi-card.size-grande,
.kpi-card.size-Grande,
.kpi-card.size-grande {
    grid-column: 1 / -1 !important;
}

.ops-kpi-head {
    display: flex !important;
    align-items: flex-start !important;
    justify-content: space-between !important;
    gap: 14px !important;
    padding: 18px 20px 10px !important;
}

.ops-kpi-title,
.kpi-name,
.kpi-title,
.hist-title {
    font-size: 1.05rem !important;
    color: var(--ops-text) !important;
    font-weight: 950 !important;
    letter-spacing: -.025em !important;
    margin: 0 !important;
}

.ops-kpi-subtitle,
.kpi-meta,
.hist-sub,
.kpi-subtitle {
    font-size: .78rem !important;
    color: var(--ops-muted) !important;
    font-weight: 800 !important;
    margin-top: 3px !important;
}

.ops-kpi-value,
.ops-kpi-result {
    padding: 0 20px !important;
    font-size: clamp(1.6rem, 2.35vw, 2.6rem) !important;
    font-weight: 950 !important;
    color: var(--ops-text) !important;
    letter-spacing: -.04em !important;
}

.ops-kpi-meta {
    padding: 5px 20px 0 !important;
    color: var(--ops-muted) !important;
    font-size: .78rem !important;
    font-weight: 800 !important;
}

.ops-kpi-chart {
    height: 320px !important;
    min-height: 320px !important;
    padding: 8px 10px 16px !important;
}

.ops-kpi-card.size-Grande .ops-kpi-chart,
.ops-kpi-card.size-grande .ops-kpi-chart {
    height: 430px !important;
}

.ops-kpi-card.size-Compacta .ops-kpi-chart,
.ops-kpi-card.size-compacta .ops-kpi-chart {
    height: 260px !important;
}

.ops-badge,
.badge {
    border-radius: 999px !important;
    font-weight: 950 !important;
    letter-spacing: .01em !important;
}

.ops-badge.success,
.badge.success {
    background: #dcfce7 !important;
    color: #166534 !important;
}

.ops-badge.danger,
.badge.danger {
    background: #fee2e2 !important;
    color: #991b1b !important;
}

.ops-badge.warning,
.badge.warning {
    background: #fef3c7 !important;
    color: #92400e !important;
}

.ops-badge.neutral,
.badge.neutral {
    background: #e2e8f0 !important;
    color: #334155 !important;
}

/* ----------------------------------------------------------
   Gestor / Nueva métrica
   ---------------------------------------------------------- */

.manager-card,
.editor-card {
    margin-bottom: 18px !important;
}

.manager-header {
    font-size: 1.04rem !important;
    font-weight: 950 !important;
    color: var(--ops-text) !important;
}

.kpi-item {
    margin-bottom: 14px !important;
}

.kpi-item-head {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 14px !important;
}

.kpi-item-body {
    background: linear-gradient(180deg, #ffffff, #f8fbff) !important;
}

.variable-row,
.variable-box {
    border: 1px dashed rgba(100, 116, 139, 0.34) !important;
    border-radius: var(--ops-radius-md) !important;
    padding: 14px !important;
    margin-bottom: 12px !important;
    background: linear-gradient(135deg, #ffffff, #f8fbff) !important;
}

.variable-row:hover,
.variable-box:hover {
    border-color: rgba(14, 165, 233, .55) !important;
    background: linear-gradient(135deg, #ffffff, #eef9ff) !important;
}

.variable-name {
    color: var(--ops-text) !important;
    font-size: .88rem !important;
    font-weight: 950 !important;
}

/* ----------------------------------------------------------
   Formularios
   ---------------------------------------------------------- */

.form-control,
.form-select {
    min-height: 42px !important;
    border-radius: 13px !important;
    border: 1px solid #d7e3ef !important;
    color: var(--ops-text) !important;
    font-weight: 800 !important;
    background-color: rgba(255,255,255,.96) !important;
    box-shadow: 0 2px 0 rgba(15,23,42,.02) !important;
}

.form-control:focus,
.form-select:focus {
    border-color: rgba(14, 165, 233, .7) !important;
    box-shadow: 0 0 0 .22rem rgba(14, 165, 233, .15) !important;
}

.input-group-text {
    border-radius: 13px !important;
    border: 1px solid #d7e3ef !important;
    background: #eef6ff !important;
    color: #075985 !important;
    font-weight: 950 !important;
}

.form-check-input {
    border-color: #9fb5cc !important;
}

.form-check-input:checked {
    background-color: var(--ops-blue-2) !important;
    border-color: var(--ops-blue-2) !important;
}

/* ----------------------------------------------------------
   Captura
   ---------------------------------------------------------- */

.ops-toolbar {
    padding: 16px !important;
    margin-bottom: 18px !important;
}

.kpi-captura-card .kpi-card-header {
    background: linear-gradient(135deg, #ffffff, #eaf7ff) !important;
}

.kpi-captura-card .kpi-body {
    background: #ffffff !important;
}

/* ----------------------------------------------------------
   Historial / Tablas / Importacion
   ---------------------------------------------------------- */

.hist-card {
    margin-bottom: 14px !important;
}

.hist-head {
    display: flex !important;
    align-items: flex-start !important;
    justify-content: space-between !important;
    gap: 12px !important;
}

.value-chip {
    display: inline-flex !important;
    align-items: center !important;
    gap: 6px !important;
    border-radius: 999px !important;
    padding: 7px 11px !important;
    margin: 3px !important;
    background: #eef6ff !important;
    border: 1px solid #dbeafe !important;
    color: #17324f !important;
    font-size: .78rem !important;
    font-weight: 900 !important;
}

.table-card {
    padding: 0 !important;
}

.table-card .table,
.table {
    --bs-table-bg: transparent !important;
    margin-bottom: 0 !important;
    vertical-align: middle !important;
}

.table thead th {
    background: linear-gradient(135deg, var(--ops-navy), var(--ops-navy-2)) !important;
    color: white !important;
    border: none !important;
    font-size: .74rem !important;
    text-transform: uppercase !important;
    letter-spacing: .06em !important;
    font-weight: 950 !important;
    padding: 13px 14px !important;
}

.table tbody td {
    border-color: rgba(203, 213, 225, 0.75) !important;
    padding: 12px 14px !important;
    color: #1e293b !important;
    font-weight: 750 !important;
}

.table-hover tbody tr:hover {
    background: rgba(14, 165, 233, 0.07) !important;
}

.summary-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
    margin: 18px 0 !important;
}

.alert {
    border-radius: var(--ops-radius-md) !important;
    font-weight: 850 !important;
    border: 1px solid rgba(15,23,42,.08) !important;
    box-shadow: var(--ops-shadow-sm) !important;
}

.empty-state,
.empty-box,
.ops-empty {
    padding: 42px 24px !important;
    text-align: center !important;
    color: var(--ops-muted) !important;
    font-weight: 800 !important;
}

/* ----------------------------------------------------------
   Modales
   ---------------------------------------------------------- */

.modal-content {
    border: 0 !important;
    border-radius: 24px !important;
    overflow: hidden !important;
    box-shadow: var(--ops-shadow-lg) !important;
}

.modal-header {
    background: linear-gradient(135deg, var(--ops-navy), var(--ops-navy-2)) !important;
    color: white !important;
    border-bottom: 0 !important;
}

.modal-title {
    font-weight: 950 !important;
}

.modal-body {
    background: #f8fbff !important;
}

.modal-footer {
    background: #ffffff !important;
    border-top: 1px solid #e2e8f0 !important;
}

/* ----------------------------------------------------------
   Responsive
   ---------------------------------------------------------- */

@@media (max-width: 1400px) {
    .ops-shell,
    .kpis-shell {
        max-width: calc(100vw - 42px) !important;
    }

    .ops-filter-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    }

    .ops-kpi-summary,
    .summary-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    }
}

@@media (max-width: 1100px) {
    .ops-grid {
        grid-template-columns: 1fr !important;
    }

    .ops-sidebar {
        position: relative !important;
        top: auto !important;
    }

    .ops-depto-list {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .ops-kpi-grid,
    .kpi-grid {
        grid-template-columns: 1fr !important;
    }
}

@@media (max-width: 768px) {
    .ops-v2-page,
    .kpis-v2-page {
        padding: 10px !important;
    }

    .ops-shell,
    .kpis-shell {
        max-width: 100% !important;
        margin: 10px auto 18px !important;
        padding: 12px !important;
        border-radius: 20px !important;
    }

    .ops-header,
    .hero-card,
    .kpi-item-head,
    .hist-head {
        flex-direction: column !important;
    }

    .ops-filter-grid,
    .ops-kpi-summary,
    .summary-grid,
    .ops-depto-list {
        grid-template-columns: 1fr !important;
    }

    .ops-title,
    .hero-title {
        font-size: 2rem !important;
    }
}

</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --op-bg: #eef5fb;
        --op-panel: #ffffff;
        --op-border: rgba(15, 23, 42, .10);
        --op-text: #0f172a;
        --op-muted: #64748b;
        --op-blue: #0ea5e9;
        --op-navy: #0f2747;
        --op-soft: #f8fafc;
        --op-success: #16a34a;
        --op-danger: #dc2626;
        --op-warning: #f59e0b;
    }

    .kpis-v2-page {
        min-height: 100vh;
        padding: 26px;
        background: linear-gradient(135deg, #eef7ff, #f8fafc 42%, #e8f3fb);
        color: var(--op-text);
    }

    .kpis-shell {
        max-width: 1320px;
        margin: 0 auto;
    }

    .hero-card {
        border-radius: 26px;
        background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(219,239,252,.88));
        border: 1px solid var(--op-border);
        box-shadow: 0 22px 60px rgba(15, 23, 42, .10);
        padding: 24px;
        margin-bottom: 18px;
    }

    .hero-title {
        font-size: clamp(1.8rem, 2.8vw, 2.6rem);
        font-weight: 950;
        letter-spacing: -.04em;
        margin: 0;
    }

    .hero-subtitle {
        color: var(--op-muted);
        font-weight: 700;
        margin-top: 4px;
        max-width: 840px;
    }

    .pill-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 999px;
        padding: 8px 12px;
        background: rgba(14,165,233,.12);
        color: #0369a1;
        font-weight: 900;
        font-size: .78rem;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .manager-card {
        border-radius: 24px;
        background: var(--op-panel);
        border: 1px solid var(--op-border);
        box-shadow: 0 18px 50px rgba(15, 23, 42, .08);
        margin-bottom: 18px;
        overflow: hidden;
    }

    .manager-header {
        padding: 18px 20px;
        background: linear-gradient(135deg, #0f2747, #0b5f8f);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .manager-header h3 {
        margin: 0;
        font-weight: 950;
        font-size: 1.05rem;
    }

    .manager-body {
        padding: 20px;
    }

    .kpi-item {
        border: 1px solid var(--op-border);
        border-radius: 22px;
        background: #fff;
        box-shadow: 0 12px 34px rgba(15, 23, 42, .06);
        margin-bottom: 16px;
        overflow: hidden;
    }

    .kpi-item-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 18px;
        background: linear-gradient(135deg, #f8fafc, #eef6fc);
        border-bottom: 1px solid var(--op-border);
    }

    .kpi-name {
        font-weight: 950;
        margin: 0;
        font-size: 1rem;
    }

    .kpi-meta {
        color: var(--op-muted);
        font-weight: 800;
        font-size: .78rem;
    }

    .kpi-item-body {
        padding: 18px;
    }

    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: .78rem;
        font-weight: 950;
        color: #0f2747;
        background: #e0f2fe;
        border: 1px solid rgba(14,165,233,.25);
        border-radius: 999px;
        padding: 7px 11px;
        margin: 8px 0 12px;
    }

    .form-label {
        font-size: .74rem;
        text-transform: uppercase;
        letter-spacing: .045em;
        font-weight: 950;
        color: #475569;
        margin-bottom: 6px;
    }

    .form-control, .form-select {
        border-radius: 14px;
        border: 1px solid rgba(15,23,42,.13);
        font-weight: 750;
        color: #0f172a;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--op-blue);
        box-shadow: 0 0 0 .18rem rgba(14,165,233,.15);
    }

    .variable-row {
        border: 1px dashed rgba(15,23,42,.18);
        border-radius: 18px;
        padding: 14px;
        background: #f8fafc;
        margin-bottom: 10px;
    }

    .btn-soft-primary {
        border: 0;
        background: linear-gradient(135deg, #0ea5e9, #0369a1);
        color: #fff;
        border-radius: 999px;
        padding: 10px 16px;
        font-weight: 950;
        box-shadow: 0 12px 30px rgba(14,165,233,.24);
    }

    .btn-soft-dark {
        border: 0;
        background: #0f172a;
        color: #fff;
        border-radius: 999px;
        padding: 10px 16px;
        font-weight: 950;
    }

    .btn-soft-danger {
        border: 0;
        background: rgba(220,38,38,.10);
        color: #991b1b;
        border-radius: 999px;
        padding: 9px 14px;
        font-weight: 950;
    }

    .btn-outline-soft {
        border: 1px solid rgba(15,23,42,.13);
        background: #fff;
        color: #0f172a;
        border-radius: 999px;
        padding: 9px 14px;
        font-weight: 950;
    }

    .empty-box {
        border: 1px dashed rgba(15,23,42,.18);
        border-radius: 24px;
        padding: 34px;
        background: rgba(255,255,255,.72);
        text-align: center;
        color: var(--op-muted);
        font-weight: 800;
    }
</style>

<div class="kpis-v2-page">
    <div class="kpis-shell">
        <div class="hero-card">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <span class="pill-badge"><i class="fas fa-sliders"></i> Operaciones V2</span>
                    <h1 class="hero-title mt-3">Gestor de KPIs</h1>
                    <p class="hero-subtitle">
                        Configura indicadores, variables, metas, lógica de cálculo y visualización del dashboard.
                    </p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="@Url.Action("Index", "Operaciones")" class="btn-outline-soft text-decoration-none">
                        <i class="fas fa-chart-line me-1"></i> Dashboard
                    </a>
                    <button class="btn-soft-primary" type="button" data-bs-toggle="collapse" data-bs-target="#crearKpiBox" aria-expanded="false">
                        <i class="fas fa-plus me-1"></i> Nuevo KPI
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(mensaje))
        {
            <div class="alert alert-@tipo rounded-4 fw-bold shadow-sm">@mensaje</div>
        }

        <div class="collapse" id="crearKpiBox">
            <div class="manager-card">
                <div class="manager-header">
                    <h3><i class="fas fa-plus-circle me-2"></i>Crear nuevo KPI</h3>
                </div>
                <div class="manager-body">
                    <form asp-action="GuardarMetrica" asp-controller="Operaciones" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MetricaID" value="0" />
                        @await Html.PartialAsync("_KpiEditorFieldsV2", new ProyectoMatrix.Models.OperacionesKpiEditorVm
                        {
                            DepartamentosDisponibles = Model.Departamentos,
                            Variables = new List<ProyectoMatrix.Models.OperacionesVariableEditorVm>
                            {
                                new ProyectoMatrix.Models.OperacionesVariableEditorVm { OrdenVisual = 1 },
                                new ProyectoMatrix.Models.OperacionesVariableEditorVm { OrdenVisual = 2 },
                                new ProyectoMatrix.Models.OperacionesVariableEditorVm { OrdenVisual = 3 }
                            }
                        })
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" class="btn-outline-soft" data-bs-toggle="collapse" data-bs-target="#crearKpiBox">Cancelar</button>
                            <button type="submit" class="btn-soft-primary"><i class="fas fa-save me-1"></i> Crear KPI</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="manager-card">
            <div class="manager-header">
                <h3><i class="fas fa-list-check me-2"></i>KPIs configurados</h3>
                <span class="badge rounded-pill bg-light text-dark fw-bold">@Model.Kpis.Count KPI(s)</span>
            </div>
            <div class="manager-body">
                @if (!Model.Kpis.Any())
                {
                    <div class="empty-box">
                        <i class="fas fa-chart-simple fa-2x mb-3"></i>
                        <div>No hay KPIs configurados todavía.</div>
                    </div>
                }
                else
                {
                    foreach (var kpi in Model.Kpis)
                    {
                        var collapseId = $"kpi-{kpi.MetricaID}";
                        <div class="kpi-item">
                            <div class="kpi-item-head">
                                <div>
                                    <h4 class="kpi-name">@kpi.NombreMetrica</h4>
                                    <div class="kpi-meta">
                                        @kpi.NombreDepartamento · @kpi.Frecuencia · @kpi.ModoCalculoKpi · @kpi.TipoGraficaDefecto
                                    </div>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <button type="button" class="btn-outline-soft" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                        <i class="fas fa-pen-to-square me-1"></i> Editar
                                    </button>
                                    <form asp-action="EliminarMetrica" asp-controller="Operaciones" method="post" class="d-inline form-archivar-kpi">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@kpi.MetricaID" />
                                        <button type="submit" class="btn-soft-danger">
                                            <i class="fas fa-box-archive me-1"></i> Archivar
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <div class="collapse" id="@collapseId">
                                <div class="kpi-item-body">
                                    <form asp-action="ActualizarMetricaCompleta" asp-controller="Operaciones" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="MetricaID" value="@kpi.MetricaID" />
                                        @await Html.PartialAsync("_KpiEditorFieldsV2", kpi)
                                        <div class="d-flex justify-content-end gap-2 mt-3">
                                            <button type="button" class="btn-outline-soft" data-bs-toggle="collapse" data-bs-target="#@collapseId">Cerrar</button>
                                            <button type="submit" class="btn-soft-primary"><i class="fas fa-save me-1"></i> Guardar cambios</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('submit', function (ev) {
        const form = ev.target;
        if (!form.classList.contains('form-archivar-kpi')) return;
        ev.preventDefault();

        Swal.fire({
            title: '¿Archivar KPI?',
            text: 'El KPI dejará de mostrarse en configuración y dashboard, pero no se eliminará el historial.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, archivar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#dc2626'
        }).then(r => {
            if (r.isConfirmed) form.submit();
        });
    });

    function agregarVariable(btn) {
        const contenedor = btn.closest('form').querySelector('[data-variable-list]');
        const index = contenedor.querySelectorAll('.variable-row').length;
        const html = crearVariableHtml(index);
        contenedor.insertAdjacentHTML('beforeend', html);
    }

    function crearVariableHtml(index) {
        return `
        <div class="variable-row">
            <input type="hidden" name="Variables[${index}].VariableID" value="0" />
            <input type="hidden" name="Variables[${index}].MetricaID" value="0" />
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Variable</label>
                    <input class="form-control" name="Variables[${index}].NombreVariable" placeholder="Nombre de variable" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tipo captura</label>
                    <select class="form-select" name="Variables[${index}].TipoCaptura">
                        <option value="Manual">Manual</option>
                        <option value="Fijo">Fijo</option>
                        <option value="Calculado">Calculado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Agregación</label>
                    <select class="form-select" name="Variables[${index}].TipoAgregacion">
                        <option value="Promedio">Promedio</option>
                        <option value="Suma">Suma</option>
                        <option value="Conteo">Conteo</option>
                        <option value="UltimoPeriodo">Último periodo</option>
                        <option value="Acumulado">Acumulado</option>
                        <option value="ValorFijo">Valor fijo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tipo valor</label>
                    <select class="form-select" name="Variables[${index}].TipoValor">
                        <option value="">Heredar</option>
                        <option value="Porcentaje">Porcentaje</option>
                        <option value="Moneda">Moneda</option>
                        <option value="Entero">Entero</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Unidad</label>
                    <input class="form-control" name="Variables[${index}].UnidadMedida" placeholder="Días, viajes..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Valor fijo</label>
                    <input class="form-control" type="number" step="0.01" name="Variables[${index}].ValorFijo" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Fórmula</label>
                    <input class="form-control" name="Variables[${index}].Formula" placeholder="Ej. [1] / [2] * 100" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check fw-bold">
                        <input class="form-check-input"
                               type="checkbox"
                               name="Variables[${index}].EsLinea"
                               value="true"
                               id="var-linea-new-${index}" />

                        <input type="hidden" name="Variables[${index}].EsLinea" value="false" />

                        <label class="form-check-label" for="var-linea-new-${index}">Línea/meta</label>
                    </div>
                </div>
            </div>
        </div>`;
    }
</script>
