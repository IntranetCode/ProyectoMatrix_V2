@model ProyectoMatrix.Models.OperacionesKpiEditorVm
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    string idSuffix = Model.MetricaID > 0 ? Model.MetricaID.ToString() : "nuevo";
    var variables = Model.Variables ?? new List<ProyectoMatrix.Models.OperacionesVariableEditorVm>();
}

<div class="row g-3">
    <div class="col-lg-5">
        <label class="form-label">Nombre KPI</label>
        <input class="form-control" name="NombreMetrica" value="@Model.NombreMetrica" placeholder="Ej. Pedidos entregados a tiempo" required />
    </div>
    <div class="col-lg-3">
        <label class="form-label">Departamento</label>
        <select class="form-select" name="DepartamentoID" required>
            <option value="">-- Selecciona --</option>
            @foreach (var d in Model.DepartamentosDisponibles)
            {
                <option value="@d.Value" selected="@(d.Value == Model.DepartamentoID.ToString())">@d.Text</option>
            }
        </select>
    </div>
    <div class="col-lg-2">
        <label class="form-label">Frecuencia</label>
        <select class="form-select" name="Frecuencia">
            <option value="Mensual" selected="@(Model.Frecuencia == "Mensual")">Mensual</option>
            <option value="Semanal" selected="@(Model.Frecuencia == "Semanal")">Semanal</option>
            <option value="Diario" selected="@(Model.Frecuencia == "Diario")">Diario</option>
        </select>
    </div>
    <div class="col-lg-2">
        <label class="form-label">Tipo valor</label>
        <select class="form-select" name="TipoValor">
            <option value="Porcentaje" selected="@(Model.TipoValor == "Porcentaje")">Porcentaje</option>
            <option value="Moneda" selected="@(Model.TipoValor == "Moneda")">Moneda</option>
            <option value="Entero" selected="@(Model.TipoValor == "Entero")">Entero</option>
        </select>
    </div>

    <div class="col-lg-3">
        <label class="form-label">Unidad</label>
        <input class="form-control" name="UnidadMedida" value="@Model.UnidadMedida" placeholder="%, $, Días, Viajes..." />
    </div>
    <div class="col-lg-3">
        <label class="form-label">Unidad personalizada</label>
        <input class="form-control" name="UnidadMedidaPersonalizada" placeholder="Solo si aplica" />
    </div>
    <div class="col-lg-2">
        <label class="form-label">Meta</label>
        <input class="form-control" type="number" step="0.01" name="MetaEsperada" value="@Model.MetaEsperada" />
    </div>
    <div class="col-lg-2">
        <label class="form-label">Sentido meta</label>
        <select class="form-select" name="SentidoMeta">
            <option value="">Sin evaluación</option>
            <option value="MayorMejor" selected="@(Model.SentidoMeta == "MayorMejor")">Mayor es mejor</option>
            <option value="MenorMejor" selected="@(Model.SentidoMeta == "MenorMejor")">Menor es mejor</option>
            <option value="Exacto" selected="@(Model.SentidoMeta == "Exacto")">Exacto</option>
        </select>
    </div>
    <div class="col-lg-2">
        <label class="form-label">Gráfica</label>
        <select class="form-select" name="TipoGraficaDefecto">
            <option value="ComboChart" selected="@(Model.TipoGraficaDefecto == "ComboChart")">Mixta</option>
            <option value="ColumnChart" selected="@(Model.TipoGraficaDefecto == "ColumnChart")">Barras</option>
            <option value="StackedBarChart" selected="@(Model.TipoGraficaDefecto == "StackedBarChart")">Barras apiladas</option>
            <option value="LineChart" selected="@(Model.TipoGraficaDefecto == "LineChart")">Líneas</option>
            <option value="AreaChart" selected="@(Model.TipoGraficaDefecto == "AreaChart")">Área</option>
            <option value="StackedAreaChart" selected="@(Model.TipoGraficaDefecto == "StackedAreaChart")">Área apilada</option>
            <option value="PieChart" selected="@(Model.TipoGraficaDefecto == "PieChart")">Pastel</option>
            <option value="DoughnutChart" selected="@(Model.TipoGraficaDefecto == "DoughnutChart")">Dona</option>
        </select>
    </div>
</div>

<div class="section-label"><i class="fas fa-calculator"></i> Lógica de cálculo</div>
<div class="row g-3">
    <div class="col-lg-3">
        <label class="form-label">Modo cálculo KPI</label>
        <select class="form-select" name="ModoCalculoKpi">
            <option value="Promedio" selected="@(Model.ModoCalculoKpi == "Promedio")">Promedio</option>
            <option value="Suma" selected="@(Model.ModoCalculoKpi == "Suma")">Suma</option>
            <option value="Conteo" selected="@(Model.ModoCalculoKpi == "Conteo")">Conteo</option>
            <option value="UltimoPeriodo" selected="@(Model.ModoCalculoKpi == "UltimoPeriodo")">Último periodo</option>
            <option value="Acumulado" selected="@(Model.ModoCalculoKpi == "Acumulado")">Acumulado</option>
            <option value="Ratio" selected="@(Model.ModoCalculoKpi == "Ratio")">Ratio / Porcentaje real</option>
            <option value="PromedioPonderado" selected="@(Model.ModoCalculoKpi == "PromedioPonderado")">Promedio ponderado</option>
            <option value="PromedioResultados" selected="@(Model.ModoCalculoKpi == "PromedioResultados")">Promedio resultados</option>
            <option value="Formula" selected="@(Model.ModoCalculoKpi == "Formula")">Fórmula</option>
        </select>
    </div>
    <div class="col-lg-3">
        <label class="form-label">Variable tarjeta</label>
        <select class="form-select" name="VariableTarjetaID">
            <option value="">Automático</option>
            @foreach (var v in variables.Where(x => x.VariableID > 0))
            {
                <option value="@v.VariableID" selected="@(Model.VariableTarjetaID == v.VariableID)">@v.NombreVariable</option>
            }
        </select>
    </div>
    <div class="col-lg-2">
        <label class="form-label">Modo tarjeta</label>
        <select class="form-select" name="ModoTarjeta">
            <option value="Automatico" selected="@(Model.ModoTarjeta == "Automatico")">Automático</option>
            <option value="UltimoPeriodo" selected="@(Model.ModoTarjeta == "UltimoPeriodo")">Último periodo</option>
            <option value="Promedio" selected="@(Model.ModoTarjeta == "Promedio")">Promedio</option>
            <option value="Suma" selected="@(Model.ModoTarjeta == "Suma")">Suma</option>
            <option value="Acumulado" selected="@(Model.ModoTarjeta == "Acumulado")">Acumulado</option>
        </select>
    </div>
    <div class="col-lg-2">
        <label class="form-label">Tamaño gráfica</label>
        <select class="form-select" name="TamanoGrafica">
            <option value="Normal" selected="@(Model.TamanoGrafica == "Normal")">Normal</option>
            <option value="Grande" selected="@(Model.TamanoGrafica == "Grande")">Grande</option>
            <option value="Compacta" selected="@(Model.TamanoGrafica == "Compacta")">Compacta</option>
        </select>
    </div>
    <div class="col-lg-2 d-flex align-items-end">
        <div class="form-check fw-bold">
            <input class="form-check-input"
                   type="checkbox"
                   name="MostrarMetaEnGrafica"
                   value="true"
                   id="meta-@idSuffix"
                   @(Model.MostrarMetaEnGrafica ? "checked" : "") />

            <input type="hidden" name="MostrarMetaEnGrafica" value="false" />

            <label class="form-check-label" for="meta-@idSuffix">Mostrar meta</label>
        </div>
    </div>

    <div class="col-lg-4">
        <label class="form-label">Variable numerador / base</label>
        <select class="form-select" name="VariableNumeradorID">
            <option value="">-- Sin variable --</option>
            @foreach (var v in variables.Where(x => x.VariableID > 0))
            {
                <option value="@v.VariableID" selected="@(Model.VariableNumeradorID == v.VariableID)">@v.NombreVariable</option>
            }
        </select>
    </div>
    <div class="col-lg-4">
        <label class="form-label">Variable denominador</label>
        <select class="form-select" name="VariableDenominadorID">
            <option value="">-- Sin variable --</option>
            @foreach (var v in variables.Where(x => x.VariableID > 0))
            {
                <option value="@v.VariableID" selected="@(Model.VariableDenominadorID == v.VariableID)">@v.NombreVariable</option>
            }
        </select>
    </div>
    <div class="col-lg-4">
        <label class="form-label">Variable peso</label>
        <select class="form-select" name="VariablePesoID">
            <option value="">-- Sin variable --</option>
            @foreach (var v in variables.Where(x => x.VariableID > 0))
            {
                <option value="@v.VariableID" selected="@(Model.VariablePesoID == v.VariableID)">@v.NombreVariable</option>
            }
        </select>
    </div>
</div>

<div class="section-label"><i class="fas fa-diagram-project"></i> Variables</div>
<div data-variable-list>
    @for (int i = 0; i < variables.Count; i++)
    {
        var v = variables[i];
        <div class="variable-row">
            <input type="hidden" name="Variables[@i].VariableID" value="@v.VariableID" />
            <input type="hidden" name="Variables[@i].MetricaID" value="@v.MetricaID" />
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Variable</label>
                    <input class="form-control" name="Variables[@i].NombreVariable" value="@v.NombreVariable" placeholder="Nombre de variable" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tipo captura</label>
                    <select class="form-select" name="Variables[@i].TipoCaptura">
                        <option value="Manual" selected="@(v.TipoCaptura == "Manual")">Manual</option>
                        <option value="Fijo" selected="@(v.TipoCaptura == "Fijo")">Fijo</option>
                        <option value="Calculado" selected="@(v.TipoCaptura == "Calculado")">Calculado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Agregación</label>
                    <select class="form-select" name="Variables[@i].TipoAgregacion">
                        <option value="Promedio" selected="@(v.TipoAgregacion == "Promedio")">Promedio</option>
                        <option value="Suma" selected="@(v.TipoAgregacion == "Suma")">Suma</option>
                        <option value="Conteo" selected="@(v.TipoAgregacion == "Conteo")">Conteo</option>
                        <option value="UltimoPeriodo" selected="@(v.TipoAgregacion == "UltimoPeriodo")">Último periodo</option>
                        <option value="Acumulado" selected="@(v.TipoAgregacion == "Acumulado")">Acumulado</option>
                        <option value="ValorFijo" selected="@(v.TipoAgregacion == "ValorFijo")">Valor fijo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tipo valor</label>
                    <select class="form-select" name="Variables[@i].TipoValor">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(v.TipoValor))">Heredar</option>
                        <option value="Porcentaje" selected="@(v.TipoValor == "Porcentaje")">Porcentaje</option>
                        <option value="Moneda" selected="@(v.TipoValor == "Moneda")">Moneda</option>
                        <option value="Entero" selected="@(v.TipoValor == "Entero")">Entero</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Unidad</label>
                    <input class="form-control" name="Variables[@i].UnidadMedida" value="@v.UnidadMedida" placeholder="Días, viajes..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Valor fijo</label>
                    <input class="form-control" type="number" step="0.01" name="Variables[@i].ValorFijo" value="@v.ValorFijo" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Fórmula</label>
                    <input class="form-control" name="Variables[@i].Formula" value="@v.Formula" placeholder="Ej. [1] / [2] * 100" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check fw-bold">
                        <input class="form-check-input"
                               type="checkbox"
                               name="Variables[@i].EsLinea"
                               value="true"
                               id="var-linea-@idSuffix-@i"
                               @(v.EsLinea ? "checked" : "") />

                        <input type="hidden" name="Variables[@i].EsLinea" value="false" />

                        <label class="form-check-label" for="var-linea-@idSuffix-@i">Línea/meta</label>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<button type="button" class="btn-outline-soft mt-2" onclick="agregarVariable(this)">
    <i class="fas fa-plus me-1"></i> Agregar variable
</button>
