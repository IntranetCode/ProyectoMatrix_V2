@model List<ProyectoMatrix.Models.Departamento>
    
@{
    ViewData["Title"] = "Tablero Operativo";
    Layout = "_LayoutComunicados";

    var misPermisos = ViewBag.MisPermisos as List<int> ?? new List<int>();
}

<style>
    :root {
        --op-bg: #f4f7fb;
        --op-bg-soft: #eef3f9;
        --op-surface: #ffffff;
        --op-surface-2: #f8fafc;

        --op-navy: #072b4a;
        --op-navy-2: #0f172a;
        --op-navy-soft: #eaf3fb;

        --op-border: #dbe4ee;
        --op-border-strong: #cbd5e1;

        --op-text: #0f172a;
        --op-text-soft: #475569;
        --op-text-muted: #64748b;

        --op-primary: #2563eb;
        --op-sky: #0ea5e9;
        --op-cyan: #06b6d4;
        --op-success: #84cc16;
        --op-success-2: #22c55e;
        --op-danger: #ef4444;
        --op-danger-soft: #fff1f2;
        --op-warning: #facc15;
        --op-warning-dark: #a16207;
        --op-purple: #8b5cf6;

        --op-shadow: 0 12px 30px rgba(15, 23, 42, .08);
        --op-shadow-hover: 0 18px 38px rgba(15, 23, 42, .14);
    }

    body {
        background:
            radial-gradient(circle at top left, rgba(14,165,233,.10), transparent 24%),
            radial-gradient(circle at top right, rgba(132,204,22,.10), transparent 22%),
            linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
        color: var(--op-text);
    }

    .dashboard-shell {
        max-width: 1320px;
        margin: 0 auto;
        padding-bottom: 2.8rem;
    }

    .dashboard-title {
        letter-spacing: -.45px;
        font-weight: 900;
        color: var(--op-text) !important;
    }

    .dashboard-title i {
        color: var(--op-sky) !important;
        filter: drop-shadow(0 8px 14px rgba(14,165,233,.25));
    }

    .dashboard-subtitle,
    .text-muted {
        color: var(--op-text-muted) !important;
    }

    .content-zone {
        max-width: 100%;
    }

    .dashboard-toolbar {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;
    }

    /* BOTONES */
    .btn-future,
    .btn-ghost-future {
        min-height: 42px;
        border-radius: 15px;
        font-weight: 900;
        font-size: .92rem;
        transition: all .2s ease;
        box-shadow: 0 8px 18px rgba(15, 23, 42, .10);
    }

    .btn-future:hover,
    .btn-ghost-future:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 26px rgba(15, 23, 42, .16);
    }

    .btn-ghost-future {
        background: rgba(255,255,255,.92);
        color: var(--op-text);
        border: 1px solid var(--op-border-strong);
        backdrop-filter: blur(10px);
    }

    .btn-ghost-future:hover {
        border-color: var(--op-primary);
        color: var(--op-primary);
        background: #ffffff;
    }

    .btn-future-primary {
        background: linear-gradient(135deg, #2563eb, #0ea5e9);
        color: #fff;
        border: none;
    }

    .btn-future-success {
        background: linear-gradient(135deg, #a3e635, #84cc16);
        color: #102a0a;
        border: none;
    }

    /* FILTROS */
    .filter-input-future {
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--op-border);
        box-shadow: var(--op-shadow);
        background: #fff;
    }

    .filter-input-future .input-group-text {
        background: #ffffff;
        color: var(--op-success-2);
        border: 0;
    }

    .filter-input-future .form-select,
    .filter-input-future .form-control {
        border: 0;
        font-weight: 800;
        color: var(--op-text);
        background: #fff;
    }

    /* SIDEBAR NUEVO */
    .sidebar-card {
        position: sticky;
        top: 1rem;
        border: 1px solid var(--op-border);
        background: rgba(255,255,255,.95);
        box-shadow: var(--op-shadow);
        border-radius: 24px !important;
        overflow: hidden;
        backdrop-filter: blur(14px);
    }

    .sidebar-header-future {
        background: linear-gradient(135deg, var(--op-navy-2), var(--op-navy));
        color: #fff;
        border-bottom: 0;
        padding: 1rem 1.1rem !important;
        font-size: .96rem;
    }

    .sidebar-header-future i {
        color: var(--op-success) !important;
    }

    .sidebar-card .bg-light {
        background: #f8fafc !important;
        border-color: var(--op-border) !important;
    }

    .sidebar-card .input-group {
        border: 1px solid var(--op-border);
        background: #ffffff;
        border-radius: 16px !important;
    }

    .sidebar-card .input-group-text,
    .sidebar-card .form-control {
        background: transparent !important;
        color: var(--op-text) !important;
        border: 0 !important;
    }

    .sidebar-card .form-control::placeholder {
        color: var(--op-text-muted);
    }

    .list-group-item {
        background: #ffffff;
        border-color: #edf2f7;
        color: var(--op-text-soft);
    }

    .op-departamento,
    #listaResultados button {
        transition: all .18s ease;
        border-left: 5px solid transparent;
        font-weight: 850;
        color: var(--op-text-soft) !important;
        background: #ffffff;
    }

    .op-departamento:hover,
    #listaResultados button:hover {
        background: #f8fbff;
        border-left-color: var(--op-sky);
        color: var(--op-text) !important;
        transform: translateX(2px);
    }

    .active-sidebar {
        background: linear-gradient(90deg, rgba(132,204,22,.18), rgba(14,165,233,.08)) !important;
        border-left: 5px solid var(--op-success) !important;
        color: var(--op-text) !important;
        font-weight: 950 !important;
    }

    .active-sidebar i {
        color: var(--op-navy) !important;
    }

    .op-departamento i,
    #listaResultados button i {
        color: #64748b !important;
    }

    /* TARJETAS SUPERIORES */
    .top-widget-card {
        min-height: 120px;
        border-radius: 22px;
        padding: 1rem 1.15rem 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border: 1px solid var(--op-border);
        box-shadow: var(--op-shadow);
        background:
            radial-gradient(circle at top right, rgba(14,165,233,.06), transparent 36%),
            linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        transition: all .22s ease;
        position: relative;
        overflow: hidden;
    }

    .top-widget-card::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 5px;
        background: var(--accent, var(--op-primary));
    }

    .top-widget-card::after {
        content: "";
        position: absolute;
        width: 90px;
        height: 90px;
        right: -35px;
        bottom: -35px;
        border-radius: 50%;
        background: color-mix(in srgb, var(--accent, var(--op-primary)) 15%, transparent);
    }

    .top-widget-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--op-shadow-hover);
    }

    .top-widget-title {
        font-size: .82rem;
        font-weight: 950;
        color: var(--op-text-soft);
        margin-bottom: .45rem;
        display: flex;
        align-items: center;
        gap: .45rem;
        position: relative;
        z-index: 1;
    }

    .top-widget-title i {
        color: var(--accent, var(--op-primary));
    }

    .top-widget-value {
        font-size: 1.9rem;
        line-height: 1.05;
        font-weight: 950;
        margin: 0;
        color: var(--accent, var(--op-text));
        position: relative;
        z-index: 1;
    }

    .top-widget-sub {
        font-size: .8rem;
        color: var(--op-text-muted);
        margin-top: .35rem;
        line-height: 1.35;
        position: relative;
        z-index: 1;
    }

    /* CARDS PRINCIPALES */
    .global-chart-card,
    .ranking-panel,
    .insight-panel,
    .metric-wall-card,
    .chart-card {
        border: 1px solid var(--op-border);
        background: rgba(255,255,255,.96);
        box-shadow: var(--op-shadow);
        border-radius: 26px;
    }

    .global-chart-card {
        padding: 1.45rem;
        height: 100%;
    }

    .global-chart-card-large {
        min-height: 620px;
    }

    .global-chart-title {
        font-size: 1.05rem;
        font-weight: 950;
        color: var(--op-text);
    }

    .global-chart-card .badge {
        background: #eef4ff !important;
        color: var(--op-primary) !important;
        border: 1px solid #dbeafe !important;
    }

    .ranking-panel {
        padding: 1.25rem;
        height: 100%;
    }

    .ranking-panel h6 {
        color: var(--op-text) !important;
    }

    .ranking-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        padding: .9rem 1rem;
        border-radius: 17px;
        background: #f8fafc;
        border: 1px solid var(--op-border);
        transition: all .2s ease;
        min-width: 245px;
    }

    .ranking-item:hover {
        transform: translateY(-2px);
        background: #ffffff;
        box-shadow: 0 12px 22px rgba(15, 23, 42, .08);
    }

    .ranking-left {
        display: flex;
        align-items: center;
        gap: .85rem;
        min-width: 0;
    }

    .ranking-medal {
        font-size: 1.4rem;
        min-width: 32px;
        text-align: center;
    }

    .ranking-name {
        font-weight: 950;
        color: var(--op-text);
        margin-bottom: 2px;
        white-space: normal;
        overflow-wrap: break-word;
    }

    .ranking-meta {
        font-size: .82rem;
        color: var(--op-text-muted);
    }

    .ranking-badge {
        border-radius: 999px;
        padding: .4rem .72rem;
        font-size: .84rem;
        font-weight: 950;
        white-space: nowrap;
    }

    .insight-panel {
        padding: 1.2rem 1.3rem;
        min-height: 100%;
    }

    .insight-panel-success {
        border-left: 5px solid var(--op-success);
        background: linear-gradient(180deg, #f7fde9 0%, #ffffff 100%);
    }

    .insight-panel-danger {
        border-left: 5px solid var(--op-danger);
        background: linear-gradient(180deg, #fff3f3 0%, #ffffff 100%);
    }

    .insight-title {
        font-weight: 950;
        font-size: 1rem;
        margin-bottom: 1rem;
        color: var(--op-text) !important;
    }

    .insight-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: .85rem;
        align-items: start;
        padding: .9rem 0;
        border-bottom: 1px dashed var(--op-border);
    }

    .insight-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .insight-kpi {
        min-width: 0;
    }

    .insight-area {
        font-weight: 950;
        margin-bottom: .15rem;
        line-height: 1.25;
        color: var(--op-text);
    }

    .insight-metric {
        color: var(--op-text-soft);
        font-size: .88rem;
        line-height: 1.35;
    }

    .insight-chip {
        border-radius: 999px;
        padding: .4rem .72rem;
        font-size: .78rem;
        font-weight: 950;
        background: #ffffff;
        color: var(--op-text);
        border: 1px solid var(--op-border);
        white-space: nowrap;
        align-self: start;
    }

    .kpi-card {
        transition: all .25s ease;
        overflow: hidden;
        border: none !important;
    }

    .kpi-card:hover {
        transform: translateY(-7px);
        box-shadow: 0 18px 34px rgba(15,23,42,.14) !important;
    }

    .kpi-icon-bg {
        position: absolute;
        font-size: 7rem;
        right: -15px;
        bottom: -20px;
        opacity: 0.12;
        transform: rotate(-15deg);
        transition: all .3s ease;
    }

    .kpi-card:hover .kpi-icon-bg {
        transform: rotate(0deg) scale(1.08);
    }

    .metric-wall-card .card-header {
        background: #f8fbff !important;
        border-bottom: 1px solid var(--op-border) !important;
    }

    .metric-wall-card h5 {
        color: var(--op-text) !important;
    }

    .wall-select {
        border-radius: 999px;
        border: 1px solid var(--op-border);
        font-weight: 850;
        background-color: #fff;
        color: var(--op-text);
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 7px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: #e2e8f0;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #94a3b8;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #64748b;
    }

    #chart_global,
    [id^="chart_"] {
        background: transparent;
    }

    @@media (max-width: 1500px) {
        .insight-item {
            grid-template-columns: 1fr;
        }

        .insight-chip {
            justify-self: start;
            white-space: normal;
            max-width: 100%;
        }
    }

    @@media (max-width: 1400px) {
        .top-widget-value {
            font-size: 1.65rem;
        }

        .global-chart-card-large {
            min-height: 580px;
        }
    }

    @@media (max-width: 991.98px) {
        .top-widget-card {
            min-height: auto;
        }

        .dashboard-toolbar {
            justify-content: flex-start;
        }

        .insight-item {
            grid-template-columns: 1fr;
        }

        .insight-chip {
            white-space: normal;
        }

        .sidebar-card {
            position: relative;
            top: 0;
        }
    }
</style>

<div class="container-fluid px-4 dashboard-shell">

    <div class="d-flex justify-content-between align-items-start mt-4 mb-3 flex-wrap gap-3">
        <div>
            <h2 class="text-dark fw-bold mb-1 dashboard-title">
                <i class="fas fa-chart-pie text-primary me-2"></i> Centro de Mando Operativo
            </h2>
            <p class="dashboard-subtitle mb-0">
                Visualiza el cumplimiento global y el desempeño por área.
            </p>
        </div>

        <div class="dashboard-toolbar">
            @if (misPermisos.Contains(33))
            {
                <a href="/Operaciones/Historial" class="btn btn-ghost-future shadow-sm">
                    <i class="fas fa-history me-1"></i> Historial
                </a>
            }

            @if (misPermisos.Contains(32))
            {
                <a href="/Operaciones/GestorMetricas" class="btn btn-ghost-future shadow-sm">
                    <i class="fas fa-cogs me-1"></i> Gestor
                </a>
            }

            @if (misPermisos.Contains(31))
            {
                <a href="/Operaciones/NuevaMetrica" class="btn btn-future btn-future-primary shadow-sm">
                    <i class="fas fa-cog me-1"></i> Configurar
                </a>
            }

            @if (misPermisos.Contains(34) || misPermisos.Contains(31) || misPermisos.Contains(32))
            {
                <a href="/Operaciones/Captura" class="btn btn-future btn-future-success shadow-sm">
                    <i class="fas fa-plus me-1"></i> Capturar
                </a>
            }

            <button type="button"
                    class="btn btn-danger fw-bold shadow-sm rounded-pill px-3"
                    data-bs-toggle="modal"
                    data-bs-target="#modalKpisPdf">
                <i class="fas fa-file-pdf me-1"></i> Ver KPIs Enero-Abril 2026
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-end flex-wrap gap-2">

            <div class="input-group filter-input-future" style="max-width: 250px;">
                <span class="input-group-text">
                    <i class="fas fa-calendar-alt"></i>
                </span>
                <select id="filtroTiempoGlobal" class="form-select" onchange="aplicarFiltroTiempo()">
                    <option value="mes">Este Mes</option>
                    <option value="semana">Esta Semana</option>
                    <option value="anio" selected>Este Año</option>
                    <option value="historico">Todo el Historial</option>
                </select>
            </div>

            <div class="input-group filter-input-future d-none" id="contenedorFiltroMes" style="max-width: 220px;">
                <span class="input-group-text">
                    <i class="fas fa-calendar-day"></i>
                </span>
                <select id="filtroMesGlobal" class="form-select" onchange="aplicarFiltroTiempo()">
                    <option value="1">Enero</option>
                    <option value="2">Febrero</option>
                    <option value="3">Marzo</option>
                    <option value="4">Abril</option>
                    <option value="5">Mayo</option>
                    <option value="6">Junio</option>
                    <option value="7">Julio</option>
                    <option value="8">Agosto</option>
                    <option value="9">Septiembre</option>
                    <option value="10">Octubre</option>
                    <option value="11">Noviembre</option>
                    <option value="12">Diciembre</option>
                </select>
            </div>

            <div class="input-group filter-input-future d-none" id="contenedorFiltroSemana" style="max-width: 220px;">
                <span class="input-group-text">
                    <i class="fas fa-calendar-week"></i>
                </span>
                <select id="filtroSemanaGlobal" class="form-select" onchange="aplicarFiltroTiempo()">
                    @for (int i = 1; i <= 53; i++)
                    {
                        <option value="@i">Semana @i</option>
                    }
                </select>
            </div>

        </div>
    </div>

    <div class="row g-4">

        <div class="col-12 col-xl-3 col-xxl-2 mb-4">
            <div class="card sidebar-card border-0 h-100 rounded-4 overflow-hidden">
                <div class="card-header sidebar-header-future fw-bold py-3">
                    <i class="fas fa-sitemap me-2" style="color: #92D050;"></i> Áreas Evaluadas
                </div>

                <div class="card-body p-0">
                    <div class="p-3 bg-light border-bottom">
                        <div class="input-group shadow-sm rounded-4 overflow-hidden">
                            <span class="input-group-text bg-white border-end-0 text-muted">
                                <i class="fas fa-search"></i>
                            </span>
                            <input type="text"
                                   id="buscadorDepto"
                                   class="form-control border-start-0"
                                   placeholder="Buscar área..."
                                   onkeyup="filtrarDepartamentos()" />
                        </div>
                    </div>

                    <div class="list-group list-group-flush custom-scrollbar" id="listaResultados" style="max-height: 70vh; overflow-y: auto;">
                        <button class="list-group-item list-group-item-action active-sidebar py-3"
                            id="btn-depto-0"
                            onclick="seleccionarDepto(0, 'General')">
                            <i class="fas fa-globe me-2"></i> Rendimiento Global
                        </button>

                        @foreach (var depto in Model)
                        {
                            <button class="list-group-item list-group-item-action op-departamento py-3"
                                    id="btn-depto-@depto.DepartamentoID"
                                    onclick="seleccionarDepto(@depto.DepartamentoID, '@depto.NombreDepartamento')">
                                <i class="fas fa-building text-secondary me-2"></i> @depto.NombreDepartamento
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-9 col-xxl-10">
            <div class="card border-0 rounded-4 mb-4 h-100 bg-transparent shadow-none content-zone">

                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <div>
                        <h4 id="titulo-panel" class="fw-bold text-dark mb-1">Visión Ejecutiva Corporativa</h4>
                        <p class="text-muted small mb-0">
                            Los datos se actualizan según el periodo seleccionado.
                        </p>
                    </div>

                    <button id="btnExportarExcel"
                            class="btn btn-ghost-future fw-bold d-none"
                            disabled
                            title="Exportación pendiente de configurar">
                        <i class="fas fa-file-excel me-1 text-success"></i> Exportar a Excel
                    </button>
                </div>

                <div id="vistaGlobal">

                    <div id="topWidgets" class="row g-3 mb-4"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-12">
                            <div class="global-chart-card global-chart-card-large">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                                    <div>
                                        <div class="global-chart-title mb-1">
                                            <i class="fas fa-chart-bar me-2"></i> Comparativa de Rendimiento
                                        </div>
                                        <small class="text-muted">
                                            Vista general del cumplimiento por área según el periodo seleccionado.
                                        </small>
                                    </div>

                                    <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                        <i class="fas fa-chart-column me-1 text-primary"></i> Vista ejecutiva
                                    </span>
                                </div>

                                <div id="chart_global" style="height: 540px; width: 100%;"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-12">
                            <div class="ranking-panel">
                                <div class="px-4 pt-4 pb-2">
                                    <h6 class="fw-bold text-dark mb-0">
                                        <i class="fas fa-trophy text-warning me-2"></i> Tabla de Posiciones
                                    </h6>
                                    <small class="text-muted">Ranking de áreas según cumplimiento.</small>
                                </div>

                                <div class="p-4 pt-3 custom-scrollbar"
                                     style="max-height: 300px; overflow-y: auto;"
                                     id="rankingGlobal">
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-4" id="insightsGlobal"></div>
                        </div>
                    </div>
                </div>

                <div id="muro_graficas" class="row g-4 d-none"></div>

                <input type="hidden" id="excelIdDepto" value="0" />
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalKpisPdf" tabindex="-1" aria-labelledby="modalKpisPdfLabel" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen-lg-down modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="modal-header text-white border-0" style="background: linear-gradient(135deg, #0f172a, #0c4a6e);">
                    <div>
                        <h5 class="modal-title fw-bold" id="modalKpisPdfLabel">
                            <i class="fas fa-file-pdf me-2 text-danger"></i>
                            KPIs 25.5.26
                        </h5>
                        <small class="text-white-50">
                            Vista previa del reporte original de KPIs
                        </small>
