            return;
        }

        const height = Math.max(310, Math.min(640, (data.length * 54) + 150));
        el.style.height = `${height}px`;
        chart.resize();

        if (dashboardState.globalChartMode === 'termometro') {
            chart.setOption(buildGlobalThermometerOption(data));
