            <aside class="ops-panel ops-sidebar">
                <div class="ops-sidebar-title">
                    <h3><i class="fas fa-sitemap me-1"></i> Áreas</h3>
                </div>

                <div class="ops-depto-list" id="departamentosList">
                    <button type="button"
                            class="ops-depto-item active ops-general-card"
                            id="navGeneralItem">
                        <div class="ops-depto-name">
                            <i class="fas fa-layer-group me-1"></i>
                            GENERAL
                        </div>
                        <div class="ops-depto-meta">
                            <span>Vista global</span>
                            <span>Todos</span>
                        </div>
                    </button>

                    <button type="button"
                            class="ops-depto-item ops-compras-card"
                            id="navComprasItem">
                        <div class="ops-depto-name">
                            <i class="fas fa-cart-shopping me-1"></i>
                            COMPRAS
                        </div>
                        <div class="ops-depto-meta">
                            <span id="comprasCardMeta">KPI automático</span>
                            <span id="comprasCardPct">Módulo</span>
                        </div>
                    </button>

                    @foreach (var depto in Model.Departamentos)
                    {
                        <button type="button"
                                class="ops-depto-item @(depto.Seleccionado ? "active" : "")"
                                data-departamento-id="@depto.DepartamentoID">
                            <div class="ops-depto-name">@depto.NombreDepartamento</div>
                            <div class="ops-depto-meta">
                                <span>@depto.TotalKpis KPI(s)</span>
                                <span>@depto.PorcentajeCumplimiento.ToString("N2")%</span>
                            </div>
                        </button>
                    }
                </div>
            </aside>

            <main class="ops-main">
                <section class="ops-panel ops-filters">
                    <div class="ops-filter-grid">
                        <div class="ops-field">
                            <label>Periodo</label>
                            <select id="filtroTiempo">
                                <option value="anio" selected="@(Model.FiltroTiempo == "anio")">Año actual</option>
                                <option value="trimestre" selected="@(Model.FiltroTiempo == "trimestre")">Trimestre</option>
                                <option value="mes" selected="@(Model.FiltroTiempo == "mes")">Mes</option>
                                <option value="semana" selected="@(Model.FiltroTiempo == "semana")">Semana</option>
                                <option value="dia" selected="@(Model.FiltroTiempo == "dia")">Día</option>
                                <option value="historico" selected="@(Model.FiltroTiempo == "historico")">Histórico</option>
                            </select>
                        </div>
                        <div class="ops-field">
                            <label>Mes</label>
                            <select id="filtroMes">
                                @for (int i = 1; i <= 12; i++)
                                {
                                    var nombreMes = new DateTime(DateTime.Now.Year, i, 1).ToString("MMMM", new System.Globalization.CultureInfo("es-MX"));
                                    <option value="@i" selected="@(Model.Mes == i)">@nombreMes</option>
                                }
                            </select>
                        </div>
                        <div class="ops-field">
                            <label>Semana</label>
                            <input id="filtroSemana" type="number" min="1" max="53" value="@(Model.Semana ?? 1)" />
                        </div>
                        <div class="ops-field">
                            <label>Día</label>
                            <input id="filtroDia" type="date" value="@Model.Dia" />
                        </div>
                        <button type="button" class="ops-btn primary" id="btnApplyFilters" style="height:42px; justify-content:center;">
                            <i class="fas fa-filter"></i> Aplicar
                        </button>
                        <button type="button" class="ops-btn" id="btnClearFilters" style="height:42px; justify-content:center;">
                            <i class="fas fa-filter-circle-xmark"></i> Limpiar
                        </button>
                    </div>
                </section>

                <section class="ops-kpi-summary" id="summaryCards"></section>

                <section class="ops-panel ops-dashboard-head">
                    <div>
                        <h2 id="dashboardTitle">@Model.Dashboard.Departamento</h2>
                        <p id="dashboardSubtitle">
                            @Model.Dashboard.TotalKpis KPI(s) evaluados · @Model.Dashboard.KpisCumplidos cumplen meta · @Model.Dashboard.KpisNoCumplidos requieren atención
                        </p>
                    </div>

                    <div class="ops-global-actions">
                        <div class="ops-badge neutral" id="dashboardScopeBadge">
                            <i class="fas fa-layer-group"></i>
                            <span>@(Model.DepartamentoSeleccionadoID.HasValue ? "Área seleccionada" : "Vista general")</span>
                        </div>

                        <div class="ops-chart-switch" aria-label="Cambiar gráfica de rendimiento general">
                            <button type="button" class="ops-chart-mode-btn active" data-global-chart-mode="resumen">
                                <i class="fas fa-chart-column"></i> Resumen
                            </button>
                            <button type="button" class="ops-chart-mode-btn" data-global-chart-mode="porcentaje">
                                <i class="fas fa-percent"></i> Cumplimiento
                            </button>
                            <button type="button" class="ops-chart-mode-btn" data-global-chart-mode="termometro">
                                <i class="fas fa-temperature-half"></i> Termómetro
                            </button>
                        </div>
                    </div>
                </section>

                <section class="ops-panel" style="margin-bottom:18px;">
                    <div id="globalChart" class="ops-global-chart"></div>
                </section>

                <section id="kpiGrid" class="ops-kpi-grid"></section>
            </main>
        </div>
    </div>
</div>


