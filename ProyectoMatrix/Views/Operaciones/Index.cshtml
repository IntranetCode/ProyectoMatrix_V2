<div class="ops-loading" id="dashboardLoading">
    <div class="ops-spinner">
        <i class="fas fa-circle-notch fa-spin"></i>
        Cargando dashboard...
    </div>
</div>

<script>
    const initialDashboard = @Html.Raw(JsonSerializer.Serialize(Model.Dashboard, jsonOptions));
    const departamentosBase = @Html.Raw(JsonSerializer.Serialize(Model.Departamentos, jsonOptions));
    const initialDepartamentoId = @(Model.DepartamentoSeleccionadoID.HasValue ? Model.DepartamentoSeleccionadoID.Value.ToString() : "null");

    const endpoints = {
        general: '@Url.Action("ObtenerDashboardGeneral", "Operaciones")',
        departamento: '@Url.Action("ObtenerDashboardDepartamento", "Operaciones")',
        compras: '@Url.Action("ObtenerKpisCompras", "Operaciones")'
    };

    const dashboardState = {
        departamentoId: initialDepartamentoId,
        filtroTiempo: document.getElementById('filtroTiempo').value || 'anio',
        mes: document.getElementById('filtroMes').value || '',
        semana: document.getElementById('filtroSemana').value || '',
        dia: document.getElementById('filtroDia').value || '',
        globalChartMode: 'resumen',
        viewMode: 'kpis'
    };

    let dashboardActual = initialDashboard;
    let comprasActual = null;
    const chartInstances = new Map();

    function pick(obj, ...keys) {
        if (!obj) return undefined;
        for (const key of keys) {
            if (Object.prototype.hasOwnProperty.call(obj, key) && obj[key] !== undefined && obj[key] !== null) {
                return obj[key];
            }
        }
        return undefined;
    }

    function safeArray(value) {
        return Array.isArray(value) ? value : [];
    }

    function normalizeText(value) {
        return (value || '').toString().trim().toLowerCase();
    }

    function getKpis(dashboard) {
        return safeArray(pick(dashboard, 'kpis', 'Kpis'));
    }

    function getTarjetas(dashboard) {
        return safeArray(pick(dashboard, 'tarjetas', 'Tarjetas'));
    }

    function getHistorial(kpi) {
        return safeArray(pick(kpi, 'historial', 'Historial'));
    }

    function getVariables(periodo) {
        return safeArray(pick(periodo, 'variables', 'Variables'));
    }

    function getResultado(kpi) {
        return pick(kpi, 'resultado', 'Resultado') || {};
    }

    function toNumber(value) {
        const n = Number(value);
        return Number.isFinite(n) ? n : 0;
    }

    function showLoading(show) {
        document.getElementById('dashboardLoading').classList.toggle('active', !!show);
    }

    function updateFilterStateFromUi() {
        dashboardState.filtroTiempo = document.getElementById('filtroTiempo').value || 'anio';
        dashboardState.mes = document.getElementById('filtroMes').value || '';
        dashboardState.semana = document.getElementById('filtroSemana').value || '';
        dashboardState.dia = document.getElementById('filtroDia').value || '';
    }

    async function cargarDashboard() {
        updateFilterStateFromUi();

        if (dashboardState.viewMode === 'compras') {
            await cargarDashboardCompras();
            return;
        }

        showLoading(true);

        const params = new URLSearchParams();
        params.set('filtroTiempo', dashboardState.filtroTiempo);
        if (dashboardState.mes) params.set('mes', dashboardState.mes);
        if (dashboardState.semana) params.set('semana', dashboardState.semana);
        if (dashboardState.dia) params.set('dia', dashboardState.dia);

        let url = endpoints.general;

        if (dashboardState.departamentoId) {
            url = endpoints.departamento;
            params.set('idDepartamento', dashboardState.departamentoId);
        }

        try {
            const response = await fetch(`${url}?${params.toString()}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            const payload = await response.json();

            if (!payload.ok) {
                console.warn(payload.mensaje || 'No se pudo cargar el dashboard.');
                return;
            }

            dashboardActual = payload.dashboard || payload.Dashboard;
            renderDashboard(dashboardActual);
        } catch (error) {
            console.error('Error al cargar dashboard V2:', error);
        } finally {
            showLoading(false);
        }
    }

    function setDepartamentoActivo(idDepartamento) {
        dashboardState.viewMode = 'kpis';
        dashboardState.departamentoId = idDepartamento && Number(idDepartamento) > 0 ? Number(idDepartamento) : null;

        document.getElementById('navGeneralItem')?.classList.remove('active');
        document.getElementById('navComprasItem')?.classList.remove('active');

        document.querySelectorAll('.ops-depto-item[data-departamento-id]').forEach(btn => {
            const id = Number(btn.dataset.departamentoId);
            btn.classList.toggle('active', dashboardState.departamentoId === id);
        });

        if (!dashboardState.departamentoId) {
            document.getElementById('navGeneralItem')?.classList.add('active');
        }

        cargarDashboard();
    }

    function limpiarFiltros() {
        dashboardState.departamentoId = null;
        document.getElementById('filtroTiempo').value = 'anio';
        document.getElementById('filtroMes').value = String(new Date().getMonth() + 1);
        document.getElementById('filtroSemana').value = '1';
        document.getElementById('filtroDia').value = '';
        dashboardState.viewMode = 'kpis';
        document.querySelectorAll('.ops-depto-item').forEach(btn => btn.classList.remove('active'));
        document.getElementById('navGeneralItem')?.classList.add('active');
        cargarDashboard();
    }

    function activarVistaKpis() {
        dashboardState.viewMode = 'kpis';
        dashboardState.departamentoId = null;
        document.querySelectorAll('.ops-depto-item').forEach(btn => btn.classList.remove('active'));
        document.getElementById('navGeneralItem')?.classList.add('active');
        document.getElementById('departamentosList')?.classList.remove('compras-mode');
        cargarDashboard();
    }

    function activarVistaCompras() {
        dashboardState.viewMode = 'compras';
        dashboardState.departamentoId = null;
        document.querySelectorAll('.ops-depto-item').forEach(btn => btn.classList.remove('active'));
        document.getElementById('navComprasItem')?.classList.add('active');
        cargarDashboardCompras();
    }

    function obtenerNombreDepartamentoActivo() {
        if (!dashboardState.departamentoId) return '';
        const depto = departamentosBase.find(d => Number(pick(d, 'departamentoID', 'DepartamentoID', 'departamentoId')) === Number(dashboardState.departamentoId));
        return pick(depto, 'nombreDepartamento', 'NombreDepartamento') || '';
    }

    function obtenerAnioComprasDesdeFiltro() {
        const filtro = dashboardState.filtroTiempo || 'anio';
        if (filtro === 'historico') return '';
        const dia = document.getElementById('filtroDia')?.value;
        if (filtro === 'dia' && dia) return new Date(dia).getFullYear();
        return new Date().getFullYear();
    }

    function obtenerMesComprasDesdeFiltro() {
        const filtro = dashboardState.filtroTiempo || 'anio';
        if (filtro === 'mes') return dashboardState.mes || '';
        if (filtro === 'dia') {
            const dia = document.getElementById('filtroDia')?.value;
            if (dia) return new Date(dia).getMonth() + 1;
        }
        return '';
    }

    async function cargarDashboardCompras() {
        updateFilterStateFromUi();
        showLoading(true);

        const params = new URLSearchParams();
        const anio = obtenerAnioComprasDesdeFiltro();
        const mes = obtenerMesComprasDesdeFiltro();
        const departamento = obtenerNombreDepartamentoActivo();

        if (anio) params.set('anio', anio);
        if (mes) params.set('mes', mes);
        if (departamento) params.set('departamento', departamento);

        try {
            const response = await fetch(`${endpoints.compras}?${params.toString()}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) {
                console.warn('No se pudo cargar KPIs automáticos de Compras.');
                return;
            }

            const payload = await response.json();
            comprasActual = payload;
            renderDashboardCompras(payload);
        } catch (error) {
            console.error('Error al cargar KPIs de Compras:', error);
        } finally {
            showLoading(false);
        }
    }


    function actualizarTarjetaComprasSidebar(data) {
        const total = Number(pick(data, 'totalSolicitudes', 'TotalSolicitudes')) || 0;
        const cumplimiento = Number(pick(data, 'cumplimientoSla', 'CumplimientoSla')) || 0;

        const meta = document.getElementById('comprasCardMeta');
        const pct = document.getElementById('comprasCardPct');

        if (meta) meta.textContent = `${total} solicitud(es)`;
        if (pct) pct.textContent = `${cumplimiento.toFixed(2)}%`;
    }

    function renderDashboardCompras(data) {
        if (!data) return;

        const total = toNumber(pick(data, 'totalSolicitudes', 'TotalSolicitudes'));
        const cerradas = toNumber(pick(data, 'totalCerradas', 'TotalCerradas'));
        const retrasadas = toNumber(pick(data, 'totalRetrasadas', 'TotalRetrasadas'));
        const cumplimiento = toNumber(pick(data, 'cumplimientoSla', 'CumplimientoSla'));
        const promedioDias = toNumber(pick(data, 'promedioDiasCompra', 'PromedioDiasCompra'));
        const departamento = obtenerNombreDepartamentoActivo();

        document.getElementById('dashboardTitle').textContent = departamento ? `Compras · ${departamento}` : 'KPIs automáticos de Compras';
        document.getElementById('dashboardSubtitle').textContent = `${total} solicitudes evaluadas · ${cerradas} cerradas · ${retrasadas} retrasadas · ${cumplimiento.toFixed(2)}% SLA`;
        document.querySelector('#dashboardScopeBadge span').textContent = 'Fuente automática: módulo Compras';

        renderSummaryCardsCompras(data);
        renderGlobalChartCompras(data);
        renderKpiGridCompras(data);
    }

    function renderSummaryCardsCompras(data) {
        const target = document.getElementById('summaryCards');
        const total = toNumber(pick(data, 'totalSolicitudes', 'TotalSolicitudes'));
        const cerradas = toNumber(pick(data, 'totalCerradas', 'TotalCerradas'));
        const retrasadas = toNumber(pick(data, 'totalRetrasadas', 'TotalRetrasadas'));
        const cumplimiento = toNumber(pick(data, 'cumplimientoSla', 'CumplimientoSla'));
        const promedioDias = toNumber(pick(data, 'promedioDiasCompra', 'PromedioDiasCompra'));

        const cards = [
            { estado: 'neutral', icono: 'fas fa-file-invoice', titulo: 'Solicitudes', valor: total, subtitulo: 'Compras evaluadas' },
            { estado: 'success', icono: 'fas fa-circle-check', titulo: 'Cerradas', valor: cerradas, subtitulo: 'Estatus finalizado' },
            { estado: retrasadas > 0 ? 'danger' : 'success', icono: 'fas fa-triangle-exclamation', titulo: 'Retrasadas', valor: retrasadas, subtitulo: 'Fuera de días permitidos' },
            { estado: cumplimiento >= 90 ? 'success' : 'warning', icono: 'fas fa-gauge-high', titulo: 'Cumplimiento SLA', valor: `${cumplimiento.toFixed(2)}%`, subtitulo: 'A tiempo / evaluables' },
            { estado: 'neutral', icono: 'fas fa-clock', titulo: 'Tiempo promedio', valor: `${promedioDias.toFixed(2)} días`, subtitulo: 'Días hábiles transcurridos' }
        ];

        target.innerHTML = cards.map(card => `
            <article class="ops-panel ops-summary-card state-${card.estado}">
                <div class="ops-summary-top">
                    <span class="ops-summary-icon"><i class="${card.icono}"></i></span>
                    <span class="ops-summary-title">${escapeHtml(card.titulo)}</span>
                </div>
                <div class="ops-summary-value">${escapeHtml(card.valor)}</div>
                <div class="ops-summary-subtitle">${escapeHtml(card.subtitulo)}</div>
            </article>
        `).join('');
    }

    function renderGlobalChartCompras(data) {
        const el = document.getElementById('globalChart');
        const departamentos = safeArray(pick(data, 'porDepartamento', 'PorDepartamento'));

        disposeChart('globalChart');
        const chart = echarts.init(el);
        chartInstances.set('globalChart', chart);

        if (!departamentos.length) {
            el.style.height = '360px';
            chart.setOption(emptyChartOption('Sin datos de Compras para el filtro actual'));
            return;
        }

        const height = Math.max(340, Math.min(640, (departamentos.length * 54) + 160));
        el.style.height = `${height}px`;
        chart.resize();

        if (dashboardState.globalChartMode === 'termometro') {
            chart.setOption(buildComprasThermometerOption(data));
            return;
        }

        if (dashboardState.globalChartMode === 'porcentaje') {
            chart.setOption(buildComprasCumplimientoDeptoOption(departamentos));
            return;
        }

        chart.setOption(buildComprasTiempoDeptoOption(departamentos));
    }

    function renderKpiGridCompras(data) {
        disposeKpiCharts();
        const grid = document.getElementById('kpiGrid');
        grid.classList.add('compras-grid');

        grid.innerHTML = `
            <article class="ops-panel ops-kpi-card">
                <div class="ops-kpi-head">
                    <div>
                        <h3 class="ops-kpi-title">Retrasadas por departamento</h3>
                        <div class="ops-kpi-subtitle">Conteo de solicitudes fuera de tiempo</div>
                    </div>
                    <span class="ops-auto-note"><i class="fas fa-database"></i> Compras</span>
                </div>
                <div id="comprasRetrasadasChart" class="ops-kpi-chart"></div>
            </article>

            <article class="ops-panel ops-kpi-card">
                <div class="ops-kpi-head">
                    <div>
                        <h3 class="ops-kpi-title">Cuello de botella por etapa</h3>
                        <div class="ops-kpi-subtitle">Promedio de días por etapa del flujo</div>
                    </div>
                    <span class="ops-auto-note"><i class="fas fa-route"></i> Flujo</span>
                </div>
                <div id="comprasEtapasChart" class="ops-kpi-chart"></div>
            </article>

            <article class="ops-panel ops-kpi-card">
                <div class="ops-kpi-head">
                    <div>
                        <h3 class="ops-kpi-title">Carga por comprador</h3>
                        <div class="ops-kpi-subtitle">Solicitudes asignadas y retrasadas</div>
                    </div>
                    <span class="ops-auto-note"><i class="fas fa-users-gear"></i> Compradores</span>
                </div>
                <div id="comprasCompradoresChart" class="ops-kpi-chart"></div>
            </article>
        `;

        renderSimpleChart('comprasRetrasadasChart', buildComprasRetrasadasDeptoOption(safeArray(pick(data, 'porDepartamento', 'PorDepartamento'))));
        renderSimpleChart('comprasEtapasChart', buildComprasEtapasOption(safeArray(pick(data, 'cuelloBotella', 'CuelloBotella'))));
        renderSimpleChart('comprasCompradoresChart', buildComprasCompradoresOption(safeArray(pick(data, 'porComprador', 'PorComprador'))));
    }

    function renderSimpleChart(id, option) {
        disposeChart(id);
        const el = document.getElementById(id);
        if (!el) return;
        const chart = echarts.init(el);
        chartInstances.set(id, chart);
        chart.setOption(option);
    }

    function buildComprasTiempoDeptoOption(departamentos) {
        const data = departamentos
            .map(x => ({
                departamento: pick(x, 'departamento', 'Departamento') || 'Sin departamento',
                promedio: toNumber(pick(x, 'promedioDias', 'PromedioDias')),
                permitido: toNumber(pick(x, 'promedioDiasPermitidos', 'PromedioDiasPermitidos'))
            }))
            .sort((a, b) => b.promedio - a.promedio);

        return {
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' }, confine: true },
            legend: { top: 4 },
            grid: { left: 155, right: 36, top: 58, bottom: 42 },
            xAxis: { type: 'value', name: 'Días', splitLine: { lineStyle: { type: 'dashed' } } },
            yAxis: { type: 'category', data: data.map(x => x.departamento), axisLabel: { fontWeight: 850 } },
            series: [
                { name: 'Promedio real', type: 'bar', data: data.map(x => x.promedio), barMaxWidth: 24, itemStyle: { borderRadius: [0, 10, 10, 0], color: '#0ea5e9' }, label: { show: true, position: 'right', formatter: '{c} d' } },
                { name: 'Días permitidos', type: 'line', data: data.map(x => x.permitido), symbolSize: 8, lineStyle: { type: 'dashed', width: 2, color: '#f59e0b' }, itemStyle: { color: '#f59e0b' } }
            ]
        };
    }

    function buildComprasCumplimientoDeptoOption(departamentos) {
        const data = departamentos
            .map(x => ({
                departamento: pick(x, 'departamento', 'Departamento') || 'Sin departamento',
                cumplimiento: toNumber(pick(x, 'cumplimientoSla', 'CumplimientoSla'))
            }))
            .sort((a, b) => b.cumplimiento - a.cumplimiento);

        return {
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' }, confine: true, valueFormatter: v => `${v}%` },
            grid: { left: 155, right: 36, top: 42, bottom: 42 },
