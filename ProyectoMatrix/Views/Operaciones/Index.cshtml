    function renderKpiGrid(dashboard) {
        const target = document.getElementById('kpiGrid');
        const kpis = getKpis(dashboard);

        disposeKpiCharts();

        if (!kpis.length) {
            target.innerHTML = `
                <div class="ops-panel ops-empty" style="grid-column: 1 / -1;">
                    <i class="fas fa-chart-simple"></i>
                    <h3>No hay KPIs con datos para este filtro</h3>
