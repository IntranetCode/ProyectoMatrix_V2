    function buildDepartamentoRendimientoData(dashboard) {
        const kpis = getKpis(dashboard);
        const grupos = new Map();

        kpis.forEach(kpi => {
            const departamento = pick(kpi, 'departamento', 'Departamento') || 'Sin departamento';
            const resultado = getResultado(kpi);
            const cumpleMeta = pick(resultado, 'cumpleMeta', 'CumpleMeta');

            if (!grupos.has(departamento)) {
                grupos.set(departamento, {
                    departamento,
                    total: 0,
                    cumplidos: 0,
                    noCumplidos: 0,
                    sinEvaluacion: 0,
                    porcentaje: 0
                });
            }

            const row = grupos.get(departamento);
            row.total += 1;

            if (cumpleMeta === true) {
                row.cumplidos += 1;
            } else if (cumpleMeta === false) {
                row.noCumplidos += 1;
            } else {
                row.sinEvaluacion += 1;
            }
        });

        let data = Array.from(grupos.values()).map(row => {
            row.porcentaje = row.total > 0 ? Number(((row.cumplidos / row.total) * 100).toFixed(2)) : 0;
            return row;
        });

        if (!data.length && Array.isArray(departamentosBase)) {
            data = departamentosBase.map(depto => ({
                departamento: pick(depto, 'nombreDepartamento', 'NombreDepartamento') || 'Departamento',
                total: toNumber(pick(depto, 'totalKpis', 'TotalKpis')),
                cumplidos: 0,
                noCumplidos: toNumber(pick(depto, 'totalKpis', 'TotalKpis')),
                sinEvaluacion: 0,
                porcentaje: toNumber(pick(depto, 'porcentajeCumplimiento', 'PorcentajeCumplimiento'))
            })).filter(row => row.total > 0);
        }

        return data.sort((a, b) => b.porcentaje - a.porcentaje || b.total - a.total);
    }

