            return;
        }

        target.innerHTML = kpis.map(kpi => buildKpiCard(kpi)).join('');

        kpis.forEach(kpi => {
            const id = `kpiChart_${pick(kpi, 'metricaID', 'MetricaID')}`;
            renderKpiChart(id, kpi);
        });
