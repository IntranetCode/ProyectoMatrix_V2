    function buildKpiCard(kpi) {
        const metricaId = pick(kpi, 'metricaID', 'MetricaID');
        const nombre = pick(kpi, 'nombreMetrica', 'NombreMetrica') || 'KPI';
        const departamento = pick(kpi, 'departamento', 'Departamento') || '';
        const frecuencia = pick(kpi, 'frecuencia', 'Frecuencia') || '';
        const modo = pick(kpi, 'modoCalculoKpi', 'ModoCalculoKpi') || 'Promedio';
        const tamano = pick(kpi, 'tamanoGrafica', 'TamanoGrafica') || 'Normal';
        const resultado = getResultado(kpi);
        const estado = pick(resultado, 'estadoVisual', 'EstadoVisual') || 'neutral';
        const resultadoTexto = pick(resultado, 'resultadoFormateado', 'ResultadoFormateado') || '--';
        const metaTexto = pick(resultado, 'metaFormateada', 'MetaFormateada') || '';
        const descripcion = pick(resultado, 'descripcionCalculo', 'DescripcionCalculo') || '';

        const badgeIcon = estado === 'success'
            ? 'fa-circle-check'
            : estado === 'danger'
                ? 'fa-triangle-exclamation'
                : 'fa-circle-info';

        const badgeText = estado === 'success'
            ? 'Cumple meta'
            : estado === 'danger'
                ? 'Fuera de meta'
                : 'Sin evaluación';

        return `
            <article class="ops-panel ops-kpi-card size-${escapeHtml(tamano)}">
                <div class="ops-kpi-head">
                    <div>
                        <h3 class="ops-kpi-title">${escapeHtml(nombre)}</h3>
                        <div class="ops-kpi-subtitle">${escapeHtml(departamento)} · ${escapeHtml(frecuencia)} · ${escapeHtml(modo)}</div>
                        <span class="ops-badge ${escapeHtml(estado)}"><i class="fas ${badgeIcon}"></i>${badgeText}</span>
                    </div>
                    <div class="ops-kpi-value">
                        <div class="ops-kpi-result">${escapeHtml(resultadoTexto)}</div>
                        <div class="ops-kpi-meta">${metaTexto ? 'Meta: ' + escapeHtml(metaTexto) : 'Sin meta'}</div>
                        <div class="ops-kpi-meta">${escapeHtml(descripcion)}</div>
                    </div>
                </div>
                <div class="ops-kpi-chart" id="kpiChart_${metricaId}"></div>
            </article>
        `;
    }

    function renderKpiChart(elementId, kpi) {
        const el = document.getElementById(elementId);
        if (!el) return;

        const historial = getHistorial(kpi);
        const tipoGrafica = normalizeText(pick(kpi, 'tipoGrafica', 'TipoGrafica') || 'ComboChart');
        const resultado = getResultado(kpi);
        const modo = normalizeText(pick(kpi, 'modoCalculoKpi', 'ModoCalculoKpi') || 'Promedio');
        const mostrarMeta = pick(kpi, 'mostrarMetaEnGrafica', 'MostrarMetaEnGrafica') !== false;
        const meta = pick(kpi, 'metaEsperada', 'MetaEsperada');

        const chart = echarts.init(el);
        chartInstances.set(elementId, chart);

        if (!historial.length) {
            chart.setOption(emptyChartOption('Sin historial capturado'));
            return;
        }

        if (tipoGrafica.includes('thermometer') || tipoGrafica.includes('termometro') || tipoGrafica.includes('termómetro')) {
            chart.setOption(buildKpiThermometerOption(kpi));
            return;
        }

        if (tipoGrafica.includes('pie') || tipoGrafica.includes('pastel') || tipoGrafica.includes('doughnut') || tipoGrafica.includes('dona')) {
            chart.setOption(buildPieOption(kpi, historial));
            return;
        }

        const periodos = historial.map(p => pick(p, 'periodo', 'Periodo') || 'Periodo');
        const variableNames = collectVariableNames(historial);
        const stacked = tipoGrafica.includes('stacked') || tipoGrafica.includes('apilad');
        const lineOnly = tipoGrafica.includes('line') || tipoGrafica.includes('linea') || tipoGrafica.includes('línea');
        const area = tipoGrafica.includes('area') || tipoGrafica.includes('área');

        const series = variableNames.map(nombre => {
            const data = historial.map(periodo => {
                const variable = getVariables(periodo).find(v => (pick(v, 'nombre', 'Nombre') || '') === nombre);
                return variable ? toNumber(pick(variable, 'valor', 'Valor')) : null;
            });

            const sampleVariable = historial.flatMap(getVariables).find(v => (pick(v, 'nombre', 'Nombre') || '') === nombre) || {};
            const esLinea = pick(sampleVariable, 'esLinea', 'EsLinea') === true;
            const tipoCaptura = normalizeText(pick(sampleVariable, 'tipoCaptura', 'TipoCaptura') || 'Manual');

            const serie = {
                name: nombre,
                type: lineOnly || esLinea ? 'line' : 'bar',
                data,
                smooth: lineOnly || esLinea,
                symbolSize: lineOnly || esLinea ? 8 : 0,
                emphasis: { focus: 'series' }
            };

            if (stacked && serie.type === 'bar') serie.stack = 'total';
            if (area && serie.type === 'line') serie.areaStyle = {};
            if (esLinea && tipoCaptura === 'fijo') serie.lineStyle = { type: 'dashed', width: 2 };
            if (serie.type === 'bar') serie.itemStyle = { borderRadius: [6, 6, 0, 0] };

            return serie;
        });

        const resultadoSerie = {
            name: 'Resultado KPI',
            type: 'line',
            yAxisIndex: shouldUseSecondaryAxis(kpi) ? 1 : 0,
            data: historial.map(p => {
                const r = pick(p, 'resultadoKpi', 'ResultadoKpi');
                return r === null || r === undefined ? null : toNumber(r);
            }),
            smooth: true,
            symbolSize: 9,
            lineStyle: { width: 3 },
            emphasis: { focus: 'series' }
        };

        if (mostrarMeta && meta !== null && meta !== undefined) {
            resultadoSerie.markLine = buildMetaMarkLine(kpi, resultadoSerie.yAxisIndex);
        }

        series.push(resultadoSerie);

        const yAxis = [{
            type: 'value',
            splitLine: { lineStyle: { type: 'dashed' } }
        }];

        if (resultadoSerie.yAxisIndex === 1) {
            yAxis.push({
                type: 'value',
                splitLine: { show: false },
                axisLabel: { formatter: value => formatAxisValue(value, pick(resultado, 'tipoValor', 'TipoValor'), pick(resultado, 'unidadMedida', 'UnidadMedida')) }
            });
        }

        chart.setOption({
            tooltip: {
                trigger: 'axis',
                confine: true
            },
            legend: {
                type: 'scroll',
                top: 4,
                left: 12,
                right: 12
            },
            grid: {
                left: 48,
                right: resultadoSerie.yAxisIndex === 1 ? 58 : 26,
                top: 58,
                bottom: 42
            },
            xAxis: {
                type: 'category',
                data: periodos,
                axisLabel: { interval: 0 }
            },
            yAxis,
            series
        });
    }


    function buildKpiThermometerOption(kpi) {
        const resultado = getResultado(kpi);
        const nombre = pick(kpi, 'nombreMetrica', 'NombreMetrica') || 'KPI';
        const valor = toNumber(pick(resultado, 'resultado', 'Resultado'));
        const valorTexto = pick(resultado, 'resultadoFormateado', 'ResultadoFormateado') || valor.toString();
        const meta = pick(kpi, 'metaEsperada', 'MetaEsperada');
        const metaNumero = meta === null || meta === undefined ? null : toNumber(meta);
        const metaTexto = pick(resultado, 'metaFormateada', 'MetaFormateada') || (metaNumero === null ? '' : metaNumero.toString());
        const tipoValor = pick(resultado, 'tipoValor', 'TipoValor') || pick(kpi, 'tipoValor', 'TipoValor') || '';
        const unidad = pick(resultado, 'unidadMedida', 'UnidadMedida') || pick(kpi, 'unidadMedida', 'UnidadMedida') || '';
        const baseMax = Math.max(valor, metaNumero || 0, 100);
        const maximo = baseMax <= 100 ? 100 : Math.ceil(baseMax * 1.18);
        const estado = pick(resultado, 'estadoVisual', 'EstadoVisual') || 'neutral';
        const color = estado === 'success' ? '#16a34a' : estado === 'danger' ? '#ef4444' : '#0ea5e9';

        return {
            title: {
                text: 'Termómetro del KPI',
                subtext: nombre,
                left: 18,
                top: 8,
                textStyle: { fontSize: 14, fontWeight: 900, color: '#0f172a' },
                subtextStyle: { fontSize: 12, fontWeight: 750, color: '#64748b' }
            },
            tooltip: {
                trigger: 'axis',
                axisPointer: { type: 'shadow' },
                formatter: () => {
                    return `<strong>${escapeHtml(nombre)}</strong><br/>` +
                        `Resultado: <strong>${escapeHtml(valorTexto)}</strong>` +
                        (metaNumero !== null ? `<br/>Meta: <strong>${escapeHtml(metaTexto)}</strong>` : '');
                }
            },
            grid: { left: 44, right: 40, top: 86, bottom: 58 },
            xAxis: {
                type: 'value',
                min: 0,
                max: maximo,
                axisLabel: { formatter: value => formatAxisValue(value, tipoValor, unidad) },
                splitLine: { lineStyle: { type: 'dashed' } }
            },
            yAxis: {
                type: 'category',
                data: ['Resultado'],
                axisLabel: { fontWeight: 900, color: '#334155' }
            },
            series: [
                {
                    name: 'Base',
                    type: 'bar',
                    barGap: '-100%',
                    data: [maximo],
                    barMaxWidth: 38,
                    silent: true,
                    itemStyle: { borderRadius: 999, color: '#e5edf6' }
                },
                {
                    name: 'Resultado',
                    type: 'bar',
                    data: [valor],
                    barMaxWidth: 38,
                    label: {
                        show: true,
                        position: 'right',
                        formatter: () => valorTexto,
                        fontWeight: 950,
                        color: '#0f172a'
                    },
                    itemStyle: { borderRadius: 999, color },
                    markLine: metaNumero !== null ? {
                        silent: true,
                        symbol: 'none',
                        lineStyle: { type: 'dashed', color: '#f59e0b', width: 2 },
                        label: { formatter: `Meta: ${metaTexto}`, fontWeight: 900 },
                        data: [{ xAxis: metaNumero }]
                    } : undefined
                }
            ]
        };
    }

    function buildPieOption(kpi, historial) {
        const ultimoPeriodo = historial[historial.length - 1];
        const variables = getVariables(ultimoPeriodo)
            .filter(v => pick(v, 'esLinea', 'EsLinea') !== true)
            .map(v => ({
                name: pick(v, 'nombre', 'Nombre') || 'Variable',
                value: toNumber(pick(v, 'valor', 'Valor'))
            }))
            .filter(v => v.value !== 0);

        const tipoGrafica = normalizeText(pick(kpi, 'tipoGrafica', 'TipoGrafica') || '');
        const isDoughnut = tipoGrafica.includes('doughnut') || tipoGrafica.includes('dona');

        if (!variables.length) return emptyChartOption('Sin datos para gráfica circular');

        return {
            tooltip: { trigger: 'item' },
            legend: { type: 'scroll', bottom: 0 },
            series: [{
                type: 'pie',
                radius: isDoughnut ? ['45%', '72%'] : '72%',
                center: ['50%', '45%'],
                data: variables,
                label: { formatter: '{b}: {d}%' }
            }]
        };
    }

    function collectVariableNames(historial) {
        const set = new Set();
        historial.forEach(periodo => {
            getVariables(periodo).forEach(v => {
                const name = pick(v, 'nombre', 'Nombre');
                if (name) set.add(name);
            });
        });
        return Array.from(set);
    }

    function shouldUseSecondaryAxis(kpi) {
        const modo = normalizeText(pick(kpi, 'modoCalculoKpi', 'ModoCalculoKpi') || '');
        return modo.includes('ratio') || modo.includes('ponderado');
    }

    function buildMetaMarkLine(kpi, yAxisIndex) {
        const meta = pick(kpi, 'metaEsperada', 'MetaEsperada');
        const resultado = getResultado(kpi);
        const metaTexto = pick(resultado, 'metaFormateada', 'MetaFormateada') || meta;

        if (meta === null || meta === undefined) return null;

        return {
            silent: true,
            symbol: 'none',
            lineStyle: { type: 'dashed', width: 2 },
            label: {
                formatter: `Meta: ${metaTexto}`,
                fontWeight: 800,
                borderRadius: 8,
                padding: [4, 8]
            },
            data: [{ yAxis: toNumber(meta) }]
        };
    }

    function emptyChartOption(message) {
        return {
            title: {
                text: message,
                left: 'center',
                top: 'middle',
                textStyle: { fontSize: 14, fontWeight: 800, color: '#64748b' }
            },
            xAxis: { show: false },
            yAxis: { show: false },
            series: []
        };
    }

    function formatAxisValue(value, tipoValor, unidadMedida) {
        tipoValor = normalizeText(tipoValor);
        unidadMedida = (unidadMedida || '').trim();

        if (tipoValor.includes('porcentaje') || unidadMedida === '%') return `${value}%`;
        if (tipoValor.includes('moneda') || unidadMedida === '$') return `$${value}`;
        return value;
    }

    function disposeChart(id) {
        const current = chartInstances.get(id);
        if (current) {
            current.dispose();
            chartInstances.delete(id);
        }
    }

    function disposeKpiCharts() {
        Array.from(chartInstances.keys()).forEach(id => {
            if (id !== 'globalChart') disposeChart(id);
        });
    }

    function escapeHtml(value) {
        return (value ?? '').toString()
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    document.addEventListener('DOMContentLoaded', () => {
        const modalKpisPdf = document.getElementById('modalKpisPdf');

        if (modalKpisPdf && modalKpisPdf.parentElement !== document.body) {
            document.body.appendChild(modalKpisPdf);
        }

        renderDashboard(dashboardActual);

        document.getElementById('btnApplyFilters').addEventListener('click', cargarDashboard);
        document.getElementById('btnRefreshDashboard').addEventListener('click', cargarDashboard);
        document.getElementById('btnClearFilters').addEventListener('click', limpiarFiltros);
        document.getElementById('navGeneralItem')?.addEventListener('click', activarVistaKpis);
        document.getElementById('navComprasItem')?.addEventListener('click', activarVistaCompras);

        document.querySelectorAll('.ops-depto-item[data-departamento-id]').forEach(btn => {
            btn.addEventListener('click', () => setDepartamentoActivo(btn.dataset.departamentoId));
        });

        document.querySelectorAll('[data-global-chart-mode]').forEach(btn => {
            btn.addEventListener('click', () => {
                dashboardState.globalChartMode = btn.dataset.globalChartMode || 'resumen';
                actualizarBotonesModoGlobal();

                if (dashboardState.viewMode === 'compras' && comprasActual) {
                    renderGlobalChartCompras(comprasActual);
                    return;
                }

                renderGlobalChart(dashboardActual);
            });
        });

        actualizarBotonesModoGlobal();

        window.addEventListener('resize', () => {
            chartInstances.forEach(chart => chart.resize());
        });
    });
</script>
