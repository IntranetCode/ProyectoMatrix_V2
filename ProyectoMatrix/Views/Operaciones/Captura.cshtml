        grid-template-columns: 1fr !important;
    }

    .ops-sidebar {
        position: relative !important;
        top: auto !important;
    }

    .ops-depto-list {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .ops-kpi-grid,
    .kpi-grid {
        grid-template-columns: 1fr !important;
    }
}

@@media (max-width: 768px) {
    .ops-v2-page,
    .kpis-v2-page {
        padding: 10px !important;
