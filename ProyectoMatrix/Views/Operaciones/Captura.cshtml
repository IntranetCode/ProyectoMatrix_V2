<style>
    :root {
        --matrix-success: #16a34a;
        --matrix-success-dark: #0f7a39;
        --matrix-primary: #2563eb;
        --matrix-primary-dark: #1d4ed8;
        --matrix-cyan: #06b6d4;
        --matrix-purple: #7c3aed;
        --matrix-dark: #111827;
        --matrix-soft: #f8fafc;
    }

    .hero-glow-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(248,250,252,.98));
    }

    .hero-glow-card::before {
        content: "";
        position: absolute;
        width: 420px;
        height: 420px;
        right: -180px;
        top: -180px;
        background: radial-gradient(circle, rgba(37,99,235,.18), transparent 65%);
        pointer-events: none;
    }

    .hero-glow-card::after {
        content: "";
        position: absolute;
        width: 360px;
        height: 360px;
        left: -160px;
        bottom: -180px;
        background: radial-gradient(circle, rgba(22,163,74,.14), transparent 65%);
        pointer-events: none;
    }

    .futuristic-option {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(148,163,184,.35) !important;
        background:
            linear-gradient(135deg, rgba(255,255,255,.98), rgba(248,250,252,.95)),
            radial-gradient(circle at top right, rgba(37,99,235,.14), transparent 35%) !important;
        transition: all .25s ease;
        isolation: isolate;
    }

    .futuristic-option::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,.75) 45%, transparent 70%);
        transform: translateX(-120%);
        transition: transform .65s ease;
        z-index: -1;
    }

    .futuristic-option:hover {
        transform: translateY(-6px) scale(1.01);
        border-color: rgba(37,99,235,.45) !important;
        box-shadow:
            0 18px 40px rgba(15,23,42,.14),
            0 0 0 4px rgba(37,99,235,.08) !important;
    }

    .futuristic-option:hover::before {
        transform: translateX(120%);
    }

    .futuristic-option.manual:hover {
        border-color: rgba(22,163,74,.55) !important;
        box-shadow:
            0 18px 40px rgba(15,23,42,.14),
            0 0 0 4px rgba(22,163,74,.10) !important;
    }

    .option-icon {
        width: 62px;
        height: 62px;
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.35rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.6), 0 12px 24px rgba(15,23,42,.12);
    }

    .option-icon.manual {
        color: #fff;
        background: linear-gradient(135deg, #22c55e, #15803d);
    }

    .option-icon.excel {
        color: #fff;
        background: linear-gradient(135deg, #3b82f6, #06b6d4);
    }

    .soft-pill {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .45rem .75rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        border: 1px solid rgba(148,163,184,.35);
        background: rgba(255,255,255,.75);
        color: #334155;
    }

    .soft-pill.success {
        color: #166534;
        background: rgba(220,252,231,.9);
        border-color: rgba(34,197,94,.25);
    }

    .soft-pill.primary {
        color: #1d4ed8;
        background: rgba(219,234,254,.9);
        border-color: rgba(59,130,246,.25);
    }

    .btn-future {
        position: relative;
        overflow: hidden;
        border: 0;
        border-radius: 16px;
        font-weight: 800;
        letter-spacing: .2px;
        transition: all .22s ease;
        box-shadow: 0 12px 24px rgba(15,23,42,.15);
    }

    .btn-future::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,.35) 45%, transparent 70%);
        transform: translateX(-120%);
        transition: transform .6s ease;
    }

    .btn-future:hover {
        transform: translateY(-3px);
        box-shadow: 0 18px 34px rgba(15,23,42,.22);
    }

    .btn-future:hover::before {
        transform: translateX(120%);
    }

    .btn-future-success {
        color: white;
        background: linear-gradient(135deg, #22c55e, #16a34a, #0f766e);
    }

    .btn-future-primary {
        color: white;
        background: linear-gradient(135deg, #2563eb, #0891b2, #06b6d4);
    }

    .btn-future-dark {
        color: white;
        background: linear-gradient(135deg, #111827, #334155);
    }

    .btn-ghost-future {
        border-radius: 14px;
        font-weight: 700;
        border: 1px solid rgba(148,163,184,.45);
        background: rgba(255,255,255,.82);
        backdrop-filter: blur(10px);
        transition: all .2s ease;
    }

    .btn-ghost-future:hover {
        transform: translateY(-2px);
        border-color: rgba(37,99,235,.4);
        box-shadow: 0 10px 22px rgba(15,23,42,.12);
    }

    .step-circle {
        width: 40px;
        height: 40px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        flex-shrink: 0;
        box-shadow: 0 10px 18px rgba(15,23,42,.12);
    }

    .excel-rule-card {
        border-left: 5px solid #0d6efd;
        background: linear-gradient(135deg, #eff6ff, #ffffff);
    }

    .excel-warning-card {
        border-left: 5px solid #ffc107;
        background: linear-gradient(135deg, #fffbeb, #ffffff);
    }

    .capture-section-title {
        letter-spacing: .2px;
    }

    .upload-panel {
        background: linear-gradient(135deg, rgba(255,255,255,.98), rgba(248,250,252,.98));
        border: 1px solid rgba(148,163,184,.28);
        box-shadow: 0 14px 30px rgba(15,23,42,.08);
    }

    .file-input-future {
        border-radius: 14px;
        border: 1px dashed rgba(37,99,235,.45);
        background-color: #f8fafc;
    }

    .file-input-future:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 .25rem rgba(37,99,235,.12);
    }

    .input-unit-addon {
        min-width: 88px;
        justify-content: center;
        font-weight: 900;
        color: #0f172a;
        background: linear-gradient(135deg, #ecfeff, #dbeafe);
        border-color: rgba(37,99,235,.28);
    }

    .input-unit-addon.money {
        color: #14532d;
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        border-color: rgba(22,163,74,.28);
    }

    .input-unit-addon.percent {
        color: #1e3a8a;
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        border-color: rgba(37,99,235,.28);
    }

    .unit-helper {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        margin-top: .35rem;
        padding: .25rem .55rem;
        border-radius: 999px;
        background: rgba(15,23,42,.05);
        color: #475569;
        font-size: .78rem;
        font-weight: 700;
    }

</style>

<div class="container-fluid px-4 my-5">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-@TempData["Tipo"] alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas @(TempData["Tipo"]?.ToString() == "success" ? "fa-check-circle" : "fa-exclamation-triangle") me-2"></i>
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!puedeCapturar)
    {
        <div class="alert alert-warning shadow-sm text-center py-5 rounded-4">
            <i class="fas fa-ban fa-2x mb-3"></i>
            <h4 class="mb-0">No tienes permiso para capturar KPI.</h4>
            <p class="mb-0">Contacta a tu administrador si necesitas acceso.</p>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-11">

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden hero-glow-card">
                    <div class="card-header bg-success text-white py-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                        <div>
                            <h4 class="mb-0 fw-bold">
                                <i class="fas fa-keyboard me-2"></i> Registro de Resultados Operativos
                            </h4>
                            <small class="opacity-75">Captura manual o carga histórica desde Excel</small>
                        </div>

                        <a href="/Operaciones/Index" class="btn btn-sm btn-light fw-bold rounded-pill px-3 shadow-sm">
                            <i class="fas fa-chart-line me-1 text-success"></i> Ver Tablero
                        </a>
                    </div>

                    <div class="card-body p-4 p-md-5">

                        <div id="bloqueSelectorModo" class="mb-4">
                            <div class="text-center mb-4">
                                <span class="badge bg-success-subtle text-success border border-success border-opacity-25 px-3 py-2 mb-2">
                                    Captura de KPIs
                                </span>

                                <h3 class="fw-bold mb-2">¿Cómo deseas capturar los datos?</h3>

                                <p class="text-muted mb-0">
                                    Usa captura manual para un registro puntual o Excel para revisar e importar históricos.
                                </p>
                            </div>

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <button type="button"
                                            class="btn w-100 h-100 p-4 rounded-4 shadow-sm text-start futuristic-option manual"
                                            onclick="mostrarModoCaptura('manual')">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="option-icon manual">
                                                <i class="fas fa-pen-nib"></i>
                                            </div>

                                            <div class="flex-grow-1">
                                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                                    <h5 class="fw-bold mb-0 text-dark">Ingresar datos manualmente</h5>
                                                    <i class="fas fa-arrow-right text-success mt-1"></i>
                                                </div>

                                                <p class="text-muted mb-3">
                                                    Captura un KPI individual seleccionando métrica, periodo y valores.
                                                </p>

                                                <div class="d-flex flex-wrap gap-2">
                                                    <span class="soft-pill success">
                                                        <i class="fas fa-check-circle"></i> Captura individual
                                                    </span>
                                                    <span class="soft-pill">
                                                        <i class="fas fa-keyboard"></i> Formulario directo
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </button>
                                </div>

                                <div class="col-md-6">
                                    <button type="button"
                                            class="btn w-100 h-100 p-4 rounded-4 shadow-sm text-start futuristic-option"
                                            onclick="mostrarModoCaptura('excel')">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="option-icon excel">
                                                <i class="fas fa-file-import"></i>
                                            </div>

                                            <div class="flex-grow-1">
                                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                                    <h5 class="fw-bold mb-0 text-dark">Importar hoja de Excel</h5>
                                                    <i class="fas fa-arrow-right text-primary mt-1"></i>
                                                </div>

                                                <p class="text-muted mb-3">
                                                    Carga históricos desde plantilla. Antes de guardar, el sistema mostrará una previsualización.
                                                </p>

                                                <div class="d-flex flex-wrap gap-2">
                                                    <span class="soft-pill primary">
                                                        <i class="fas fa-clock-rotate-left"></i> Carga histórica
                                                    </span>
                                                    <span class="soft-pill">
                                                        <i class="fas fa-eye"></i> Revisión previa
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div id="bloqueExcel" class="d-none">
                            <div class="rounded-4 p-4 upload-panel mb-4">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                                    <div>
                                        <h5 class="fw-bold text-dark mb-2">
                                            <i class="fas fa-file-excel text-success me-2"></i> Preparar plantilla por KPI
                                        </h5>

                                        <p class="text-muted mb-0">
                                            Selecciona el KPI que deseas importar. El Excel solo incluirá variables manuales para evitar confusiones.
                                        </p>
                                    </div>

                                    <button type="button" class="btn btn-ghost-future btn-sm px-3" onclick="volverSelectorCaptura()">
                                        <i class="fas fa-arrow-left me-1"></i> Cambiar opción
                                    </button>
                                </div>

                                <div class="row g-3">

                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Área</label>

                                        <select id="selectDepartamentoImportacion"
                                                class="form-select"
                                                onchange="cargarKpisImportables()"
                                                @(departamentoBloqueado ? "disabled" : "")>

                                            <option value="">Selecciona un área</option>

                                            @foreach (var d in departamentosImportacion)
                                            {
                                                if (departamentoUsuarioID.HasValue && d.DepartamentoID == departamentoUsuarioID.Value)
                                                {
                                                    <option value="@d.DepartamentoID" selected>@d.NombreDepartamento</option>
                                                }
                                                else
                                                {
                                                    <option value="@d.DepartamentoID">@d.NombreDepartamento</option>
                                                }
                                            }
                                        </select>

                                        @if (departamentoBloqueado && departamentoUsuarioID.HasValue)
                                        {
                                            <input type="hidden"
                                                   id="departamentoImportacionBloqueado"
                                                   value="@departamentoUsuarioID.Value" />
                                        }

                                        <small class="text-muted">
                                            Los jefes de departamento solo pueden importar KPIs de su propia área.
                                        </small>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">KPI a importar</label>
                                        <select id="selectKpiImportacion"
                                                class="form-select"
                                                onchange="actualizarAyudaKpiImportacion()">
                                            <option value="">Primero selecciona un área</option>
                                        </select>

                                        <small class="text-muted" id="ayudaKpiImportacion">
                                            Solo aparecerán KPIs con variables manuales.
                                        </small>
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label fw-bold">Año</label>
                                        <input type="number"
                                               id="inputAnioImportacion"
                                               class="form-control"
                                               value="@DateTime.Now.Year"
                                               min="2020"
                                               max="2100" />
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label fw-bold">Periodo</label>
                                        <input type="number"
                                               id="inputPeriodoInicio"
                                               class="form-control"
                                               value="1"
                                               min="1"
                                               max="53" />
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label fw-bold">Hasta</label>
                                        <input type="number"
                                               id="inputPeriodoFin"
                                               class="form-control"
                                               value="12"
                                               min="1"
                                               max="53" />
                                    </div>

                                    <div class="col-md-10 d-flex align-items-end">
                                        <div class="alert alert-info border-0 rounded-4 mb-0 w-100">
                                            <i class="fas fa-circle-info me-2"></i>
                                            La plantilla descargada solo mostrará columnas simples:
                                            <strong>Año, Periodo, Fecha, Variable y Valor</strong>.
                                            Los valores fijos y calculados los agregará el sistema automáticamente.
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <button type="button"
                                                class="btn btn-future btn-future-success btn-lg w-100 py-3"
                                                onclick="descargarPlantillaKpiSeleccionado()">
                                            <i class="fas fa-cloud-arrow-down me-2"></i> Descargar plantilla de este KPI
                                        </button>
                                    </div>

                                    <div class="mt-4 pt-4 border-top">
                                        <div class="d-flex align-items-start gap-3 mb-3">
                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                                style="width: 42px; height: 42px; min-width: 42px;">
                                                <i class="fas fa-upload"></i>
                                            </div>

                                            <div>
                                                <h5 class="fw-bold text-dark mb-1">Subir Excel ya llenado</h5>
                                                <p class="text-muted mb-0">
                                                    Después de descargar y completar la plantilla, sube el archivo para revisar los datos antes de guardarlos.
                                                </p>
                                            </div>
                                        </div>

                                        <form action="/Operaciones/PrevisualizarImportacionExcel"
                                            method="post"
                                            enctype="multipart/form-data"
                                            class="upload-excel-box rounded-4 p-4">

                                            @Html.AntiForgeryToken()

                                            <div class="row g-3 align-items-end">
                                                <div class="col-md-8">
                                                    <label class="form-label fw-bold">
                                                        Archivo Excel
                                                    </label>

                                                    <input type="file"
                                                        name="excelFile"
                                                        id="excelFile"
                                                        class="form-control form-control-lg file-input-future"
                                                        accept=".xlsx,.xls"
                                                        required />

                                                    <small class="text-muted d-block mt-2">
                                                        Formatos permitidos: .xlsx o .xls. Usa preferentemente la plantilla descargada desde este módulo.
                                                    </small>
                                                </div>

                                                <div class="col-md-4">
                                                    <button type="submit"
                                                            class="btn btn-future btn-future-primary btn-lg w-100 py-3">
                                                        <i class="fas fa-eye me-2"></i> Previsualizar Excel
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="bloqueManual" class="d-none">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">
                                <div>
                                    <h4 class="fw-bold text-success mb-1 capture-section-title">
                                        <i class="fas fa-edit me-2"></i> Captura manual de KPI
                                    </h4>

                                    <p class="text-muted mb-0">
                                        Selecciona una métrica, define el periodo y captura sus valores.
                                    </p>
                                </div>

                                <button type="button" class="btn btn-ghost-future btn-sm px-3" onclick="volverSelectorCaptura()">
                                    <i class="fas fa-arrow-left me-1"></i> Cambiar opción
                                </button>
                            </div>

                            <form action="/Operaciones/GuardarKpi" method="post" id="formCaptura">

                                <div class="mb-4">
                                    <label class="form-label fw-bold text-secondary">
                                        1. Selecciona la Métrica a Evaluar
                                    </label>

                                    <select name="metricaId"
                                            id="metricaSelect"
                                            class="form-select form-select-lg shadow-sm border-success"
                                            onchange="manejarSeleccionMetrica()"
                                            required>
                                        <option value="">-- Elige un indicador --</option>

                                        @foreach (var m in Model)
                                        {
                                            <option value="@m.MetricaID" data-frecuencia="@m.Frecuencia">
                                                @m.Departamento.NombreDepartamento - @m.NombreMetrica
                                            </option>
                                        }
                                    </select>
                                </div>

                                <div class="row mb-4 bg-light p-3 rounded-3 border d-none" id="bloqueTiempo">
                                    <div class="col-md-6 d-none" id="divPeriodoMensualSemanal">
                                        <label class="form-label fw-bold text-primary" id="labelPeriodo">Periodo</label>
                                        <select name="numeroPeriodo" id="selectPeriodo" class="form-select shadow-sm"></select>
                                    </div>

                                    <div class="col-md-6 d-none" id="divAnio">
                                        <label class="form-label fw-bold text-primary">
                                            <i class="fas fa-calendar"></i> Año
                                        </label>
                                        <input type="number" name="anio" id="inputAnio" class="form-control shadow-sm" value="@DateTime.Now.Year" />
                                    </div>

                                    <div class="col-md-12 d-none" id="divPeriodoDiario">
                                        <label class="form-label fw-bold text-danger">
                                            <i class="fas fa-calendar-day"></i> Fecha Exacta de la Medición
                                        </label>
                                        <input type="date" name="fechaDiaria" id="inputFechaDiaria" class="form-control shadow-sm border-danger" />
                                    </div>
                                </div>

                                <hr class="my-4">

                                <div id="contenedorVariables">
                                    <div class="alert alert-secondary text-center">
                                        <i class="fas fa-arrow-up fa-2x mb-2 text-muted"></i>
                                        <h5>Selecciona un indicador arriba para comenzar</h5>
                                    </div>
                                </div>

                                <div class="d-grid mt-5">
                                    <button type="submit" id="btnGuardar" class="btn btn-future btn-future-success btn-lg fw-bold py-3" disabled>
                                        <i class="fas fa-floppy-disk me-2"></i> Guardar Resultados
                                    </button>
                                </div>
                            </form>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const hiddenDepto = document.getElementById('departamentoImportacionBloqueado');
            const selectDepto = document.getElementById('selectDepartamentoImportacion');

            const departamentoId = hiddenDepto && hiddenDepto.value
                ? hiddenDepto.value
                : (selectDepto ? selectDepto.value : "");

            console.log('Departamento inicial:', departamentoId);

            if (departamentoId) {
                cargarKpisImportables();
            }
        });

        function mostrarModoCaptura(modo) {
            const selector = document.getElementById('bloqueSelectorModo');
            const bloqueManual = document.getElementById('bloqueManual');
            const bloqueExcel = document.getElementById('bloqueExcel');

            if (!selector || !bloqueManual || !bloqueExcel) {
                console.error('No se encontraron los bloques de captura.');
                return;
            }

            selector.classList.add('d-none');
            bloqueManual.classList.add('d-none');
            bloqueExcel.classList.add('d-none');

            if (modo === 'manual') {
                bloqueManual.classList.remove('d-none');
            }

            if (modo === 'excel') {
                bloqueExcel.classList.remove('d-none');

                setTimeout(() => {
                    cargarKpisImportables();
                }, 150);
            }
        }

        function volverSelectorCaptura() {
            const selector = document.getElementById('bloqueSelectorModo');
            const bloqueManual = document.getElementById('bloqueManual');
            const bloqueExcel = document.getElementById('bloqueExcel');

            if (!selector || !bloqueManual || !bloqueExcel) {
                console.error('No se encontraron los bloques de captura.');
                return;
            }

            selector.classList.remove('d-none');
            bloqueManual.classList.add('d-none');
            bloqueExcel.classList.add('d-none');
        }

        async function cargarKpisImportables() {
            const selectDepto = document.getElementById('selectDepartamentoImportacion');
            const hiddenDepto = document.getElementById('departamentoImportacionBloqueado');
            const selectKpi = document.getElementById('selectKpiImportacion');
            const ayuda = document.getElementById('ayudaKpiImportacion');

            if (!selectKpi) {
                console.error('No existe selectKpiImportacion');
                return;
            }

            let departamentoId = "";

            if (hiddenDepto && hiddenDepto.value) {
                departamentoId = hiddenDepto.value;
            }
            else if (selectDepto && selectDepto.value) {
                departamentoId = selectDepto.value;
            }

            console.log('Departamento detectado para importar:', departamentoId);

            selectKpi.innerHTML = '<option value="">Cargando KPIs...</option>';

            if (!departamentoId) {
                selectKpi.innerHTML = '<option value="">Primero selecciona un área</option>';

                if (ayuda) {
                    ayuda.innerText = 'No se detectó el departamento del usuario.';
                }

                return;
            }

            try {
                const url = `/Operaciones/ObtenerKpisImportablesPorDepartamento?departamentoId=${departamentoId}`;
                console.log('Consultando:', url);

                const response = await fetch(url);

                if (!response.ok) {
                    selectKpi.innerHTML = '<option value="">Error al consultar KPIs</option>';

                    if (ayuda) {
                        ayuda.innerText = `Error HTTP: ${response.status}`;
                    }

                    return;
                }

                const data = await response.json();

                console.log('Respuesta KPIs:', data);

                const success = data.success ?? data.Success;
                const metricas = data.metricas ?? data.Metricas;
                const mensaje = data.mensaje ?? data.Mensaje;

                if (!success) {
                    selectKpi.innerHTML = '<option value="">No se pudieron cargar KPIs</option>';

                    if (ayuda) {
                        ayuda.innerText = mensaje || 'Ocurrió un error al cargar los KPIs.';
                    }

                    return;
                }

                if (!metricas || metricas.length === 0) {
                    selectKpi.innerHTML = '<option value="">No hay KPIs importables</option>';

                    if (ayuda) {
                        ayuda.innerText = 'Esta área no tiene KPIs activos con variables manuales.';
                    }

                    return;
                }

                selectKpi.innerHTML = '<option value="">Selecciona un KPI</option>';

                metricas.forEach(kpi => {
                    const metricaId = kpi.metricaId ?? kpi.MetricaId ?? kpi.MetricaID;
                    const nombreMetrica = kpi.nombreMetrica ?? kpi.NombreMetrica;
                    const frecuencia = kpi.frecuencia ?? kpi.Frecuencia;
                    const totalVariablesManuales = kpi.totalVariablesManuales ?? kpi.TotalVariablesManuales;
                    const tipoValor = kpi.tipoValor ?? kpi.TipoValor ?? '';
                    const unidadMedida = kpi.unidadMedida ?? kpi.UnidadMedida ?? '';

                    selectKpi.innerHTML += `
                        <option value="${metricaId}"
                                data-frecuencia="${frecuencia}"
                                data-manuales="${totalVariablesManuales}"
                                data-tipo-valor="${tipoValor}"
                                data-unidad-medida="${unidadMedida}">
                            ${nombreMetrica} - ${frecuencia}
                        </option>
                    `;
                });

                if (ayuda) {
                    ayuda.innerText = 'Selecciona el KPI para descargar una plantilla específica.';
                }

            } catch (error) {
                console.error('Error cargando KPIs:', error);

                selectKpi.innerHTML = '<option value="">Error al cargar KPIs</option>';

                if (ayuda) {
                    ayuda.innerText = 'No se pudo conectar con el servidor.';
                }
            }
        }

        function actualizarAyudaKpiImportacion() {
            const selectKpi = document.getElementById('selectKpiImportacion');
            const ayuda = document.getElementById('ayudaKpiImportacion');

            if (!selectKpi || !ayuda) {
                return;
            }

            const option = selectKpi.options[selectKpi.selectedIndex];

            if (!selectKpi.value || !option) {
                ayuda.innerText = 'Solo aparecerán KPIs con variables manuales.';
                return;
            }

            const frecuencia = option.getAttribute('data-frecuencia');
            const manuales = option.getAttribute('data-manuales');
            const tipoValor = option.getAttribute('data-tipo-valor') || '';
            const unidadMedida = option.getAttribute('data-unidad-medida') || '';
            const unidad = obtenerTextoUnidadInput(tipoValor, unidadMedida);
            const textoUnidad = unidad ? ` Unidad de captura: ${unidad}.` : '';

            ayuda.innerText = `Frecuencia: ${frecuencia}. Variables manuales a llenar: ${manuales}.${textoUnidad}`;
        }

        function descargarPlantillaKpiSeleccionado() {
            const metricaId = document.getElementById('selectKpiImportacion').value;
            const anio = document.getElementById('inputAnioImportacion').value;
            const periodoInicio = document.getElementById('inputPeriodoInicio').value;
            const periodoFin = document.getElementById('inputPeriodoFin').value;

            if (!metricaId) {
                alert('Selecciona un KPI antes de descargar la plantilla.');
                return;
            }

            if (!anio || parseInt(anio) < 2020) {
                alert('Captura un año válido.');
                return;
            }

            if (!periodoInicio || !periodoFin) {
                alert('Captura el periodo inicial y final.');
                return;
            }

            if (parseInt(periodoInicio) > parseInt(periodoFin)) {
                alert('El periodo inicial no puede ser mayor al periodo final.');
                return;
            }

            window.location.href =
                `/Operaciones/DescargarPlantillaExcelKpi?metricaId=${metricaId}&anio=${anio}&periodoInicio=${periodoInicio}&periodoFin=${periodoFin}`;
        }

        async function manejarSeleccionMetrica() {
            const select = document.getElementById('metricaSelect');
            const opcionSeleccionada = select.options[select.selectedIndex];
            const metricaId = select.value;
            const frecuencia = opcionSeleccionada.getAttribute('data-frecuencia');

            const bloqueTiempo = document.getElementById('bloqueTiempo');
            const divPeriodo = document.getElementById('divPeriodoMensualSemanal');
            const divAnio = document.getElementById('divAnio');
            const divDiario = document.getElementById('divPeriodoDiario');
            const btnGuardar = document.getElementById('btnGuardar');
            const contenedorVars = document.getElementById('contenedorVariables');

            if (!metricaId) {
                bloqueTiempo.classList.add('d-none');
                contenedorVars.innerHTML = '<div class="alert alert-secondary text-center"><i class="fas fa-arrow-up fa-2x mb-2 text-muted"></i><h5>Selecciona un indicador arriba para comenzar</h5></div>';
                btnGuardar.disabled = true;
                return;
            }

            bloqueTiempo.classList.remove('d-none');

            if (frecuencia === 'Diario') {
                divPeriodo.classList.add('d-none');
                divAnio.classList.add('d-none');
                divDiario.classList.remove('d-none');
                document.getElementById('inputFechaDiaria').valueAsDate = new Date();
            } else {
                divDiario.classList.add('d-none');
                divPeriodo.classList.remove('d-none');
                divAnio.classList.remove('d-none');

                const label = document.getElementById('labelPeriodo');
                const selectPeriodo = document.getElementById('selectPeriodo');
                selectPeriodo.innerHTML = '';

                if (frecuencia === 'Mensual') {
                    label.innerHTML = '<i class="far fa-calendar-alt"></i> Mes a Evaluar';

                    const meses = [
                        'Enero', 'Febrero', 'Marzo', 'Abril',
                        'Mayo', 'Junio', 'Julio', 'Agosto',
                        'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'
                    ];

                    meses.forEach((m, i) => {
                        selectPeriodo.innerHTML += `<option value="${i + 1}">${m}</option>`;
                    });

                    selectPeriodo.value = new Date().getMonth() + 1;
                } else if (frecuencia === 'Semanal') {
                    label.innerHTML = '<i class="fas fa-calendar-week"></i> Semana a Evaluar';

                    for (let i = 1; i <= 53; i++) {
                        selectPeriodo.innerHTML += `<option value="${i}">Semana ${i}</option>`;
                    }
                }
            }

            btnGuardar.disabled = false;

            contenedorVars.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-success"></div>
                    <p class="mt-2 text-muted fw-bold">Cargando variables...</p>
                </div>
            `;

            try {
                const response = await fetch(`/Operaciones/ObtenerVariablesPorMetrica?idMetrica=${metricaId}`);
                const variables = await response.json();
                pintarCamposDeCaptura(variables);
            } catch (e) {
                contenedorVars.innerHTML = '<div class="alert alert-danger">Error al cargar variables.</div>';
                btnGuardar.disabled = true;
            }
        }


        function obtenerPropiedad(obj, nombres, valorDefault = '') {
            if (!obj) {
                return valorDefault;
            }

            for (const nombre of nombres) {
                if (obj[nombre] !== undefined && obj[nombre] !== null) {
                    return obj[nombre];
                }
            }

            return valorDefault;
        }

        function escapeHtml(valor) {
            return (valor ?? '').toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function obtenerTipoValorVariable(variable) {
            return obtenerPropiedad(variable, ['tipoValor', 'TipoValor'], '').toString().trim();
        }

        function obtenerUnidadMedidaVariable(variable) {
            return obtenerPropiedad(variable, ['unidadMedida', 'UnidadMedida'], '').toString().trim();
        }

        function obtenerTextoUnidadInput(tipoValor, unidadMedida) {
            const tipo = (tipoValor || '').toLowerCase();
            const unidad = (unidadMedida || '').trim();

            if (tipo === 'moneda' || unidad === '$') {
                return '$';
            }

            if (tipo === 'porcentaje' || unidad === '%') {
                return '%';
            }

            if (unidad && unidad.toLowerCase() !== 'unidades') {
                return unidad;
            }

            if (tipo === 'entero') {
                return 'Unidades';
            }

            return '';
        }

        function obtenerClaseUnidad(tipoValor, unidadMedida) {
            const tipo = (tipoValor || '').toLowerCase();
            const unidad = (unidadMedida || '').trim();

            if (tipo === 'moneda' || unidad === '$') {
                return 'money';
            }

            if (tipo === 'porcentaje' || unidad === '%') {
                return 'percent';
            }

            return '';
        }

        function obtenerDescripcionUnidad(tipoValor, unidadMedida) {
            const textoUnidad = obtenerTextoUnidadInput(tipoValor, unidadMedida);

            if (!textoUnidad) {
                return 'Captura el valor correspondiente a esta variable.';
            }

            if (textoUnidad === '$') {
                return 'Captura el valor en moneda.';
            }

            if (textoUnidad === '%') {
                return 'Captura el valor en porcentaje.';
            }

            return `Captura el valor en ${textoUnidad}.`;
        }

        function envolverInputConUnidad(inputHtml, tipoValor, unidadMedida) {
            const unidad = obtenerTextoUnidadInput(tipoValor, unidadMedida);

            if (!unidad) {
                return inputHtml;
            }

            const claseUnidad = obtenerClaseUnidad(tipoValor, unidadMedida);
            const addon = `<span class="input-group-text input-unit-addon ${claseUnidad}">${escapeHtml(unidad)}</span>`;
            const esMoneda = (tipoValor || '').toLowerCase() === 'moneda' || unidad === '$';

            return esMoneda
                ? `<div class="input-group input-group-lg">${addon}${inputHtml}</div>`
                : `<div class="input-group input-group-lg">${inputHtml}${addon}</div>`;
        }

        function pintarCamposDeCaptura(variables) {
            const contenedor = document.getElementById('contenedorVariables');

            contenedor.innerHTML = '<h5 class="fw-bold text-dark mb-3"><i class="fas fa-list-ol text-primary me-2"></i> 2. Ingresa los Valores</h5>';

            if (!variables || variables.length === 0) {
                contenedor.innerHTML += '<div class="alert alert-warning">Esta métrica no tiene variables configuradas.</div>';
                document.getElementById('btnGuardar').disabled = true;
                return;
            }

            let indiceVariable = 1;

            variables.forEach(v => {
                let inputHTML = '';
                let labelBadge = '';

                const tipoValor = obtenerTipoValorVariable(v);
                const unidadMedida = obtenerUnidadMedidaVariable(v);
                const ayudaUnidad = obtenerDescripcionUnidad(tipoValor, unidadMedida);

                if (v.tipoCaptura === 'Fijo') {
                    labelBadge = '<span class="badge bg-secondary ms-2 shadow-sm"><i class="fas fa-lock me-1"></i> Fijo</span>';

                    inputHTML = `
                        <input type="number"
                               step="0.01"
                               name="valores[${v.id}]"
                               data-index="${indiceVariable}"
                               class="form-control form-control-lg bg-light text-muted fw-bold border-secondary"
                               value="${v.valorFijo ?? 0}"
                               readonly
                               required />
                    `;

                    inputHTML = envolverInputConUnidad(inputHTML, tipoValor, unidadMedida);
                }
                else if (v.tipoCaptura === 'Calculado') {
                    labelBadge = '<span class="badge bg-info text-dark ms-2 shadow-sm"><i class="fas fa-calculator me-1"></i> Auto-Calculado</span>';

                    inputHTML = `
                        <input type="number"
                               step="0.01"
                               name="valores[${v.id}]"
                               data-index="${indiceVariable}"
                               class="form-control form-control-lg bg-light fw-bolder text-primary border-info variable-calculada"
                               data-formula="${v.formula ?? ''}"
                               placeholder="0.00"
                               readonly
                               required />
                    `;

                    inputHTML = envolverInputConUnidad(inputHTML, tipoValor, unidadMedida) + `
                        <small class="text-muted d-block mt-2 formula-debug fw-bold" style="font-size: 0.8rem;">
                            Fórmula base: ${v.formula ?? ''}
                        </small>
                    `;
                }
                else {
                    inputHTML = `
                        <input type="number"
                               step="0.01"
                               name="valores[${v.id}]"
                               data-index="${indiceVariable}"
                               class="form-control form-control-lg border-primary shadow-sm variable-manual"
                               placeholder="0.00"
                               required />
                    `;

                    inputHTML = envolverInputConUnidad(inputHTML, tipoValor, unidadMedida);
                }

                contenedor.innerHTML += `
                    <div class="mb-4 p-3 rounded-4 border bg-white shadow-sm variable-capture-box">
                        <label class="form-label fw-bold text-dark fs-6 mb-1">
                            ${v.nombre} ${labelBadge}
                        </label>
                        <div>
                            <span class="unit-helper">
                                <i class="fas fa-ruler-combined"></i> ${escapeHtml(ayudaUnidad)}
                            </span>
                        </div>
                        <div class="mt-2">
                            ${inputHTML}
                        </div>
                    </div>
                `;

                indiceVariable++;
            });

            contenedor.removeEventListener('input', ejecutarFormulasMatematicas);
            contenedor.addEventListener('input', ejecutarFormulasMatematicas);

            ejecutarFormulasMatematicas();
        }

        function ejecutarFormulasMatematicas() {
            const camposCalculados = document.querySelectorAll('.variable-calculada');

            camposCalculados.forEach(input => {
                let formula = input.getAttribute('data-formula');

                if (!formula) {
                    input.value = "0.00";
                    return;
                }

                let formulaEvaluada = formula.replace(/\[(\d+)\]/g, function (match, numero) {
                    let caja = document.querySelector(`input[data-index="${numero}"]`);
                    let val = caja && caja.value ? parseFloat(caja.value) : 0;
                    return isNaN(val) ? 0 : val;
                });

                let debugText = input.closest('.variable-capture-box')?.querySelector('.formula-debug');

                try {
                    if (formulaEvaluada.includes('/0') || formulaEvaluada.includes('/ 0')) {
                        input.value = "0.00";

                        if (debugText) {
                            debugText.innerText = "Esperando datos... división entre 0 detectada.";
                            debugText.classList.remove('text-danger');
                            debugText.classList.add('text-muted');
                        }
                    } else {
                        let resultadoFinal = eval(formulaEvaluada);

                        input.value = (isNaN(resultadoFinal) || !isFinite(resultadoFinal))
                            ? "0.00"
                            : resultadoFinal.toFixed(2);

                        if (debugText) {
                            debugText.innerText = "Operación interna: " + formulaEvaluada;
                            debugText.classList.remove('text-danger');
                            debugText.classList.add('text-muted');
                        }
                    }
                } catch (error) {
                    input.value = "0.00";

                    if (debugText) {
                        debugText.innerText = "Error en la fórmula: " + formulaEvaluada;
                        debugText.classList.remove('text-muted');
                        debugText.classList.add('text-danger');
                    }
                }
            });
        }
    </script>
}