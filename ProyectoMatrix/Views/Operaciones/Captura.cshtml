    .ops-shell,
    .kpis-shell {
        max-width: 100% !important;
        margin: 10px auto 18px !important;
        padding: 12px !important;
        border-radius: 20px !important;
    }

    .ops-header,
    .hero-card,
    .kpi-item-head,
    .hist-head {
        flex-direction: column !important;
    }

    .ops-filter-grid,
    .ops-kpi-summary,
    .summary-grid,
    .ops-depto-list {
        grid-template-columns: 1fr !important;
    }

    .ops-title,
    .hero-title {
        font-size: 2rem !important;
    }
