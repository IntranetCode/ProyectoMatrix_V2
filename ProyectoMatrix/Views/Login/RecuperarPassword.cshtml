@{
    Layout = null;
    ViewData["Title"] = "Recuperar contraseña";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Recuperar contraseña | NSGroup</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="~/css/stylesLoginLogin.css" rel="stylesheet" />

    <style>
        .login-container::before,
        .login-container::after {
            pointer-events: none !important;
        }

        .recovery-card {
            width: min(100%, 560px);
            background: rgba(255, 255, 255, 0.96);
            border-radius: 28px;
            box-shadow: 0 28px 75px rgba(15, 23, 42, .28);
            padding: 2.1rem;
            position: relative;
            z-index: 10;
            backdrop-filter: blur(10px);
        }

        .recovery-card * {
            position: relative;
            z-index: 11;
        }

        .brand-logo-recovery {
            width: 116px;
            height: 116px;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            background: #ffffff;
            box-shadow: 0 14px 36px rgba(15, 23, 42, .12);
            overflow: hidden;
        }

        .brand-logo-recovery img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .recovery-title {
            color: #0b1744;
            font-weight: 800;
            text-align: center;
            margin-bottom: .3rem;
        }

        .recovery-subtitle {
            text-align: center;
            color: #64748b;
            font-size: .95rem;
            margin-bottom: 1.4rem;
        }

        .stepper {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: .6rem;
            margin-bottom: 1.35rem;
        }

        .stepper-item {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .35rem;
            border-radius: 999px;
            padding: .55rem .6rem;
            font-size: .78rem;
            font-weight: 800;
            background: #e2e8f0;
            color: #475569;
            text-align: center;
        }

        .stepper-item.active {
            background: #0b1744;
            color: #ffffff;
        }

        .step-panel {
            display: none;
        }

        .step-panel.active {
            display: block;
        }

        .form-label-recovery {
            color: #0f172a;
            font-weight: 800;
            margin-bottom: .45rem;
        }

        .input-recovery {
            width: 100%;
            min-height: 50px;
            border: 1px solid #cbd5e1;
            border-radius: 16px;
            padding: .75rem .95rem;
            font-size: .95rem;
            outline: none;
            transition: border-color .18s ease, box-shadow .18s ease;
        }

        .input-recovery:focus {
            border-color: #0b1744;
            box-shadow: 0 0 0 .22rem rgba(11, 23, 68, .12);
        }

        .code-input {
            text-align: center;
            letter-spacing: .45rem;
            font-size: 1.35rem;
            font-weight: 800;
        }

        .btn-recovery-primary {
            width: 100%;
            min-height: 50px;
            border: none;
            border-radius: 999px;
            background: #0b1744;
            color: #ffffff;
            font-weight: 800;
            transition: transform .15s ease, background .15s ease, box-shadow .15s ease;
            box-shadow: 0 14px 28px rgba(11, 23, 68, .22);
        }

        .btn-recovery-primary:hover {
            background: #102b63;
            transform: translateY(-1px);
        }

        .btn-recovery-primary:disabled {
            opacity: .72;
            cursor: not-allowed;
            transform: none;
        }

        .btn-recovery-secondary {
            color: #0b1744;
            font-weight: 800;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
        }

        .btn-recovery-secondary:hover {
            color: #f47b20;
            text-decoration: underline;
        }

        .message-box {
            display: none;
            border-radius: 16px;
            padding: .9rem 1rem;
            font-size: .9rem;
            margin-bottom: 1rem;
        }

        .message-box.show {
            display: block;
        }

        .message-box.success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }

        .message-box.error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .message-box.info {
            background: #e0f2fe;
            color: #075985;
            border: 1px solid #bae6fd;
        }

        .password-rules {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: .9rem 1rem;
            margin-bottom: 1rem;
        }

        .password-rule {
            color: #64748b;
            font-size: .86rem;
            margin-bottom: .25rem;
        }

        .password-rule.ok {
            color: #15803d;
            font-weight: 800;
        }

        .footer-recovery {
            text-align: center;
            margin-top: 1.1rem;
        }

        @@media (max-width: 576px) {
            .recovery-card {
                padding: 1.4rem;
                border-radius: 22px;
            }

            .stepper {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <main class="recovery-card">
            @Html.AntiForgeryToken()

            <div class="brand-logo-recovery">
                <img src="~/Imagenes/logoAzul.jpeg" alt="Logo de la empresa" />
            </div>

            <h1 class="recovery-title">Recuperar contraseña</h1>
            <p class="recovery-subtitle">
                Valida tu cuenta con el código enviado a tu correo registrado.
            </p>

            <div class="stepper" aria-label="Pasos de recuperación">
                <div class="stepper-item active" id="stepper1">
                    <i class="fas fa-user"></i> Cuenta
                </div>
                <div class="stepper-item" id="stepper2">
                    <i class="fas fa-envelope-open-text"></i> Código
                </div>
                <div class="stepper-item" id="stepper3">
                    <i class="fas fa-lock"></i> Contraseña
                </div>
            </div>

            <div id="messageBox" class="message-box"></div>

            <section class="step-panel active" id="panelPaso1">
                <div class="mb-3">
                    <label for="usuarioOCorreo" class="form-label-recovery">Usuario o correo registrado</label>
                    <input id="usuarioOCorreo"
                           class="input-recovery"
                           type="text"
                           autocomplete="username"
                           placeholder="Ej. usuario o correo@empresa.com" />
                </div>

                <button type="button" class="btn-recovery-primary" id="btnSolicitarCodigo">
                    <i class="fas fa-paper-plane me-1"></i>
                    Enviar código
                </button>
            </section>

            <section class="step-panel" id="panelPaso2">
                <div class="mb-3">
                    <label for="codigoRecuperacion" class="form-label-recovery">Código de verificación</label>
                    <input id="codigoRecuperacion"
                           class="input-recovery code-input"
                           type="text"
                           maxlength="6"
                           inputmode="numeric"
                           autocomplete="one-time-code"
                           placeholder="000000" />
                </div>

                <button type="button" class="btn-recovery-primary" id="btnValidarCodigo">
                    <i class="fas fa-check-circle me-1"></i>
                    Validar código
                </button>

                <div class="text-center mt-3">
                    <button type="button" class="btn btn-link btn-recovery-secondary p-0" id="btnReenviarCodigo">
                        <i class="fas fa-rotate-right"></i>
                        Reenviar código
                    </button>
                </div>
            </section>

            <section class="step-panel" id="panelPaso3">
                <div class="mb-3">
                    <label for="nuevaPassword" class="form-label-recovery">Nueva contraseña</label>
                    <input id="nuevaPassword"
                           class="input-recovery"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Nueva contraseña" />
                </div>

                <div class="mb-3">
                    <label for="confirmarPassword" class="form-label-recovery">Confirmar contraseña</label>
                    <input id="confirmarPassword"
                           class="input-recovery"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Confirmar contraseña" />
                </div>

                <div class="password-rules">
                    <div class="password-rule" id="ruleLength">
                        <i class="fas fa-circle me-1"></i> Mínimo 6 caracteres
                    </div>
                    <div class="password-rule" id="ruleMatch">
                        <i class="fas fa-circle me-1"></i> Las contraseñas coinciden
                    </div>
                </div>

                <button type="button" class="btn-recovery-primary" id="btnCambiarPassword">
                    <i class="fas fa-save me-1"></i>
                    Guardar nueva contraseña
                </button>
            </section>

            <section class="step-panel" id="panelExito">
                <div class="message-box success show mb-3">
                    <strong>Contraseña actualizada correctamente.</strong><br />
                    Ya puedes iniciar sesión con tu nueva contraseña.
                </div>

                <a href="@Url.Action("Login", "Login")" class="btn-recovery-primary text-decoration-none d-flex align-items-center justify-content-center">
                    <i class="fas fa-arrow-right-to-bracket me-1"></i>
                    Ir al inicio de sesión
                </a>
            </section>

            <div class="footer-recovery">
                <a href="@Url.Action("Login", "Login")" class="btn-recovery-secondary">
                    <i class="fas fa-arrow-left"></i>
                    Volver al inicio de sesión
                </a>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const endpoints = {
                solicitar: '@Url.Action("SolicitarCodigoRecuperacion", "Login")',
                validar: '@Url.Action("ValidarCodigoRecuperacion", "Login")',
                cambiar: '@Url.Action("CambiarPasswordRecuperacion", "Login")'
            };

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            const usuarioInput = document.getElementById('usuarioOCorreo');
            const codigoInput = document.getElementById('codigoRecuperacion');
            const nuevaInput = document.getElementById('nuevaPassword');
            const confirmarInput = document.getElementById('confirmarPassword');

            const btnSolicitar = document.getElementById('btnSolicitarCodigo');
            const btnValidar = document.getElementById('btnValidarCodigo');
            const btnCambiar = document.getElementById('btnCambiarPassword');
            const btnReenviar = document.getElementById('btnReenviarCodigo');

            const messageBox = document.getElementById('messageBox');

            function setLoading(button, loading, textLoading, textNormal) {
                if (!button) return;
                button.disabled = loading;
                button.innerHTML = loading
                    ? `<i class="fas fa-spinner fa-spin me-1"></i>${textLoading}`
                    : textNormal;
            }

            function showMessage(type, message) {
                messageBox.className = `message-box show ${type}`;
                messageBox.innerHTML = message || '';
            }

            function hideMessage() {
                messageBox.className = 'message-box';
                messageBox.innerHTML = '';
            }

            function goStep(step) {
                document.querySelectorAll('.step-panel').forEach(panel => panel.classList.remove('active'));
                document.querySelectorAll('.stepper-item').forEach(item => item.classList.remove('active'));

                if (step === 1) {
                    document.getElementById('panelPaso1').classList.add('active');
                    document.getElementById('stepper1').classList.add('active');
                    usuarioInput.focus();
                }

                if (step === 2) {
                    document.getElementById('panelPaso2').classList.add('active');
                    document.getElementById('stepper1').classList.add('active');
                    document.getElementById('stepper2').classList.add('active');
                    codigoInput.focus();
                }

                if (step === 3) {
                    document.getElementById('panelPaso3').classList.add('active');
                    document.getElementById('stepper1').classList.add('active');
                    document.getElementById('stepper2').classList.add('active');
                    document.getElementById('stepper3').classList.add('active');
                    nuevaInput.focus();
                }

                if (step === 4) {
                    document.getElementById('panelExito').classList.add('active');
                    document.getElementById('stepper1').classList.add('active');
                    document.getElementById('stepper2').classList.add('active');
                    document.getElementById('stepper3').classList.add('active');
                    document.querySelector('.footer-recovery')?.classList.add('d-none');
                }
            }

            async function postForm(url, data) {
                const formData = new FormData();
                Object.keys(data).forEach(key => formData.append(key, data[key] ?? ''));

                const response = await fetch(url, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Error de comunicación con el servidor.');
                }

                return await response.json();
            }

            async function solicitarCodigo() {
                hideMessage();
                const usuarioOCorreo = usuarioInput.value.trim();

                if (!usuarioOCorreo) {
                    showMessage('error', 'Ingresa tu usuario o correo registrado.');
                    usuarioInput.focus();
                    return;
                }

                setLoading(btnSolicitar, true, 'Enviando...', '<i class="fas fa-paper-plane me-1"></i>Enviar código');

                try {
                    const result = await postForm(endpoints.solicitar, { usuarioOCorreo });

                    if (!result.ok) {
                        showMessage('error', result.mensaje || 'No fue posible enviar el código.');
                        return;
                    }

                    showMessage('success', result.mensaje || 'Código enviado. Revisa tu correo registrado.');
                    goStep(2);
                } catch (error) {
                    showMessage('error', error.message || 'Ocurrió un error al solicitar el código.');
                } finally {
                    setLoading(btnSolicitar, false, '', '<i class="fas fa-paper-plane me-1"></i>Enviar código');
                }
            }

            async function validarCodigo() {
                hideMessage();

                const usuarioOCorreo = usuarioInput.value.trim();
                const codigo = codigoInput.value.trim();

                if (!codigo || codigo.length !== 6) {
                    showMessage('error', 'Ingresa el código de 6 dígitos.');
                    codigoInput.focus();
                    return;
                }

                setLoading(btnValidar, true, 'Validando...', '<i class="fas fa-check-circle me-1"></i>Validar código');

                try {
                    const result = await postForm(endpoints.validar, { usuarioOCorreo, codigo });

                    if (!result.ok) {
                        showMessage('error', result.mensaje || 'El código no es válido.');
                        return;
                    }

                    showMessage('success', result.mensaje || 'Código validado correctamente.');
                    goStep(3);
                } catch (error) {
                    showMessage('error', error.message || 'Ocurrió un error al validar el código.');
                } finally {
                    setLoading(btnValidar, false, '', '<i class="fas fa-check-circle me-1"></i>Validar código');
                }
            }

            async function cambiarPassword() {
                hideMessage();

                const usuarioOCorreo = usuarioInput.value.trim();
                const codigo = codigoInput.value.trim();
                const nuevaPassword = nuevaInput.value;
                const confirmarPassword = confirmarInput.value;

                if (nuevaPassword.length < 6) {
                    showMessage('error', 'La contraseña debe tener al menos 6 caracteres.');
                    nuevaInput.focus();
                    return;
                }

                if (nuevaPassword !== confirmarPassword) {
                    showMessage('error', 'Las contraseñas no coinciden.');
                    confirmarInput.focus();
                    return;
                }

                setLoading(btnCambiar, true, 'Guardando...', '<i class="fas fa-save me-1"></i>Guardar nueva contraseña');

                try {
                    const result = await postForm(endpoints.cambiar, {
                        usuarioOCorreo,
                        codigo,
                        nuevaPassword,
                        confirmarPassword
                    });

                    if (!result.ok) {
                        showMessage('error', result.mensaje || 'No fue posible actualizar la contraseña.');
                        return;
                    }

                    hideMessage();
                    goStep(4);
                } catch (error) {
                    showMessage('error', error.message || 'Ocurrió un error al cambiar la contraseña.');
                } finally {
                    setLoading(btnCambiar, false, '', '<i class="fas fa-save me-1"></i>Guardar nueva contraseña');
                }
            }

            function setRule(id, ok) {
                const el = document.getElementById(id);
                if (!el) return;

                el.classList.toggle('ok', ok);
                const icon = el.querySelector('i');

                if (icon) {
                    icon.className = ok ? 'fas fa-check-circle me-1' : 'fas fa-circle me-1';
                }
            }

            function validarPasswordVisual() {
                const p1 = nuevaInput.value || '';
                const p2 = confirmarInput.value || '';

                setRule('ruleLength', p1.length >= 6);
                setRule('ruleMatch', p1.length > 0 && p1 === p2);
            }

            codigoInput.addEventListener('input', function () {
                this.value = this.value.replace(/\D/g, '').slice(0, 6);
            });

            nuevaInput.addEventListener('input', validarPasswordVisual);
            confirmarInput.addEventListener('input', validarPasswordVisual);

            btnSolicitar.addEventListener('click', solicitarCodigo);
            btnValidar.addEventListener('click', validarCodigo);
            btnCambiar.addEventListener('click', cambiarPassword);
            btnReenviar.addEventListener('click', solicitarCodigo);

            [usuarioInput, codigoInput, nuevaInput, confirmarInput].forEach(input => {
                input.addEventListener('keydown', function (event) {
                    if (event.key !== 'Enter') return;
                    event.preventDefault();

                    if (document.getElementById('panelPaso1').classList.contains('active')) solicitarCodigo();
                    else if (document.getElementById('panelPaso2').classList.contains('active')) validarCodigo();
                    else if (document.getElementById('panelPaso3').classList.contains('active')) cambiarPassword();
                });
            });

            validarPasswordVisual();
            goStep(1);
        });
    </script>
</body>
</html>
