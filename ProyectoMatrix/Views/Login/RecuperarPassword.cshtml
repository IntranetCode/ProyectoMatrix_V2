@{
    Layout = null;
    ViewData["Title"] = "Recuperar contraseña";

    var cambioExitoso = ViewBag.CambioExitoso as bool? ?? false;
    var usuarioOCorreo = ViewBag.UsuarioOCorreo as string ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Recuperar contraseña - Intranet</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="~/css/stylesLoginLogin.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>

        .recovery-card {
            width: min(100%, 540px);
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 24px 55px rgba(0,0,0,.28);
            overflow: hidden;
        }

        .recovery-header {
            background: linear-gradient(135deg, #07164a, #102b63);
            color: #fff;
            padding: 32px;
            text-align: center;
        }

        .recovery-icon {
            width: 78px;
            height: 78px;
            margin: 0 auto 16px;
            border-radius: 50%;
            background: rgba(244,123,32,.18);
            color: #f47b20;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
        }

        .recovery-body {
            padding: 32px;
        }

        .form-label {
            color: #0f172a;
            font-weight: 700;
        }

        .form-control {
            border-radius: 14px;
            min-height: 48px;
        }

        .btn-ns {
            background: #07164a;
            border-color: #07164a;
            color: #fff;
            font-weight: 800;
            border-radius: 999px;
            padding: .78rem 1rem;
        }

        .btn-ns:hover {
            background: #102b63;
            border-color: #102b63;
            color: #fff;
        }

        .login-link {
            color: #07164a;
            font-weight: 800;
            text-decoration: none;
        }

        .login-link:hover {
            color: #f47b20;
            text-decoration: underline;
        }

        .input-group .form-control {
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
        }

        .toggle-password {
            border-top-right-radius: 14px;
            border-bottom-right-radius: 14px;
            min-width: 48px;
        }

        .password-rule {
            font-size: .86rem;
            color: #64748b;
        }

        .password-rule.ok {
            color: #15803d;
            font-weight: 700;
        }
        .login-container::before,
        .login-container::after {
            pointer-events: none !important;
        }

        .recovery-card {
            position: relative;
            z-index: 10;
        }

        .recovery-body,
        .recovery-body form,
        .recovery-body input,
        .recovery-body button,
        .recovery-body a {
            position: relative;
            z-index: 11;
        }

        
    </style>
</head>
<body>
    <div class="login-container">
        <div class="recovery-card">
            <div class="recovery-header">
                <div class="recovery-icon">
                    <i class="fas fa-key"></i>
                </div>

                <h3 class="fw-bold mb-1">Recuperar contraseña</h3>
                <p class="mb-0 opacity-75">
                    Ingresa tu usuario o correo y define una nueva contraseña.
                </p>
            </div>

            <div class="recovery-body">
                @if (cambioExitoso)
                {
                    <div class="alert alert-success">
                        <strong>Contraseña actualizada correctamente.</strong><br />
                        Ya puedes iniciar sesión con tu nueva contraseña.
                    </div>

                    <div class="d-grid mt-4">
                        <a href="@Url.Action("Login", "Login")" class="btn btn-ns">
                            <i class="fas fa-arrow-right-to-bracket me-1"></i>
                            Ir al inicio de sesión
                        </a>
                    </div>
                }
                else
                {
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                        </div>
                    }

                    <form asp-controller="Login" asp-action="RecuperarPassword" method="post" autocomplete="off">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="usuarioOCorreo" class="form-label">Usuario o correo registrado</label>
                            <input id="usuarioOCorreo"
                                name="usuarioOCorreo"
                                class="form-control"
                                value="@usuarioOCorreo"
                                placeholder="Ej. usuario o correo@empresa.com" />
                        </div>

                        <div class="mb-3">
                            <label for="nuevaPassword" class="form-label">Nueva contraseña</label>
                            <div class="input-group">
                                <input id="nuevaPassword"
                                    name="nuevaPassword"
                                    type="password"
                                    class="form-control"
                                    placeholder="Nueva contraseña" />
                                <button class="btn btn-outline-secondary toggle-password" type="button" data-target="nuevaPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="confirmarPassword" class="form-label">Confirmar contraseña</label>
                            <div class="input-group">
                                <input id="confirmarPassword"
                                    name="confirmarPassword"
                                    type="password"
                                    class="form-control"
                                    placeholder="Confirmar contraseña" />
                                <button class="btn btn-outline-secondary toggle-password" type="button" data-target="confirmarPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="border rounded-4 p-3 mb-3 bg-light">
                            <div class="password-rule" id="ruleLength">
                                <i class="fas fa-circle me-1"></i> Mínimo 6 caracteres
                            </div>
                            <div class="password-rule" id="ruleMatch">
                                <i class="fas fa-circle me-1"></i> Las contraseñas coinciden
                            </div>
                        </div>

                        <button type="submit" class="btn btn-ns w-100">
                            <i class="fas fa-save me-1"></i>
                            Cambiar contraseña
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a href="@Url.Action("Login", "Login")" class="login-link">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver al inicio de sesión
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <script>
        (function () {
            const nueva = document.getElementById('nuevaPassword');
            const confirmar = document.getElementById('confirmarPassword');

            function setRule(id, ok) {
                const el = document.getElementById(id);
                if (!el) return;

                el.classList.toggle('ok', ok);

                const icon = el.querySelector('i');
                if (icon) {
                    icon.className = ok
                        ? 'fas fa-check-circle me-1'
                        : 'fas fa-circle me-1';
                }
            }

            function validar() {
                const p1 = nueva ? nueva.value : '';
                const p2 = confirmar ? confirmar.value : '';

                setRule('ruleLength', p1.length >= 6);
                setRule('ruleMatch', p1.length > 0 && p1 === p2);
            }

            document.querySelectorAll('.toggle-password').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const target = document.getElementById(btn.getAttribute('data-target'));
                    const icon = btn.querySelector('i');
                    if (!target) return;

                    const visible = target.type === 'text';
                    target.type = visible ? 'password' : 'text';

                    if (icon) {
                        icon.className = visible ? 'fas fa-eye' : 'fas fa-eye-slash';
                    }
                });
            });

            nueva?.addEventListener('input', validar);
            confirmar?.addEventListener('input', validar);
            validar();
        })();
    </script>
</body>
</html>
