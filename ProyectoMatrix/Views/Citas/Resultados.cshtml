@section Scripts {
    
    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const svg = document.getElementById("radarDimensionesSvg");
        if (!svg) return;

        const dimensiones = [
            @foreach (var dimension in dimensionesConCalificacionGlobal)
            {
                var nombre = (dimension.Dimension ?? "").Replace("\\", "\\\\").Replace("\"", "\\\"");
                var porcentaje = Math.Max(0, Math.Min(100, dimension.Porcentaje));
                var puntaje = dimension.Promedio;

                <text>{ nombre: "@nombre", porcentaje: @porcentaje.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture), puntaje: @puntaje.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) },</text>
            }
        ];

        if (dimensiones.length < 3) return;

        const width = 620;
        const height = 500;
        const cx = width / 2;
        const cy = 245;
        const radius = 150;
        const niveles = [20, 40, 60, 80, 100];

        function puntoPolar(index, total, valor) {
            const angulo = (-Math.PI / 2) + ((Math.PI * 2) * index / total);
            const radio = radius * (valor / 100);

            return {
                x: cx + radio * Math.cos(angulo),
                y: cy + radio * Math.sin(angulo)
            };
        }

        function puntosPoligono(valor) {
            return dimensiones.map((_, index) => {
                const p = puntoPolar(index, dimensiones.length, valor);
                return `${p.x},${p.y}`;
            }).join(" ");
        }

        let html = "";

        niveles.forEach(nivel => {
            html += `
                <polygon
                    points="${puntosPoligono(nivel)}"
                    fill="none"
                    stroke="#dbe4f0"
                    stroke-width="1">
                </polygon>
            `;
        });

        niveles.forEach(nivel => {
            const y = cy - (radius * (nivel / 100));

            html += `
                <text x="${cx + 8}" y="${y - 4}" class="radar-svg-level">
                    ${nivel}%
                </text>
            `;
        });

        dimensiones.forEach((dimension, index) => {
            const eje = puntoPolar(index, dimensiones.length, 100);
            const label = puntoPolar(index, dimensiones.length, 118);
            const value = puntoPolar(index, dimensiones.length, 108);

            html += `
                <line
                    x1="${cx}" y1="${cy}"
                    x2="${eje.x}" y2="${eje.y}"
                    stroke="#cbd5e1"
                    stroke-width="1">
                </line>

                <text
                    x="${label.x}"
                    y="${label.y}"
                    text-anchor="middle"
                    class="radar-svg-label">
                    ${dimension.nombre}
                </text>

                <text
                    x="${value.x}"
                    y="${value.y + 15}"
                    text-anchor="middle"
                    class="radar-svg-value">
                    ${dimension.puntaje}/10
                </text>
            `;
        });

        const puntosResultado = dimensiones.map((dimension, index) => {
            const p = puntoPolar(index, dimensiones.length, dimension.porcentaje);
            return `${p.x},${p.y}`;
        }).join(" ");

        html += `
            <polygon
                points="${puntosResultado}"
                fill="rgba(37, 99, 235, 0.20)"
                stroke="#2563eb"
                stroke-width="3">
            </polygon>
        `;

        dimensiones.forEach((dimension, index) => {
            const p = puntoPolar(index, dimensiones.length, dimension.porcentaje);

            html += `
                <circle
                    cx="${p.x}"
                    cy="${p.y}"
                    r="5"
                    fill="#2563eb"
                    stroke="#ffffff"
                    stroke-width="2">
                </circle>
            `;
        });

        html += `
            <circle cx="${cx}" cy="${cy}" r="4" fill="#64748b"></circle>
        `;

        svg.innerHTML = html;
    });
</script>
}