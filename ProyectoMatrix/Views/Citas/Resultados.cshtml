<div class="container py-4 resultados-page">
    <div class="rs-header">
        <div>
            <h2>Resultados de Mapeo</h2>

            @if (mostrarIndividual)
            {
                <p>Mapa de calor y resumen de competencias por dimensión.</p>
            }
            else if (esAdmin)
            {
                <p>Vista administrativa de todos los usuarios que ya asistieron o finalizaron entrevista.</p>
            }
            else
            {
                <p>Consulta tus resultados individuales de mapeo de talento.</p>
            }
        </div>

        <div class="rs-actions">
           @if (mostrarIndividual && esEditor && origen == "captura")
{
    <a class="btn btn-outline-secondary" asp-controller="Citas" asp-action="Bandeja">
        ← Volver a bandeja
    </a>
}
else if (mostrarIndividual && esEditor)
{
    <a class="btn btn-outline-secondary" asp-controller="Citas" asp-action="Resultados">
        ← Volver a resultados
    </a>
}
else
{
    <a class="btn btn-outline-secondary" asp-controller="Citas" asp-action="Index">
        ← Volver al dashboard
    </a>
}

          @if (esEditor && mostrarIndividual)
            {
                <a class="btn btn-outline-primary" asp-controller="Citas" asp-action="Resultados">
                    Ver todos
                </a>
            }

            <button type="button" class="btn btn-dark" onclick="window.print()">
                🖨️ Exportar vista
            </button>
        </div>
    </div>

    @if (TempData["CitasOk"] != null)
    {
        <div class="alert alert-success">
            @TempData["CitasOk"]
        </div>
    }

    @if (TempData["CitasError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["CitasError"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Mensaje))
    {
        <div class="alert alert-warning">
            @Model.Mensaje
        </div>
    }

    @if (mostrarIndividual && individual != null)
    {
        var preguntasEvaluables = individual.Preguntas
            .Where(x => x.EsEvaluable)
            .ToList();

        <section class="rs-shell">
            <div class="rs-kpis">
                <article class="rs-kpi">
                    <span>Resultado global</span>
                    <strong>@Porcentaje(individual.PorcentajeGlobal)</strong>
                    <small>@individual.NivelGeneral · @Puntaje(individual.PuntajeGlobal) / 10</small>
                </article>

                <article class="rs-kpi">
                    <span>Promedio</span>
                    <strong>@Puntaje(individual.PuntajeGlobal)</strong>
                    <small>escala 1 a 10</small>
                </article>

                <article class="rs-kpi">
                    <span>Preguntas respondidas</span>
                    <strong>@individual.TotalRespondidas</strong>
                    <small>de @individual.TotalPreguntas preguntas</small>
                </article>

                <article class="rs-kpi">
                    <span>Preguntas calificadas</span>
                    <strong>@individual.TotalPreguntasEvaluables</strong>
                    <small>con puntaje asignado</small>
                </article>

                <article class="rs-kpi">
                    <span>Folio</span>
                    <strong>CIT-@individual.CitaID.ToString("D5")</strong>
                    <small>cita evaluada</small>
                </article>
            </div>

            <div class="rs-grid">
                <aside>
                    <article class="rs-card mb-3">
                        <h4>Resumen ejecutivo</h4>
                        <p>Lectura rápida del resultado obtenido.</p>

                        <span class="rs-pill @individual.CssNivelGeneral">
                            @individual.NivelGeneral
                        </span>

                        <div class="mt-3">
                            <strong>@Puntaje(individual.PuntajeGlobal) / 10</strong>
                            <p class="mb-0 mt-2">@individual.ResumenResultado</p>
                        </div>
                    </article>

                    <article class="rs-card">
                        <h4>Datos de la evaluación</h4>
                        <p>Información asociada a la cita y cuestionario.</p>

                        <div class="rs-info-list">
                            <div class="rs-info-item">
                                <span>Persona</span>
                                <strong>@individual.NombrePersona</strong>
                            </div>

                            <div class="rs-info-item">
                                <span>Empresa</span>
                                <strong>@individual.NombreEmpresa</strong>
