                    @{
    var resultadoDimensiones = Model.Individual;

    var dimensionesMapa = dimensionesMapaGlobal;
var dimensionesConCalificacion = dimensionesConCalificacionGlobal;

    var promedioDimensiones = dimensionesConCalificacion.Any()
        ? Math.Round(dimensionesConCalificacion.Average(x => x.Porcentaje), 1)
        : 0;

    string ClaseHeat(decimal porcentaje)
    {
        if (porcentaje <= 0)
            return "dimension-heat-empty";

        if (porcentaje < 60)
            return "dimension-heat-low";

        if (porcentaje < 75)
            return "dimension-heat-mid";

        if (porcentaje < 90)
            return "dimension-heat-good";

        return "dimension-heat-high";
    }

    string TextoNivelDimension(decimal porcentaje)
    {
        if (porcentaje <= 0)
            return "Sin calificación";

        if (porcentaje < 60)
            return "Bajo";

        if (porcentaje < 75)
            return "Medio";

        if (porcentaje < 90)
            return "Bueno";

        return "Sobresaliente";
    }
}

@if (dimensionesMapaGlobal.Any())
{
    <section class="dimension-heatmap-card">
        <div class="dimension-heatmap-head">
            <div>
                <h4>Mapa de calor por dimensiones</h4>
                <p>Resultado visual de las dimensiones evaluadas durante la entrevista.</p>
            </div>

            <span class="dimension-heatmap-summary">
                @dimensionesMapaGlobal.Count dimensión(es)
            </span>
        </div>

        <div class="dimension-heatmap-grid">
            @foreach (var dimension in dimensionesMapaGlobal.OrderByDescending(x => x.Porcentaje))
            {
                var porcentaje = Math.Max(0, Math.Min(100, dimension.Porcentaje));
                var promedio = dimension.Promedio;
                var clase = ClaseHeatDimension(porcentaje);
                var nivel = TextoNivelDimension(porcentaje);
                var ancho = porcentaje <= 0 ? 100 : porcentaje;

                <article class="dimension-heat-row">
                    <div class="dimension-heat-info">
                        <div class="dimension-heat-title">
                            <strong>@dimension.Dimension</strong>
