@model ProyectoMatrix.Models.ResultadosIndexVm

@{
    Layout = "_LayoutComunicados";
    ViewData["Title"] = "Resultados de Mapeo";

    var admin = Model.Admin;
    var individual = Model.Individual;
    var esEditor = Model.RolID == 1 || Model.RolID == 2 || Model.RolID == 3;
    var esUsuarioFinal = Model.RolID == 5;
    var esAdmin = admin != null;
    var mostrarIndividual = individual != null;
    var origen = ViewBag.Origen as string ?? "";

    var dimensionesMapaGlobal = individual?.Dimensiones?
    .Where(x => !string.IsNullOrWhiteSpace(x.Dimension))
    .ToList() ?? new List<ResultadoDimensionVm>();

var dimensionesConCalificacionGlobal = dimensionesMapaGlobal
    .Where(x => x.Porcentaje > 0)
    .ToList();

var promedioDimensionesGlobal = dimensionesConCalificacionGlobal.Any()
    ? Math.Round(dimensionesConCalificacionGlobal.Average(x => x.Porcentaje), 1)
    : 0;
}

@functions {
    private static string Porcentaje(decimal value)
    {
        if (value < 0) value = 0;
        if (value > 100) value = 100;

        return value.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture) + "%";
    }

    private static string Puntaje(decimal value)
    {
        return value.ToString("0.##", System.Globalization.CultureInfo.GetCultureInfo("es-MX"));
    }

    private static string PuntajeNullable(decimal? value)
    {
        return value.HasValue
            ? value.Value.ToString("0.##", System.Globalization.CultureInfo.GetCultureInfo("es-MX"))
            : "--";
    }

    private static string Fecha(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("dd/MM/yyyy") : "Sin fecha";
    }

    private static string Fecha(DateTime value)
    {
        return value.ToString("dd/MM/yyyy");
    }

    private static string Hora(TimeSpan? value)
    {
        return value.HasValue ? value.Value.ToString(@"hh\:mm") : "--:--";
    }

    private static string Hora(TimeSpan value)
    {
        return value.ToString(@"hh\:mm");
    }

    private static string EstadoTexto(string? estado)
    {
        return (estado ?? "").ToLowerInvariant() switch
        {
            "asistio" => "Asistió",
            "finalizada" => "Finalizada",
            "pendiente" => "Pendiente",
            "en_captura" => "En captura",
            "completado" => "Completado",
            "no_asistio" => "No asistió",
            "cancelada" => "Cancelada",
            _ => string.IsNullOrWhiteSpace(estado) ? "Sin estado" : estado
        };
    }

    private static string TipoTexto(string? tipo)
    {
        return (tipo ?? "").ToLowerInvariant() switch
        {
            "texto" => "Texto",
            "escala" => "Escala",
            "opcion_multiple" => "Opción múltiple",
            "checkbox" => "Selección múltiple",
            _ => "Pregunta"
        };
    }

    private static string ClaseHeatDimension(decimal porcentaje)
{
    if (porcentaje <= 0)
        return "dimension-heat-empty";

    if (porcentaje < 60)
        return "dimension-heat-low";

    if (porcentaje < 75)
        return "dimension-heat-mid";

    if (porcentaje < 90)
        return "dimension-heat-good";

    return "dimension-heat-high";
}

private static string TextoNivelDimension(decimal porcentaje)
{
    if (porcentaje <= 0)
        return "Sin calificación";

    if (porcentaje < 60)
        return "Bajo";

    if (porcentaje < 75)
        return "Medio";

    if (porcentaje < 90)
        return "Bueno";

    return "Sobresaliente";
}
}

<style>
