        margin-top: .2rem;
        font-weight: 700;
    }

    .appointment-info {
        min-width: 0;
    }

    .appointment-meta {
        display: grid;
        gap: .5rem;
    }

    .appointment-date {
        font-weight: 950;
    }

    .appointment-time {
        color: var(--bd-muted);
        font-weight: 850;
    }

    .appointment-statuses {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
    }

    .status {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .36rem .65rem;
        font-size: .74rem;
        font-weight: 950;
        white-space: nowrap;
    }

    .status-success {
        background: #d1fae5;
        color: #047857;
    }

    .status-info {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-warning {
        background: #fef3c7;
        color: #b45309;
    }

    .status-danger {
        background: #fee2e2;
        color: #b91c1c;
    }

    .status-muted {
        background: #f3f4f6;
        color: #4b5563;
    }

    .actions-wrap {
        display: flex;
        justify-content: flex-end;
        align-items: center;
