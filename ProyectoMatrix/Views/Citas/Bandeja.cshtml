        background: #ecfdf5;
        box-shadow: 0 14px 26px rgba(16, 185, 129, .11);
    }

    .company-chip-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .6rem;
    }

    .company-avatar {
        width: 42px;
        height: 42px;
        border-radius: 16px;
        background: #eef4ff;
        color: #1d4ed8;
        display: grid;
        place-items: center;
        font-weight: 950;
        flex: 0 0 auto;
    }

    .company-chip.is-active .company-avatar {
        background: var(--bd-green);
        color: #fff;
    }

    .company-chip h4 {
        margin: .75rem 0 .25rem;
        font-size: .96rem;
        font-weight: 950;
        line-height: 1.2;
    }

    .company-chip p {
        margin: 0;
        color: var(--bd-muted);
        font-size: .78rem;
        font-weight: 750;
        min-height: 37px;
    }

    .company-mini-stats {
