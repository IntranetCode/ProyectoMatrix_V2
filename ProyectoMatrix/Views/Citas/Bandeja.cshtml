    @@media (max-width: 768px) {
        .bd-hero-row,
        .bd-section-head,
        .context-top {
            flex-direction: column;
        }

        .bd-hero-actions,
        .context-tags {
            justify-content: flex-start;
        }

        .event-toolbar,
        .context-metrics,
        .filters-bar {
            grid-template-columns: 1fr;
        }

        .company-chip {
            min-width: 220px;
            max-width: 220px;
        }

        .bd-panel {
            padding: .9rem;
        }
    }
</style>

<div class="container py-4 bandeja-page">
    <section class="bd-hero">
        <div class="bd-hero-row">
            <div>
                <h2>Bandeja de entrevistas</h2>
                <p>
                    Selecciona un evento, elige una empresa participante y comienza las citas de mapeo desde una vista limpia.
                </p>
            </div>

            <div class="bd-hero-actions">
                <a class="bd-btn bd-btn-light" href="@Url.Action("Index", "Citas")">
                    ← Dashboard
                </a>

                <a class="bd-btn bd-btn-green" href="@Url.Action("CrearAgenda", "Citas")">
                    ＋ Nuevo evento
                </a>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.AlertaSistema))
    {
        <div class="alert alert-warning">
            @Model.AlertaSistema
        </div>
    }

    @if (TempData["CitasOk"] != null)
    {
        <div class="alert alert-success">
            @TempData["CitasOk"]
        </div>
    }

    @if (TempData["CitasError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["CitasError"]
        </div>
    }

    <section class="bd-panel">
        <div class="bd-section-head">
            <div>
                <h3>Evento de trabajo</h3>
                <p>Selecciona el evento que quieres revisar.</p>
            </div>

            <span class="bd-pill">@totalEventos eventos</span>
        </div>

        <form asp-controller="Citas" asp-action="Bandeja" method="get" class="event-toolbar">
            <div>
                <label class="bd-label">Evento</label>
                <select class="bd-select" name="agendaId" onchange="this.form.submit()">
                    @foreach (var evento in Model.Eventos)
                    {
                        if (evento.AgendaID == Model.AgendaID)
                        {
                            <option value="@evento.AgendaID" selected>
                                @evento.NombreEvento (@evento.FechaInicio.ToString("dd/MM/yyyy") - @evento.FechaFin.ToString("dd/MM/yyyy"))
                            </option>
                        }
                        else
                        {
                            <option value="@evento.AgendaID">
                                @evento.NombreEvento (@evento.FechaInicio.ToString("dd/MM/yyyy") - @evento.FechaFin.ToString("dd/MM/yyyy"))
                            </option>
                        }
                    }
                </select>
            </div>

            <input type="hidden" name="fecha" value="@fechaFiltro" />

            <button class="btn btn-primary" type="submit">
                Cargar evento
            </button>

            <a class="btn btn-outline-secondary" href="@Url.Action("Bandeja", "Citas")">
                Limpiar
            </a>
        </form>

        <div class="context-card">
            <div class="context-top">
                <div class="context-title">
                    <h3>@Texto(tituloEvento, "Selecciona un evento")</h3>
                    <p>@Texto(tituloEmpresa, "Todas las empresas participantes")</p>
                </div>

                <div class="context-tags">
                    @if (eventoSeleccionado != null)
                    {
                        <span class="status @EstadoClase(eventoSeleccionado.Estatus)">
                            @EstadoTexto(eventoSeleccionado.Estatus)
                        </span>

                        <span class="bd-pill">
                            @Fecha(eventoSeleccionado.FechaInicio) - @Fecha(eventoSeleccionado.FechaFin)
                        </span>
                    }
                </div>
            </div>

            <div class="context-metrics">
                <article class="context-metric">
                    <span>Empresas</span>
                    <strong>@totalEmpresas</strong>
                </article>

                <article class="context-metric yellow">
                    <span>Total citas</span>
                    <strong>@Model.Total</strong>
                </article>

                <article class="context-metric purple">
                    <span>Pendientes</span>
                    <strong>@Model.Pendientes</strong>
                </article>

                <article class="context-metric green">
                    <span>Finalizadas</span>
                    <strong>@Model.Finalizadas</strong>
                </article>

                <article class="context-metric red">
                    <span>No asistieron</span>
                    <strong>@Model.NoAsistieron</strong>
                </article>
            </div>
        </div>
    </section>

    <section class="bd-panel">
        <div class="bd-section-head">
            <div>
                <h3>Empresas participantes</h3>
                <p>Elige una empresa para filtrar las citas. También puedes verlas todas.</p>
            </div>

            <span class="bd-pill">@Model.Empresas.Count empresas</span>
        </div>

        @if (!Model.AgendaID.HasValue)
        {
            <div class="empty-state">
                <strong>Selecciona un evento</strong>
                <span>Después podrás elegir una empresa participante.</span>
            </div>
        }
        else if (!Model.Empresas.Any())
        {
            <div class="empty-state">
                <strong>Sin empresas asignadas</strong>
                <span>Este evento todavía no tiene empresas participantes.</span>
            </div>
        }
        else
        {
            <div class="company-scroll">
                <a class="company-chip @(Model.EmpresaID.HasValue ? "" : "is-active")"
                   href="@Url.Action("Bandeja", "Citas", new { agendaId = Model.AgendaID, fecha = fechaFiltro })">
                    <div class="company-chip-head">
                        <div class="company-avatar">ALL</div>
                        <span class="status status-info">General</span>
                    </div>

                    <h4>Todas las empresas</h4>
                    <p>Vista general de todas las citas del evento seleccionado.</p>

                    <div class="company-mini-stats">
                        <div>
                            <strong>@Model.Empresas.Sum(x => x.TotalCitas)</strong>
                            <span>Citas</span>
                        </div>

                        <div>
                            <strong>@Model.Empresas.Sum(x => x.Pendientes)</strong>
                            <span>Pend.</span>
                        </div>

                        <div>
                            <strong>@Model.Empresas.Sum(x => x.Finalizadas)</strong>
                            <span>Fin.</span>
                        </div>
                    </div>
                </a>

                @foreach (var empresa in Model.Empresas)
                {
                    var activa = empresa.EmpresaID == Model.EmpresaID;

                    <a class="company-chip @(activa ? "is-active" : "")"
                       href="@Url.Action("Bandeja", "Citas", new
                       {
                           agendaId = Model.AgendaID,
                           empresaId = empresa.EmpresaID,
                           fecha = fechaFiltro
                       })">
                        <div class="company-chip-head">
                            <div class="company-avatar">
                                @Iniciales(empresa.NombreEmpresa)
                            </div>

                            <span class="status @EstadoClase(empresa.EstadoAsignacion)">
                                @EstadoTexto(empresa.EstadoAsignacion)
                            </span>
                        </div>

                        <h4>@Texto(empresa.NombreEmpresa, "Empresa sin nombre")</h4>

                        <p>
                            @Fecha(empresa.FechaInicioSolicitud) -
                            @Fecha(empresa.FechaFinSolicitud)
                        </p>

                        <div class="company-mini-stats">
                            <div>
                                <strong>@empresa.TotalCitas</strong>
                                <span>Citas</span>
                            </div>

                            <div>
                                <strong>@empresa.Pendientes</strong>
                                <span>Pend.</span>
                            </div>

                            <div>
                                <strong>@empresa.Finalizadas</strong>
                                <span>Fin.</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </section>

    <section class="bd-panel">
        <div class="bd-section-head">
            <div>
                <h3>Citas para iniciar</h3>
                <p>
                    @(empresaSeleccionada == null
                        ? "Mostrando citas de todas las empresas del evento seleccionado."
                        : $"Mostrando citas de {empresaSeleccionada.NombreEmpresa}.")
                </p>
            </div>

            <span class="bd-pill">@Model.Total citas</span>
        </div>

        <form asp-controller="Citas" asp-action="Bandeja" method="get" class="filters-bar">
            <input type="hidden" name="agendaId" value="@Model.AgendaID" />
            <input type="hidden" name="empresaId" value="@Model.EmpresaID" />

            <div>
                <label class="bd-label">Filtrar por fecha</label>
                <input class="bd-control"
                       type="date"
                       name="fecha"
                       value="@fechaFiltro" />
            </div>

            <button class="btn btn-primary" type="submit">
                Filtrar
            </button>

            <a class="btn btn-outline-secondary"
               href="@Url.Action("Bandeja", "Citas", new
               {
                   agendaId = Model.AgendaID,
                   empresaId = Model.EmpresaID
               })">
                Limpiar
            </a>
        </form>

        @if (!Model.Citas.Any())
        {
            <div class="empty-state">
                <strong>No hay citas registradas</strong>
                <span>Cambia el evento, la empresa o el filtro de fecha para buscar más resultados.</span>
            </div>
        }
        else
        {
            <div class="appointment-list">
                @foreach (var item in Model.Citas)
                {
                    var entrevistaTerminada = EstaFinalizada(item.Estado, item.EstadoFormulario);
                    var noAsistio = EsNoAsistio(item.Estado);
                    var cancelada = EsCancelada(item.Estado);

                    var puedeIniciar =
                        !entrevistaTerminada &&
                        !noAsistio &&
                        !cancelada;

                    var puedeMarcarNoAsistio =
                        !entrevistaTerminada &&
                        !noAsistio &&
                        !cancelada;

                    <article class="appointment-card">
                        <div class="appointment-grid">
                            <div class="appointment-person">
                                <div class="employee-avatar">
                                    @Iniciales(item.NombrePersona)
                                </div>

                                <div>
                                    <strong>
                                    @Texto(item.NombrePersona, "Empleado sin nombre")</strong>
                                    <small>@item.Folio</small>
                                </div>
                            </div>

                            <div class="appointment-info">
                                <strong>@Texto(item.NombreEvento, "Evento sin nombre")</strong>
                                <small>@Texto(item.NombreEmpresa, "Empresa sin nombre")</small>
                            </div>

                            <div class="appointment-meta">
                                <div>
                                    <span class="appointment-date">@item.FechaCita.ToString("dd/MM/yyyy")</span>
                                    <span class="appointment-time"> · @item.Horario</span>
                                </div>

                                <div class="appointment-statuses">
                                    <span class="status @EstadoClase(item.Estado)">
                                        @EstadoTexto(item.Estado)
                                    </span>

                                    <span class="status @EstadoClase(item.EstadoFormulario)">
                                        @EstadoFormularioTexto(item.EstadoFormulario)
                                    </span>
                                </div>
                            </div>

                            <div class="actions-wrap">
                                <div class="btn-group btn-group-sm cita-btn-group" role="group">
                                    <a class="btn btn-outline-primary"
                                       href="@Url.Action("Resultados", "Citas", new { citaId = item.CitaID })">
                                        Ver Resultados
                                    </a>

                                    @if (puedeIniciar)
                                    {
                                        <a class="btn btn-outline-success"
                                           href="@Url.Action("Capturar", "Citas", new { citaId = item.CitaID })">
                                            Iniciar
                                        </a>
                                    }

                                    @if (puedeMarcarNoAsistio)
                                    {
                                        <form asp-controller="Citas"
                                              asp-action="MarcarNoAsistio"
                                              method="post"
                                              class="d-inline form-no-asistio">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="citaId" value="@item.CitaID" />
                                            <input type="hidden" name="agendaId" value="@Model.AgendaID" />
                                            <input type="hidden" name="empresaId" value="@Model.EmpresaID" />

                                            @if (Model.Fecha.HasValue)
                                            {
                                                <input type="hidden"
                                                       name="fecha"
                                                       value="@Model.Fecha.Value.ToString("yyyy-MM-dd")" />
                                            }

                                            <button type="button"
                                                    class="btn btn-outline-danger btn-confirmar-no-asistio"
                                                    data-persona="@Texto(item.NombrePersona, "Empleado sin nombre")"
                                                    data-folio="@item.Folio">
                                                No asistió
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>


<div class="modal fade" id="modalNoAsistio" tabindex="-1" aria-labelledby="modalNoAsistioLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 22px; overflow:hidden;">
            <div class="modal-header bg-danger text-white border-0">
                <div>
                    <h5 class="modal-title fw-bold" id="modalNoAsistioLabel">
                        Confirmar inasistencia
                    </h5>
                    <small>Esta acción actualizará el estado de la cita.</small>
                </div>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar"></button>
            </div>

            <div class="modal-body p-4">
                <div class="d-flex gap-3 align-items-start">
                    <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center"
                         style="width:48px;height:48px;min-width:48px;font-weight:900;">
                        !
                    </div>

                    <div>
                        <p class="mb-2">
                            ¿Seguro que deseas marcar esta cita como <strong>no asistió</strong>?
                        </p>

                        <div class="p-3 rounded-3 bg-light border">
                            <div class="small text-muted fw-bold text-uppercase">Empleado</div>
                            <div id="modalNoAsistioPersona" class="fw-bold">Empleado</div>

                            <div class="small text-muted fw-bold text-uppercase mt-2">Folio</div>
                            <div id="modalNoAsistioFolio" class="fw-bold">CIT-00000</div>
                        </div>

                        <p class="text-muted small mb-0 mt-3">
                            Se notificará al usuario por correo si tiene email disponible y activo.
                        </p>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0 px-4 pb-4">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="button"
                        class="btn btn-danger"
                        id="btnEnviarNoAsistio">
                    Sí, marcar no asistió
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let formSeleccionado = null;

            const modalElement = document.getElementById("modalNoAsistio");
            const modalPersona = document.getElementById("modalNoAsistioPersona");
            const modalFolio = document.getElementById("modalNoAsistioFolio");
            const btnEnviar = document.getElementById("btnEnviarNoAsistio");

            if (!modalElement || !btnEnviar) return;

            const modal = new bootstrap.Modal(modalElement);

            document.querySelectorAll(".btn-confirmar-no-asistio").forEach(btn => {
                btn.addEventListener("click", function () {
                    formSeleccionado = btn.closest("form");

                    modalPersona.textContent = btn.dataset.persona || "Empleado";
                    modalFolio.textContent = btn.dataset.folio || "CIT-00000";

                    modal.show();
                });
            });

            btnEnviar.addEventListener("click", function () {
                if (!formSeleccionado) return;

                btnEnviar.disabled = true;
                btnEnviar.innerHTML = "Procesando...";

                formSeleccionado.submit();
            });

            modalElement.addEventListener("hidden.bs.modal", function () {
                btnEnviar.disabled = false;
                btnEnviar.innerHTML = "Sí, marcar no asistió";
                formSeleccionado = null;
            });
        });
    </script>
}