        --bd-blue: #2563eb;
        --bd-blue-soft: #dbeafe;
        --bd-green: #10b981;
        --bd-green-dark: #047857;
        --bd-green-soft: #d1fae5;
        --bd-yellow: #f59e0b;
        --bd-yellow-soft: #fef3c7;
        --bd-red: #ef4444;
        --bd-red-soft: #fee2e2;
        --bd-purple: #7c3aed;
        --bd-dark: #0f172a;
