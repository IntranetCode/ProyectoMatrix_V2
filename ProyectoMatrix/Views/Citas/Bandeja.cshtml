    }

    .cita-btn-group {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: .38rem;
    }

    .cita-btn-group .btn {
        border-radius: 13px !important;
        font-weight: 900;
        white-space: nowrap;
        min-height: 38px;
        padding: .45rem .72rem;
        font-size: .8rem;
    }

    .empty-state {
        border: 1px dashed #cbd5e1;
        background: #f8fafc;
        color: var(--bd-muted);
        border-radius: 18px;
        padding: 1.4rem;
        text-align: center;
        font-weight: 850;
    }

    .empty-state strong {
        display: block;
        color: var(--bd-text);
        font-size: 1.05rem;
        margin-bottom: .25rem;
