        min-height: 42px;
        border: 1px solid #d7deea;
        border-radius: 14px;
        padding: .6rem .75rem;
        background: #fff;
        color: var(--bd-text);
        font-weight: 750;
        outline: none;
    }

    .bd-select:focus,
    .bd-control:focus {
        border-color: var(--bd-blue);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, .09);
    }

    .context-card {
        border-radius: 24px;
        padding: 1.15rem;
        background:
            radial-gradient(circle at top right, rgba(37, 99, 235, .12), transparent 30%),
            linear-gradient(135deg, #ffffff, #f8fafc);
