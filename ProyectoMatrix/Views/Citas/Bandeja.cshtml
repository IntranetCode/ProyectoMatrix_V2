    }

    .bd-btn-light {
        background: #fff;
        color: #0f172a;
    }

    .bd-btn-light:hover {
        color: #0f172a;
        opacity: .92;
    }

    .bd-btn-green {
        background: var(--bd-green);
        color: #052e16;
    }

    .bd-btn-green:hover {
        color: #052e16;
        opacity: .92;
    }

    .bd-panel {
