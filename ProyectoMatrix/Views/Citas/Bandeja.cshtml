@model ProyectoMatrix.Models.CitasBandejaVm

@{
    Layout = "_LayoutComunicados";
    ViewData["Title"] = "Bandeja de Citas";

    var eventoSeleccionado = Model.Eventos.FirstOrDefault(x => x.AgendaID == Model.AgendaID);
    var empresaSeleccionada = Model.Empresas.FirstOrDefault(x => x.EmpresaID == Model.EmpresaID);

    var fechaFiltro = Model.Fecha.HasValue
        ? Model.Fecha.Value.ToString("yyyy-MM-dd")
        : string.Empty;

    var totalEventos = Model.Eventos.Count;
    var totalEmpresas = Model.Empresas.Count;

    var tituloEvento = eventoSeleccionado?.NombreEvento ?? "Selecciona un evento";
    var tituloEmpresa = empresaSeleccionada?.NombreEmpresa ?? "Todas las empresas";
}

@functions {
    private static string Texto(string? value, string fallback = "Sin información")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private static string Fecha(DateTime value)
    {
        return value == DateTime.MinValue ? "Pendiente" : value.ToString("dd/MM/yyyy");
    }

    private static string EstadoTexto(string? estado)
    {
        return (estado ?? "").ToLowerInvariant() switch
        {
            "borrador" => "Borrador",
            "activo" => "Activo",
            "cerrado" => "Cerrado",
            "cancelado" => "Cancelado",
            "programada" => "Programada",
            "abierta" => "Abierta",
            "oculta" => "Oculta",
            "pendiente" => "Pendiente",
            "asistio" => "Asistió",
            "no_asistio" => "No asistió",
            "cancelada" => "Cancelada",
            "finalizada" => "Finalizada",
            "en_captura" => "En captura",
            "completado" => "Completado",
            _ => string.IsNullOrWhiteSpace(estado) ? "Sin estado" : estado
        };
    }

    private static string EstadoFormularioTexto(string? estado)
    {
        return (estado ?? "").ToLowerInvariant() switch
        {
            "pendiente" => "Pendiente",
            "en_captura" => "En captura",
            "completado" => "Completado",
            _ => string.IsNullOrWhiteSpace(estado) ? "Sin estado" : estado
        };
    }

    private static string EstadoClase(string? estado)
    {
        return (estado ?? "").ToLowerInvariant() switch
        {
            "activo" => "status-success",
            "abierta" => "status-success",
            "finalizada" => "status-success",
            "completado" => "status-success",
            "asistio" => "status-info",
            "en_captura" => "status-info",
            "borrador" => "status-warning",
            "programada" => "status-warning",
            "pendiente" => "status-warning",
            "cerrado" => "status-muted",
            "cancelado" => "status-danger",
            "cancelada" => "status-danger",
            "no_asistio" => "status-danger",
            "oculta" => "status-muted",
            _ => "status-muted"
        };
    }

    private static string Porcentaje(decimal value)
    {
        if (value < 0) value = 0;
        if (value > 100) value = 100;

        return value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) + "%";
    }

    private static string Iniciales(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre))
            return "TM";

        var partes = nombre
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .ToList();

        if (!partes.Any())
            return "TM";

        return string.Join("", partes.Select(x => x[0])).ToUpperInvariant();
    }

    private static bool EstaFinalizada(string? estado, string? estadoFormulario)
    {
        return string.Equals(estado, "finalizada", StringComparison.OrdinalIgnoreCase)
            || string.Equals(estadoFormulario, "completado", StringComparison.OrdinalIgnoreCase);
    }

    private static bool EsNoAsistio(string? estado)
    {
        return string.Equals(estado, "no_asistio", StringComparison.OrdinalIgnoreCase);
    }

    private static bool EsCancelada(string? estado)
    {
        return string.Equals(estado, "cancelada", StringComparison.OrdinalIgnoreCase)
            || string.Equals(estado, "cancelado", StringComparison.OrdinalIgnoreCase);
    }
}

<style>
