        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .bd-hero h2 {
        margin: 0 0 .35rem;
        font-weight: 950;
        letter-spacing: -.04em;
    }

    .bd-hero p {
        margin: 0;
        color: rgba(255, 255, 255, .78);
        max-width: 760px;
    }

    .bd-hero-actions {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        flex-wrap: wrap;
        flex: 0 0 auto;
    }

    .bd-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
