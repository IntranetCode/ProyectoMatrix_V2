        margin-bottom: 1rem;
    }

    .bd-section-head h3 {
        margin: 0;
        font-weight: 950;
        letter-spacing: -.03em;
    }

    .bd-section-head p {
        margin: .25rem 0 0;
        color: var(--bd-muted);
    }

    .bd-pill {
