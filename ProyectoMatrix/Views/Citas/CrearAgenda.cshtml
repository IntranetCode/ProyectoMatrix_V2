<div class="agenda-modal" id="modalCuestionarioAgenda" aria-hidden="true">
    <div class="agenda-modal-card agenda-modal-small">
        <div class="agenda-modal-header">
            <div>
                <h3>Cuestionario del evento</h3>
                <p>Indica si deseas crear un cuestionario para este evento.</p>
            </div>

            <button type="button" class="agenda-modal-close" data-close-modal>×</button>
