                </div>

                <button type="button" class="agenda-modal-close" data-close-modal>×</button>
            </div>

            <div class="agenda-modal-body">
                <div class="delete-warning">
                    Estás por eliminar la agenda <strong>@Texto(Model.Nombre)</strong>.
                    No se borrará físicamente de la base de datos; se marcará como cancelada e inactiva.
                </div>
            </div>

            <div class="agenda-modal-footer">
                <button type="button" class="btn-agenda btn-agenda-light" data-close-modal>
                    Cancelar
                </button>

                <form asp-controller="Citas"
                      asp-action="EliminarAgenda"
