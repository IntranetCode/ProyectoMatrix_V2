            <p class="mb-0">
                El evento puede guardarse y agendarse sin cuestionario.
                Si eliges crear uno, primero se guardará el evento y después se abrirá la pantalla para capturar el cuestionario.
            </p>
        </div>

        <div class="agenda-modal-footer">
            <button type="button"
                    class="btn-agenda btn-agenda-light"
                    id="btnNoAgregarCuestionario">
                No, guardar sin cuestionario
            </button>

            <button type="button"
                    class="btn-agenda btn-agenda-dark"
                    id="btnSiAgregarCuestionario">
                Sí, crear cuestionario
            </button>
        </div>
    </div>
</div>



<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("agendaForm");
        const statusInput = document.getElementById("agendaEstatus");
        const omitirCuestionarioInput = document.getElementById("OmitirCuestionario");
        const crearCuestionarioDespuesInput = document.getElementById("CrearCuestionarioDespues");
        const decisionCuestionarioTomadaInput = document.getElementById("DecisionCuestionarioTomada");
        const submitFromModal = document.getElementById("submitFromModal");

        const summaryStatus = document.getElementById("summaryStatus");
        const summaryCompanies = document.getElementById("summaryCompanies");
        const summaryDays = document.getElementById("summaryDays");
        const summaryTime = document.getElementById("summaryTime");

        function timeToMinutes(value) {
            if (!value || !value.includes(":")) return null;

            const parts = value.split(":");
            const hours = parseInt(parts[0], 10);
            const minutes = parseInt(parts[1], 10);

            if (isNaN(hours) || isNaN(minutes)) return null;

            return (hours * 60) + minutes;
        }

        function calculateCapacity(startValue, endValue, durationValue, breakValue) {
            const start = timeToMinutes(startValue);
            const end = timeToMinutes(endValue);
            const duration = parseInt(durationValue, 10);
            const rest = parseInt(breakValue, 10) || 0;

            if (start === null || end === null) return 0;
            if (end <= start) return 0;
            if (isNaN(duration) || duration <= 0) return 0;

            const totalMinutes = end - start;
            const blockMinutes = duration + rest;

            if (blockMinutes <= 0) return 0;

            return Math.floor((totalMinutes + rest) / blockMinutes);
        }

        function updateCapacityForCard(card) {
            if (!card) return;

            const start = card.querySelector(".agenda-time-start");
            const end = card.querySelector(".agenda-time-end");
            const duration = card.querySelector(".agenda-duration");
            const rest = card.querySelector(".agenda-break");
            const capacity = card.querySelector(".agenda-capacity");

            if (!capacity) return;

            const result = calculateCapacity(
                start?.value,
                end?.value,
                duration?.value,
                rest?.value
            );

            capacity.value = result.toString();
        }

        function updateAllCapacities() {
            document.querySelectorAll("[data-day-card]").forEach(card => {
                updateCapacityForCard(card);
            });
        }

        function updateCardState(check, selectedClass, disabledClass) {
            const targetSelector = check.getAttribute("data-target");
            const target = targetSelector ? document.querySelector(targetSelector) : null;
            const card = check.closest("[data-company-card], [data-day-card]");

            if (card) {
                card.classList.toggle(selectedClass, check.checked);
            }

            if (target && disabledClass) {
                target.classList.toggle(disabledClass, !check.checked);
            }
        }

        function updateSummary() {
            updateAllCapacities();

            const selectedCompanies = document.querySelectorAll(".empresa-check:checked").length;
            const activeDays = document.querySelectorAll(".day-check:checked").length;
            const firstActiveDay = document.querySelector(".day-check:checked");

            if (summaryCompanies) summaryCompanies.textContent = selectedCompanies.toString();
            if (summaryDays) summaryDays.textContent = activeDays.toString();

            if (summaryStatus && statusInput) {
                summaryStatus.textContent = statusInput.value || "borrador";
            }

            if (summaryTime) {
                if (firstActiveDay) {
                    const card = firstActiveDay.closest("[data-day-card]");
                    const start = card?.querySelector(".agenda-time-start")?.value || "--:--";
                    const end = card?.querySelector(".agenda-time-end")?.value || "--:--";
                    summaryTime.textContent = start + " - " + end;
                } else {
                    summaryTime.textContent = "--:-- - --:--";
                }
            }
        }

        function openModal(id) {
            const modal = document.getElementById(id);

            if (!modal) return;

            document.querySelectorAll(".agenda-modal.is-open").forEach(item => {
                item.classList.remove("is-open");
            });

            modal.classList.add("is-open");
            document.body.classList.add("agenda-modal-open");
        }

        function closeModal(modal) {
            if (!modal) return;

            modal.classList.remove("is-open");

            if (!document.querySelector(".agenda-modal.is-open")) {
                document.body.classList.remove("agenda-modal-open");
            }
        }

        function enviarDesdeModal(crearCuestionario) {
            if (!form) return;

            if (crearCuestionarioDespuesInput) {
                crearCuestionarioDespuesInput.value = crearCuestionario ? "true" : "false";
            }

            if (omitirCuestionarioInput) {
                omitirCuestionarioInput.value = crearCuestionario ? "false" : "true";
            }

            if (decisionCuestionarioTomadaInput) {
                decisionCuestionarioTomadaInput.value = "true";
            }

            if (statusInput && !statusInput.value) {
                statusInput.value = "activo";
            }

            if (submitFromModal && statusInput) {
                submitFromModal.value = statusInput.value || "activo";
            }

            updateAllCapacities();
            updateSummary();

            if (!form.checkValidity()) {
                closeModal(document.getElementById("modalCuestionarioAgenda"));
                form.reportValidity();
                return;
            }

            if (typeof form.requestSubmit === "function" && submitFromModal) {
                form.requestSubmit(submitFromModal);
            } else {
                form.submit();
            }
        }

        document.querySelectorAll(".empresa-check").forEach(check => {
            updateCardState(check, "is-selected", "is-collapsed");

            check.addEventListener("change", () => {
                updateCardState(check, "is-selected", "is-collapsed");
                updateSummary();
            });
        });

        document.querySelectorAll(".day-check").forEach(check => {
            updateCardState(check, "is-active", "is-disabled");

            check.addEventListener("change", () => {
                updateCardState(check, "is-active", "is-disabled");
                updateSummary();
            });
        });

        document.querySelectorAll(".agenda-time-start, .agenda-time-end, .agenda-duration, .agenda-break").forEach(input => {
            input.addEventListener("input", () => {
                const card = input.closest("[data-day-card]");
                updateCapacityForCard(card);
                updateSummary();
            });

            input.addEventListener("change", () => {
                const card = input.closest("[data-day-card]");
                updateCapacityForCard(card);
                updateSummary();
            });
        });

        document.querySelectorAll("[data-status-submit]").forEach(button => {
            button.addEventListener("click", () => {
                const status = button.getAttribute("data-status-submit") || "borrador";

                if (statusInput) {
                    statusInput.value = status;
                }

                if (omitirCuestionarioInput) {
                    omitirCuestionarioInput.value = "false";
                }

                if (crearCuestionarioDespuesInput) {
                    crearCuestionarioDespuesInput.value = "false";
                }

                if (decisionCuestionarioTomadaInput) {
                    decisionCuestionarioTomadaInput.value = "false";
                }

                updateSummary();
            });
        });

        document.querySelectorAll("input, select, textarea").forEach(input => {
            input.addEventListener("change", updateSummary);
            input.addEventListener("input", updateSummary);
        });

        document.querySelectorAll("[data-open-modal]").forEach(button => {
            button.addEventListener("click", () => {
                const modalId = button.getAttribute("data-open-modal");
                openModal(modalId);
            });
        });

        document.querySelectorAll("[data-close-modal]").forEach(button => {
            button.addEventListener("click", () => {
                closeModal(button.closest(".agenda-modal"));
            });
        });

        document.querySelectorAll(".agenda-modal").forEach(modal => {
            modal.addEventListener("click", event => {
                if (event.target === modal) {
                    closeModal(modal);
                }
            });
        });

        document.addEventListener("keydown", event => {
            if (event.key === "Escape") {
                document.querySelectorAll(".agenda-modal.is-open").forEach(closeModal);
            }
        });

        const btnSiAgregarCuestionario = document.getElementById("btnSiAgregarCuestionario");

        if (btnSiAgregarCuestionario) {
            btnSiAgregarCuestionario.addEventListener("click", () => {
                enviarDesdeModal(true);
            });
        }

        const btnNoAgregarCuestionario = document.getElementById("btnNoAgregarCuestionario");

        if (btnNoAgregarCuestionario) {
            btnNoAgregarCuestionario.addEventListener("click", () => {
                enviarDesdeModal(false);
            });
        }

        if (form) {
            form.addEventListener("submit", event => {
                updateAllCapacities();

                if (statusInput && !statusInput.value) {
                    statusInput.value = "borrador";
                }

                const decisionTomada = decisionCuestionarioTomadaInput?.value === "true";

                if (!decisionTomada) {
                    event.preventDefault();
                    openModal("modalCuestionarioAgenda");
                    return;
                }
            });
        }

        updateSummary();
    });
</script>