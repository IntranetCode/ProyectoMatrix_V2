    @if (!mostrarPanelEditor && !mostrarVistaUsuario)
    {
        <div class="alert alert-warning">
            Tu rol actual no tiene permisos para visualizar el módulo de Mapeo de Talento.
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll("[data-countdown]").forEach(wrapper => {
            const targetValue = wrapper.getAttribute("data-countdown");
            const targetDate = new Date(targetValue).getTime();

            const daysEl = wrapper.querySelector("[data-days]");
            const hoursEl = wrapper.querySelector("[data-hours]");
            const minutesEl = wrapper.querySelector("[data-minutes]");

            const pad = value => value.toString().padStart(2, "0");

            function tick() {
                const now = new Date().getTime();
                let diff = targetDate - now;

                if (isNaN(targetDate) || diff < 0) {
                    diff = 0;
                }

                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
                const minutes = Math.floor((diff / (1000 * 60)) % 60);

                if (daysEl) daysEl.textContent = pad(days);
                if (hoursEl) hoursEl.textContent = pad(hours);
                if (minutesEl) minutesEl.textContent = pad(minutes);
            }

            tick();
            setInterval(tick, 1000);
        });

        document.querySelectorAll("a.disabled, a[aria-disabled='true']").forEach(link => {
            link.addEventListener("click", event => {
                event.preventDefault();
            });
        });

        document.querySelectorAll("a[href='#misEventosMapeo']").forEach(link => {
            link.addEventListener("click", event => {
                event.preventDefault();

                const target = document.getElementById("misEventosMapeo");

                if (target) {
                    target.scrollIntoView({
                        behavior: "smooth",
                        block: "start"
                    });
                }
            });
        });
    });
</script>