                        <div>
                            <span>Evento principal</span>
                            <strong>@Texto(usuario.NombreEvento, "Sin evento asignado")</strong>
                        </div>

                        <div>
                            <span>Empresa</span>
                            <strong>
                                @Texto(usuario.NombreEmpresa, Model.EmpresaID.HasValue ? $"Empresa #{Model.EmpresaID}" : "Sin empresa")
                            </strong>
                        </div>

                        <div>
                            <span>Agenda ID</span>
                            <strong>@(usuario.AgendaID?.ToString() ?? "Sin AgendaID")</strong>
                        </div>

