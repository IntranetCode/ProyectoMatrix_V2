                        </div>
                    </div>

                    <div class="summary-list">
                        <div>
                            <span>Folio</span>
                            <strong>@Folio(usuario.CitaID)</strong>
                        </div>

                        <div>
                            <span>Fecha</span>
                            <strong>@Fecha(usuario.FechaCita)</strong>
                        </div>

                        <div>
                            <span>Horario</span>
                            <strong>@Hora(usuario.HoraInicio) - @Hora(usuario.HoraFin)</strong>
                        </div>

                        <div>
                            <span>Estado</span>
                            <strong>
                                <span class="status @EstadoClase(usuario.EstadoCita)">
                                    @EstadoTexto(usuario.EstadoCita)
                                </span>
                            </strong>
                        </div>

                        <div>
                            <span>Formulario</span>
                            <strong>@EstadoTexto(usuario.EstadoFormulario)</strong>
                        </div>
                    </div>
                </article>
 @*
                <article class="panel-card resultado-card">
               
                    <div>
                        <span class="status @(usuario.EntrevistaFinalizada ? "status-success" : "status-muted")">
                            @(usuario.EntrevistaFinalizada ? "Evaluación completada" : "Evaluación pendiente")
                        </span>

                        <h4>Tus resultados de mapeo</h4>

                        <p>
                            @Texto(usuario.ResultadoResumen, "Cuando finalice tu entrevista, aquí podrás consultar tu resumen y tu gráfico de competencias.")
                        </p>

                        <a class="btn btn-outline-primary @(usuario.EntrevistaFinalizada && usuario.CitaID.HasValue ? "" : "disabled")"
                           href="@(usuario.EntrevistaFinalizada && usuario.CitaID.HasValue ? resultadosUrl : "#")"
                           aria-disabled="@(!(usuario.EntrevistaFinalizada && usuario.CitaID.HasValue)).ToString().ToLowerInvariant()">
                            Ver resultados completos
                        </a>
                    </div>

                    <div class="radar-preview">
                        <div class="radar-shape"></div>
                    </div>
                </article>
                *@
            </div>
        </section>
