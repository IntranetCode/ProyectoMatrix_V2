    @@media (max-width: 992px) {
        .ag-header,
        .ag-card-head,
        .ag-footer {
            flex-direction: column;
            align-items: flex-start;
        }

        .ag-header-actions,
        .ag-actions {
            justify-content: flex-start;
            width: 100%;
        }

        .ag-kpi-grid,
        .ag-grid-main {
            grid-template-columns: 1fr;
        }

        .ag-slot-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 576px) {
        .ag-shell {
            padding: 1rem;
        }

        .ag-kpi-grid,
        .ag-slot-grid {
            grid-template-columns: 1fr;
        }

        .ag-date-btn {
            grid-template-columns: auto minmax(0, 1fr);
        }

        .ag-date-count {
            grid-column: 1 / -1;
            width: fit-content;
        }
    }
</style>

<div class="container py-4 agendar-page">
    <div class="ag-header">
        <div>
            <h2>Agendar Cita de Mapeo</h2>
            <p>Selecciona una fecha y un horario disponible para tu sesión de mapeo de talento.</p>
        </div>

        <div class="ag-header-actions">
            <a class="btn btn-outline-secondary btn-ag-secondary" asp-controller="Citas" asp-action="Index">
                ← Volver al panel
            </a>
        </div>
    </div>

    @if (TempData["CitasOk"] != null)
    {
        <div class="alert alert-success">
            @TempData["CitasOk"]
        </div>
    }

    @if (TempData["CitasError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["CitasError"]
        </div>
    }

    <section class="ag-shell">
        <form asp-controller="Citas" asp-action="Agendar" method="post" id="formAgendarCita">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="AgendaID" />
            <input type="hidden" asp-for="AgendaEmpresaID" />
            <input type="hidden" name="FechaCita" id="FechaCita" />
            <input type="hidden" name="HoraInicio" id="HoraInicio" />
            <input type="hidden" name="HoraFin" id="HoraFin" />

            <div class="ag-kpi-grid">
                <article class="ag-kpi">
                    <div class="ag-kpi-label">Evento</div>
                    <strong class="ag-kpi-value">@Model.NombreEvento</strong>
                    <span class="ag-kpi-caption">Mapeo de talento y competencias</span>
                </article>

                <article class="ag-kpi blue">
                    <div class="ag-kpi-label">Fechas configuradas</div>
                    <strong class="ag-kpi-value">@totalFechas</strong>
                    <span class="ag-kpi-caption">Días mostrados</span>
                </article>

                <article class="ag-kpi yellow">
                    <div class="ag-kpi-label">Horarios disponibles</div>
                    <strong class="ag-kpi-value">@totalHorariosDisponibles</strong>
                    <span class="ag-kpi-caption">De @totalHorarios horarios configurados</span>
                </article>

                <article class="ag-kpi">
                    <div class="ag-kpi-label">Duración estimada</div>
                    <strong class="ag-kpi-value">40 min</strong>
                    <span class="ag-kpi-caption">Una persona por horario</span>
                </article>
            </div>

            <div class="ag-grid-main">
                <aside>
                    <article class="ag-card mb-3">
                        <div class="ag-card-head">
                            <div>
                                <h4>Información del evento</h4>
                                <p>Periodo autorizado para solicitar cita.</p>
                            </div>

                            <span class="ag-pill">Activo</span>
                        </div>

                        <div class="ag-card-body">
                            <div class="ag-info-list">
                                <div class="ag-info-item">
                                    <span>Evento</span>
                                    <strong>@Model.NombreEvento</strong>
                                </div>

                                <div class="ag-info-item">
                                    <span>Inicio de solicitud</span>
                                    <strong>@Model.FechaInicioSolicitud.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>

                                <div class="ag-info-item">
                                    <span>Fin de solicitud</span>
                                    <strong>@Model.FechaFinSolicitud.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>

                                <div class="ag-info-item">
                                    <span>Tipo de evaluación</span>
                                    <strong>Mapeo de talento</strong>
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="ag-card">
                        <div class="ag-card-head">
                            <div>
                                <h4>Selecciona una fecha</h4>
                                <p>Días configurados por RH. Los días sin espacios se muestran bloqueados.</p>
                            </div>

                            <span class="ag-pill info">@totalFechas días</span>
                        </div>

                        <div class="ag-card-body">
                            @if (!fechas.Any())
                            {
                                <div class="ag-empty">
                                    No hay fechas configuradas por el momento.
                                </div>
                            }
                            else
                            {
                                <div class="ag-date-list">
                                    @foreach (var grupo in fechas)
                                    {
                                        var fecha = grupo.Key;

                                        var disponiblesFecha = grupo.Count(s =>
                                            s.Disponible &&
                                            s.Fecha.Date >= ahora.Date &&
                                            s.Fecha.Date.Add(s.HoraInicio) > ahora);

                                        var fechaBloqueada = disponiblesFecha <= 0;
                                        var active = fecha == primerDia ? "active" : "";
                                        var disabledClass = fechaBloqueada ? "is-disabled" : "";

                                        <button type="button"
                                                class="ag-date-btn @active @disabledClass"
                                                data-date="@FechaIso(fecha)"
                                                data-display="@FechaLarga(fecha)"
                                                data-disabled="@fechaBloqueada.ToString().ToLowerInvariant()">
                                            <span class="ag-date-day">
                                                <span>
                                                    @fecha.Day
                                                    <small>@DiaCorto(fecha)</small>
                                                </span>
                                            </span>

                                            <span class="ag-date-text">
                                                <strong>@FechaCorta(fecha)</strong>
                                                <small>@FechaLarga(fecha)</small>
                                            </span>

                                            <span class="ag-date-count @(fechaBloqueada ? "disabled" : "")">
                                                @(disponiblesFecha > 0 ? $"{disponiblesFecha} disponibles" : "Sin espacios")
                                            </span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </article>
                </aside>

                <main class="ag-card">
                    <div class="ag-card-head">
                        <div>
                            <h4>Horarios disponibles</h4>
                            <p>Elige el horario que mejor se ajuste a tu disponibilidad.</p>
                        </div>

                        <span class="ag-pill warning" id="FechaSeleccionadaPill">
                            Selecciona fecha
                        </span>
                    </div>

                    <div class="ag-card-body">
                        @if (!slots.Any())
                        {
                            <div class="ag-empty">
                                No hay horarios configurados para esta agenda.
                            </div>
                        }
                        else
                        {
                            @if (slotsManana.Any())
                            {
                                <section class="ag-slot-section">
                                    <div class="ag-slot-title">☀ AM</div>

                                    <div class="ag-slot-grid">
                                        @foreach (var slot in slotsManana)
                                        {
                                            var bloqueado = SlotEstaBloqueado(slot, ahora);
                                            var motivo = MotivoBloqueoSlot(slot, ahora);

                                            <button type="button"
                                                    class="ag-slot-btn @(bloqueado ? "is-disabled" : "")"
                                                    data-date="@FechaIso(slot.Fecha)"
                                                    data-start="@Hora(slot.HoraInicio)"
                                                    data-end="@Hora(slot.HoraFin)"
                                                    data-disabled="@bloqueado.ToString().ToLowerInvariant()"
                                                    data-reason="@motivo"
                                                    aria-disabled="@bloqueado.ToString().ToLowerInvariant()"
                                                    title="@motivo">
                                                <span class="slot-hour">@Hora12(slot.HoraInicio)</span>
                                                <span class="slot-period">@Meridiano(slot.HoraInicio)</span>
                                            </button>
                                        }
                                    </div>
                                </section>
                            }

                            @if (slotsTarde.Any())
                            {
                                <section class="ag-slot-section">
                                    <div class="ag-slot-title">◐ PM</div>

                                    <div class="ag-slot-grid">
                                        @foreach (var slot in slotsTarde)
                                        {
                                            var bloqueado = SlotEstaBloqueado(slot, ahora);
                                            var motivo = MotivoBloqueoSlot(slot, ahora);

                                            <button type="button"
                                                    class="ag-slot-btn @(bloqueado ? "is-disabled" : "")"
                                                    data-date="@FechaIso(slot.Fecha)"
                                                    data-start="@Hora(slot.HoraInicio)"
                                                    data-end="@Hora(slot.HoraFin)"
                                                    data-disabled="@bloqueado.ToString().ToLowerInvariant()"
                                                    data-reason="@motivo"
                                                    aria-disabled="@bloqueado.ToString().ToLowerInvariant()"
                                                    title="@motivo">
                                                <span class="slot-hour">@Hora12(slot.HoraInicio)</span>
                                                <span class="slot-period">@Meridiano(slot.HoraInicio)</span>
                                            </button>
                                        }
                                    </div>
                                </section>
                            }

                            <div class="ag-empty" id="SinHorariosFecha" style="display:none;">
                                No hay horarios disponibles para la fecha seleccionada.
                            </div>

                            <div class="ag-summary mt-4">
                                <div>
                                    <div class="ag-summary-main" id="ResumenFecha">
                                        Selecciona una fecha
                                    </div>
                                    <div class="ag-summary-sub" id="ResumenHora">
                                        Después elige un horario disponible.
                                    </div>
                                </div>

                                <div class="ag-summary-row">
                                    <span>Evento</span>
                                    <strong>@Model.NombreEvento</strong>
                                </div>

                                <div class="ag-summary-row">
                                    <span>Duración estimada</span>
                                    <strong>40 minutos</strong>
                                </div>
                            </div>
                        }

                        <div class="ag-footer">
                            <div class="ag-footer-note">
                                <span>ⓘ</span>
                                <span>Los horarios en gris ya vencieron o están ocupados.</span>
                            </div>

                            <div class="ag-actions">
                                <a class="btn btn-outline-secondary btn-ag-secondary" asp-controller="Citas" asp-action="Index">
                                    Cancelar
                                </a>

                                <button type="submit" class="btn btn-ag-primary" id="btnConfirmar" disabled>
                                    Confirmar Agendamiento
                                </button>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
        </form>
    </section>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const dateButtons = document.querySelectorAll(".ag-date-btn[data-date]");
        const slotButtons = document.querySelectorAll(".ag-slot-btn");

        const fechaInput = document.getElementById("FechaCita");
        const horaInicioInput = document.getElementById("HoraInicio");
        const horaFinInput = document.getElementById("HoraFin");

        const resumenFecha = document.getElementById("ResumenFecha");
        const resumenHora = document.getElementById("ResumenHora");
        const btnConfirmar = document.getElementById("btnConfirmar");
        const fechaSeleccionadaPill = document.getElementById("FechaSeleccionadaPill");
        const sinHorariosFecha = document.getElementById("SinHorariosFecha");
        const form = document.getElementById("formAgendarCita");

        let selectedDate = null;
        let selectedDateDisplay = null;
        let selectedStart = null;
        let selectedEnd = null;

        function formatIsoDate(isoDate) {
            if (!isoDate) return "";

            const parts = isoDate.split("-");

            if (parts.length !== 3) return isoDate;

            return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function isDisabled(element) {
            return element.getAttribute("data-disabled") === "true";
        }

        function clearSlotSelection() {
            selectedStart = null;
            selectedEnd = null;

            slotButtons.forEach(slot => {
                slot.classList.remove("active");
            });
        }

        function updateSlotsVisibility() {
            let visibles = 0;
            let disponibles = 0;

            slotButtons.forEach(slot => {
                const slotDate = slot.getAttribute("data-date");
                const visible = !selectedDate || slotDate === selectedDate;

                slot.style.display = visible ? "" : "none";

                if (visible) {
                    visibles++;

                    if (!isDisabled(slot)) {
                        disponibles++;
                    }
                }
            });

            if (sinHorariosFecha) {
                sinHorariosFecha.style.display = visibles === 0 || disponibles === 0 ? "" : "none";
                sinHorariosFecha.textContent = visibles === 0
                    ? "No hay horarios configurados para la fecha seleccionada."
                    : "Todos los horarios de esta fecha ya vencieron o están ocupados.";
            }
        }

        function updateSummary() {
            if (selectedDate) {
                fechaInput.value = selectedDate;
                resumenFecha.textContent = selectedDateDisplay || formatIsoDate(selectedDate);

                if (fechaSeleccionadaPill) {
                    fechaSeleccionadaPill.textContent = formatIsoDate(selectedDate);
                    fechaSeleccionadaPill.classList.remove("muted");
                }
            } else {
                fechaInput.value = "";
                resumenFecha.textContent = "Selecciona una fecha";

                if (fechaSeleccionadaPill) {
                    fechaSeleccionadaPill.textContent = "Selecciona fecha";
                    fechaSeleccionadaPill.classList.add("muted");
                }
            }

            if (selectedStart && selectedEnd) {
                horaInicioInput.value = selectedStart;
                horaFinInput.value = selectedEnd;
                resumenHora.textContent = `${selectedStart} - ${selectedEnd}`;
                btnConfirmar.disabled = false;
            } else {
                horaInicioInput.value = "";
                horaFinInput.value = "";
                resumenHora.textContent = "Después elige un horario disponible.";
                btnConfirmar.disabled = true;
            }
        }

        function selectDate(btn) {
            if (!btn) return;

            dateButtons.forEach(x => x.classList.remove("active"));
            btn.classList.add("active");

            selectedDate = btn.getAttribute("data-date");
            selectedDateDisplay = btn.getAttribute("data-display");

            clearSlotSelection();
            updateSlotsVisibility();
            updateSummary();
        }

        function selectFirstEnabledDate() {
            const enabledDate = Array.from(dateButtons)
                .find(btn => !isDisabled(btn));

            if (enabledDate) {
                selectDate(enabledDate);
                return;
            }

            if (dateButtons.length > 0) {
                selectDate(dateButtons[0]);
                return;
            }

            updateSlotsVisibility();
            updateSummary();
        }

        dateButtons.forEach(btn => {
            btn.addEventListener("click", () => {
                if (isDisabled(btn)) {
                    selectDate(btn);
                    return;
                }

                selectDate(btn);
            });
        });

        slotButtons.forEach(btn => {
            btn.addEventListener("click", () => {
                if (isDisabled(btn)) {
                    return;
                }

                const slotDate = btn.getAttribute("data-date");

                if (!selectedDate || selectedDate !== slotDate) {
                    selectedDate = slotDate;

                    dateButtons.forEach(dateBtn => {
                        const isActive = dateBtn.getAttribute("data-date") === selectedDate;
                        dateBtn.classList.toggle("active", isActive);

                        if (isActive) {
                            selectedDateDisplay = dateBtn.getAttribute("data-display");
                        }
                    });

                    updateSlotsVisibility();
                }

                slotButtons.forEach(x => x.classList.remove("active"));
                btn.classList.add("active");

                selectedStart = btn.getAttribute("data-start");
                selectedEnd = btn.getAttribute("data-end");

                updateSummary();
            });
        });

        selectFirstEnabledDate();

        if (form) {
            form.addEventListener("submit", event => {
                if (!fechaInput.value || !horaInicioInput.value || !horaFinInput.value) {
                    event.preventDefault();
                    alert("Selecciona una fecha y un horario disponible antes de confirmar.");
                }
            });
        }
    });
</script>