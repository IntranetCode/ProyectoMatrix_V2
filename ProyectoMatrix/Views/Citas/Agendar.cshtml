@using System.Globalization
@using ProyectoMatrix.Models
@model ProyectoMatrix.Models.AgendarCitaVm

@{
    Layout = "_LayoutComunicados";
    ViewData["Title"] = "Agendar Cita";

    var cultura = CultureInfo.GetCultureInfo("es-MX");
    var ahora = DateTime.Now;

    var slots = Model.Slots ?? new List<SlotDisponibleVm>();

    var fechas = slots
        .GroupBy(x => x.Fecha.Date)
        .OrderBy(x => x.Key)
        .ToList();

    var primerDiaDisponible = fechas
        .Where(g => g.Any(s =>
            s.Disponible &&
            s.Fecha.Date >= ahora.Date &&
            s.Fecha.Date.Add(s.HoraInicio) > ahora))
        .Select(g => g.Key)
        .FirstOrDefault();

    var primerDia = primerDiaDisponible != DateTime.MinValue
        ? primerDiaDisponible
        : fechas.FirstOrDefault()?.Key ?? DateTime.Today;

    var slotsManana = slots
        .Where(x => x.HoraInicio < new TimeSpan(12, 0, 0))
        .OrderBy(x => x.Fecha)
        .ThenBy(x => x.HoraInicio)
        .ToList();

    var slotsTarde = slots
        .Where(x => x.HoraInicio >= new TimeSpan(12, 0, 0))
        .OrderBy(x => x.Fecha)
        .ThenBy(x => x.HoraInicio)
        .ToList();

    var totalFechas = fechas.Count;

    var totalHorariosDisponibles = slots.Count(x =>
        x.Disponible &&
        x.Fecha.Date >= ahora.Date &&
        x.Fecha.Date.Add(x.HoraInicio) > ahora);

    var totalHorarios = slots.Count;
}

@functions {
    private static string Hora(TimeSpan hora)
    {
        return hora.ToString(@"hh\:mm");
    }

    private static string Hora12(TimeSpan hora)
    {
        var date = DateTime.Today.Add(hora);
        return date.ToString("hh:mm", System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string Meridiano(TimeSpan hora)
    {
        return hora.Hours < 12 ? "AM" : "PM";
    }

    private static string FechaIso(DateTime fecha)
    {
        return fecha.ToString("yyyy-MM-dd");
    }

    private static string FechaLarga(DateTime fecha)
    {
        return fecha.ToString("dddd, dd 'de' MMMM 'de' yyyy", CultureInfo.GetCultureInfo("es-MX"));
    }

    private static string FechaCorta(DateTime fecha)
    {
        return fecha.ToString("dd MMM", CultureInfo.GetCultureInfo("es-MX"));
    }

    private static string DiaCorto(DateTime fecha)
    {
        return fecha.ToString("ddd", CultureInfo.GetCultureInfo("es-MX")).ToUpperInvariant();
    }

    private static string RangoHora(TimeSpan inicio, TimeSpan fin)
    {
        return $"{Hora(inicio)} - {Hora(fin)}";
    }

    private static bool SlotEstaBloqueado(SlotDisponibleVm slot, DateTime ahora)
    {
        var fechaHoraInicio = slot.Fecha.Date.Add(slot.HoraInicio);

        return !slot.Disponible || fechaHoraInicio <= ahora;
    }

    private static string MotivoBloqueoSlot(SlotDisponibleVm slot, DateTime ahora)
    {
        var fechaHoraInicio = slot.Fecha.Date.Add(slot.HoraInicio);

        if (fechaHoraInicio <= ahora)
            return "Horario vencido";

        if (!slot.Disponible)
            return "Horario ocupado";

        return "Disponible";
    }
}

<style>
