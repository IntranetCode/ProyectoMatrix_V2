@model ProyectoMatrix.Models.OrganigramaEditorVm

@{
    ViewData["Title"] = "Nuevo Organigrama";
    Layout = "_LayoutComunicados";
}

<link rel="stylesheet" href="~/css/organigramas.css" asp-append-version="true" />

<div class="organigrama-form-page">
    <div class="org-shell">

        <section class="org-hero">
            <div class="org-hero-content">
                <div class="org-hero-left">
                    <div class="org-icon-box">
                        <i class="fa-solid fa-sitemap fa-xl"></i>
                    </div>

                    <div>
                        <h1 class="org-hero-title">Nuevo Organigrama</h1>
                        <p class="org-hero-text">
                            Sube un archivo y define qué empresas podrán consultarlo.
                        </p>
                    </div>
                </div>

                <a asp-action="Index"
                   asp-controller="Organigramas"
                   class="btn org-main-btn">
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Regresar
                </a>
            </div>
        </section>

        <form asp-action="Crear"
              asp-controller="Organigramas"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0"></div>

            <div class="org-form-grid">

                <section class="org-form-panel">
                    <div class="org-form-panel-header">
                        <div class="org-panel-heading">
                            <span class="org-panel-icon">
                                <i class="fa-solid fa-file-lines"></i>
                            </span>

                            <div>
                                <div class="org-panel-eyebrow">Captura principal</div>
                                <h2 class="org-panel-title">Información del organigrama</h2>
                                <p class="org-panel-subtitle">
                                    Estos datos serán visibles para los usuarios finales.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="org-form-panel-body">

                        <div class="org-field">
                            <label asp-for="Titulo" class="org-label">
                                Título
                            </label>

                            <input asp-for="Titulo"
                                   class="form-control form-control-lg"
                                   placeholder="Ej. Organigrama FORT + Equipo" />

                            <span asp-validation-for="Titulo" class="text-danger small"></span>
                        </div>

                        <div class="org-field">
                            <label asp-for="Descripcion" class="org-label">
                                Descripción
                            </label>

                            <textarea asp-for="Descripcion"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Descripción opcional del organigrama"></textarea>

                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="org-field">
                            <label asp-for="Archivo" class="org-label">
                                Archivo
                            </label>

                            <div class="org-upload-box">
                                <div class="org-upload-content">
                                    <span class="org-upload-icon">
                                        <i class="fa-solid fa-cloud-arrow-up"></i>
                                    </span>

                                    <div class="flex-grow-1">
                                        <input asp-for="Archivo"
                                               type="file"
                                               class="form-control"
                                               accept=".pdf,.png,.jpg,.jpeg" />

                                        <div class="form-text mt-2">
                                            Formatos permitidos: PDF, PNG, JPG, JPEG. Tamaño máximo: 20 MB.
                                        </div>

                                        <span asp-validation-for="Archivo" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </section>

                <aside>
                    <section class="org-side-panel mb-3">
                        <div class="org-side-panel-header dark">
                            <div class="org-panel-heading">
                                <span class="org-panel-icon">
                                    <i class="fa-solid fa-building"></i>
                                </span>

                                <div>
                                    <div class="org-panel-eyebrow">Control de acceso</div>
                                    <h2 class="org-panel-title">Empresas asignadas</h2>
                                    <p class="org-panel-subtitle">
                                        Selecciona quién podrá ver este archivo.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="org-side-panel-body">
                            <span asp-validation-for="EmpresasSeleccionadas"
                                  class="text-danger small d-block mb-2"></span>

                            @if (Model.Empresas != null && Model.Empresas.Any())
                            {
                                <div class="empresa-check-list">
                                    @foreach (var empresa in Model.Empresas)
                                    {
                                        var empresaId = Convert.ToInt32(empresa.Value);
                                        var estaSeleccionada = Model.EmpresasSeleccionadas.Contains(empresaId);

                                        <label class="empresa-check-item">
                                            @if (estaSeleccionada)
                                            {
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="EmpresasSeleccionadas"
                                                       value="@empresa.Value"
                                                       checked />
                                            }
                                            else
                                            {
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="EmpresasSeleccionadas"
                                                       value="@empresa.Value" />
                                            }

                                            <span class="empresa-check-text">
                                                @empresa.Text
                                            </span>
                                        </label>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning mb-0">
                                    No hay empresas activas disponibles.
                                </div>
                            }
                        </div>
                    </section>

                    <section class="org-help-card">
                        <h3 class="org-help-title">
                            <i class="fa-solid fa-circle-info text-warning"></i>
                            Recomendación
                        </h3>

                        <p class="org-help-text">
                            Para organigramas compartidos, selecciona todas las empresas que cohabitan bajo el mismo esquema.
                        </p>
                    </section>
                </aside>

            </div>

            <div class="org-form-actions">
                <a asp-action="Index"
                   asp-controller="Organigramas"
                   class="org-secondary-btn">
                    Cancelar
                </a>

                <button type="submit" class="btn org-main-btn">
                    <i class="fa-solid fa-save me-2"></i>
                    Guardar Organigrama
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}