@model ProyectoMatrix.Models.OrganigramasIndexVm

@{
    ViewData["Title"] = "Organigramas";
    Layout = "_LayoutComunicados";
}

<link rel="stylesheet" href="~/css/organigramas.css" asp-append-version="true" />

<div class="organigramas-page">
    <div class="org-shell">

        <section class="org-hero">
            <div class="org-hero-content">
                <div class="org-hero-left">
                    <div class="org-icon-box">
                        <i class="fa-solid fa-sitemap fa-xl"></i>
                    </div>

                    <div>
                        <h1 class="org-hero-title">Organigramas</h1>
                        <p class="org-hero-text">
                            Consulta los organigramas disponibles para tu empresa.
                        </p>
                    </div>
                </div>

                @if (Model.PuedeCrear)
                {
                    <a asp-action="Crear"
                       asp-controller="Organigramas"
                       class="btn org-main-btn">
                        <i class="fa-solid fa-plus me-2"></i>
                        Nuevo Organigrama
                    </a>
                }
            </div>
        </section>

        @if (TempData["Ok"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i>
                @TempData["Ok"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.AlertaSistema))
        {
            <div class="alert alert-warning shadow-sm border-0">
                <i class="fa-solid fa-circle-info me-2"></i>
                @Model.AlertaSistema
            </div>
        }

        @if (Model.EsEditor)
        {
            <div class="org-kpi-row">
                <div class="org-kpi-card">
                    <div>
                        <div class="org-kpi-label">Disponibles</div>
                        <div class="org-kpi-value">@(Model.Organigramas?.Count ?? 0)</div>
                    </div>

                    <div class="org-kpi-icon">
                        <i class="fa-solid fa-folder-open"></i>
                    </div>
                </div>

                <div class="org-kpi-card editor">
                    <div>
                        <div class="org-kpi-label">Perfil</div>
                        <div class="org-kpi-text">Modo editor</div>
                    </div>

                    <span class="org-editor-pill">Override activo</span>
                </div>

                <div class="org-kpi-card files">
                    <div>
                        <div class="org-kpi-label">Formatos permitidos</div>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="org-badge">PDF</span>
                            <span class="org-badge">PNG</span>
                            <span class="org-badge">JPG</span>
                            <span class="org-badge">JPEG</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.Organigramas == null || !Model.Organigramas.Any())
        {
            <div class="org-board">
                <div class="org-empty">
                    <div class="org-empty-icon">
                        <i class="fa-solid fa-sitemap fa-3x"></i>
                    </div>

                    <h5 class="org-empty-title">No hay organigramas disponibles</h5>

                    <p class="org-empty-text">
                        Aún no existen organigramas asignados para tu empresa.
                    </p>

                    @if (Model.PuedeCrear)
                    {
                        <div class="mt-4">
                            <a asp-action="Crear"
                               asp-controller="Organigramas"
                               class="btn org-main-btn">
                                <i class="fa-solid fa-plus me-2"></i>
                                Crear primer organigrama
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
        else if (!Model.EsEditor)
        {
            <div class="org-user-grid">
                @foreach (var item in Model.Organigramas)
                {
                    var extension = item.Extension?.ToLowerInvariant() ?? "";
                    var viewerUrl = Url.Action("Visor", "Organigramas", new { id = item.OrganigramaID }) ?? "#";

                    <article class="org-doc-card">
                        <div class="org-doc-preview">
                            <div class="org-doc-preview-fallback">
                                @if (item.EsPdf)
                                {
                                    <i class="fa-solid fa-file-pdf text-danger"></i>
                                }
                                else if (item.EsImagen)
                                {
                                    <i class="fa-solid fa-file-image text-primary"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-file text-muted"></i>
                                }
                            </div>
                        </div>

                        <div class="org-doc-body">
                            <h3 class="org-doc-title">@item.Titulo</h3>

                            @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                            {
                                <p class="org-doc-desc">@item.Descripcion</p>
                            }
                            else
                            {
                                <p class="org-doc-desc">
                                    Organigrama disponible para consulta.
                                </p>
                            }

                            <div class="org-doc-meta">
                                @if (item.EsPdf)
                                {
                                    <span class="org-badge org-badge-pdf">@extension</span>
                                }
                                else if (item.EsImagen)
                                {
                                    <span class="org-badge org-badge-img">@extension</span>
                                }
                                else
                                {
                                    <span class="org-badge">@extension</span>
                                }

                                <span class="org-doc-company">
                                    @item.FechaCreacion.ToString("dd/MM/yyyy")
                                </span>
                            </div>

                            <button type="button"
                                    class="org-doc-action btn-ver-organigrama"
                                    data-viewer-url="@viewerUrl"
                                    data-titulo="@item.Titulo">
                                <i class="fa-solid fa-eye"></i>
                                <span>Ver organigrama</span>
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="org-board">
                <div class="org-board-header">
                    <div class="org-board-title-wrap">
                        <span class="org-board-icon">
                            <i class="fa-solid fa-diagram-project"></i>
                        </span>

                        <div>
                            <div class="org-board-eyebrow">Directorio corporativo</div>
                            <h2 class="org-board-title">Listado de organigramas</h2>
                            <p class="org-board-subtitle">
                                Archivos asignados por empresa.
                            </p>
                        </div>
                    </div>

                    <span class="org-editor-pill">
                        <i class="fa-solid fa-user-gear me-1"></i>
                        Modo editor
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table org-table align-middle">
                        <thead>
                            <tr>
                                <th>Organigrama</th>
                                <th>Formato</th>
                                <th>Empresas asignadas</th>
                                <th>Fecha de carga</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Organigramas)
                            {
                                var extension = item.Extension?.ToLowerInvariant() ?? "";
                                var viewerUrl = Url.Action("Visor", "Organigramas", new { id = item.OrganigramaID }) ?? "#";

                                <tr>
                                    <td>
                                        <div class="org-file-cell">
                                            <div class="org-file-icon">
                                                @if (item.EsPdf)
                                                {
                                                    <i class="fa-solid fa-file-pdf fa-xl text-danger"></i>
                                                }
                                                else if (item.EsImagen)
                                                {
                                                    <i class="fa-solid fa-file-image fa-xl text-primary"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-file fa-xl text-muted"></i>
                                                }
                                            </div>

                                            <div>
                                                <div class="org-file-title">@item.Titulo</div>

                                                @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                                {
                                                    <div class="org-file-desc">@item.Descripcion</div>
                                                }
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        @if (item.EsPdf)
                                        {
                                            <span class="org-badge org-badge-pdf">@extension</span>
                                        }
                                        else if (item.EsImagen)
                                        {
                                            <span class="org-badge org-badge-img">@extension</span>
                                        }
                                        else
                                        {
                                            <span class="org-badge">@extension</span>
                                        }
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.EmpresasAsignadas))
                                        {
                                            <span class="org-company-text">@item.EmpresasAsignadas</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin empresas asignadas</span>
                                        }
                                    </td>

                                    <td>
                                        <span class="text-muted">
                                            @item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <div class="org-actions">
                                            <button type="button"
                                                    class="btn-ver-organigrama"
                                                    data-viewer-url="@viewerUrl"
                                                    data-titulo="@item.Titulo"
                                                    title="Ver organigrama">
                                                <i class="fa-solid fa-eye"></i>
                                                <span>Ver</span>
                                            </button>

                                            @if (Model.PuedeEditar)
                                            {
                                                <a asp-action="Editar"
                                                   asp-controller="Organigramas"
                                                   asp-route-id="@item.OrganigramaID"
                                                   class="btn btn-outline-primary"
                                                   title="Editar organigrama">
                                                    <i class="fa-solid fa-pen"></i>
                                                    <span>Editar</span>
                                                </a>
                                            }

                                            @if (Model.PuedeEliminar)
                                            {
                                                <form asp-action="Eliminar"
                                                      asp-controller="Organigramas"
                                                      asp-route-id="@item.OrganigramaID"
                                                      method="post"
                                                      onsubmit="return confirm('¿Seguro que deseas eliminar este organigrama?');">

                                                    @Html.AntiForgeryToken()

                                                    <button type="submit"
                                                            class="btn btn-outline-danger"
                                                            title="Eliminar organigrama">
                                                        <i class="fa-solid fa-trash-alt"></i>
                                                        <span>Eliminar</span>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="table-footer-line">
                    <span>
                        Mostrando @Model.Organigramas.Count registro@(Model.Organigramas.Count == 1 ? "" : "s")
                    </span>

                    <span class="table-pager">
                        <i class="fa-solid fa-angle-left"></i>
                        <i class="fa-solid fa-angle-right"></i>
                    </span>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade org-modal"
     id="modalOrganigrama"
     tabindex="-1"
     aria-labelledby="modalOrganigramaLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="modalOrganigramaLabel">
                    Vista de organigrama
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar"></button>
            </div>

            <div class="modal-body">
                <div id="visorPlaceholder" class="org-viewer-placeholder">
                    <div class="org-viewer-icon">
                        <i class="fa-solid fa-file-lines"></i>
                    </div>

                    <h5 class="org-viewer-title">
                        Vista previa no cargada
                    </h5>

                    <p class="org-viewer-text">
                        Para mejorar el rendimiento, el visor se cargará solo cuando lo solicites.
                    </p>

                    <button type="button"
                            id="btnCargarVistaPrevia"
                            class="btn org-main-btn">
                        <i class="fa-solid fa-play me-2"></i>
                        Cargar visor
                    </button>
                </div>

                <iframe id="iframeViewerOrganigrama"
                        src=""
                        class="org-iframe d-none"
                        title="Visor de organigrama">
                </iframe>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="org-close-btn"
                        data-bs-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const modalElement = document.getElementById('modalOrganigrama');
        const iframeViewer = document.getElementById('iframeViewerOrganigrama');
        const tituloModal = document.getElementById('modalOrganigramaLabel');
        const placeholder = document.getElementById('visorPlaceholder');
        const btnCargar = document.getElementById('btnCargarVistaPrevia');

        let modalInstance = null;
        let viewerUrlActual = '';

        if (window.bootstrap && bootstrap.Modal) {
            modalInstance = new bootstrap.Modal(modalElement);
        }

        document.querySelectorAll('.btn-ver-organigrama').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const viewerUrl = this.getAttribute('data-viewer-url');
                const titulo = this.getAttribute('data-titulo') || 'Vista de organigrama';

                viewerUrlActual = viewerUrl || '';
                tituloModal.textContent = titulo;

                iframeViewer.src = '';
                iframeViewer.classList.add('d-none');
                placeholder.classList.remove('d-none');

                if (modalInstance) {
                    modalInstance.show();
                } else if (window.jQuery) {
                    $('#modalOrganigrama').modal('show');
                }
            });
        });

        btnCargar.addEventListener('click', function () {
            if (!viewerUrlActual) {
                return;
            }

            placeholder.classList.add('d-none');
            iframeViewer.classList.remove('d-none');
            iframeViewer.src = viewerUrlActual;
        });

        modalElement.addEventListener('hidden.bs.modal', function () {
            iframeViewer.src = '';
            iframeViewer.classList.add('d-none');
            placeholder.classList.remove('d-none');
            tituloModal.textContent = 'Vista de organigrama';
            viewerUrlActual = '';
        });

        if (window.jQuery) {
            $('#modalOrganigrama').on('hidden.bs.modal', function () {
                iframeViewer.src = '';
                iframeViewer.classList.add('d-none');
                placeholder.classList.remove('d-none');
                tituloModal.textContent = 'Vista de organigrama';
                viewerUrlActual = '';
            });
        }
    });
</script>