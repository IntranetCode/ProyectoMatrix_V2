@model ProyectoMatrix.Models.ModelUsuarios.CambioPasswordInicialViewModel

@{
    Layout = "_LayoutComunicados";
    ViewData["Title"] = "Cambiar contraseña";
}

<style>
    :root {
        --ns-primary: #1a237e;
        --ns-primary-dark: #0d47a1;
        --ns-primary-soft: #eef2ff;
        --ns-accent: #ff6d00;
        --ns-bg: #f4f6fb;
        --ns-card: #ffffff;
        --ns-border: #e5e7eb;
        --ns-text: #1f2937;
        --ns-muted: #6b7280;
    }

    body {
        background: var(--ns-bg);
    }

    .password-page {
        min-height: calc(100dvh - 72px);
        display: flex;
        align-items: center;
        padding: clamp(1rem, 3vw, 2.5rem);
        background:
            radial-gradient(circle at top left, rgba(26, 35, 126, .10), transparent 34%),
            radial-gradient(circle at bottom right, rgba(255, 109, 0, .10), transparent 34%),
            var(--ns-bg);
    }

    .password-shell {
        width: min(100%, 920px);
        margin: 0 auto;
    }

    .password-card {
        width: 100%;
        border: 0;
        border-radius: 24px;
        overflow: hidden;
        background: var(--ns-card);
        box-shadow: 0 20px 45px rgba(15, 23, 42, .13);
    }

    .password-grid {
        display: grid;
        grid-template-columns: minmax(280px, 38%) 1fr;
        min-height: 520px;
    }

    .password-side {
        position: relative;
        color: #ffffff;
        padding: clamp(1.35rem, 3vw, 2rem);
        background: linear-gradient(135deg, var(--ns-primary) 0%, var(--ns-primary-dark) 100%);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 1.5rem;
    }

    .password-side::before,
    .password-side::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, .12);
        pointer-events: none;
    }

    .password-side::before {
        width: 210px;
        height: 210px;
        top: -90px;
        right: -95px;
    }

    .password-side::after {
        width: 150px;
        height: 150px;
        bottom: -70px;
        left: -70px;
    }

    .password-side-content {
        position: relative;
        z-index: 1;
    }

    .password-icon-box {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        background: rgba(255, 255, 255, .16);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.45rem;
        margin-bottom: 1rem;
    }

    .password-title {
        margin: 0;
        font-weight: 850;
        font-size: clamp(1.25rem, 2.2vw, 1.65rem);
        line-height: 1.2;
    }

    .password-subtitle {
        margin: .65rem 0 0;
        color: rgba(255, 255, 255, .86);
        font-size: .96rem;
        line-height: 1.55;
    }

    .password-side-note {
        position: relative;
        z-index: 1;
        background: rgba(255, 255, 255, .12);
        border: 1px solid rgba(255, 255, 255, .18);
        border-radius: 18px;
        padding: 1rem;
        font-size: .9rem;
        color: rgba(255, 255, 255, .9);
    }

    .password-form-area {
        padding: clamp(1.25rem, 3vw, 2rem);
        display: flex;
        align-items: center;
    }

    .password-form-inner {
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
    }

    .security-alert {
        border: 1px solid rgba(13, 110, 253, .15);
        background: #eaf7ff;
        color: #075985;
        border-radius: 16px;
        padding: .95rem 1rem;
        display: flex;
        gap: .75rem;
        align-items: flex-start;
        margin-bottom: 1rem;
        font-size: .94rem;
    }

    .security-alert i {
        font-size: 1.15rem;
        margin-top: .12rem;
    }

    .password-rules {
        background: #f8fafc;
        border: 1px solid var(--ns-border);
        border-radius: 16px;
        padding: .95rem 1rem;
        margin-bottom: 1.15rem;
    }

    .password-rules-title {
        font-weight: 800;
        color: var(--ns-text);
        margin-bottom: .55rem;
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .password-rules-list {
        list-style: none;
        padding-left: 0;
        margin-bottom: 0;
        display: grid;
        gap: .35rem;
    }

    .password-rules-list li {
        color: var(--ns-muted);
        font-size: .88rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .password-rules-list li i {
        color: #16a34a;
        font-size: .8rem;
    }

    .form-label-modern {
        font-weight: 750;
        color: var(--ns-text);
        margin-bottom: .4rem;
    }

    .password-input-group {
        border: 1px solid var(--ns-border);
        border-radius: 15px;
        overflow: hidden;
        background: #ffffff;
        transition: border-color .2s ease, box-shadow .2s ease;
    }

    .password-input-group:focus-within {
        border-color: var(--ns-accent);
        box-shadow: 0 0 0 .22rem rgba(255, 109, 0, .16);
    }

    .password-input-icon {
        width: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ns-muted);
        background: #ffffff;
    }

    .password-input {
        border: 0 !important;
        box-shadow: none !important;
        padding: .78rem .45rem;
        background: #ffffff;
        min-width: 0;
    }

    .password-input:focus {
        border: 0 !important;
        box-shadow: none !important;
    }

    .password-toggle-btn {
        border: 0;
        border-left: 1px solid var(--ns-border);
        width: 48px;
        background: #f8fafc;
        color: var(--ns-primary);
        transition: background .2s ease, color .2s ease;
        flex: 0 0 48px;
    }

    .password-toggle-btn:hover {
        background: var(--ns-primary-soft);
        color: var(--ns-primary-dark);
    }

    .pm-secret-masked {
        -webkit-text-security: disc;
        text-security: disc;
    }

    .pm-secret-unmasked {
        -webkit-text-security: none;
        text-security: none;
    }

    .password-help {
        color: var(--ns-muted);
        font-size: .84rem;
        margin-top: .35rem;
    }

    .btn-password-submit {
        border: 0;
        border-radius: 15px;
        padding: .86rem 1rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--ns-primary) 0%, var(--ns-primary-dark) 100%);
        box-shadow: 0 10px 22px rgba(26, 35, 126, .25);
    }

    .btn-password-submit:hover {
        filter: brightness(1.06);
        transform: translateY(-1px);
    }

    .password-footer-note {
        text-align: center;
        color: var(--ns-muted);
        font-size: .84rem;
        margin-top: .9rem;
    }

    .validation-summary-errors {
        border: 1px solid rgba(220, 53, 69, .25);
        background: rgba(220, 53, 69, .08);
        border-radius: 14px;
        padding: .85rem 1rem;
        margin-bottom: 1rem;
    }

    .validation-summary-errors ul {
        margin-bottom: 0;
        padding-left: 1.15rem;
    }

    input::-ms-reveal,
    input::-ms-clear {
        display: none !important;
    }

    input::-webkit-credentials-auto-fill-button,
    input::-webkit-caps-lock-indicator {
        visibility: hidden !important;
        display: none !important;
        pointer-events: none !important;
    }

    @@media (max-width: 991.98px) {
        .password-page {
            align-items: flex-start;
            padding-top: 1.25rem;
            padding-bottom: 1.25rem;
        }

        .password-shell {
            width: min(100%, 560px);
        }

        .password-grid {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .password-side {
            padding: 1.35rem;
            gap: 1rem;
        }

        .password-icon-box {
            width: 48px;
            height: 48px;
            border-radius: 15px;
            font-size: 1.25rem;
            margin-bottom: .8rem;
        }

        .password-side-note {
            display: none;
        }

        .password-form-area {
            padding: 1.35rem;
        }
    }

    @@media (max-width: 575.98px) {
        .password-page {
            min-height: auto;
            padding: .85rem;
        }

        .password-card {
            border-radius: 18px;
        }

        .password-side {
            border-radius: 0;
        }

        .password-subtitle {
            font-size: .9rem;
        }

        .password-form-area {
            padding: 1rem;
        }

        .security-alert,
        .password-rules {
            padding: .85rem;
            border-radius: 14px;
        }

        .password-rules-list {
            gap: .3rem;
        }

        .password-input-icon {
            width: 40px;
        }

        .password-toggle-btn {
            width: 44px;
            flex-basis: 44px;
        }

        .password-footer-note {
            font-size: .78rem;
        }
    }

    @@media (max-height: 760px) and (min-width: 992px) {
        .password-page {
            align-items: flex-start;
            padding-top: 1.25rem;
            padding-bottom: 1.25rem;
        }

        .password-grid {
            min-height: auto;
        }

        .password-side,
        .password-form-area {
            padding: 1.25rem;
        }

        .password-rules {
            padding: .8rem .9rem;
            margin-bottom: .9rem;
        }

        .security-alert {
            padding: .8rem .9rem;
            margin-bottom: .9rem;
        }

        .mb-4 {
            margin-bottom: 1rem !important;
        }
    }
</style>

<div class="password-page">
    <div class="password-shell">
        <div class="card password-card">
            <div class="password-grid">
                <aside class="password-side">
                    <div class="password-side-content">
                        <div class="password-icon-box">
                            <i class="fas fa-lock"></i>
                        </div>

                        <h4 class="password-title">Cambio obligatorio de contraseña</h4>

                        <p class="password-subtitle">
                            Actualiza tu contraseña inicial para continuar usando la intranet de forma segura.
                        </p>
                    </div>

                    <div class="password-side-note">
                        <i class="fas fa-shield-alt me-2"></i>
                        Este paso protege tu cuenta y evita que sigas usando una contraseña temporal.
                    </div>
                </aside>

                <main class="password-form-area">
                    <div class="password-form-inner">
                        @if (TempData["InfoMessage"] != null)
                        {
                            <div class="security-alert">
                                <i class="fas fa-info-circle"></i>
                                <div>@TempData["InfoMessage"]</div>
                            </div>
                        }
                        else
                        {
                            <div class="security-alert">
                                <i class="fas fa-shield-alt"></i>
                                <div>
                                    Por seguridad, antes de entrar a la intranet debes cambiar la contraseña temporal que recibiste.
                                </div>
                            </div>
                        }

                        <div class="password-rules">
                            <div class="password-rules-title">
                                <i class="fas fa-check-circle text-success"></i>
                                Recomendaciones
                            </div>

                            <ul class="password-rules-list">
                                <li>
                                    <i class="fas fa-circle-check"></i>
                                    Usa mínimo 6 caracteres.
                                </li>
                                <li>
                                    <i class="fas fa-circle-check"></i>
                                    Evita usar tu nombre o usuario.
                                </li>
                                <li>
                                    <i class="fas fa-circle-check"></i>
                                    Combina letras, números y símbolos.
                                </li>
                            </ul>
                        </div>

                        <form asp-action="CambiarPasswordInicial"
                              asp-controller="CuentaPassword"
                              method="post"
                              id="formCambioPasswordInicial">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="UsuarioID" />

                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="NuevaPassword" class="form-label-modern"></label>

                                <div class="input-group password-input-group">
                                    <span class="password-input-icon">
                                        <i class="fas fa-key"></i>
                                    </span>

                                    <input asp-for="NuevaPassword"
                                           type="text"
                                           class="form-control password-input pm-secret-masked"
                                           id="NuevaPassword"
                                           autocomplete="off"
                                           spellcheck="false" />

                                    <button class="password-toggle-btn"
                                            type="button"
                                            data-toggle-password="NuevaPassword"
                                            aria-label="Ver u ocultar contraseña">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>

                                <div class="password-help">
                                    Esta será tu nueva contraseña para ingresar a la intranet.
                                </div>

                                <span asp-validation-for="NuevaPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ConfirmarPassword" class="form-label-modern"></label>

                                <div class="input-group password-input-group">
                                    <span class="password-input-icon">
                                        <i class="fas fa-lock"></i>
                                    </span>

                                    <input asp-for="ConfirmarPassword"
                                           type="text"
                                           class="form-control password-input pm-secret-masked"
                                           id="ConfirmarPassword"
                                           autocomplete="off"
                                           spellcheck="false" />

                                    <button class="password-toggle-btn"
                                            type="button"
                                            data-toggle-password="ConfirmarPassword"
                                            aria-label="Ver u ocultar confirmación">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>

                                <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-primary btn-password-submit w-100">
                                <i class="fas fa-save me-2"></i>Actualizar contraseña
                            </button>
                        </form>

                        <div class="password-footer-note">
                            Después de actualizarla, vuelve a iniciar sesión con tu nueva contraseña.
                        </div>
                    </div>
                </main>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('click', function (event) {
            const button = event.target.closest('[data-toggle-password]');
            if (!button) return;

            const inputId = button.getAttribute('data-toggle-password');
            const input = document.getElementById(inputId);
            const icon = button.querySelector('i');

            if (!input) return;

            const mostrar = input.classList.contains('pm-secret-masked');

            input.classList.toggle('pm-secret-masked', !mostrar);
            input.classList.toggle('pm-secret-unmasked', mostrar);

            if (icon) {
                icon.classList.toggle('fa-eye', !mostrar);
                icon.classList.toggle('fa-eye-slash', mostrar);
            }
        });

        document.getElementById('formCambioPasswordInicial')?.addEventListener('submit', function () {
            const submitBtn = this.querySelector('button[type="submit"]');

            if (!submitBtn) return;

            setTimeout(function () {
                if (typeof window.jQuery !== 'undefined' && !$('#formCambioPasswordInicial').valid()) {
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Actualizando...';
            }, 0);
        });
    </script>
}