@model ProyectoMatrix.Models.DetalleCompraVm

@{
    ViewData["Title"] = "Detalle de Solicitud";
    Layout = "_LayoutComunicados";

    bool esRechazada = Model.EstatusID == 9;
    bool rechazadaCxP = Model.EstatusID == 11;
    bool cerradaAdministrativamente = Model.EstatusID == 10;
    bool pendienteCxP = Model.EstatusID == 8;

    bool puedeRegistrarOC = Model.EsCompras   && Model.EstatusID == 4    && Model.CotizacionSeleccionadaID.HasValue    && !Model.TieneOC    && !esRechazada;
    bool puedeEnviarProveedor =   Model.EsCompras    && Model.EstatusID == 4    && Model.TieneOC    && !Model.OCEnviadaProveedor    && !esRechazada;
  
    bool puedeEntregarUsuario =    Model.EsCompras    && Model.EstatusID == 6    && Model.RecibidaEnAlmacen    && !Model.EntregadaUsuario    && !esRechazada;

    string badgeEstatus = Model.EstatusID switch
    {
        1 => "badge-secondary",
        2 => "badge-info",
        3 => "badge-warning",
        4 => "badge-primary",
        5 => "badge-primary",
        6 => "badge-info",
        7 => "badge-info",
        8 => "badge-warning",
        9 => "badge-danger",
        10 => "badge-success",
        11 => "badge-danger",
        _ => "badge-secondary"
    };

}

@{
    string returnUrl = Context.Request.Query["returnUrl"].ToString();

    if (string.IsNullOrWhiteSpace(returnUrl))
    {
        returnUrl = Url.Action("Index", "Compras");
    }
}

<div class="container-fluid">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensaje"]
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-body py-2">
            <div class="row no-gutters align-items-center">
                <div class="col mr-2">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Progreso del Proceso</div>
                    <div class="progress progress-sm mr-2">
                        <div class="progress-bar @Model.ColorProgreso" role="progressbar"
                             style="width: @Model.Porcentaje%"
                             aria-valuenow="@Model.Porcentaje"
                             aria-valuemin="0"
                             aria-valuemax="100">
                         </div>
                </div>
                <div class="col-auto">
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Porcentaje%</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="@returnUrl" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i> Volver
            </a>
    </div>

    <div class="row">
        <div class="col-lg-7">

            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">Folio: @Model.Folio</h6>
                        <span class="badge @badgeEstatus">
                        <i class="fas fa-info-circle mr-1"></i> @Model.EstatusActual
                    </span>
                </div>

                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6 border-left-primary">
                            <label class="small font-weight-bold text-primary uppercase">Solicitante</label>
                            <p class="h6 font-weight-bold text-gray-800">@Model.NombreSolicitante</p>
                        </div>
                        <div class="col-md-6 border-left-info">
                            <label class="small font-weight-bold text-info uppercase">Empresa</label>
                            <p class="h6 font-weight-bold text-gray-800">@Model.Empresa</p>
                        </div>
                    </div>

                        @if (!string.IsNullOrEmpty(Model.ArchivoReferenciaPath))
                        {
                            bool esImagenReferencia =
                            Model.ArchivoReferenciaPath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                            Model.ArchivoReferenciaPath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
                            Model.ArchivoReferenciaPath.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                            Model.ArchivoReferenciaPath.EndsWith(".webp", StringComparison.OrdinalIgnoreCase);

                            <div class="card border-left-info mb-4">
                                <div class="card-header py-2">
                                    <h6 class="m-0 font-weight-bold text-info">
                                        <i class="fas fa-paperclip mr-2"></i>
                                        Archivo de Referencia
                                    </h6>
                                </div>

                                <div class="card-body">

                                    @if (esImagenReferencia)
                                    {
                                        <div class="text-center">
                                            <img src="@Url.Action("VerPdfNas", new { ruta = Model.ArchivoReferenciaPath })"
                                                 class="img-fluid rounded border"
                                                 style="max-height:350px;" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="border rounded bg-light"
                                             style="height:400px; overflow:hidden;">

                                            <iframe src="@Url.Action("VerPdfNas", new { ruta = Model.ArchivoReferenciaPath })#toolbar=0"
                                                    width="100%"
                                                    height="100%"
                                                    style="border:none;">
                                            </iframe>
                                        </div>
                                    }

                                    <button type="button"
                                            class="btn btn-outline-primary btn-sm btn-block mt-3 btn-ver-archivo"
                                            data-ruta="@Model.ArchivoReferenciaPath"
                                            data-titulo="Archivo de referencia">
                                        <i class="fas fa-eye mr-1"></i>
                                        Ver archivo completo
                                    </button>

                                </div>
                            </div>
                        }


                    <h6 class="font-weight-bold mt-4 text-gray-800">
                        <i class="fas fa-list mr-2"></i>Artículos Requeridos
                    </h6>

                    <div class="table-responsive">
                        <table class="table table-bordered table-sm" width="100%">
                            <thead class="bg-gray-100 italic">
                                <tr>
                                    <th>Descripción</th>
                                    <th class="text-center" style="width: 15%">Cant.</th>
                                    <th class="text-center" style="width: 20%">U.M.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mat in Model.Materiales)
                                {
                                    <tr>
                                        <td>@mat.Nombre</td>
                                        <td class="text-center">@mat.Cantidad</td>
                                        <td class="text-center">@mat.UnidadMedida</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

                @if (
                                (Model.EstatusID >= 4 || Model.EstatusID == 9)
                                && !string.IsNullOrWhiteSpace(Model.TipoGasto)
                                && Model.DentroPresupuesto.HasValue
                                )
            {
                <div class="card shadow mb-4 border-left-info">
                    <div class="card-header py-3 bg-info text-white">
                        <h6 class="m-0 font-weight-bold text-white">
                            <i class="fas fa-gavel mr-2"></i>Veredicto Presupuestal
                        </h6>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 text-center border-right">
                                <label class="small font-weight-bold text-muted uppercase d-block">Proceso</label>
                                <span class="badge badge-pill badge-primary px-3">@Model.TipoGasto</span>
                            </div>

                            <div class="col-md-4 text-center border-right">
                                <label class="small font-weight-bold text-muted uppercase d-block">Presupuesto</label>
                                @if (Model.DentroPresupuesto == true)
                                {
                                    <span class="text-success font-weight-bold">
                                        <i class="fas fa-check-circle"></i> Liberado
                                    </span>
                                }
                                else if (Model.DentroPresupuesto == false)
                                {
                                    <span class="text-warning font-weight-bold">
                                        <i class="fas fa-exclamation-triangle"></i> Desviación
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted font-weight-bold">
                                        Pendiente
                                    </span>
                                }
                            </div>

                            <div class="col-md-4 text-center">
                                <label class="small font-weight-bold text-muted uppercase d-block">ID Requisición</label>
                                <span class="h6 font-weight-bold text-dark">
                                    @(string.IsNullOrEmpty(Model.NumeroRequisicion) ? "N/A" : Model.NumeroRequisicion)
                                </span>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ObservacionesPresupuesto))
                        {
                            <div class="mt-3 p-2 bg-light border-left-info rounded text-sm">
                                <small class="font-weight-bold text-info">Notas de Finanzas:</small>
                                <p class="mb-0 italic">"@Model.ObservacionesPresupuesto"</p>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (esRechazada)
            {
                <div class="card shadow mb-4 border-left-danger">
                    <div class="card-body text-center">
                        <h5 class="text-danger font-weight-bold">
                            <i class="fas fa-ban mr-2"></i>SOLICITUD RECHAZADA
                        </h5>
                        <p class="text-muted italic mb-0">Motivo: @Model.ObservacionesPresupuesto</p>
                    </div>
                </div>
            }

            @if (Model.EsCompras && !esRechazada)
            {
                <div class="card shadow mb-4 border-left-primary">
                    <div class="card-header py-3 bg-info text-white">
                        <h6 class="m-0 font-weight-bold text-white">
                            <i class="fas fa-route mr-2"></i>Seguimiento Operativo de Compra
                        </h6>
                    </div>

                    <div class="card-body">

                        <div class="workflow-step @(Model.TieneOC ? "step-done" : puedeRegistrarOC ? "step-active" : "step-disabled")">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="font-weight-bold mb-0">
                                    <i class="fas fa-file-invoice mr-2"></i>1. Orden de Compra
                                </h6>
                                <span class="badge @(Model.TieneOC ? "badge-success" : puedeRegistrarOC ? "badge-warning" : "badge-secondary")">
                                    @(Model.TieneOC ? "Completado" : puedeRegistrarOC ? "Disponible" : "Bloqueado")
                                </span>
                            </div>

                            @if (Model.TieneOC)
                            {
                                <div class="alert alert-success mb-0">
                                    <strong>O.C. registrada:</strong> @Model.NumeroOC<br />
                                    <strong>Proveedor:</strong> @(string.IsNullOrEmpty(Model.ProveedorOC) ? "No capturado" : Model.ProveedorOC)<br />
                                    <strong>Fecha:</strong> @(Model.FechaOC.HasValue? Model.FechaOC.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")

                                    @if (!string.IsNullOrEmpty(Model.ComentariosOC))
                                    {
                                        <br />
                                        <strong>Comentarios:</strong>
 
                                        @Model.ComentariosOC
                                    }
                                </div>
                            }
                            else
                            {
                                <form asp-action="RegistrarOC" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="solicitudId" value="@Model.SolicitudID" />

                                    <div class="form-group">
                                        <label class="small font-weight-bold">Número de O.C.</label>
                                        <input type="text" name="numeroOC" class="form-control" required @(puedeRegistrarOC ? "" : "disabled") />
                                    </div>

                                    <div class="form-group">
                                        <label class="small font-weight-bold">Proveedor</label>
                                        <input type="text" name="proveedor" class="form-control" @(puedeRegistrarOC ? "" : "disabled") />
                                    </div>

                                    <div class="form-group">
                                        <label class="small font-weight-bold">Comentarios</label>
                                        <textarea name="comentarios" class="form-control" rows="2" @(puedeRegistrarOC ? "" : "disabled")></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-success btn-block shadow" @(puedeRegistrarOC ? "" : "disabled")>
                                        <i class="fas fa-save mr-2"></i>Registrar O.C.
                                    </button>

                                    @if (!puedeRegistrarOC)
                                    {
                                        <small class="text-muted d-block mt-2">
                                            Se habilitará cuando Control Presupuestal apruebe el gasto.
                                        </small>
                                    }
                                </form>
                            }
                        </div>

                        <hr />

                        <div class="workflow-step @(Model.OCEnviadaProveedor ? "step-done" : puedeEnviarProveedor ? "step-active" : "step-disabled")">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="font-weight-bold mb-0">
                                    <i class="fas fa-paper-plane mr-2"></i>2. Envío a Proveedor
                                </h6>
                                <span class="badge @(Model.OCEnviadaProveedor ? "badge-success" : puedeEnviarProveedor ? "badge-warning" : "badge-secondary")">
                                    @(Model.OCEnviadaProveedor ? "Completado" : puedeEnviarProveedor ? "Disponible" : "Bloqueado")
                                </span>
                            </div>

                            @if (Model.OCEnviadaProveedor)
                            {
                                <div class="alert alert-warning mb-0">
                                    <strong>O.C. enviada al proveedor</strong><br />
                                    <strong>Fecha envío:</strong> @Model.FechaEnvioProveedor?.ToString("dd/MM/yyyy HH:mm")<br />
                                    <strong>Entrega estimada:</strong> @Model.FechaEstimadaEntrega?.ToString("dd/MM/yyyy")
                                </div>
                            }
                            else
                            {
                                <form asp-action="EnviarOCProveedor" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="solicitudId" value="@Model.SolicitudID" />

                                    <div class="form-group">
                                        <label class="small font-weight-bold">Fecha estimada de entrega</label>
                                        <input type="date" name="fechaEstimadaEntrega" class="form-control" required @(puedeEnviarProveedor ? "" : "disabled") />
                                    </div>

                                    <div class="form-group">
                                        <label class="small font-weight-bold">Comentarios del envío</label>
                                        <textarea name="comentarios" class="form-control" rows="2" @(puedeEnviarProveedor ? "" : "disabled")></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-warning btn-block shadow" @(puedeEnviarProveedor ? "" : "disabled")>
                                        <i class="fas fa-paper-plane mr-2"></i>Registrar envío a proveedor
                                    </button>
                                </form>
                            }
                        </div>

                        <hr />

                            <hr />

                            <div class="workflow-step @(Model.RecibidaEnAlmacen ? "step-done" : "step-disabled")">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="font-weight-bold mb-0">
                                        <i class="fas fa-warehouse mr-2"></i>3. Recepción en Almacén
                                    </h6>

                                    <span class="badge @(Model.RecibidaEnAlmacen ? "badge-success" : "badge-secondary")">
                                        @(Model.RecibidaEnAlmacen ? "Completado" : "Pendiente en Almacén")
                                    </span>
                                </div>

                                @if (Model.RecibidaEnAlmacen)
                                {
                                    <div class="alert alert-info mb-0">
                                        <strong>Material recibido en almacén</strong><br />
                                        <strong>Fecha:</strong> @Model.FechaRecepcionAlmacen?.ToString("dd/MM/yyyy HH:mm")<br />
                                        <strong>Comentarios:</strong>
                                        @(string.IsNullOrWhiteSpace(Model.ComentariosRecepcionAlmacen)
                                                                        ? "Sin comentarios"
                                                                        : Model.ComentariosRecepcionAlmacen)
                            </div>
                                                        }
                                else
                                {
                                    <div class="alert alert-light border mb-0">
                                        La recepción se registra desde la Bandeja de Almacén.
                                    </div>
                                }
                            </div>

                        <hr />

                        <div class="workflow-step @(Model.EntregadaUsuario ? "step-done" : puedeEntregarUsuario ? "step-active" : "step-disabled")">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="font-weight-bold mb-0">
                                    <i class="fas fa-handshake mr-2"></i>4. Entrega a Usuario
                                </h6>
                                <span class="badge @(Model.EntregadaUsuario ? "badge-success" : puedeEntregarUsuario ? "badge-warning" : "badge-secondary")">
                                    @(Model.EntregadaUsuario ? "Completado" : puedeEntregarUsuario ? "Disponible" : "Bloqueado")
                                </span>
                            </div>

                            @if (Model.EntregadaUsuario)
                            {
                                <div class="alert alert-success mb-0">
                                    <strong>Entregada al usuario - Pendiente de Cuentas por Pagar</strong><br />
                                    <strong>Fecha entrega:</strong> @Model.FechaEntregaUsuario?.ToString("dd/MM/yyyy HH:mm")<br />
                                    <strong>Recibió:</strong> @Model.NombreRecibeUsuario<br />
                                    <strong>Comentarios:</strong> @(string.IsNullOrEmpty(Model.ComentariosEntregaUsuario) ? "Sin comentarios" : Model.ComentariosEntregaUsuario)
                                </div>
                            }
                            else
                            {
                                <form asp-action="RegistrarEntregaUsuario" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="solicitudId" value="@Model.SolicitudID" />

                                    <div class="form-group">
                                        <label class="small font-weight-bold">Nombre de quien recibe</label>
                                        <input type="text" name="nombreRecibe" class="form-control" required @(puedeEntregarUsuario ? "" : "disabled") />
                                    </div>

                                    <div class="form-group">
                                        <label class="small font-weight-bold">Comentarios de entrega</label>
                                        <textarea name="comentarios" class="form-control" rows="2" @(puedeEntregarUsuario ? "" : "disabled")></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-success btn-block shadow" @(puedeEntregarUsuario ? "" : "disabled")>
                                        <i class="fas fa-check-circle mr-2"></i>Entregar y enviar a CxP
                                    </button>
                                </form>
                            }
                        </div>

                    </div>
                </div>
            }
        </div>

        <div class="col-lg-5">
            <div class="card shadow mb-4 border-left-primary">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-file-invoice-dollar mr-2"></i>Cotización Registrada
                    </h6>
                </div>

                <div class="card-body">
                    @if (Model.Cotizaciones != null && Model.Cotizaciones.Any())
                    {
                        foreach (var cot in Model.Cotizaciones)
                        {
                            bool esImagen =
                            cot.Extension == ".jpg" ||
                            cot.Extension == ".jpeg" ||
                            cot.Extension == ".png" ||
                            cot.Extension == ".webp";

                            <div class="card border mb-3 @(cot.EsRecomendada ? "border-success shadow" : "")">

                                

                                <div class="card-body">

                                    <div class="d-flex justify-content-between align-items-center mb-2">


                                        <h6 class="font-weight-bold text-primary mb-0">
                                            @cot.Proveedor
                                        </h6>

                                        @if (cot.EsRecomendada)
                                        {
                                            <span class="badge badge-success">
                                                Recomendada
                                            </span>
                                        }

                                        @if (cot.FueSeleccionadaPorUsuario)
                                        {
                                            <span class="badge badge-primary">
                                                Seleccionada por solicitante
                                            </span>
                                        }
                                    </div>

                                    <p class="mb-1">
                                        <strong>Monto:</strong>
                                        @cot.MontoTotal.ToString("C")
                                    </p>


                                    @if (cot.FueSeleccionadaPorUsuario)
                                    {
                                        <div class="alert alert-primary mt-2 mb-2">
                                            <i class="fas fa-check-circle mr-1"></i>
                                            Esta cotización fue seleccionada por el solicitante.
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(cot.ComentariosCompras))
                                    {
                                        <div class="alert alert-light border mt-2 mb-2">
                                            <small class="font-weight-bold text-muted">
                                                Comentarios compras
                                            </small>

                                            <div>
                                                @cot.ComentariosCompras
                                            </div>
                                        </div>
                                    }

                                    @if (esImagen)
                                    {
                                        <div class="text-center mb-3">
                                            <img src="@Url.Action("VerPdfNas", new { ruta = cot.ArchivoPath })"
                                                 class="img-fluid rounded border"
                                                 style="max-height:350px;" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="border rounded bg-light mb-3"
                                             style="height:400px; overflow:hidden;">

                                            <iframe src="@Url.Action("VerPdfNas", new { ruta = cot.ArchivoPath })#toolbar=0"
                                                    width="100%"
                                                    height="100%"
                                                    style="border:none;">
                                            </iframe>
                                        </div>
                                    }

                                        <button type="button"
                                                class="btn btn-outline-primary btn-sm btn-block btn-ver-archivo"
                                                data-ruta="@cot.ArchivoPath"
                                                data-titulo="Cotización - @cot.Proveedor">
                                            <i class="fas fa-eye mr-1"></i>
                                            Ver archivo
                                        </button>

                                    @if (Model.EsSolicitante
                                                                && Model.EstatusID == 2
                                                                && Model.CotizacionSeleccionadaID == null)
                                    {
                                        <form asp-action="SeleccionarCotizacion"
                                              method="post"
                                              class="mt-2">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="solicitudId" value="@Model.SolicitudID" />
                                            <input type="hidden" name="cotizacionId" value="@cot.CotizacionID" />

                                            <div class="form-group">
                                                <textarea name="comentarios"
                                              class="form-control"
                                              rows="2"
                                              placeholder="Comentario opcional sobre tu selección"></textarea>
                                            </div>

                                            <button type="submit"
                                                    class="btn btn-success btn-sm btn-block">
                                                Elegir esta cotización
                                            </button>
                                        </form>
                                    }

                                </div>
                            </div>
                        }
                    }
                   

                    else if (Model.EsCompras && Model.EstatusID == 1)
                    {
                        <form asp-action="ProcesarCotizacion"
                              method="post"
                              enctype="multipart/form-data">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="SolicitudID"
                                   value="@Model.SolicitudID" />

                            <div class="alert alert-info small">
                                Puedes subir de 1 a 3 cotizaciones.
                                Se permiten PDF o imágenes.
                            </div>

                            @for (int i = 1; i <= 3; i++)
                            {
                                <div class="border rounded p-3 mb-3">

                                    <h6 class="font-weight-bold text-primary">
                                        Cotización @i
                                    </h6>

                                        <div class="form-group">
                                            <label class="small font-weight-bold text-muted">
                                                Proveedor de la cotización @i
                                            </label>
                                            <input type="text"
                                                   name="Proveedores[@(i - 1)]"
                                                   class="form-control"
                                                   placeholder="Ej. Proveedor ABC"
                                                   @(i == 1 ? "required" : "") />
                                        </div>

                                        <div class="form-group">
                                            <label class="small font-weight-bold text-muted">
                                                Monto total de la cotización @i
                                            </label>
                                            <input type="number"
                                                   step="0.01"
                                                   min="0"
                                                   name="Montos[@(i - 1)]"
                                                   class="form-control"
                                                   placeholder="Ej. 12500.00"
                                                   @(i == 1 ? "required" : "") />
                                        </div>

                                    <input type="file"
                                           name="ArchivosCotizacion"
