@*CODIGO PARA EL MODAL*@
    <div class="modal fade" id="modalArchivo" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width:95%;">
            <div class="modal-content" style="height:90vh;">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalArchivoTitulo">Archivo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body p-0" id="modalArchivoBody" style="height:calc(90vh - 60px);">
                </div>
            </div>
        </div>
    </div>

@section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll(".btn-ver-archivo").forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        const ruta = this.dataset.ruta;
                        const titulo = this.dataset.titulo || "Archivo";

                        const url = '@Url.Action("VerPdfNas", "Compras")' + '?ruta=' + encodeURIComponent(ruta);
                        const body = document.getElementById("modalArchivoBody");

                        document.getElementById("modalArchivoTitulo").innerText = titulo;

                        const esImagen =
                            ruta.toLowerCase().endsWith(".jpg") ||
                            ruta.toLowerCase().endsWith(".jpeg") ||
                            ruta.toLowerCase().endsWith(".png") ||
                            ruta.toLowerCase().endsWith(".webp");

                        if (esImagen) {
                            body.innerHTML = `
                                <div class="d-flex justify-content-center align-items-center h-100 bg-light">
                                    <img src="${url}"
                                         class="img-fluid"
                                         style="max-height:100%; max-width:100%; object-fit:contain;" />
                                </div>`;
                        } else {
                            body.innerHTML = `
                                <iframe src="${url}#toolbar=0"
                                        width="100%"
                                        height="100%"
                                        style="border:none;">
                                </iframe>`;
                        }

                        const modal = new bootstrap.Modal(document.getElementById("modalArchivo"));
                        modal.show();
                    });
                });
            });
        </script>
}

