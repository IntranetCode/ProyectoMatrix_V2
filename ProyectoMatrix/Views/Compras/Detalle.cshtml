                            </div>

                            <button type="submit"
                                    class="btn btn-success btn-block shadow">

                                Procesar Cotizaciones
                            </button>
                        </form>
                    }
                    
                   else
{
    if (Model.EstatusID == 1)
    {
        <div class="alert alert-warning">
            Compras aún no ha cargado cotizaciones para esta solicitud.
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            No hay cotizaciones disponibles para mostrar en este estatus.
        </div>
    }
}

                </div>
