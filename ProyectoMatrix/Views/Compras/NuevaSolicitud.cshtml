@model ProyectoMatrix.Models.CompraViewModel

@{
    ViewData["Title"] = "Nueva Solicitud de Compra";
    Layout = "_LayoutComunicados";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </a>
    </div>

   
    <form asp-controller="Compras" asp-action="NuevaSolicitud" method="post" id="formCompra">

        <div asp-validation-summary="All" class="text-danger"></div>
        @Html.AntiForgeryToken()

        @* Campo oculto para el controlador *@
        <input type="hidden" asp-for="TipoCompra" id="hfTipoCompra" value="Nacional" />

        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
                <h6 class="m-0 font-weight-bold text-primary">DATOS DE LA SOLICITUD</h6>
                <div class="btn-group btn-group-toggle" data-toggle="buttons">
                    <label class="btn btn-outline-primary active" onclick="cambiarTipoCompra('Nacional')">
                        <input type="radio" name="options" id="option1" autocomplete="off" checked> Nacional
                    </label>
                    <label class="btn btn-outline-primary" onclick="cambiarTipoCompra('Internacional')">
                        <input type="radio" name="options" id="option2" autocomplete="off"> Internacional
                    </label>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label class="font-weight-bold">Empresa Solicitante</label>
                        <select asp-for="EmpresaID" class="form-control" asp-items="ViewBag.Empresas" required>
                            <option value="">-- Selecciona Empresa --</option>
                        </select>
                    </div>
                    <div class="col-md-4 form-group">
                        <label class="font-weight-bold">Prioridad / Urgencia</label>
                        <select asp-for="UrgenciaID" class="form-control" asp-items="ViewBag.Urgencias" required>
                            <option value="">-- Selecciona Prioridad --</option>
                        </select>
                    </div>

                    @* Este div se muestra solo si es Internacional *@
                    <div class="col-md-4 form-group" id="divTransporte" style="display:none;">
                        <label class="text-warning font-weight-bold">Tipo de Transporte</label>
                        <select asp-for="TransporteID" class="form-control border-warning">
                            <option value="">-- Selecciona Transporte --</option>
                            <option value="1">Marítimo</option>
                            <option value="2">Aéreo</option>
                            <option value="3">Terrestre</option>
                        </select>
                    </div>

                    <div class="col-md-4 form-group" id="divProyecto" style="display:none;">
                        <label class="font-weight-bold">Nombre del Proyecto</label>
                        <input asp-for="NombreProyecto" id="txtNombreProyecto" class="form-control" placeholder="Nombre del proyecto destinado" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-12">
                        <label class="font-weight-bold">Comentarios adicionales</label>
                        <textarea asp-for="Comentarios" class="form-control" rows="2" placeholder="Detalles extras de la compra..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        @* --- SECCIÓN DE MATERIALES --- *@
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-light">
                <h6 class="m-0 font-weight-bold text-secondary text-uppercase">Materiales o Servicios</h6>
            </div>
            <div class="card-body">
                <div class="row mb-3 bg-light p-3 rounded border">
                    <div class="col-md-4">
                        <label class="small font-weight-bold">Descripción del Producto</label>
                        <input type="text" id="txtMatNombre" class="form-control" placeholder="  ">
                    </div>
                    <div class="col-md-2">
                        <label class="small font-weight-bold">Cant.</label>
                        <input type="number" id="txtMatCant" class="form-control" value="1">
                    </div>
                    <div class="col-md-2">
                        <label class="small font-weight-bold">U. Medida</label>
                        <input type="text" id="txtMatUnidad" class="form-control" placeholder="Pza, Kg, etc.">
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="button" class="btn btn-success btn-block" onclick="agregarMaterial()">
                            <i class="fas fa-plus mr-1"></i> Agregar a la lista
                        </button>
                    </div>
                </div>

                <table class="table table-bordered table-striped" id="tablaMateriales">
                    <thead class="bg-dark text-white text-center">
                        <tr>
                            <th>Producto / Servicio</th>
                            <th style="width: 15%">Cantidad</th>
                            <th style="width: 15%">U. Medida</th>
                            <th style="width: 10%">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Dinámico *@
                    </tbody>
                </table>
            </div>
        </div>

        @* REGRESAR A INDEX una vez enviada la solicitud *@

        <div class="text-right pb-5">
            <button type="submit" class="btn btn-primary btn-lg shadow">
                <i class="fas fa-paper-plane mr-2"></i>Enviar Solicitud de Compra
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let matIndex = 0;

               function cambiarTipoCompra(tipo) {
            $('#hfTipoCompra').val(tipo);
            if (tipo === 'Internacional') {
                $('#divTransporte').fadeIn();
                $('#divProyecto').fadeIn(); // Mostrar campo Proyecto
                $('#divTransporte select').attr('required', true);
                $('#txtNombreProyecto').attr('required', true); // Hacerlo obligatorio solo aquí
            } else {
                $('#divTransporte').fadeOut();
                $('#divProyecto').fadeOut(); // Ocultar campo Proyecto
                $('#divTransporte select').removeAttr('required').val('');
                $('#txtNombreProyecto').removeAttr('required').val(''); // Quitar obligación y limpiar
            }
        }

        function agregarMaterial() {
            const nom = $('#txtMatNombre').val();
            const cant = $('#txtMatCant').val();
            const uni = $('#txtMatUnidad').val();

            if (!nom || cant <= 0) {
                Swal.fire('Atención', 'Ingresa una descripción y cantidad válida', 'warning');
                return;
            }

            const fila = `<tr>
                <td><input type="hidden" name="Materiales[${matIndex}].Nombre" value="${nom}" />${nom}</td>
                <td class="text-center"><input type="hidden" name="Materiales[${matIndex}].Cantidad" value="${cant}" />${cant}</td>
                <td class="text-center"><input type="hidden" name="Materiales[${matIndex}].UnidadMedida" value="${uni}" />${uni}</td>
                <td class="text-center">
                           <button type="button" class="btn btn-danger btn-sm" onclick="eliminarMaterial(this)">
            <i class="fas fa-trash"></i>
        </button>
                </td>
            </tr>`;

            $('#tablaMateriales tbody').append(fila);
            matIndex++;

            // Limpiar campos
            $('#txtMatNombre').val('');
            $('#txtMatCant').val('1');
            $('#txtMatUnidad').val('');
            $('#txtMatNombre').focus();
        }

        // Prevenir envío si no hay materiales
        $('#formCompra').submit(function(e) {
            if ($('#tablaMateriales tbody tr').length === 0) {
                e.preventDefault();
                Swal.fire('Error', 'Debes agregar al menos un material a la lista.', 'error');
            }
        });


        function eliminarMaterial(boton) {
            $(boton).closest('tr').remove();
            reindexarMateriales();
        }

                function reindexarMateriales() {
            let contador = 0; //  variable local para el bucle
            $('#tablaMateriales tbody tr').each(function() {
                $(this).find('input[type="hidden"]').each(function() {
                    let name = $(this).attr('name');
                    if (name.includes("Nombre")) $(this).attr('name', `Materiales[${contador}].Nombre`);
                    if (name.includes("Cantidad")) $(this).attr('name', `Materiales[${contador}].Cantidad`);
                    if (name.includes("UnidadMedida")) $(this).attr('name', `Materiales[${contador}].UnidadMedida`);
                });
                contador++;
            });
            matIndex = contador; 
        }

    </script>
}

                    <style>
    /* --- Títulos y Secciones --- */
    h6.text-primary {
        color: #004a99 !important; /* Azul Corporativo */
        letter-spacing: 1px;
    }

    .card-header.bg-light {
        background-color: #f0f4f8 !important;
        border-bottom: 2px solid #004a99;
    }

    /* --- Inputs y Formularios --- */
    .form-control {
        border-radius: 6px;
        border: 1px solid #ced4da;
        transition: all 0.2s ease-in-out;
    }

        .form-control:focus {
            border-color: #ff6b00; /* Foco Naranja */
            box-shadow: 0 0 0 0.2rem rgba(255, 107, 0, 0.15);
        }

    label.font-weight-bold {
        color: #2c3e50;
        font-size: 0.9rem;
        margin-bottom: 0.4rem;
    }

    /* --- Botones de Selección (Nacional/Internacional) --- */
    .btn-outline-primary {
        color: #004a99;
        border-color: #004a99;
    }

        .btn-outline-primary:hover, .btn-outline-primary.active {
            background-color: #004a99 !important;
            border-color: #004a99 !important;
            color: white !important;
        }

    /* --- Sección de Transporte (Alerta Visual) --- */
    .border-warning {
        border: 2px solid #ff9f1a !important;
    }

    .text-warning {
        color: #e67e22 !important; /* Naranja oscuro para legibilidad */
    }

    /* --- Tabla de Materiales --- */
    #tablaMateriales thead.bg-dark {
        background-color: #004a99 !important; /* Encabezado Azul */
    }

    #tablaMateriales tbody tr {
        transition: background 0.2s;
    }

        #tablaMateriales tbody tr:hover {
            background-color: #fdf2e9 !important; /* Fondo naranja tenue */
        }

    /* --- Botones de Acción --- */
    .btn-success {
        background-color: #27ae60;
        border: none;
    }

        .btn-success:hover {
            background-color: #219150;
            transform: translateY(-1px);
        }

    /* Botón Principal Enviar */
    .btn-primary.btn-lg {
        background-color: #ff6b00 !important; /* Naranja Corporativo */
        border: none;
        padding: 12px 30px;
        font-weight: 700;
        text-transform: uppercase;
    }

        .btn-primary.btn-lg:hover {
            background-color: #e65c00 !important;
            box-shadow: 0 5px 15px rgba(255, 107, 0, 0.4) !important;
        }

    .btn-outline-secondary {
        border-radius: 8px;
        color: #7f8c8d;
    }

    /* --- Ajustes de Materiales --- */
    .bg-light.p-3.rounded.border {
        background-color: #f8f9fa !important;
        border-left: 4px solid #ff6b00 !important; /* Acento naranja en la zona de carga */
    }
                    </style>