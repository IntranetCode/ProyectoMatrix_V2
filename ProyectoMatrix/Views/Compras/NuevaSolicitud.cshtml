@model ProyectoMatrix.Models.CompraViewModel

@{
    ViewData["Title"] = "Nueva Solicitud de Compra";
    Layout = "_LayoutComunicados";

    // Conserva la selección cuando el formulario regresa por un error de validación.
    bool presupuestoOpcionalInicial =
        Context.Request.HasFormContentType
        && string.Equals(
            Context.Request.Form["PresupuestoOpcional"].ToString(),
            "true",
            StringComparison.OrdinalIgnoreCase
        );
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </a>
    </div>

   
    <form asp-controller="Compras"
          asp-action="NuevaSolicitud"
          method="post"
          id="formCompra"
          enctype="multipart/form-data">

        <div asp-validation-summary="All" class="text-danger"></div>
        @Html.AntiForgeryToken()

        @* Campo oculto para el controlador *@
        <input type="hidden" asp-for="TipoCompra" id="hfTipoCompra" value="Nacional" />

        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
                <h6 class="m-0 font-weight-bold text-primary">DATOS DE LA SOLICITUD</h6>
                <div class="btn-group btn-group-toggle" data-toggle="buttons">
                    <label class="btn btn-outline-primary active" onclick="cambiarTipoCompra('Nacional')">
                        <input type="radio" name="options" id="option1" autocomplete="off" checked> Nacional
                    </label>
                    <label class="btn btn-outline-primary" onclick="cambiarTipoCompra('Internacional')">
                        <input type="radio" name="options" id="option2" autocomplete="off"> Internacional
                    </label>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label class="font-weight-bold">Empresa Solicitante</label>
                        <select asp-for="EmpresaID" class="form-control" asp-items="ViewBag.Empresas" required>
                            <option value="">-- Selecciona Empresa --</option>
                        </select>
                    </div>
                    <div class="col-md-4 form-group">
                        <label class="font-weight-bold">Prioridad / Urgencia</label>
                        <select asp-for="UrgenciaID" class="form-control" asp-items="ViewBag.Urgencias" required>
                            <option value="">-- Selecciona Prioridad --</option>
                        </select>
                    </div>

                    @* Este div se muestra solo si es Internacional *@
                    <div class="col-md-4 form-group" id="divTransporte" style="display:none;">
                        <label class="text-warning font-weight-bold">Tipo de Transporte</label>
                        <select asp-for="TransporteID" class="form-control border-warning">
                            <option value="">-- Selecciona Transporte --</option>
                            <option value="1">Marítimo</option>
                            <option value="2">Avión</option>
                            <option value="3">Terrestre</option>
                            <option value="4">Sin transporte</option>
                        </select>
                    </div>

                    <div class="col-md-4 form-group" id="divProyecto">
                        <label class="font-weight-bold">Nombre del Proyecto</label>
                        <input asp-for="NombreProyecto"
                               id="txtNombreProyecto"
                               class="form-control"
                               placeholder="Nombre del proyecto destinado"
                               required />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-12">
                        <label class="font-weight-bold">Comentarios adicionales</label>
                        <textarea asp-for="Comentarios" class="form-control" rows="2" placeholder="Detalles extras de la compra..."></textarea>
                       
                    </div>
                </div>
            </div>
        </div>


        @* Sección de datos para presupuesto *@

        <div class="card shadow mb-4 border-left-warning" id="cardPresupuesto">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-warning">
                    <i class="fas fa-coins mr-2"></i>
                    Presupuesto de la compra
                </h6>

                <button type="button"
                        id="btnPresupuestoOpcional"
                        class="btn btn-outline-warning btn-sm">
                    <i class="fas fa-toggle-off mr-1"></i>
                    Hacer presupuesto opcional
                </button>
            </div>

            <div class="card-body">
                <input type="hidden"
                       name="PresupuestoOpcional"
                       id="hfPresupuestoOpcional"
                       value="@(presupuestoOpcionalInicial ? "true" : "false")" />

                <div id="mensajePresupuestoOpcional"
                     class="alert alert-info small"
                     style="display:none;">
                    <i class="fas fa-info-circle mr-1"></i>
                    El presupuesto se guardará sin monto. Puedes volver a activarlo con el botón superior.
                </div>

                <div class="form-group" id="grupoMontoPresupuesto">
                    <label asp-for="MontoPresupuestoSolicitado" class="small font-weight-bold">
                        Presupuesto aproximado o solicitado
                    </label>

                    <input asp-for="MontoPresupuestoSolicitado"
                           id="txtMontoPresupuesto"
                           type="number"
                           step="0.01"
                           min="0.01"
                           class="form-control"
                           placeholder="Ej. 15000.00"
                           required />

                    <span asp-validation-for="MontoPresupuestoSolicitado"
                          class="text-danger small"></span>

                    <small class="form-text text-muted">
                        Captura el monto previamente consultado o estimado para esta compra.
                    </small>
                </div>

                <div class="form-check mb-3" id="grupoFueraPresupuesto">
                    <input asp-for="FueraPresupuestoUsuario"
                           class="form-check-input"
                           type="checkbox"
                           id="chkFueraPresupuesto" />

                    <label class="form-check-label font-weight-bold" for="chkFueraPresupuesto">
                        Esta compra está fuera de presupuesto
                    </label>
                </div>

                <div id="bloqueDesviacion" style="display:none;">
                    <div class="alert alert-warning small">
                        <i class="fas fa-exclamation-triangle mr-1"></i>
                        Esta compra está fuera de presupuesto. Debes adjuntar el formato de desviación firmado y llenado correctamente.
                    </div>

                    <div class="form-group">
                        <label asp-for="ArchivoDesviacion" class="small font-weight-bold">
                            Archivo de desviación firmado
                        </label>

                        <input asp-for="ArchivoDesviacion"
                               type="file"
                               class="form-control-file"
                               accept=".pdf,.jpg,.jpeg,.png,.webp" />

                        <span asp-validation-for="ArchivoDesviacion"
                              class="text-danger small"></span>

                        <small class="form-text text-muted">
                            Se permiten PDF o imágenes JPG, PNG o WEBP.
                        </small>
                    </div>
                </div>

            </div>
        </div>



        @* --- SECCIÓN DE MATERIALES --- *@
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-light">
                <h6 class="m-0 font-weight-bold text-secondary text-uppercase">Materiales o Servicios</h6>
            </div>

            <div class="card shadow mb-4 border-left-info">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">
                        <i class="fas fa-file-excel mr-2"></i>
                        Carga masiva de productos
                    </h6>
                </div>

                <div class="card-body">
                    <div class="row align-items-end">
                        <div class="col-md-8">
                            <label class="font-weight-bold">
                                Archivo Excel o CSV
                            </label>

                            <input type="file"
                                   id="archivoCargaMasiva"
                                   class="form-control"
                                   accept=".xlsx,.xls,.csv" />

                            <small class="text-muted">
                                El archivo debe contener las columnas:
                                Nombre, Descripción, Cantidad y Unidad.
                            </small>
                        </div>

                        <div class="col-md-4">
                            <button type="button"
                                    id="btnCargarProductosArchivo"
                                    class="btn btn-info btn-block">
                                <i class="fas fa-upload mr-1"></i>
                                Cargar productos
                            </button>
                        </div>
                    </div>

                    <div class="alert alert-warning mt-3 mb-0">
                        <strong>Formato esperado:</strong>
                        Nombre | Descripción | Cantidad | Unidad
                    </div>
                </div>
            </div>


            <div class="card-body">
                <div class="row mb-3 bg-light p-3 rounded border">
                    <div class="col-md-3">
                        <label class="small font-weight-bold">Producto</label>
                        <input type="text"
                               id="txtMatNombre"
                               class="form-control"
                               placeholder="Ej. Laptop, monitor, cable, servicio">
                    </div>

                    <div class="col-md-4">
                        <label class="small font-weight-bold">Descripción</label>
                        <input type="text"
                               id="txtMatDescripcion"
                               class="form-control"
                               placeholder="Marca, modelo, medidas, características, etc.">
                    </div>

                    <div class="col-md-2">
                        <label class="small font-weight-bold">Cant.</label>
                        <input type="number"
                               id="txtMatCant"
                               class="form-control"
                               value="1"
                               min="1">
                    </div>

                    <div class="col-md-2">
                        <label class="small font-weight-bold">U. Medida</label>
                        <input type="text"
                               id="txtMatUnidad"
                               class="form-control"
                               placeholder="Pza, Kg, m, caja">
                    </div>

                    <div class="col-md-1 d-flex align-items-end">
                        <button type="button"
                                class="btn btn-success btn-block"
                                onclick="agregarMaterial()">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>

                <table class="table table-bordered table-striped" id="tablaMateriales">
                    <thead class="text-center">
                        <tr>
                            <th>Producto</th>
                            <th>Descripción</th>
                            <th style="width: 12%">Cantidad</th>
                            <th style="width: 12%">U. Medida</th>
                            <th style="width: 22%">Archivo referencia</th>
                            <th style="width: 10%">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Dinámico *@
                    </tbody>
                </table>
            </div>
        </div>

        @* REGRESAR A INDEX una vez enviada la solicitud *@

        <div class="text-right pb-5">
            <button type="submit" class="btn btn-primary btn-lg shadow">
                <i class="fas fa-paper-plane mr-2"></i>Enviar Solicitud de Compra
            </button>
        </div>
    </form>
</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

    <script>
        let matIndex = 0;

                     function cambiarTipoCompra(tipo) {
            $('#hfTipoCompra').val(tipo);

            if (tipo === 'Internacional') {
                $('#divTransporte').fadeIn();
                $('#divTransporte select').attr('required', true);
            } else {
                $('#divTransporte').fadeOut();
                $('#divTransporte select').removeAttr('required').val('');
            }

            $('#divProyecto').show();
            $('#txtNombreProyecto').attr('required', true);
        }

                function agregarMaterial(nombreArchivo = null, descripcionArchivo = null, cantidadArchivo = null, unidadArchivo = null) {
            const nom = nombreArchivo !== null ? nombreArchivo : $('#txtMatNombre').val();
            const descripcion = descripcionArchivo !== null ? descripcionArchivo : $('#txtMatDescripcion').val();
            const cant = cantidadArchivo !== null ? cantidadArchivo : $('#txtMatCant').val();
            const uni = unidadArchivo !== null ? unidadArchivo : $('#txtMatUnidad').val();

            const nomTexto = (nom || '').toString().trim();
            const descripcionTexto = (descripcion || '').toString().trim();
            const unidadTexto = (uni || '').toString().trim();

            const cantidadNumero = parseFloat(
                (cant || '').toString().replace(',', '.')
            );

            if (!nomTexto) {
                Swal.fire('Atención', 'Ingresa el producto.', 'warning');
                return false;
            }

            if (!descripcionTexto) {
                Swal.fire('Atención', 'Ingresa la descripción del producto.', 'warning');
                return false;
            }

            if (isNaN(cantidadNumero) || cantidadNumero <= 0) {
                Swal.fire('Atención', 'Ingresa una cantidad válida.', 'warning');
                return false;
            }

            const nomSeguro = escapeHtml(nomTexto);
            const descripcionSeguro = escapeHtml(descripcionTexto);
            const uniSeguro = escapeHtml(unidadTexto);
            const cantidadSeguro = cantidadNumero.toString();

            const fila = `<tr>
                <td>
                    <input type="hidden" name="Materiales[${matIndex}].Nombre" value="${nomSeguro}" />
                    ${nomSeguro}
                </td>

                <td>
                    <input type="hidden" name="Materiales[${matIndex}].Descripcion" value="${descripcionSeguro}" />
                    ${descripcionSeguro}
                </td>

                <td class="text-center">
                    <input type="hidden" name="Materiales[${matIndex}].Cantidad" value="${cantidadSeguro}" />
                    ${cantidadSeguro}
                </td>

                <td class="text-center">
                    <input type="hidden" name="Materiales[${matIndex}].UnidadMedida" value="${uniSeguro}" />
                    ${uniSeguro}
                </td>

                <td>
                    <label class="btn btn-outline-primary btn-sm btn-block mb-1">
                        <i class="fas fa-paperclip mr-1"></i>
                        Adjuntar archivo

                        <input type="file"
                               name="Materiales[${matIndex}].ArchivoReferencia"
                               class="d-none input-archivo-ref"
                               accept=".pdf,.jpg,.jpeg,.png,.webp"
                               onchange="mostrarNombreArchivo(this)" />
                    </label>

                    <small class="text-muted nombre-archivo-ref d-block">
                        Sin archivo seleccionado
                    </small>
                </td>

                <td class="text-center">
                    <button type="button" class="btn btn-danger btn-sm" onclick="eliminarMaterial(this)">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>`;

            $('#tablaMateriales tbody').append(fila);
            matIndex++;

            if (nombreArchivo === null) {
                $('#txtMatNombre').val('');
                $('#txtMatDescripcion').val('');
                $('#txtMatCant').val('1');
                $('#txtMatUnidad').val('');
                $('#txtMatNombre').focus();
            }

            return true;
        }

                function agregarMaterialDesdeArchivo(nombre, descripcion, cantidad, unidad) {
            nombre = (nombre || '').toString().trim();
            descripcion = (descripcion || '').toString().trim();
            unidad = (unidad || '').toString().trim();

            cantidad = (cantidad || '').toString().trim();

            if (!nombre || !descripcion || !cantidad) {
                return false;
            }

            return agregarMaterial(nombre, descripcion, cantidad, unidad);
        }

        function eliminarMaterial(boton) {
            $(boton).closest('tr').remove();
            reindexarMateriales();
        }

                            function reindexarMateriales() {
            let contador = 0;

            $('#tablaMateriales tbody tr').each(function () {
                $(this).find('input').each(function () {
                    let name = $(this).attr('name');

                    if (!name) return;

                    if (name.includes("Nombre"))
                        $(this).attr('name', `Materiales[${contador}].Nombre`);

                    if (name.includes("Descripcion"))
                        $(this).attr('name', `Materiales[${contador}].Descripcion`);

                    if (name.includes("Cantidad"))
                        $(this).attr('name', `Materiales[${contador}].Cantidad`);

                    if (name.includes("UnidadMedida"))
                        $(this).attr('name', `Materiales[${contador}].UnidadMedida`);

                    if (name.includes("ArchivoReferencia"))
                        $(this).attr('name', `Materiales[${contador}].ArchivoReferencia`);
                });

                contador++;
            });

            matIndex = contador;
        }

                function escapeHtml(valor) {
            return String(valor ?? '')
                .replace(/&/g, '&amp;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
        }

                function mostrarNombreArchivo(input) {
            const contenedor = $(input).closest('td');
            const nombre = input.files && input.files.length > 0
                ? input.files[0].name
                : 'Sin archivo seleccionado';

            contenedor.find('.nombre-archivo-ref').text(nombre);
        }


    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnPresupuestoOpcional = document.getElementById("btnPresupuestoOpcional");
            const hfPresupuestoOpcional = document.getElementById("hfPresupuestoOpcional");
            const inputMontoPresupuesto = document.getElementById("txtMontoPresupuesto");
            const grupoMontoPresupuesto = document.getElementById("grupoMontoPresupuesto");
            const grupoFueraPresupuesto = document.getElementById("grupoFueraPresupuesto");
            const mensajePresupuestoOpcional = document.getElementById("mensajePresupuestoOpcional");
            const chkFueraPresupuesto = document.getElementById("chkFueraPresupuesto");
            const bloqueDesviacion = document.getElementById("bloqueDesviacion");
            const inputArchivoDesviacion = document.getElementById("ArchivoDesviacion");

            let presupuestoOpcional =
                (hfPresupuestoOpcional?.value || "false").toLowerCase() === "true";

            function toggleDesviacion() {
                const fuera = !presupuestoOpcional && chkFueraPresupuesto.checked;

                bloqueDesviacion.style.display = fuera ? "block" : "none";

                if (inputArchivoDesviacion) {
                    inputArchivoDesviacion.required = fuera;

                    if (!fuera) {
                        inputArchivoDesviacion.value = "";
                    }
                }
            }

            function actualizarModoPresupuesto() {
                hfPresupuestoOpcional.value = presupuestoOpcional ? "true" : "false";

                inputMontoPresupuesto.disabled = presupuestoOpcional;
                inputMontoPresupuesto.required = !presupuestoOpcional;
                chkFueraPresupuesto.disabled = presupuestoOpcional;

                if (presupuestoOpcional) {
                    inputMontoPresupuesto.value = "";
                    chkFueraPresupuesto.checked = false;

                    grupoMontoPresupuesto.classList.add("presupuesto-deshabilitado");
                    grupoFueraPresupuesto.classList.add("presupuesto-deshabilitado");
                    mensajePresupuestoOpcional.style.display = "block";

                    btnPresupuestoOpcional.classList.remove("btn-outline-warning");
                    btnPresupuestoOpcional.classList.add("btn-warning");
                    btnPresupuestoOpcional.innerHTML =
                        '<i class="fas fa-toggle-on mr-1"></i> Capturar presupuesto';
                } else {
                    grupoMontoPresupuesto.classList.remove("presupuesto-deshabilitado");
                    grupoFueraPresupuesto.classList.remove("presupuesto-deshabilitado");
                    mensajePresupuestoOpcional.style.display = "none";

                    btnPresupuestoOpcional.classList.remove("btn-warning");
                    btnPresupuestoOpcional.classList.add("btn-outline-warning");
                    btnPresupuestoOpcional.innerHTML =
                        '<i class="fas fa-toggle-off mr-1"></i> Hacer presupuesto opcional';
                }

                toggleDesviacion();
            }

            btnPresupuestoOpcional.addEventListener("click", function () {
                presupuestoOpcional = !presupuestoOpcional;
                actualizarModoPresupuesto();
            });

            chkFueraPresupuesto.addEventListener("change", toggleDesviacion);

            actualizarModoPresupuesto();
        });
    </script>

    <script>
                function normalizarTexto(valor) {
            return (valor || "")
                .toString()
                .trim()
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "");
        }

        function obtenerValorFila(fila, posiblesNombres) {
            const llaves = Object.keys(fila);

            for (const nombre of posiblesNombres) {
                const nombreNormalizado = normalizarTexto(nombre);

                const llaveEncontrada = llaves.find(k =>
                    normalizarTexto(k) === nombreNormalizado
                );

                if (llaveEncontrada) {
                    return fila[llaveEncontrada];
                }
            }

            return "";
        }
    </script>

    <script>
                document.addEventListener("DOMContentLoaded", function () {
            const inputArchivo = document.getElementById("archivoCargaMasiva");
            const btnCargar = document.getElementById("btnCargarProductosArchivo");

            if (!inputArchivo || !btnCargar) return;

            btnCargar.addEventListener("click", function () {
                const archivo = inputArchivo.files[0];

                if (!archivo) {
                    Swal.fire('Atención', 'Selecciona un archivo Excel o CSV.', 'warning');
                    return;
                }

                const extension = archivo.name.split(".").pop().toLowerCase();

                if (!["xlsx", "xls", "csv"].includes(extension)) {
                    Swal.fire('Atención', 'Solo se permiten archivos Excel o CSV.', 'warning');
                    return;
                }

                const lector = new FileReader();

                lector.onload = function (e) {
                            let workbook;
        if (extension === "csv") {
            workbook = XLSX.read(e.target.result, { type: "string" });
        } else {
            const datos = new Uint8Array(e.target.result);
            workbook = XLSX.read(datos, { type: "array" });
        }

                    const primeraHoja = workbook.SheetNames[0];
                    const hoja = workbook.Sheets[primeraHoja];

                    const filas = XLSX.utils.sheet_to_json(hoja, {
                        defval: ""
                    });

                    if (!filas || filas.length === 0) {
                        Swal.fire('Atención', 'El archivo no contiene productos.', 'warning');
                        return;
                    }

                    let agregados = 0;
                    let omitidos = 0;

                    filas.forEach(function (fila) {
                        const nombre = obtenerValorFila(fila, [
                            "Nombre",
                            "NombreMaterial",
                            "Material",
                            "Producto"
                        ]);

                        const descripcion = obtenerValorFila(fila, [
                            "Descripción",
                            "Descripcion",
                            "DescripcionMaterial",
                            "Detalle"
                        ]);

                        const cantidad = obtenerValorFila(fila, [
                            "Cantidad",
                            "Qty"
                        ]);

                        const unidad = obtenerValorFila(fila, [
                            "Unidad",
                            "UnidadMedida",
                            "Unidad de Medida",
                            "UM"
                        ]);

                        const ok = agregarMaterialDesdeArchivo(
                            nombre,
                            descripcion,
                            cantidad,
                            unidad
                        );

                        if (ok) {
                            agregados++;
                        } else {
                            omitidos++;
                        }
                    });

                            Swal.fire( 'Carga completada',  `Productos cargados: ${agregados}. Omitidos: ${omitidos}.`,    agregados > 0 ? 'success' : 'warning' );

                    inputArchivo.value = "";
                };

                       if (extension === "csv") {
                           lector.readAsText(archivo, "UTF-8");
        } else {
            lector.readAsArrayBuffer(archivo);
        }
            });
        });
    </script>

}

<style>

    body {
        background: #f5f7fb;
    }

    .container-fluid {
        padding-bottom: 2rem;
    }

  

    .btn {
        border-radius: 10px;
        font-weight: 700;
        transition: 0.25s;
    }

        .btn:hover {
            transform: translateY(-1px);
        }

    .btn-outline-secondary {
        border-color: #cbd5e1;
        color: #475569;
        background: #ffffff;
    }

        .btn-outline-secondary:hover {
            background: #475569;
            color: #ffffff;
        }

    .btn-outline-primary {
        color: #2563eb;
        border-color: #bfdbfe;
        background: #eff6ff;
    }

        .btn-outline-primary:hover,
        .btn-outline-primary.active {
            background: #2563eb !important;
            border-color: #2563eb !important;
            color: #ffffff !important;
        }

    .btn-success {
        background: #16a34a !important;
        border-color: #16a34a !important;
        color: #ffffff !important;
    }

        .btn-success:hover {
            background: #15803d !important;
        }

