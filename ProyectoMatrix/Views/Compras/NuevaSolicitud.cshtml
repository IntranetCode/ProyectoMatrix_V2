@model ProyectoMatrix.Models.CompraViewModel

@{
    ViewData["Title"] = "Nueva Solicitud de Compra";
    Layout = "_LayoutComunicados";
}


<a asp-action="Index" class="btn btn-primary">
    <i class="fas fa-arrow-left me-1"></i> Volver
</a>

<div class="container-fluid">
    <form asp-action="NuevaSolicitud" method="post" id="formCompra">
        @Html.AntiForgeryToken()


        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Datos Generales</h6>
                <div class="btn-group btn-group-toggle" data-toggle="buttons">
                    <label class="btn btn-outline-primary active">
                        <input type="radio" name="TipoCompra" value="Nacional" checked onchange="$('#hfTipoCompra').val('Nacional')"> Nacional
                    </label>
                    <label class="btn btn-outline-primary">
                        <input type="radio" name="TipoCompra" value="Internacional" onchange="$('#hfTipoCompra').val('Internacional')"> Internacional
                    </label>
                </div>
                <input type="hidden" asp-for="TipoCompra" id="hfTipoCompra" value="Nacional" />
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Empresa Solicitante</label>
                        <select asp-for="EmpresaID" class="form-control" asp-items="ViewBag.Empresas" required>
                            <option value="">-- Selecciona Empresa --</option>
                        </select>
                    </div>
                    <div class="col-md-6 form-group">
                        <label>Prioridad / Urgencia</label>
                        <select asp-for="UrgenciaID" class="form-control" asp-items="ViewBag.Urgencias" required>
                            <option value="">-- Selecciona Prioridad --</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @* --- SECCIÓN DE MATERIALES (TABLA DINÁMICA) --- *@
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-light">
                <h6 class="m-0 font-weight-bold text-secondary text-uppercase">Materiales o Servicios</h6>
            </div>
            <div class="card-body">
                <div class="row mb-3 bg-gray-100 p-3 rounded">
                    <div class="col-md-4"><input type="text" id="txtMatNombre" class="form-control" placeholder="Producto/Servicio"></div>
                    <div class="col-md-2"><input type="number" id="txtMatCant" class="form-control" placeholder="Cant."></div>
                    <div class="col-md-2"><input type="text" id="txtMatUnidad" class="form-control" placeholder="U. Medida"></div>
                    <div class="col-md-4"><button type="button" class="btn btn-success btn-block" onclick="agregarMaterial()">+ Agregar</button></div>
                </div>

                <table class="table table-bordered" id="tablaMateriales">
                    <thead class="thead-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Cantidad</th>
                            <th>Unidad</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Aquí se insertan las filas con JS *@
                    </tbody>
                </table>
            </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg shadow-sm float-right">
            <i class="fas fa-paper-plane mr-2"></i>Enviar Solicitud
        </button>
    </form>
</div>

@section Scripts {
    <script>
        let matIndex = 0;
        function agregarMaterial() {
            const nom = $('#txtMatNombre').val();
            const cant = $('#txtMatCant').val();
            const uni = $('#txtMatUnidad').val();

            if (!nom || cant <= 0) {
                Swal.fire('Atención', 'Nombre y cantidad son obligatorios', 'warning');
                return;
            }

            const fila = `<tr>
                <td><input type="hidden" name="Materiales[${matIndex}].Nombre" value="${nom}" />${nom}</td>
                <td><input type="hidden" name="Materiales[${matIndex}].Cantidad" value="${cant}" />${cant}</td>
                <td><input type="hidden" name="Materiales[${matIndex}].UnidadMedida" value="${uni}" />${uni}</td>
                <td><button type="button" class="btn btn-danger btn-sm" onclick="$(this).closest('tr').remove()">X</button></td>
            </tr>`;

            $('#tablaMateriales tbody').append(fila);
            matIndex++;
            $('#txtMatNombre, #txtMatCant, #txtMatUnidad').val('');
        }
    </script>
}