@model ProyectoMatrix.Models.CompraViewModel

@{
    ViewData["Title"] = "Nueva Solicitud de Compra";
    Layout = "_LayoutComunicados";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Volver
        </a>
    </div>

   
    <form asp-controller="Compras"
          asp-action="NuevaSolicitud"
          method="post"
          id="formCompra"
          enctype="multipart/form-data">

        <div asp-validation-summary="All" class="text-danger"></div>
        @Html.AntiForgeryToken()

        @* Campo oculto para el controlador *@
        <input type="hidden" asp-for="TipoCompra" id="hfTipoCompra" value="Nacional" />

        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
                <h6 class="m-0 font-weight-bold text-primary">DATOS DE LA SOLICITUD</h6>
                <div class="btn-group btn-group-toggle" data-toggle="buttons">
                    <label class="btn btn-outline-primary active" onclick="cambiarTipoCompra('Nacional')">
                        <input type="radio" name="options" id="option1" autocomplete="off" checked> Nacional
                    </label>
                    <label class="btn btn-outline-primary" onclick="cambiarTipoCompra('Internacional')">
                        <input type="radio" name="options" id="option2" autocomplete="off"> Internacional
                    </label>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label class="font-weight-bold">Empresa Solicitante</label>
                        <select asp-for="EmpresaID" class="form-control" asp-items="ViewBag.Empresas" required>
                            <option value="">-- Selecciona Empresa --</option>
                        </select>
                    </div>
                    <div class="col-md-4 form-group">
                        <label class="font-weight-bold">Prioridad / Urgencia</label>
                        <select asp-for="UrgenciaID" class="form-control" asp-items="ViewBag.Urgencias" required>
                            <option value="">-- Selecciona Prioridad --</option>
                        </select>
                    </div>

                    @* Este div se muestra solo si es Internacional *@
                    <div class="col-md-4 form-group" id="divTransporte" style="display:none;">
                        <label class="text-warning font-weight-bold">Tipo de Transporte</label>
                        <select asp-for="TransporteID" class="form-control border-warning">
                            <option value="">-- Selecciona Transporte --</option>
                            <option value="1">Marítimo</option>
                            <option value="2">Aéreo</option>
                            <option value="3">Terrestre</option>
                        </select>
                    </div>

                    <div class="col-md-4 form-group" id="divProyecto">
                        <label class="font-weight-bold">Nombre del Proyecto</label>
                        <input asp-for="NombreProyecto"
                               id="txtNombreProyecto"
                               class="form-control"
                               placeholder="Nombre del proyecto destinado"
                               required />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-12">
                        <label class="font-weight-bold">Comentarios adicionales</label>
                        <textarea asp-for="Comentarios" class="form-control" rows="2" placeholder="Detalles extras de la compra..."></textarea>
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <label class="font-weight-bold">
                                    Archivo de referencia (Opcional)
                                </label>

                                <input type="file"
                                       name="ArchivoReferencia"
                                       class="form-control"
                                       accept=".pdf,.jpg,.jpeg,.png" />

                                <small class="text-muted">
                                    Adjunta una imagen o PDF con información adicional para Compras.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* --- SECCIÓN DE MATERIALES --- *@
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-light">
                <h6 class="m-0 font-weight-bold text-secondary text-uppercase">Materiales o Servicios</h6>
            </div>
            <div class="card-body">
                <div class="row mb-3 bg-light p-3 rounded border">
                    <div class="col-md-4">
                        <label class="small font-weight-bold">Descripción del Producto</label>
                        <input type="text" id="txtMatNombre" class="form-control" placeholder="  ">
                    </div>
                    <div class="col-md-2">
                        <label class="small font-weight-bold">Cant.</label>
                        <input type="number" id="txtMatCant" class="form-control" value="1">
                    </div>
                    <div class="col-md-2">
                        <label class="small font-weight-bold">U. Medida</label>
                        <input type="text" id="txtMatUnidad" class="form-control" placeholder="Pza, Kg, etc.">
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="button" class="btn btn-success btn-block" onclick="agregarMaterial()">
                            <i class="fas fa-plus mr-1"></i> Agregar a la lista
                        </button>
                    </div>
                </div>

                <table class="table table-bordered table-striped" id="tablaMateriales">
                    <thead class="text-center">
                        <tr>
                            <th>Producto / Servicio</th>
                            <th style="width: 15%">Cantidad</th>
                            <th style="width: 15%">U. Medida</th>
                            <th style="width: 10%">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Dinámico *@
                    </tbody>
                </table>
            </div>
        </div>

        @* REGRESAR A INDEX una vez enviada la solicitud *@

        <div class="text-right pb-5">
            <button type="submit" class="btn btn-primary btn-lg shadow">
                <i class="fas fa-paper-plane mr-2"></i>Enviar Solicitud de Compra
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let matIndex = 0;

                     function cambiarTipoCompra(tipo) {
            $('#hfTipoCompra').val(tipo);

            if (tipo === 'Internacional') {
                $('#divTransporte').fadeIn();
                $('#divTransporte select').attr('required', true);
            } else {
                $('#divTransporte').fadeOut();
                $('#divTransporte select').removeAttr('required').val('');
            }

            $('#divProyecto').show();
            $('#txtNombreProyecto').attr('required', true);
        }
        

        function agregarMaterial() {
            const nom = $('#txtMatNombre').val();
            const cant = $('#txtMatCant').val();
            const uni = $('#txtMatUnidad').val();

            if (!nom || cant <= 0) {
                Swal.fire('Atención', 'Ingresa una descripción y cantidad válida', 'warning');
                return;
            }

            const fila = `<tr>
                <td><input type="hidden" name="Materiales[${matIndex}].Nombre" value="${nom}" />${nom}</td>
                <td class="text-center"><input type="hidden" name="Materiales[${matIndex}].Cantidad" value="${cant}" />${cant}</td>
                <td class="text-center"><input type="hidden" name="Materiales[${matIndex}].UnidadMedida" value="${uni}" />${uni}</td>
                <td class="text-center">
                           <button type="button" class="btn btn-danger btn-sm" onclick="eliminarMaterial(this)">
            <i class="fas fa-trash"></i>
        </button>
                </td>
            </tr>`;

            $('#tablaMateriales tbody').append(fila);
            matIndex++;

            // Limpiar campos
            $('#txtMatNombre').val('');
            $('#txtMatCant').val('1');
            $('#txtMatUnidad').val('');
            $('#txtMatNombre').focus();
        }

        // Prevenir envío si no hay materiales
        $('#formCompra').submit(function(e) {
            if ($('#tablaMateriales tbody tr').length === 0) {
                e.preventDefault();
                Swal.fire('Error', 'Debes agregar al menos un material a la lista.', 'error');
            }
        });


        function eliminarMaterial(boton) {
            $(boton).closest('tr').remove();
            reindexarMateriales();
        }

                function reindexarMateriales() {
            let contador = 0; //  variable local para el bucle
            $('#tablaMateriales tbody tr').each(function() {
                $(this).find('input[type="hidden"]').each(function() {
                    let name = $(this).attr('name');
                    if (name.includes("Nombre")) $(this).attr('name', `Materiales[${contador}].Nombre`);
                    if (name.includes("Cantidad")) $(this).attr('name', `Materiales[${contador}].Cantidad`);
                    if (name.includes("UnidadMedida")) $(this).attr('name', `Materiales[${contador}].UnidadMedida`);
                });
                contador++;
            });
            matIndex = contador; 
        }

    </script>
}

<style>

    body {
        background: #f5f7fb;
    }

    .container-fluid {
        padding-bottom: 2rem;
    }

  

    .btn {
        border-radius: 10px;
        font-weight: 700;
        transition: 0.25s;
    }

        .btn:hover {
            transform: translateY(-1px);
        }

    .btn-outline-secondary {
        border-color: #cbd5e1;
        color: #475569;
        background: #ffffff;
    }

        .btn-outline-secondary:hover {
            background: #475569;
            color: #ffffff;
        }

    .btn-outline-primary {
        color: #2563eb;
        border-color: #bfdbfe;
        background: #eff6ff;
    }

        .btn-outline-primary:hover,
        .btn-outline-primary.active {
            background: #2563eb !important;
            border-color: #2563eb !important;
            color: #ffffff !important;
        }

    .btn-success {
        background: #16a34a !important;
        border-color: #16a34a !important;
        color: #ffffff !important;
    }

        .btn-success:hover {
            background: #15803d !important;
        }

    .btn-danger {
        background: #dc2626 !important;
        border-color: #dc2626 !important;
        color: #ffffff !important;
    }

    .btn-primary.btn-lg {
        background: #f97316 !important;
        border-color: #f97316 !important;
        color: #ffffff !important;
        padding: 0.85rem 1.8rem;
        border-radius: 12px;
        font-weight: 800;
        text-transform: uppercase;
        box-shadow: 0 10px 22px rgba(249, 115, 22, 0.22);
    }

        .btn-primary.btn-lg:hover {
            background: #ea580c !important;
            box-shadow: 0 12px 28px rgba(249, 115, 22, 0.30);
        }

   

    .card {
        border: 1px solid #e2e8f0 !important;
        border-radius: 18px !important;
        overflow: hidden;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08) !important;
    }

    .card-header {
        background: #ffffff !important;
        border-bottom: 1px solid #e2e8f0;
    }

        .card-header h6 {
            color: #2563eb !important;
            font-weight: 800;
            letter-spacing: 0.4px;
        }

        .card-header.bg-light {
            background: #f8fafc !important;
            border-bottom: 1px solid #e2e8f0;
        }

    .card-body {
        padding: 1.4rem;
    }

    

    label,
    label.font-weight-bold,
    label.small {
        color: #334155;
        font-weight: 700;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        min-height: 42px;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 0.15rem rgba(37, 99, 235, 0.15);
        }

    textarea.form-control {
        resize: vertical;
    }

    .text-danger {
        color: #dc2626 !important;
        font-weight: 700;
    }


    .btn-group-toggle .btn {
        border-radius: 10px !important;
        padding: 0.55rem 1rem;
    }

    #divTransporte,
    #divProyecto {
        animation: fadeInCompra 0.25s ease;
    }

    @@keyframes fadeInCompra {
        from {
            opacity: 0;
            transform: translateY(-4px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .border-warning {
        border: 2px solid #f97316 !important;
    }

    .text-warning {
        color: #f97316 !important;
    }

  

    .bg-light.p-3.rounded.border {
        background: #fff7ed !important;
        border: 1px solid #fed7aa !important;
        border-left: 5px solid #f97316 !important;
        border-radius: 14px !important;
    }

    #txtMatNombre,
    #txtMatCant,
    #txtMatUnidad {
        background: #ffffff;
    }


    #tablaMateriales {
        border-collapse: separate;
        border-spacing: 0 0.55rem;
        margin-bottom: 0;
    }

        #tablaMateriales thead th {
            background: #2563eb !important;
            color: #ffffff !important;
            border: none;
            text-transform: uppercase;
            font-size: 0.72rem;
            letter-spacing: 0.5px;
            padding: 0.9rem;
            font-weight: 800;
        }

        #tablaMateriales tbody tr {
            background: #ffffff;
            transition: 0.2s;
        }

            #tablaMateriales tbody tr:hover {
                background: #fff7ed !important;
                transform: translateY(-1px);
            }

        #tablaMateriales td {
            vertical-align: middle;
            padding: 0.9rem;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
        }

            #tablaMateriales td:first-child {
                border-left: 1px solid #e2e8f0;
                border-radius: 12px 0 0 12px;
                font-weight: 700;
                color: #0f172a;
            }

            #tablaMateriales td:last-child {
                border-right: 1px solid #e2e8f0;
                border-radius: 0 12px 12px 0;
            }

        #tablaMateriales .btn-danger {
            border-radius: 10px;
            padding: 0.35rem 0.6rem;
        }


    .text-right.pb-5 {
        margin-top: 1rem;
    }



    @@media (max-width: 768px) {
        .d-flex.justify-content-between {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 0.75rem;
        }

        .btn,
        .btn-primary.btn-lg {
            width: 100%;
            margin-bottom: 0.4rem;
        }

        .btn-group {
            width: 100%;
        }

            .btn-group .btn {
                width: 50%;
            }

        .card-body {
            padding: 1rem;
        }

        .text-right {
            text-align: left !important;
        }
    }

</style>