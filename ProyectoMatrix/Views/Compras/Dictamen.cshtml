@model ProyectoMatrix.Models.DictamenPresupuestalVm

@{
    ViewData["Title"] = "Dictamen Presupuestal";
    Layout = "_LayoutComunicados";

}
<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="BandejaPresupuestos" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
</div>
<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-dark text-white">
            <h6 class="m-0 font-weight-bold">Dictamen de Control Presupuestal - @Model.Folio</h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                Monto a Dictaminar: <strong>@Model.MontoCotizado.ToString("C")</strong>
            </div>

            <div class="card border-left-info shadow mb-4">
                <div class="card-header">
                    <h6 class="m-0 font-weight-bold text-info">
                        Cotización seleccionada 
                    </h6>
                </div>
                <div class="card-body">
                    <p><strong>Proveedor:</strong> @Model.Proveedor</p>
                    <p><strong>Monto:</strong> @Model.MontoCotizado.ToString("C")</p>

                    @if (!string.IsNullOrWhiteSpace(Model.ArchivoPath))
                    {
                        <button type="button"
                                class="btn btn-outline-primary btn-sm btn-ver-archivo"
                                data-ruta="@Model.ArchivoPath"
                                data-titulo="Cotización seleccionada - @Model.Proveedor">
                            <i class="fas fa-eye mr-1"></i>
                            Ver cotización
                        </button>
                    }
                    else
                    {
                        <span class="text-muted">Sin archivo disponible</span>
                    }
                </div>
            </div>


            <div class="card shadow mb-4 border-left-warning">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-warning">
                        <i class="fas fa-coins mr-2"></i>
                        Presupuesto declarado por el solicitante
                    </h6>
                </div>

                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-4 border-right">
                            <label class="small font-weight-bold text-muted text-uppercase d-block">
                                Presupuesto solicitado
                            </label>

                            <span class="h5 font-weight-bold text-gray-800">
                                @(Model.MontoPresupuestoSolicitado.HasValue
                                                                ? Model.MontoPresupuestoSolicitado.Value.ToString("C")
                                                                : "No capturado")
                            </span>
                        </div>

                        <div class="col-md-4 border-right">
                            <label class="small font-weight-bold text-muted text-uppercase d-block">
                                Cotización dictaminada
                            </label>

                            <span class="h5 font-weight-bold text-gray-800">
                                @Model.MontoCotizado.ToString("C")
                            </span>
                        </div>

                        <div class="col-md-4">
                            <label class="small font-weight-bold text-muted text-uppercase d-block">
                                Diferencia
                            </label>

                            @{
                                decimal presupuesto = Model.MontoPresupuestoSolicitado ?? 0;
                                decimal diferencia = Model.MontoCotizado - presupuesto;
                                bool requiereDesviacionPorMonto =   Model.MontoPresupuestoSolicitado.HasValue && Model.MontoCotizado > Model.MontoPresupuestoSolicitado.Value;
                            }

                            @if (Model.MontoPresupuestoSolicitado.HasValue)
                            {
                                <span class="h5 font-weight-bold @(diferencia > 0 ? "text-danger" : "text-success")">
                                    @diferencia.ToString("C")
                                </span>

                                <small class="d-block text-muted">
                                    @(diferencia > 0
                                                                    ? "La cotización supera el presupuesto declarado."
                                                                    : "La cotización está dentro del presupuesto declarado.")
                            </small>
                                                        }
                            else
                            {
                                <span class="text-muted">No disponible</span>
                            }
                        </div>
                    </div>

                    <hr />

                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <label class="small font-weight-bold text-muted text-uppercase d-block">
                                Estatus presupuestal inicial
                            </label>

                            @if (Model.FueraPresupuestoUsuario || requiereDesviacionPorMonto)
                            {
                                <span class="badge badge-warning">
                                    <i class="fas fa-exclamation-triangle mr-1"></i>
                                    Requiere desviación
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-success">
                                    <i class="fas fa-check-circle mr-1"></i>
                                    Dentro de presupuesto
                                </span>
                            }
                        </div>

                        <div class="col-md-6">
                            @if (!string.IsNullOrWhiteSpace(Model.ArchivoDesviacionPath))
                            {
                                <div class="alert alert-warning mb-2">
                                    <i class="fas fa-file-signature mr-1"></i>
                                    Esta solicitud cuenta con archivo de desviación cargado.
                                </div>

                                <button type="button"
                                        class="btn btn-outline-warning btn-sm btn-block btn-ver-archivo"
                                        data-ruta="@Model.ArchivoDesviacionPath"
                                        data-titulo="Desviación firmada - @Model.Folio">
                                    <i class="fas fa-eye mr-1"></i>
                                    Ver archivo de desviación
                                </button>
                            }
                            else if (Model.FueraPresupuestoUsuario || requiereDesviacionPorMonto)
                            {
                                <div class="alert alert-danger mb-0">
                                    <i class="fas fa-exclamation-circle mr-1"></i>
                                    La cotización supera el presupuesto o fue marcada fuera de presupuesto. Se requiere archivo de desviación.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-success mb-0">
                                    <i class="fas fa-check-circle mr-1"></i>
                                    La cotización está dentro del presupuesto declarado.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow mb-4 border-left-info">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">
                        <i class="fas fa-file-excel mr-2"></i>
                        Formato de requisición
                    </h6>
                </div>

                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.ArchivoFormatoRequisicionPath))
                    {
                        <p class="mb-2">
                            <strong>Archivo:</strong>
                            <span class="text-muted">
                                @Model.NombreArchivoFormatoRequisicion
                            </span>
                        </p>

                        <button type="button"
                                class="btn btn-outline-primary btn-sm btn-ver-archivo"
                                data-ruta="@Model.ArchivoFormatoRequisicionPath"
                                data-titulo="Formato de requisición - @Model.Folio">
                            <i class="fas fa-eye mr-1"></i>
                            Ver formato de requisición
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-light border mb-0">
                            <i class="fas fa-info-circle mr-1"></i>
                            No se cargó formato de requisición para esta solicitud.
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-4 border-left-warning">
                <div class="card-body">
                    <h6 class="font-weight-bold text-warning">
                        <i class="fas fa-folder-open mr-1"></i>
                        ¿Falta documentación?
                    </h6>

                    <p class="text-muted mb-3">
                        Usa esta opción si necesitas que el solicitante cargue o corrija documentos antes de dictaminar.
                    </p>

                    <button type="button"
                            class="btn btn-warning btn-block"
                            id="btnMostrarSolicitarDocumentos">
                        <i class="fas fa-file-upload mr-1"></i>
                        Solicitar documentos al usuario
                    </button>

                    <div id="seccionSolicitarDocumentos" style="display:none;" class="mt-3">
                        <form asp-action="SolicitarDocumentosPresupuesto" method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="solicitudId" value="@Model.SolicitudID" />

                            <div class="form-group">
                                <label class="font-weight-bold text-warning">
                                    Indica qué documento falta o qué debe corregirse
                                </label>

                                <textarea name="observaciones"
                                          class="form-control"
                                          rows="3"
                                          required
                                          placeholder="Ej. Favor de cargar la desviación firmada / formato de requisición correcto / documento actualizado."></textarea>
                            </div>

                            <button type="submit" class="btn btn-warning btn-block">
                                Enviar solicitud de documentos
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <form asp-action="ProcesarDictamen" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="SolicitudID" />

                <div class="form-group">
                    <label class="font-weight-bold">¿La solicitud procede?</label>
                    <select asp-for="Pasa" class="form-control" id="selectPasa">
                        <option value="true">SÍ - Procede</option>
                        <option value="false">NO - Rechazada</option>
                    </select>
                </div>

                <div id="seccionProcede">
                    <div class="form-group">
                        <label class="font-weight-bold">Tipo de Proceso</label>

                        <div class="btn-group btn-group-toggle d-block" data-toggle="buttons">
                            <label class="btn btn-outline-primary active">
                                <input type="radio" asp-for="TipoGasto" value="GASTO" checked />
                                GASTO DIRECTO
                            </label>

                            <label class="btn btn-outline-primary">
                                <input type="radio" asp-for="TipoGasto" value="REQUISICION" />
                                CON REQUISICIÓN
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Estatus Presupuestal</label>
                        <select asp-for="DentroDePresupuesto" class="form-control">
                            <option value="true">Dentro del Presupuesto</option>
                            <option value="false">Fuera de Presupuesto (Desviación)</option>
                        </select>
                    </div>

                    <div id="seccionRequisicion" style="display:none;">
                        <div class="form-group">
                            <label class="font-weight-bold">ID de Requisición</label>
                            <input asp-for="NumeroRequisicion"
                                   class="form-control"
                                   placeholder="Ingrese ID de Requi..." />
                        </div>
                    </div>
                </div>

                <div id="seccionRechazo" style="display:none;">
                    <div class="form-group">
                        <label class="font-weight-bold text-danger">Motivo de Rechazo</label>
                        <textarea asp-for="Observaciones"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>
                </div>

                <hr />

                <button type="submit" class="btn btn-success btn-block">
                    Aplicar Dictamen Final
                </button>
            </form>

            <hr />

           
    </div>
</div>



<div class="modal fade" id="modalArchivo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width:95%;">
        <div class="modal-content" style="height:90vh;">
            <div class="modal-header">
                <h5 class="modal-title" id="modalArchivoTitulo">Cotización</h5>

                <button type="button"
                        class="close"
                        data-dismiss="modal"
                        aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body p-0"
                 id="modalArchivoBody"
                 style="height:calc(90vh - 60px);">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            toggleSecciones($('#selectPasa').val());

            $('#selectPasa').change(function () {
                toggleSecciones($(this).val());
            });

            function toggleSecciones(valor) {
                if (valor === "true") {
                    $('#seccionProcede').show();
                    $('#seccionRechazo').hide();
                } else {
                    $('#seccionProcede').hide();
                    $('#seccionRechazo').show();
                }
            }

            $('input[type=radio][name="TipoGasto"]').change(function () {
                if (this.value === "REQUISICION") {
                    $('#seccionRequisicion').stop(true, true).fadeIn();
                } else {
                    $('#seccionRequisicion').stop(true, true).fadeOut();
                    $('#NumeroRequisicion').val('');
                }
            });

        $('.btn-ver-archivo').on('click', function () {
            const ruta = $(this).attr('data-ruta');

            if (!ruta || ruta.trim() === '') {
                alert('No hay archivo disponible para mostrar.');
                return;
            }

            const titulo = $(this).attr('data-titulo') || 'Cotización';
            const url = '@Url.Action("VerArchivoNas", "Compras")' + '?ruta=' + encodeURIComponent(ruta);

            const body = document.getElementById("modalArchivoBody");
            document.getElementById("modalArchivoTitulo").innerText = titulo;

            const rutaLower = ruta.toLowerCase();

           const esImagen =
            rutaLower.endsWith(".jpg") ||
            rutaLower.endsWith(".jpeg") ||
            rutaLower.endsWith(".png") ||
            rutaLower.endsWith(".webp");

        const esExcel =
            rutaLower.endsWith(".xlsx") ||
            rutaLower.endsWith(".xls");

        if (esImagen) {
                body.innerHTML = `
                    <div class="d-flex justify-content-center align-items-center h-100 bg-light">
                        <img src="${url}"
                             class="img-fluid"
                             style="max-height:100%; max-width:100%; object-fit:contain;" />
                    </div>`;
            }
                    else if (esExcel) {
            body.innerHTML = `
                <div class="d-flex flex-column justify-content-center align-items-center h-100 bg-light text-center p-4">
                    <i class="fas fa-file-excel fa-4x text-success mb-3"></i>
                    <h5>El archivo de Excel no se puede previsualizar aquí.</h5>
                    <p class="text-muted mb-3">
                        Descárgalo para revisarlo.
                    </p>
                    <a href="${url}"
                       class="btn btn-success"
                       target="_blank">
                        Descargar Excel
                    </a>
                </div>`;
        }
            
            else {
                body.innerHTML = `
                    <iframe src="${url}#toolbar=0"
                            width="100%"
                            height="100%"
                            style="border:none;">
                    </iframe>`;
            }

            $('#modalArchivo').modal('show');
        });
        });

                $('#btnMostrarSolicitarDocumentos').on('click', function () {
            $('#seccionSolicitarDocumentos').stop(true, true).slideToggle();
        });

    </script>
}

