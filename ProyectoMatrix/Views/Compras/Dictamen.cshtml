        }


    .form-group label {
        font-weight: 700;
        color: #334155;
    }

    

    .form-control {
        border-radius: 10px;
        border: 1px solid #cbd5e1;
    }

        .form-control:focus {
            border-color: #16a34a;
            box-shadow: 0 0 0 .15rem rgba(22,163,74,.15);
        }

  

    #selectPasa {
        font-weight: 700;
    }

    

    .btn-group-toggle .btn-outline-primary {
