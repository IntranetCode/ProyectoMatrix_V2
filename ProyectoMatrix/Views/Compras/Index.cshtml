@model ProyectoMatrix.Models.IndexComprasVm

@{
    ViewData["Title"] = "Gestión de Compras";
    Layout = "_LayoutComunicados";

    string puesto = (ViewBag.Puesto ?? "").ToString().ToUpper().Trim();
    string departamentos = (ViewBag.DepartamentosUsuario ?? "").ToString().ToUpper().Trim();

    bool esDireccion =
        puesto.Contains("DIRECCION") ||
        puesto.Contains("DIRECCIÓN") ||
        puesto.Contains("DIRECTOR") ||
        puesto.Contains("DIRECTORA") ||
        puesto.StartsWith("DIR.");

    bool esCompras =
        esDireccion ||
        puesto.Contains("COMPRAS") ||
        puesto.Contains("COMPRADOR") ||
        departamentos.Contains("COMPRAS");

    bool esPresupuestos =
        departamentos.Contains("PRESUPUEST") ||
        departamentos.Contains("CONTROL PRESUPUESTAL") ||
        departamentos.Contains("CIS");

    bool esAlmacen =
        departamentos.Contains("ALMACEN") ||
        departamentos.Contains("ALMACÉN");
  

}

<div class="compras-page">

    <div class="compras-header mb-4">

        <div>
            <h2 class="mb-1">Gestión de Compras</h2>
            <small class="text-muted">Panel de Control Unificado</small>
        </div>

        <div class="compras-actions">

            <a asp-action="NuevaSolicitud" class="btn btn-ns-orange">
                <i class="fas fa-plus me-1"></i>
                Nueva Solicitud
            </a>

            @if (esCompras)
            {
                <a asp-action="BandejaCompras" class="btn btn-ns-blue">
                    <i class="fas fa-user-shield me-1"></i>
                    Bandeja Compras
                </a>
            }

            @if (esPresupuestos)
            {
                <a asp-action="BandejaPresupuestos" class="btn btn-ns-cyan">
                    <i class="fas fa-wallet me-1"></i>
                    Validar Presupuestos
                </a>
            }

            @if (esDireccion)
            {
                <a asp-action="Seguimiento" class="btn btn-ns-green">
                    <i class="fas fa-chart-line me-1"></i>
                    Seguimiento
                </a>
            }

            @if (esAlmacen)
            {
                <a asp-action="BandejaAlmacen" class="btn btn-ns-purple">
                    <i class="fas fa-boxes me-1"></i>
                    Bandeja Almacén
                </a>
            }

            

        </div>

    </div>

    @if (!esCompras && !esPresupuestos && !esDireccion && !esAlmacen )
    {
        <div class="alert ns-alert-info mb-4">
            <div class="d-flex align-items-start">
                <i class="fas fa-info-circle me-2 mt-1"></i>
                <div>
                    <strong>--</strong><br />
                    
                </div>
            </div>
        </div>
    }

    @if (esDireccion)
    {
        <div class="row mb-4">

            <div class="col-md-3 mb-3">
                <div class="ns-kpi-card ns-kpi-danger">
                    <div class="ns-kpi-label">Críticos Vencidos</div>
                    <div class="ns-kpi-value">@Model.Estadisticas.CriticosVencidos</div>
                </div>
            </div>
            @*
            <div class="col-md-3 mb-3">
                <div class="ns-kpi-card ns-kpi-warning">
                    <div class="ns-kpi-label">Promedio Atención</div>
                    <div class="ns-kpi-value">@Model.Estadisticas.PromedioTotal.ToString("N1") Horas</div>
                </div>
            </div>*@

        </div>

        <div class="row mb-4">

            <div class="col-lg-4 mb-4">
                <div class="ns-card h-100">
                    <div class="ns-card-header">
                        <h6>
                            <i class="fas fa-hourglass-half me-2"></i>
                            Cuellos de Botella
                        </h6>
                    </div>

                    <div class="ns-card-body">
                        <div id="chartCuellosBotella" style="min-height: 350px;"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 mb-4">
                <div class="ns-card h-100">
                    <div class="ns-card-header">
                        <h6>
                            <i class="fas fa-chart-pie me-2"></i>
                            Estatus General
                        </h6>
                    </div>

                    <div class="ns-card-body">
                        <div id="chartDonaEstatus" style="min-height: 350px;"></div>
                    </div>
                </div>
            </div>

        </div>
    }

    <div class="ns-card mb-5">

        <div class="ns-card-header">
            <h6>
                <i class="fas fa-list me-2"></i>
                Mi Historial de Solicitudes
            </h6>
        </div>

        <div class="ns-card-body">

            <div class="table-responsive">

                <table class="table table-hover datatable-compras">

                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Empresa</th>
                            <th style="width: 25%;">Estatus / Progreso</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model.MisCompras != null && Model.MisCompras.Any())
                        {
                            foreach (var item in Model.MisCompras)
                            {
                                <tr>

                                    <td>
                                        <strong>@item.Folio</strong>
                                    </td>

                                    <td>
                                        @item.Fecha.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        @item.Tipo
                                    </td>

                                    <td>
                                        @item.Empresa
                                    </td>

                                    <td>
                                        <div class="progress ns-progress mb-1">
                                            <div class="progress-bar @item.ColorProgreso"
                                                 style="width: @item.Porcentaje%">
                                            </div>
                                        </div>

                                        <small class="text-muted">
                                            @item.Estatus (@item.Porcentaje%)
                                        </small>
                                    </td>

                                    <td>
                                        <a asp-action="Detalle"
                                           asp-route-id="@item.SolicitudID"
                                           asp-route-returnUrl="@Context.Request.Path"
                                           class="btn btn-sm btn-outline-ns">
                                            <i class="fas fa-search me-1"></i>
                                            Seguimiento
                                        </a>
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-folder-open d-block mb-2 fs-4"></i>
                                    Aún no tienes solicitudes registradas.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @if (esDireccion)
    {
        <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

        <script>
            document.addEventListener("DOMContentLoaded", function () {

                const cuellosElement = document.querySelector("#chartCuellosBotella");
                const donaElement = document.querySelector("#chartDonaEstatus");
                       const tiemposRaw = @Html.Raw(Json.Serialize(Model.Estadisticas.TiemposPromedio));

            const tiemposCuellos = tiemposRaw.map(x => {
                const horas = Number(x || 0);
                return Number((horas / 24).toFixed(1));
            });

                if (cuellosElement) {

                    const optionsBar = {
                        series: [{
                            name: 'Días promedio',
                            data: tiemposCuellos
                        }],
                        chart: {
                            type: 'bar',
                            height: 350,
                            toolbar: {
                                show: false
                            },
                            fontFamily: 'Segoe UI, Arial, sans-serif'
                        },
                        plotOptions: {
                            bar: {
                                distributed: true,
                                horizontal: true,
                                borderRadius: 8,
                                barHeight: '45%'
                            }
                        },
                colors: [
                '#2563EB',
                '#F59E0B',
                '#16A34A',
                '#7C3AED',
                '#0891B2'
            ],
                        xaxis: {
                                        categories: [
                "Compras",
                "Control Presupuestal",
                "Orden de Compra",
                "Proveedor",
                "Almacén"
               
            ],
                            labels: {
                                style: {
                                                colors: [
                '#2563EB',
                '#F59E0B',
                '#16A34A',
                '#7C3AED',
                '#0891B2',
               
            ],
                                    fontSize: '12px'
                                }
                            }
                        },
                        yaxis: {
                            labels: {
                                style: {
                                    colors: '#0F172A',
                                    fontSize: '12px'
                                }
                            }
                        },
                        dataLabels: {
                            enabled: true,
                                                               formatter: function (val) {
                return Number(val).toFixed(1) + " días promedio";
            },
                            style: {
                                fontSize: '12px',
                                fontWeight: '700',
                                colors: ['#ffffff']
                            }
                        },
                        tooltip: {
                            y: {
                                            formatter: function (val) {
                return val + " días promedio";
            }
                            }
                        },
                        legend: {
                            show: false
                        },
                        grid: {
                            borderColor: '#E2E8F0'
                        }
                    };

                    new ApexCharts(cuellosElement, optionsBar).render();
                }

                if (donaElement) {

                    const optionsDona = {
                        series: @Html.Raw(Json.Serialize(Model.Estadisticas.DonaValores)),
                        chart: {
                            type: 'donut',
                            height: 360,
                            fontFamily: 'Segoe UI, Arial, sans-serif'
                        },
                        labels: @Html.Raw(Json.Serialize(Model.Estadisticas.DonaEtiquetas)),
                        colors: [
                            '#2563EB',
                            '#16A34A',
                            '#F97316',
                            '#DC2626',
                            '#7C3AED',
                            '#0891B2',
                            '#DB2777',
                            '#65A30D',
                            '#9333EA',
                            '#EA580C',
                            '#0F766E',
                            '#475569',
                            '#B45309',
                            '#1D4ED8',
                            '#BE123C'
                        ],
                        legend: {
                            position: 'right',
                            fontSize: '13px',
                            markers: {
                                width: 11,
                                height: 11,
                                radius: 12
                            },
                            labels: {
                                colors: '#0F172A'
                            }
                        },
                        stroke: {
                            width: 3,
                            colors: ['#ffffff']
                        },
                        plotOptions: {
                            pie: {
                                donut: {
                                    size: '65%',
                                    labels: {
                                        show: true,
                                        name: {
                                            show: true,
                                            color: '#334155'
                                        },
                                        value: {
                                            show: true,
                                            color: '#0F172A',
                                            fontSize: '22px',
                                            fontWeight: 700
                                        },
                                        total: {
                                            show: true,
                                            label: 'Total',
                                            color: '#334155'
                                        }
                                    }
                                }
                            }
                        },
                        dataLabels: {
                            enabled: true,
                            formatter: function (val) {
                                return val.toFixed(1) + "%";
                            },
                            style: {
                                fontSize: '11px',
                                fontWeight: '700'
                            },
                            dropShadow: {
                                enabled: false
                            }
                        },
                        tooltip: {
                            y: {
                                formatter: function (val) {
                                    return val + " solicitudes";
                                }
                            }
                        },
                        responsive: [{
                            breakpoint: 768,
                            options: {
                                chart: {
                                    height: 320
                                },
                                legend: {
                                    position: 'bottom'
                                }
                            }
                        }]
                    };

                    new ApexCharts(donaElement, optionsDona).render();
                }

            });
        </script>
    }

}

<style>
    .compras-page {
        padding: 1rem 0;
    }

    .compras-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
    }

        .compras-header h2 {
            color: #0F172A;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

    .compras-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.5rem;
    }

        .compras-actions .btn,
        .btn-outline-ns {
            border-radius: 10px;
            padding: 0.6rem 1rem;
            font-weight: 700;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
            transition: all 0.2s ease;
            border: 0;
        }

            .compras-actions .btn:hover,
            .btn-outline-ns:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 24px rgba(15, 23, 42, 0.16);
            }

    .btn-ns-orange {
        background: #F97316;
        color: #ffffff;
    }

    .btn-ns-blue {
        background: #2563EB;
        color: #ffffff;
    }

    .btn-ns-cyan {
        background: #0891B2;
        color: #ffffff;
    }

    .btn-ns-green {
        background: #16A34A;
        color: #ffffff;
    }

    .btn-ns-purple {
        background: #7C3AED;
        color: #ffffff;
    }

    .btn-ns-dark {
        background: #334155;
        color: #ffffff;
    }

        .btn-ns-orange:hover,
        .btn-ns-blue:hover,
        .btn-ns-cyan:hover,
        .btn-ns-green:hover,
        .btn-ns-purple:hover,
        .btn-ns-dark:hover {
            color: #ffffff;
        }

    .btn-outline-ns {
        background: #ffffff;
        color: #2563EB;
        border: 1px solid #BFDBFE;
        box-shadow: none;
    }

        .btn-outline-ns:hover {
            background: #2563EB;
            color: #ffffff;
            border-color: #2563EB;
        }

    .ns-alert-info {
        border: 1px solid #BFDBFE;
        background: #EFF6FF;
        color: #1E3A8A;
        border-radius: 14px;
    }

    .ns-kpi-card {
        background: #ffffff;
        border: 1px solid #E2E8F0;
        border-radius: 16px;
        padding: 1.4rem;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.10);
        min-height: 110px;
        position: relative;
        overflow: hidden;
    }

        .ns-kpi-card::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            width: 5px;
            height: 100%;
        }

    .ns-kpi-danger::before {
        background: #DC2626;
    }

    .ns-kpi-warning::before {
        background: #F59E0B;
    }

    .ns-kpi-label {
        font-size: 0.78rem;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: 0.5px;
        color: #64748B;
        margin-bottom: 0.5rem;
    }

    .ns-kpi-danger .ns-kpi-label {
        color: #DC2626;
    }

    .ns-kpi-warning .ns-kpi-label {
        color: #D97706;
    }

    .ns-kpi-value {
        color: #0F172A;
        font-size: 1.35rem;
        font-weight: 800;
    }

    .ns-card {
        background: #ffffff;
        border: 1px solid #E2E8F0;
        border-radius: 18px;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.10);
        overflow: hidden;
    }

    .ns-card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #E2E8F0;
        background: #ffffff;
    }

        .ns-card-header h6 {
            margin: 0;
            color: #2563EB;
            font-weight: 800;
        }

    .ns-card-body {
        padding: 1.25rem;
    }

    .datatable-compras {
        border-collapse: separate;
        border-spacing: 0 0.6rem;
        margin-bottom: 0;
    }

        .datatable-compras thead th {
            background: #F8FAFC;
            color: #334155;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.4px;
            border: 0;
            padding: 0.9rem 1rem;
        }

        .datatable-compras tbody tr {
            background: #ffffff;
            transition: all 0.2s ease;
        }

            .datatable-compras tbody tr:hover {
                background: #FFF7ED;
                transform: translateY(-1px);
            }

        .datatable-compras td {
            vertical-align: middle;
            padding: 1rem;
            border-top: 1px solid #E2E8F0;
            border-bottom: 1px solid #E2E8F0;
        }

            .datatable-compras td:first-child {
                border-left: 1px solid #E2E8F0;
                border-radius: 12px 0 0 12px;
            }

            .datatable-compras td:last-child {
                border-right: 1px solid #E2E8F0;
                border-radius: 0 12px 12px 0;
            }

    .ns-progress {
        height: 9px;
        background: #E2E8F0;
        border-radius: 999px;
        overflow: hidden;
    }

        .ns-progress .progress-bar {
            border-radius: 999px;
        }

    .text-muted {
        color: #64748B !important;
    }

    @@media (max-width: 768px) {
        .compras-header {
            align-items: stretch;
        }

        .compras-actions {
            justify-content: flex-start;
            width: 100%;
        }

            .compras-actions .btn {
                width: 100%;
            }
    }
</style>