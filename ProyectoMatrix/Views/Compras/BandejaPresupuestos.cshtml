@model List<ProyectoMatrix.Models.BandejaComprasVm>

@{
    ViewData["Title"] = "Bandeja Presupuestal";
    Layout = "_LayoutComunicados";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="container-fluid">
    <h3 class="h3 mb-2 text-gray-800">Control Presupuestal</h3>
    <p class="mb-4">Solicitudes pendientes de dictamen y asignación de presupuesto.</p>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-dark">
            <h6 class="m-0 font-weight-bold text-white">Solicitudes por Revisar</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead class="bg-light">
                        <tr>
                            <th>Folio</th>
                            <th>Solicitante</th>
                            <th>Tipo</th>
                            <th>Fecha</th>
                            <th>Estatus</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="font-weight-bold text-primary">@item.Folio</td>
                                <td>@item.Solicitante</td>
                                <td>@item.TipoCompra</td>
                                <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge badge-warning">@item.Estatus</span>
                                </td>
                                <td class="text-center">
                                    @* Este botón manda a la vista que ya configuramos *@
                                    <a href="@Url.Action("Dictamen", "Compras", new { id = item.SolicitudID })"
                                       class="btn btn-info btn-sm shadow-sm">
                                        <i class="fas fa-gavel fa-sm text-white-50 mr-1"></i> Dictaminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


                                    <style>
    /* --- Encabezado y Títulos --- */
    h3.text-gray-800 {
        color: #004a99 !important; /* Azul Corporativo */
        font-weight: 800;
        text-transform: uppercase;
    }

    .card-header.bg-dark {
        background-color: #004a99 !important; /* Azul Sólido */
        border-bottom: 3px solid #ff6b00; /* Acento Naranja */
    }

    /* --- Tabla de Dictamen --- */
    #dataTable {
        border-collapse: separate;
        border-spacing: 0 5px;
    }

        #dataTable thead.bg-light {
            background-color: #f0f4f8 !important;
            color: #004a99;
        }

        #dataTable thead th {
            border: none;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 15px;
        }

        #dataTable tbody tr {
            background-color: white;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            #dataTable tbody tr:hover {
                transform: scale(1.01);
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                background-color: #fdfdfd;
            }

        #dataTable td {
            vertical-align: middle;
            padding: 12px;
            border-top: 1px solid #e3e6f0;
            border-bottom: 1px solid #e3e6f0;
        }

    /* --- Folio y Estatus --- */
    td.text-primary {
        color: #004a99 !important;
        font-family: 'Consolas', monospace; /* Estilo técnico para Folios */
    }

    .badge-warning {
        background-color: #ff6b00 !important; /* Naranja para pendientes */
        color: white !important;
        padding: 6px 10px;
        font-weight: 600;
        border-radius: 4px;
        text-transform: uppercase;
    }

    /* --- Botón de Acción: Dictaminar --- */
    .btn-info.btn-sm {
        background-color: #004a99 !important; /* Azul para el mazo */
        border: none;
        font-weight: 700;
        padding: 8px 16px;
        transition: all 0.3s;
    }

        .btn-info.btn-sm:hover {
            background-color: #ff6b00 !important; /* Switch a Naranja en hover */
            box-shadow: 0 4px 10px rgba(255, 107, 0, 0.3) !important;
        }

    /* --- Mensajes de Ayuda --- */
    p.mb-4 {
        color: #5a5c69;
        font-style: italic;
        border-left: 3px solid #ff6b00;
        padding-left: 10px;
    }
                                    </style>