        background-color: #f5f7fb;
    }

    .container-fluid {
        padding-bottom: 2rem;
    }

    h2.fw-bold {
        color: #0f172a;
        font-weight: 800 !important;
        letter-spacing: -0.5px;
    }

    .btn {
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.2s ease;
    }

        .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.12);
        }

    .btn-outline-secondary {
        border-color: #cbd5e1;
        color: #475569;
        background: #ffffff;
    }

        .btn-outline-secondary:hover {
            background: #475569;
            color: #ffffff;
        }

    .btn-primary {
        background: #f97316 !important;
        border-color: #f97316 !important;
    }

    .btn-outline-info {
        color: #0891b2;
        border-color: #67e8f9;
        background: #ecfeff;
    }

        .btn-outline-info:hover {
            color: #ffffff;
            background: #0891b2;
            border-color: #0891b2;
        }

    .btn-outline-primary {
        color: #2563eb;
        border-color: #bfdbfe;
        background: #eff6ff;
    }

        .btn-outline-primary:hover {
            color: #ffffff;
            background: #2563eb;
            border-color: #2563eb;
        }

    .card {
        border-radius: 18px !important;
        border: 1px solid #e2e8f0 !important;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08) !important;
        overflow: hidden;
    }

    .card-body {
        padding: 1.25rem;
    }

    .row.mb-4 > .col-md-3 .card {
        min-height: 110px;
        position: relative;
    }

    .row.mb-4 > .col-md-3:nth-child(1) .card::before,
    .row.mb-4 > .col-md-3:nth-child(2) .card::before,
    .row.mb-4 > .col-md-3:nth-child(3) .card::before,
    .row.mb-4 > .col-md-3:nth-child(4) .card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        width: 5px;
        height: 100%;
    }

    .row.mb-4 > .col-md-3:nth-child(1) .card::before {
        background: #2563eb;
    }

    .row.mb-4 > .col-md-3:nth-child(2) .card::before {
        background: #0891b2;
    }

    .row.mb-4 > .col-md-3:nth-child(3) .card::before {
        background: #16a34a;
    }

    .row.mb-4 > .col-md-3:nth-child(4) .card::before {
        background: #dc2626;
    }

    .card h6.text-muted {
        color: #64748b !important;
        text-transform: uppercase;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
    }

    .card h3 {
        color: #0f172a;
        font-weight: 800;
        margin-bottom: 0;
    }

    .form-label {
        color: #334155;
        font-size: 0.85rem;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        min-height: 42px;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.15);
        }

    .form-check-input:checked {
        background-color: #f97316;
        border-color: #f97316;
    }

    .seguimiento-table-wrap {
        width: 100%;
        overflow: visible;
        border-radius: 14px;
    }

    .seguimiento-table {
        width: 100%;
        table-layout: auto;
    }

    .table {
        border-collapse: separate;
        border-spacing: 0 0.55rem;
        margin-bottom: 0;
    }

        .table thead th {
            background: #0f172a !important;
            color: #ffffff;
            border: none;
            text-transform: uppercase;
            font-size: 0.72rem;
