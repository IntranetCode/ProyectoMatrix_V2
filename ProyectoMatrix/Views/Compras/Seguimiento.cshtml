            }

        .table strong {
            color: #0f172a;
        }

    .seguimiento-table thead th {
        font-size: 0.68rem;
        padding: 0.75rem 0.65rem;
    }

    .seguimiento-table tbody td {
        font-size: 0.82rem;
        padding: 0.75rem 0.65rem;
    }

    .seguimiento-table td:nth-child(3),
    .seguimiento-table td:nth-child(4),
    .seguimiento-table td:nth-child(5),
    .seguimiento-table td:nth-child(6) {
