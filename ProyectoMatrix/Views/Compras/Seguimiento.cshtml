@model ProyectoMatrix.Models.SeguimientoDireccionVm

@{
    ViewData["Title"] = "Seguimiento";
    Layout = "_LayoutComunicados";
}

@{
    string returnUrl = Context.Request.Query["returnUrl"].ToString();

    if (string.IsNullOrWhiteSpace(returnUrl))
    {
        returnUrl = Url.Action("Index", "Compras");
    }
}

<a href="@returnUrl" class="btn btn-outline-secondary">
    Volver
</a>

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Seguimiento de Compras</h2>
    </div>

    <!-- KPIs -->
    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Total Solicitudes</h6>
                    <h3>@Model.TotalSolicitudes</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Activas</h6>
                    <h3 class="text-primary">@Model.TotalActivas</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Cerradas</h6>
                    <h3 class="text-success">@Model.TotalCerradas</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Retrasadas</h6>
                    <h3 class="text-danger">@Model.TotalRetrasadas</h3>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">

            <form method="get" asp-action="Seguimiento">

                <div class="row">

                    <div class="col-md-3 mb-2">
                        <label class="form-label fw-bold">Estatus</label>

                        <select name="estatus" class="form-select">
                            <option value="">Todos</option>
                            <option value="1">Solicitado</option>
                            <option value="2">Cotizado</option>
                            <option value="3">Presupuesto</option>
                            <option value="4">OC Generada</option>
                            <option value="5">OC Enviada</option>
                            <option value="6">Almacén</option>
                            <option value="8">Pendiente CxP</option>
                            <option value="10">Cerrada</option>
                            <option value="11">Rechazada CxP</option>
                        </select>
                    </div>

                    <div class="col-md-3 mb-2">
                        <label class="form-label fw-bold">Departamento</label>

                        <input type="text"
                               name="departamento"
                               class="form-control"
                               placeholder="Ej. Compras">
                    </div>

                    <div class="col-md-3 mb-2">
                        <label class="form-label fw-bold">Comprador</label>

                        <input type="text"
                               name="comprador"
                               class="form-control"
                               placeholder="Nombre comprador">
                    </div>

                    <div class="col-md-2 mb-2 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="soloRetrasadas"
                                   value="true"
                                   id="soloRetrasadas">

                            <label class="form-check-label" for="soloRetrasadas">
                                Solo retrasadas
                            </label>
                        </div>
                    </div>

                    <div class="col-md-1 mb-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            Filtrar
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>

    <!-- TABLA -->
    <div class="card shadow-sm border-0">

        <div class="card-body">

            <div class="seguimiento-table-container">

                <table class="table table-hover align-middle seguimiento-table">

                    <thead class="table-dark">
                        <tr>
                            <th>Folio</th>
                            <th>Fecha</th>
                            <th>Solicitante</th>
                            <th>Departamento</th>
                            <th>Comprador</th>
                            <th>Estatus</th>
                            @* <th>Días Estatus</th>*@
                            <th>Días transcurridos</th>
                            <th>Días permitidos</th>
                            <th>Urgencia</th>
                            <th>Semáforo</th>
                            <th>Monto</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>

                        @for (int i = 0; i < Model.Solicitudes.Count; i++)
                        {
                            var item = Model.Solicitudes[i];

                            <tr>

                                <td>
                                    <strong>@item.Folio</strong>
                                </td>

                                <td>
                                    @item.FechaCreacion.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @item.Solicitante
                                </td>

                                <td>
                                    @item.Departamento
                                </td>

                                <td>
                                    @item.CompradorAsignado
                                </td>

                                <td>
                                    @item.Estatus
                                </td>

                                @*
                                <td>
                                    <span class="fw-bold">
                                        @item.DiasEnEstatus
                                    </span>
                                </td>*@

                                <td>
                                    @item.DiasHabilesTranscurridos
                                </td>

                                <td>
                                    @item.DiasPermitidos
                                </td>

                                <td>
                                    @item.Urgencia
                                </td>

                                <td>
                                    <span class="@item.SemaforoCss">
                                        @item.SemaforoTexto
                                    </span>
                                </td>

                                <td>
                                    @String.Format("{0:C}", item.MontoCotizado)
                                </td>

                                <td>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-info btn-detalle"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalDetalleSeguimiento"
                                            data-folio="@item.Folio"
                                            data-solicitante="@item.Solicitante"
                                            data-comprador="@(string.IsNullOrWhiteSpace(item.CompradorAsignado) ? "Sin asignar" : item.CompradorAsignado)"
                                            data-compras="@item.DiasCompras"
                                            data-presupuesto="@item.DiasPresupuesto"
             
                                            data-proveedor="@item.DiasProveedor"
                                            data-almacen="@item.DiasAlmacen"
                                            data-cxp="@item.DiasCxP">
                                        Ver detalles
                                    </button>

                                    <a asp-action="Detalle"
                                       asp-route-id="@item.SolicitudID"
                                       asp-route-returnUrl="@Context.Request.Path"
                                       class="btn btn-sm btn-outline-primary">
                                        Ver
                                    </a>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- MODAL ÚNICO -->
<div class="modal fade"
     id="modalDetalleSeguimiento"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-primary text-white">

                <h5 class="modal-title">
                    Seguimiento detallado -
                    <span id="mdFolio"></span>
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="row mb-3">

                    <div class="col-md-6">
                        <strong>Solicitante:</strong><br />
                        <span id="mdSolicitante"></span>
                    </div>

                    <div class="col-md-6">
                        <strong>Comprador:</strong><br />
                        <span id="mdComprador"></span>
                    </div>

                </div>

                <table class="table table-bordered">

                    <thead class="table-light">
                        <tr>
                            <th>Área</th>
                            <th>Días hábiles</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>Compras (Cotizando)</td>
                            <td id="mdCompras"></td>
                        </tr>

                        <tr>
                            <td>Control Presupuestal</td>
                            <td id="mdPresupuesto"></td>
                        </tr>

                        <tr>
                            <td>Compras generando O.C.</td>
                            <td id="mdOC"></td>
                        </tr>

                        <tr>
                            <td>En espera del proveedor</td>
                            <td id="mdProveedor"></td>
                        </tr>

                        <tr>
                            <td>Recepción en almacén</td>
                            <td id="mdAlmacen"></td>
                        </tr>

                        <tr>
                            <td>Cuentas por Pagar</td>
                            <td id="mdCxP"></td>
                        </tr>

                    </tbody>

                </table>

                <div class="alert alert-info">
                    <strong>Total días hábiles del proceso:</strong>
                    <span id="mdTotal"></span>
                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cerrar
                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            document.querySelectorAll('.btn-detalle').forEach(function (btn) {

                btn.addEventListener('click', function () {

                    const compras = parseInt(btn.dataset.compras || '0');
                    const presupuesto = parseInt(btn.dataset.presupuesto || '0');
                    const oc = parseInt(btn.dataset.oc || '0');
                    const proveedor = parseInt(btn.dataset.proveedor || '0');
                    const almacen = parseInt(btn.dataset.almacen || '0');
                    const cxp = parseInt(btn.dataset.cxp || '0');

                    document.getElementById('mdFolio').innerText =
                        btn.dataset.folio || '';

                    document.getElementById('mdSolicitante').innerText =
                        btn.dataset.solicitante || '';

                    document.getElementById('mdComprador').innerText =
                        btn.dataset.comprador || 'Sin asignar';

                    document.getElementById('mdCompras').innerText =
                        compras;

                    document.getElementById('mdPresupuesto').innerText =
                        presupuesto;

                    document.getElementById('mdOC').innerText =
                        oc;

                    document.getElementById('mdProveedor').innerText =
                        proveedor;

                    document.getElementById('mdAlmacen').innerText =
                        almacen;

                    document.getElementById('mdCxP').innerText =
                        cxp;

                    document.getElementById('mdTotal').innerText =
                        compras + presupuesto + oc + proveedor + almacen + cxp;

                });

            });

        });
    </script>

}

<style>
