@model ProyectoMatrix.Models.CuentasPorPagarVm

@{
    ViewData["Title"] = "Cuentas por Pagar";
    Layout = "_LayoutComunicados";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="container-fluid">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-info text-white">
            <h6 class="m-0 font-weight-bold">
                <i class="fas fa-file-invoice-dollar mr-2"></i>
                Bandeja Cuentas por Pagar
            </h6>
        </div>

        <div class="card-body">

            <ul class="nav nav-tabs mb-4">
                <li class="nav-item">
                    <button class="nav-link active"
                            data-bs-toggle="tab"
                            data-bs-target="#tabPendientes"
                            type="button">
                        Pendientes
                        <span class="badge bg-info ms-1">
                            @(Model.Pendientes?.Count ?? 0)
                        </span>
                    </button>
                </li>

                <li class="nav-item">
                    <button class="nav-link"
                            data-bs-toggle="tab"
                            data-bs-target="#tabHistorico"
                            type="button">
                        Histórico
                        <span class="badge bg-secondary ms-1">
                            @(Model.Historico?.Count ?? 0)
                        </span>
                    </button>
                </li>
            </ul>

            <div class="tab-content">

                <div class="tab-pane fade show active" id="tabPendientes">
                    @if (Model.Pendientes != null && Model.Pendientes.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover table-sm">
                                <thead>
                                    <tr>
                                        <th>Folio</th>
                                        <th>Solicitante</th>
                                        <th>Empresa</th>
                                        <th>Proveedor</th>
                                        <th>Monto</th>
                                        <th>O.C.</th>
                                        <th>Tipo</th>
                                        <th>Fecha entrega</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Pendientes)
                                    {
                                        <tr>
                                            <td class="font-weight-bold">@item.Folio</td>
                                            <td>@item.Solicitante</td>
                                            <td>@item.Empresa</td>
                                            <td>@item.Proveedor</td>
                                            <td>@item.MontoTotal.ToString("C")</td>
                                            <td>@item.NumeroOC</td>
                                            <td>
                                                <span class="badge badge-primary">
                                                    @(string.IsNullOrEmpty(item.TipoGasto) ? "N/A" : item.TipoGasto)
                                                </span>
                                            </td>
                                            <td>
                                                @(item.FechaEntregaUsuario.HasValue
                                                                                        ? item.FechaEntregaUsuario.Value.ToString("dd/MM/yyyy HH:mm")
                                                                                        : "N/A")
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="DetalleCuentasPorPagar"
                                           asp-route-id="@item.SolicitudID"
                                           class="btn btn-sm btn-outline-primary">
                                            Ver expediente
                                        </a>
                                    </td>
                                </tr>
                                                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            No hay solicitudes pendientes de validación por Cuentas por Pagar.
                        </div>
                    }
                </div>

                <div class="tab-pane fade" id="tabHistorico">
                    @if (Model.Historico != null && Model.Historico.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover table-sm">
                                <thead>
                                    <tr>
                                        <th>Folio</th>
                                        <th>Solicitante</th>
                                        <th>Empresa</th>
                                        <th>Proveedor</th>
                                        <th>Monto</th>
                                        <th>O.C.</th>
                                        <th>Tipo</th>
                                        <th>Estatus</th>
                                        <th>Fecha CxP</th>
                                        <th class="text-center">Detalle</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Historico)
                                    {
                                        <tr>
                                            <td class="font-weight-bold">@item.Folio</td>
                                            <td>@item.Solicitante</td>
                                            <td>@item.Empresa</td>
                                            <td>@item.Proveedor</td>
                                            <td>@item.MontoTotal.ToString("C")</td>
                                            <td>@item.NumeroOC</td>
                                            <td>
                                                <span class="badge badge-primary">
                                                    @(string.IsNullOrEmpty(item.TipoGasto) ? "N/A" : item.TipoGasto)
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @(item.EstatusID == 10 ? "bg-success" : "bg-danger")">
                                                    @item.Estatus
                                                </span>
                                            </td>
                                            <td>
                                                @(item.FechaCierreCxP.HasValue
                                                                                        ? item.FechaCierreCxP.Value.ToString("dd/MM/yyyy HH:mm")
                                                                                        : "N/A")
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="DetalleCuentasPorPagar"
                                           asp-route-id="@item.SolicitudID"
                                           class="btn btn-sm btn-outline-primary">
                                            Ver
                                        </a>
                                    </td>
                                </tr>

                                @if (!string.IsNullOrWhiteSpace(item.ComentariosCxP))
                                        {
                                            <tr>
                                                <td colspan="10">
                                                    <small class="text-muted font-weight-bold">Comentarios CxP:</small>
                                                    <div>@item.ComentariosCxP</div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            No hay solicitudes en el histórico de Cuentas por Pagar.
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

<style>

    body {
        background: #f5f7fb;
    }


    .btn {
        border-radius: 10px;
        font-weight: 700;
        transition: .25s;
    }

        .btn:hover {
            transform: translateY(-1px);
        }

    .btn-outline-secondary {
        border-color: #cbd5e1;
        color: #475569;
        background: white;
    }

        .btn-outline-secondary:hover {
            background: #475569;
            color: white;
        }

    .btn-outline-primary {
        color: #0891b2;
        border-color: #0891b2;
        background: #f0fdfa;
    }

        .btn-outline-primary:hover {
            background: #0891b2;
            border-color: #0891b2;
            color: white;
        }

  

    .card {
        border: none !important;
        border-radius: 18px !important;
        overflow: hidden;
        box-shadow: 0 12px 28px rgba(15,23,42,.08) !important;
    }

    .card-header.bg-info {
        background: linear-gradient( 135deg, #0891b2, #06b6d4 ) !important;
        border: none;
    }

    .card-header h6 {
        color: white !important;
        font-weight: 800;
        letter-spacing: .3px;
    }


    .table {
        border-collapse: separate;
        border-spacing: 0 .55rem;
        margin-bottom: 0;
    }

        .table thead th {
            background: #f8fafc !important;
            color: #334155;
            border: none !important;
            text-transform: uppercase;
            font-size: .72rem;
            letter-spacing: .5px;
            font-weight: 800;
            padding: 14px;
            white-space: nowrap;
        }

        .table tbody tr {
            background: white;
            transition: .2s;
        }

            .table tbody tr:hover {
                background: #ecfeff;
                transform: translateY(-1px);
            }

        .table td {
            vertical-align: middle;
            padding: 14px;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
        }

            .table td:first-child {
                border-left: 1px solid #e2e8f0;
                border-radius: 12px 0 0 12px;
                font-weight: 800;
                color: #0891b2;
            }

            .table td:last-child {
                border-right: 1px solid #e2e8f0;
                border-radius: 0 12px 12px 0;
            }

        

            .table td:nth-child(5) {
                font-weight: 800;
                color: #0f172a;
            }

   

    .badge-primary {
        background: #0891b2 !important;
        color: white !important;
        padding: .55rem .85rem;
        border-radius: 999px;
        font-weight: 700;
    }

  

    .alert {
        border: none;
        border-radius: 14px;
    }

    .alert-info {
        background: #ecfeff;
        color: #155e75;
        border-left: 5px solid #0891b2;
    }

    .alert-danger {
        background: #fef2f2;
        color: #991b1b;
        border-left: 5px solid #dc2626;
    }

    .alert-success {
        background: #f0fdf4;
        color: #166534;
        border-left: 5px solid #16a34a;
    }

    

    .table-responsive {
        border-radius: 14px;
    }


    @@media(max-width:768px) {

        .btn {
            width: 100%;
            margin-bottom: 6px;
        }

        .d-flex.justify-content-between {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 10px;
        }
    }

</style>