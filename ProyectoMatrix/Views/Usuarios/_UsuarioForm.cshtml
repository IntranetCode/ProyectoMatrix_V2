<script>

    // ===== MODAL RESTABLECER CONTRASEÑA =====
    window.prepararModalRestablecerPasswordUsuario = function (modalId) {
        if (!modalId) return null;

        const modalEl = document.getElementById(modalId);
        if (!modalEl) return null;

        document.querySelectorAll('#' + modalId).forEach(function (x) {
            if (x !== modalEl) x.remove();
        });

        if (modalEl.parentElement !== document.body) {
            modalEl.__usuarioFormOriginalParent = modalEl.parentElement;
            modalEl.__usuarioFormNextSibling = modalEl.nextSibling;
            document.body.appendChild(modalEl);
        }

        modalEl.classList.add('pm-reset-password-modal');
        modalEl.style.setProperty('z-index', '2147483000', 'important');
        document.body.classList.add('pm-reset-password-open');

        function ajustarBackdrops() {
            document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                backdrop.classList.add('pm-reset-password-backdrop');
                backdrop.style.setProperty('z-index', '2147482990', 'important');
            });
        }

        ajustarBackdrops();
        setTimeout(ajustarBackdrops, 0);
        setTimeout(ajustarBackdrops, 80);

        return modalEl;
    };

    window.abrirRestablecerPasswordUsuario = function (ev, modalId) {
        if (ev) {
            ev.preventDefault();
            ev.stopPropagation();
        }

        const modalEl = window.prepararModalRestablecerPasswordUsuario(modalId);

        if (!modalEl) {
            alert('No se encontró el modal de restablecer contraseña.');
            return false;
        }

        if (!window.bootstrap?.Modal) {
            alert('No se encontró Bootstrap Modal. Revisa que bootstrap.bundle.js esté cargado.');
            return false;
        }

        const form = modalEl.querySelector('#form-restablecer-password');
        if (form) form.reset();

        const resultado = modalEl.querySelector('#resetPasswordResultado');
        if (resultado) {
            resultado.className = 'alert d-none';
            resultado.textContent = '';
        }

        const forzar = modalEl.querySelector('#resetForzarCambio');
        const enviar = modalEl.querySelector('#resetEnviarCorreo');
        if (forzar) forzar.checked = true;
        if (enviar) enviar.checked = true;

        modalEl.querySelectorAll('.pm-secret-field').forEach(function (input) {
            input.type = 'text';
            input.classList.add('pm-secret-masked');
            input.classList.remove('pm-secret-unmasked');
        });

        modalEl.querySelectorAll('.js-toggle-reset-password i').forEach(function (icon) {
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        });

        bootstrap.Modal.getOrCreateInstance(modalEl, {
            backdrop: true,
            keyboard: true,
            focus: true
        }).show();

        return false;
    };


    (function () {
        const resetModalId = '@resetPasswordModalId';
        const modalEl = document.getElementById(resetModalId);
        const form = modalEl?.querySelector('#form-restablecer-password');
        const abrirBtn = document.getElementById('btnAbrirRestablecerPassword');

        if (!modalEl || !form || form.dataset.bound === '1') return;
        form.dataset.bound = '1';

        const resultado = modalEl.querySelector('#resetPasswordResultado');
        const submitBtn = modalEl.querySelector('#btnRestablecerPasswordSubmit');

        function moverModalAlBody() {
            document.querySelectorAll('#' + resetModalId).forEach(function (x) {
                if (x !== modalEl) x.remove();
            });

            if (modalEl.parentElement === document.body) return;

            modalEl.__usuarioFormOriginalParent = modalEl.parentElement;
            modalEl.__usuarioFormNextSibling = modalEl.nextSibling;
            document.body.appendChild(modalEl);
        }

        function regresarModalAlPanel() {
            const originalParent = modalEl.__usuarioFormOriginalParent;
            const nextSibling = modalEl.__usuarioFormNextSibling;

            if (!originalParent || !document.body.contains(modalEl)) return;

            if (nextSibling && nextSibling.parentElement === originalParent) {
                originalParent.insertBefore(modalEl, nextSibling);
            } else {
                originalParent.appendChild(modalEl);
            }
        }

        function limpiarBackdropsHuerfanos() {
            if (document.querySelector('.modal.show')) return;
            document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                backdrop.remove();
            });
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('overflow');
            document.body.style.removeProperty('padding-right');
        }

        function mostrarResultado(tipo, mensaje) {
            if (!resultado) {
                alert(mensaje);
                return;
            }

            resultado.className = 'alert ' + (tipo === 'success' ? 'alert-success' : 'alert-danger');
            resultado.textContent = mensaje;
            resultado.classList.remove('d-none');
        }

        function limpiarResultado() {
            if (!resultado) return;
            resultado.className = 'alert d-none';
            resultado.textContent = '';
        }

        function limpiarFormulario() {
            limpiarResultado();
            form.reset();

            const forzar = modalEl.querySelector('#resetForzarCambio');
            const enviar = modalEl.querySelector('#resetEnviarCorreo');
            const nueva = modalEl.querySelector('#resetNuevaPassword');
            const confirmar = modalEl.querySelector('#resetConfirmarPassword');

            if (forzar) forzar.checked = true;
            if (enviar) enviar.checked = true;

            [nueva, confirmar].forEach(function (input) {
                if (!input) return;
                input.type = 'text';
                input.classList.add('pm-secret-field', 'pm-secret-masked');
                input.classList.remove('pm-secret-unmasked');
            });

            modalEl.querySelectorAll('.js-toggle-reset-password i').forEach(function (icon) {
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            });
        }

        function reforzarCapasRestablecerPassword() {
            modalEl.classList.add('pm-reset-password-modal');
            modalEl.style.setProperty('z-index', '2147483000', 'important');
            document.body.classList.add('pm-reset-password-open');

            document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                backdrop.classList.add('pm-reset-password-backdrop');
                backdrop.style.setProperty('z-index', '2147482990', 'important');
            });

            setTimeout(function () {
                document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                    backdrop.classList.add('pm-reset-password-backdrop');
                    backdrop.style.setProperty('z-index', '2147482990', 'important');
                });
            }, 0);
        }

        modalEl.addEventListener('show.bs.modal', function () {
            moverModalAlBody();
            limpiarFormulario();
            reforzarCapasRestablecerPassword();
        });

        modalEl.addEventListener('shown.bs.modal', function () {
            reforzarCapasRestablecerPassword();

            const primerInput = modalEl.querySelector('#resetNuevaPassword');
            if (primerInput) primerInput.focus();
        });

        abrirBtn?.addEventListener('pointerdown', function () {
            moverModalAlBody();
            reforzarCapasRestablecerPassword();
        }, true);

        abrirBtn?.addEventListener('click', function () {
            moverModalAlBody();
            reforzarCapasRestablecerPassword();
            // No usamos preventDefault: Bootstrap abre el modal por data-bs-toggle/data-bs-target.
        }, true);

        modalEl.addEventListener('hidden.bs.modal', function () {
            limpiarFormulario();

            modalEl.classList.remove('pm-reset-password-modal');
            modalEl.style.removeProperty('z-index');
            document.body.classList.remove('pm-reset-password-open');

            regresarModalAlPanel();
            limpiarBackdropsHuerfanos();
        });

        document.addEventListener('click', function (ev) {
            const btn = ev.target.closest('.js-toggle-reset-password');
            if (!btn || !modalEl.contains(btn)) return;
            if (btn.hasAttribute('onclick')) return;

            ev.preventDefault();
            ev.stopPropagation();

            const input = modalEl.querySelector('#' + btn.dataset.target);
            const icon = btn.querySelector('i');
            if (!input) return;

            input.type = 'text';
            input.classList.add('pm-secret-field');

            const revelar = input.classList.contains('pm-secret-masked');
            input.classList.toggle('pm-secret-masked', !revelar);
            input.classList.toggle('pm-secret-unmasked', revelar);

            if (icon) {
                icon.classList.toggle('fa-eye', !revelar);
                icon.classList.toggle('fa-eye-slash', revelar);
            }
        });

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            limpiarResultado();

            const nueva = form.querySelector('[name="nuevaPassword"]')?.value || '';
            const confirmar = form.querySelector('[name="confirmarPassword"]')?.value || '';

            if (nueva.length < 6) {
                mostrarResultado('error', 'La contraseña debe tener al menos 6 caracteres.');
                return;
            }

            if (nueva !== confirmar) {
                mostrarResultado('error', 'La confirmación no coincide con la nueva contraseña.');
                return;
            }

            const originalHtml = submitBtn?.innerHTML;
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';
            }

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: new FormData(form),
                    credentials: 'same-origin'
                });

                const data = await response.json().catch(function () { return null; });
                if (!response.ok || !data?.ok) {
                    throw new Error(data?.message || 'No fue posible restablecer la contraseña.');
                }

                mostrarResultado('success', data.message || 'Contraseña restablecida correctamente.');

                const nuevaInput = form.querySelector('[name="nuevaPassword"]');
                const confirmarInput = form.querySelector('[name="confirmarPassword"]');
                if (nuevaInput) nuevaInput.value = '';
                if (confirmarInput) confirmarInput.value = '';
            } catch (err) {
                mostrarResultado('error', err.message || 'Error al restablecer la contraseña.');
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                }
            }
        });
    })();

    (function () {
        const userForm = document.getElementById('user-form');
        if (!userForm) return;

        function mostrarModalConfirmacion(message, redirectUrl) {
            const modalEl = document.getElementById('modalUsuarioGuardado');
            if (modalEl && modalEl.parentElement !== document.body) {
                document.body.appendChild(modalEl);
            }
            const msgEl = document.getElementById('modalUsuarioGuardadoMensaje');
            if (msgEl) msgEl.textContent = message || 'Los cambios se han guardado correctamente.';

            if (!modalEl || !window.bootstrap?.Modal) {
                alert(message || 'Los cambios se han guardado correctamente.');
                if (redirectUrl) window.location.href = redirectUrl;
                return;
            }

            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modalEl.addEventListener('hidden.bs.modal', function handler() {
                modalEl.removeEventListener('hidden.bs.modal', handler);
                if (redirectUrl) window.location.href = redirectUrl;
            });
            modal.show();
        }

        userForm.addEventListener('submit', async function (e) {
            e.preventDefault();

            if (window.jQuery && $.validator && !$(userForm).valid()) return;

            const submitBtn = userForm.querySelector('button[type="submit"]');
            const originalHtml = submitBtn?.innerHTML;
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';
            }

            try {
                const response = await fetch(userForm.action, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: new FormData(userForm),
                    credentials: 'same-origin'
                });

                const contentType = response.headers.get('content-type') || '';
                if (contentType.includes('application/json')) {
                    const data = await response.json();
                    if (!response.ok || !data?.ok) throw new Error(data?.message || 'No fue posible guardar los cambios.');
                    mostrarModalConfirmacion(data.message, data.redirectUrl);
                    return;
                }

                const html = await response.text();
                const doc = new DOMParser().parseFromString(html, 'text/html');
                const updatedForm = doc.getElementById('user-form');
                if (updatedForm) {
                    userForm.outerHTML = updatedForm.outerHTML;
                } else {
                    throw new Error('La respuesta del servidor no pudo procesarse correctamente.');
                }
            } catch (err) {
                alert(err.message || 'Error al guardar los cambios.');
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                }
            }
        });
    })();

    // ===== GESTOR DE PERMISOS =====
    (function () {
        const ovForm = document.getElementById('ov-form');
        const ovSave = document.getElementById('ov-save');
        const dirtyTop = document.getElementById('ov-dirty-indicator');
        const dirtyBot = document.getElementById('ov-dirty-indicator-bottom');
        const resetAllBtn = document.getElementById('ov-reset-all');

        if (!ovForm) return;

        let isDirty = false;

        function markDirty() {
            if (!isDirty) {
                isDirty = true;
                dirtyTop?.classList.remove('d-none');
                dirtyBot?.classList.remove('d-none');
            }
        }

        function clearDirty() {
            isDirty = false;
            dirtyTop?.classList.add('d-none');
            dirtyBot?.classList.add('d-none');
        }

        function updateBadge(tr, estado) {
            const badgeWrap = tr.querySelector('.ov-badge');
            const badge = badgeWrap?.querySelector('.badge');
            if (estado === -1) {
                badgeWrap?.classList.add('d-none');
            } else {
                if (badge) {
                    badge.className = 'badge ' + (estado === 1 ? 'bg-success' : 'bg-warning text-dark');
                    badge.textContent = estado === 1 ? 'Override: Permitido' : 'Override: Denegado';
                }
                badgeWrap?.classList.remove('d-none');
            }
        }

        function showToast(type, message) {
            document.querySelectorAll('.alert.position-fixed').forEach(a => a.remove());
            const alertClass = type === 'success' ? 'alert-success' : type === 'error' ? 'alert-danger' : 'alert-info';
            const icon = type === 'success' ? '✓' : type === 'error' ? '✗' : 'ℹ';
            const el = document.createElement('div');
            el.className = `alert ${alertClass} alert-dismissible fade show position-fixed`;
            el.style.cssText = 'top:20px;right:20px;z-index:9999;min-width:350px;box-shadow:0 4px 12px rgba(0,0,0,.15)';
            el.innerHTML = `<strong>${icon} ${type === 'success' ? 'Éxito' : type === 'error' ? 'Error' : 'Info'}:</strong> ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), type === 'success' ? 4000 : 7000);
        }

        document.getElementById('tab-permisos')?.addEventListener('change', (ev) => {
            if (!ev.target.classList.contains('ov-radio')) return;
            const tr = ev.target.closest('tr');
            updateBadge(tr, parseInt(ev.target.value));
            markDirty();
        });

        ovForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const originalHtml = ovSave.innerHTML;
            ovSave.disabled = true;
            ovSave.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';

            try {
                const fd = new FormData(ovForm);
                const url = '@Url.Action("GuardarOverrides", "Usuarios")';
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
                    body: fd,
                    credentials: 'same-origin'
                });

                const data = await res.json();
                if (!res.ok || !data?.ok) throw new Error(data?.message || `Error HTTP ${res.status}`);

                clearDirty();
                showToast('success', data.message || 'Permisos actualizados correctamente');

                document.querySelectorAll('#tab-permisos tr[data-submenu]').forEach(tr => {
                    const checked = tr.querySelector('.ov-radio:checked');
                    if (checked) tr.setAttribute('data-estado-inicial', checked.value);
                });

            } catch (err) {
                showToast('error', err.message || 'Error al guardar los cambios');
            } finally {
                ovSave.disabled = false;
                ovSave.innerHTML = originalHtml;
            }
        });

        resetAllBtn?.addEventListener('click', () => {
            if (!isDirty) { showToast('info', 'No hay cambios para deshacer'); return; }
            if (!confirm('¿Descartar todos los cambios no guardados?')) return;

            document.querySelectorAll('#ov-form tr[data-submenu]').forEach(tr => {
                const estadoInicial = parseInt(tr.getAttribute('data-estado-inicial') ?? '-1');
                const radio = tr.querySelector(`.ov-radio[value="${estadoInicial}"]`);
                if (radio) { radio.checked = true; updateBadge(tr, estadoInicial); }
            });
            clearDirty();
        });
    })();

