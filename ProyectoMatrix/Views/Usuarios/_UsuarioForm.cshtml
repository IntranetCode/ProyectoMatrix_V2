    if (window.jQuery && $.fn && $.fn.select2) {
    $(document).ready(function() {
           const commonOptions = {
        theme: 'bootstrap-5',
        width: '100%',
        // Esto asegura que el buscador "viva" dentro del panel y no sea bloqueado
        dropdownParent: $('#user-form'),
        language: {
            inputTooShort: () => "Por favor, introduzca 1 o más caracteres",
            noResults: () => "No se encontraron resultados",
            searching: () => "Buscando..."
        },
        minimumInputLength: 1
    };

        // 1. Selector de Departamento vinculado directamente al campo DepartamentoID
        $('#selectDepartamento').select2({
            theme: 'bootstrap-5',
            width: '100%',
            dropdownParent: $('#user-form'),
            placeholder: '-- Seleccione un Departamento --',
            allowClear: true,
            language: {
                noResults: () => "No se encontraron resultados"
            }
        });

        // 2. Buscador de Jefes
        $('#selectJefe').select2({
            ...commonOptions,
            placeholder: '-- Buscar Jefe --',
            ajax: {
                url: '@Url.Action("BuscarPersonasJefes", "Usuarios")',
                dataType: 'json',
                delay: 250,
                data: params => ({ term: params.term }),
                processResults: data => ({ results: data.results })
            }
        });

    

        @if (Model.JefeInmediatoPersonaID > 0)
        {
                <text>
                var optJefe = new Option('@Model.JefeInmediatoNombreCompleto', '@Model.JefeInmediatoPersonaID', true, true);
                $('#selectJefe').append(optJefe).trigger('change');
                </text>
        }
    });
    }

    window.togglePasswordVisibility = function togglePasswordVisibility() {
        const passInput = document.getElementById('txtPassword');
        const eyeIcon = document.getElementById('eyeIcon');
        if (!passInput) return;

        passInput.type = 'text';
        passInput.classList.add('pm-secret-field');

        const revelar = passInput.classList.contains('pm-secret-masked');
        passInput.classList.toggle('pm-secret-masked', !revelar);
        passInput.classList.toggle('pm-secret-unmasked', revelar);

        if (eyeIcon) {
            eyeIcon.classList.toggle('fa-eye', !revelar);
            eyeIcon.classList.toggle('fa-eye-slash', revelar);
        }
    };
</script>
