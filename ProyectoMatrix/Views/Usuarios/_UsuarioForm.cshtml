                                        onclick="if(event){event.preventDefault();event.stopPropagation();}var input=this.closest('.input-group').querySelector('input');var icon=this.querySelector('i');if(input){input.type='text';input.classList.add('pm-secret-field');var reveal=input.classList.contains('pm-secret-masked');input.classList.toggle('pm-secret-masked',!reveal);input.classList.toggle('pm-secret-unmasked',reveal);if(icon){icon.classList.toggle('fa-eye',!reveal);icon.classList.toggle('fa-eye-slash',reveal);}}return false;"
