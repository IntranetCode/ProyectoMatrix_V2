                                <span class="input-group-text bg-white"><i class="fas fa-user-tie text-primary"></i></span>
                                <select asp-for="JefeInmediatoPersonaID" id="selectJefe" class="form-select">
                                    @if (Model.JefeInmediatoPersonaID > 0)
                                    {
                                        <option value="@Model.JefeInmediatoPersonaID" selected>@Model.JefeInmediatoNombreCompleto</option>
                                    }
                                    else
                                    {
                                        <option value="">-- Buscar Jefe --</option>
                                    }
                                </select>
                            </div>
                        </div>

                        
                    @*    @if (!Model.EsModoCrear)
                        {
                            <div class="col-md-12 mt-3">
                                <div class="p-3 border border-warning rounded bg-light bg-opacity-10">
                                    <h6 class="text-warning d-flex align-items-center">
                                        <i class="fas fa-calendar-alt me-2"></i> Ajuste Manual de Vacaciones (RH)
                                    </h6>
                                    <p class="small text-muted mb-3">Utilice esta opción para cargar días que el colaborador ya tomó antes de la implementación del sistema.</p>
                                    <button type="button" class="btn btn-outline-warning btn-sm" onclick="abrirModalAjuste(@Model.UsuarioID)">
                                        <i class="fas fa-plus-circle me-1"></i> Cargar Saldo Pendiente
                                    </button>
                                </div>
                            </div>
                        }*@

                    </div>
                </div>


                @if (Model.EsModoCrear)
                {
                    <div class="form-section">
                        <div class="section-header">
                            <i class="fas fa-lock section-icon"></i>
                            <h5 class="section-title">Credenciales de Acceso</h5>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Username" class="form-label-modern"></label>
                                <input asp-for="Username" class="form-control form-control-modern" placeholder="usuario123" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label-modern">Contraseña</label>
                                <div class="input-group">
                                    <input asp-for="Password" type="text" id="txtPassword" class="form-control form-control-modern pm-secret-field pm-secret-masked" placeholder="••••••••" autocomplete="off" data-lpignore="true" data-1p-ignore="true" />
                                    <button class="btn btn-outline-secondary border-2" type="button" onclick="if(event){event.preventDefault();event.stopPropagation();}var input=this.closest('.input-group').querySelector('input');var icon=this.querySelector('i');if(input){input.type='text';input.classList.add('pm-secret-field');var reveal=input.classList.contains('pm-secret-masked');input.classList.toggle('pm-secret-masked',!reveal);input.classList.toggle('pm-secret-unmasked',reveal);if(icon){icon.classList.toggle('fa-eye',!reveal);icon.classList.toggle('fa-eye-slash',reveal);}}return false;">
                                        <i id="eyeIcon" class="fas fa-eye"></i>
