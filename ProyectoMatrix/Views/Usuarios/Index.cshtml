    <script>
            function abrirModalAjuste(usuarioId) {
        $('#ajusteUsuarioID').val(usuarioId);
        $('#formAjusteVacaciones')[0].reset();
        $('#modalAjusteVacaciones').modal('show');
    }

    function guardarAjuste() {
        const formData = $('#formAjusteVacaciones').serialize();

        $.post('/AdminUsuarios/Usuarios/RegistrarAjusteVacaciones', formData, function (response) {
            if (response.success) {
                Swal.fire('¡Éxito!', response.message, 'success');
                $('#modalAjusteVacaciones').modal('hide');
            } else {
                Swal.fire('Error', response.message, 'error');
            }
        });
    }
    </script>