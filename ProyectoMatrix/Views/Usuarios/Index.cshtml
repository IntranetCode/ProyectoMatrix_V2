        }

        .usuarios-mobile-list {
            display: grid;
        }

        .usuarios-list-header {
            padding: 1rem;
            align-items: flex-start;
            flex-direction: column;
            gap: .3rem;
        }
    }

    @@media (max-width: 420px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .usuarios-search-group {
            grid-template-columns: 1fr auto;
        }

        .usuarios-search-group .form-control {
            grid-column: 1 / 2;
            min-width: 0;
        }

        .usuarios-search-group .btn-clear {
            grid-column: 1 / -1;
            border-left: 0 !important;
            border-top: 1px solid var(--ns-border) !important;
        }
    }
</style>

<div class="page-container">
    <div class="usuarios-shell">
        <div class="page-header-static">
            <section class="usuarios-hero">
                <div class="usuarios-hero-grid">
                    <aside class="usuarios-hero-side">
                        <div class="usuarios-hero-content">
                            <div class="usuarios-icon-box">
                                <i class="@(modoAccesos ? "fas fa-paper-plane" : "fas fa-users-cog")"></i>
                            </div>

                            <h1 class="usuarios-title">@ViewData["Title"]</h1>
                            <p class="usuarios-subtitle">
                                @if (modoAccesos)
                                {
                                    @:Selecciona un usuario activo con correo para reenviarle sus credenciales de acceso.
                                }
                                else
                                {
                                    @:Administra usuarios, consulta su estado y actualiza su información de forma rápida.
                                }
                            </p>

                            @if (!modoAccesos)
                            {
                                <a id="btn-crear-usuario"
                                   asp-action="Crear"
                                   asp-controller="Usuarios"
                                   class="btn-modern-primary">
                                    <i class="fas fa-plus"></i>
                                    Agregar usuario
                                </a>
                            }
                            else
                            {
                                <div class="hero-info-note">
                                    <i class="fas fa-envelope"></i>
                                    Reenvío individual por correo
                                </div>
                            }
                        </div>

                        <div class="usuarios-filter-note">
                            <i class="fas fa-filter me-1"></i>@EstadoFiltroLabel()
                        </div>
                    </aside>

                    <main class="usuarios-hero-main">
                        <div class="usuarios-actions-row">
                            <form asp-action="@actionBusqueda" method="get" class="usuarios-search-form">
                                @if (!modoAccesos)
                                {
                                    <input type="hidden" name="activos" value="@activosQuery" />
                                }

                                <div class="input-group usuarios-search-group">
                                    <select name="filtroCampo" class="form-select flex-grow-0" aria-label="Campo de búsqueda">
                                        <option value="Todos" selected="@(filtroCampoActual == "Todos")">Todos los campos</option>
                                        <option value="Nombre" selected="@(filtroCampoActual == "Nombre")">Nombre</option>
                                        <option value="ApellidoPaterno" selected="@(filtroCampoActual == "ApellidoPaterno")">Apellido</option>
                                        <option value="Correo" selected="@(filtroCampoActual == "Correo")">Correo</option>
                                        <option value="Username" selected="@(filtroCampoActual == "Username")">Username</option>
                                    </select>

                                    <input type="text"
                                           name="busqueda"
                                           class="form-control"
                                           placeholder="Buscar usuario..."
                                           value="@busquedaActual"
                                           aria-label="Buscar usuario" />

                                    <button class="btn btn-search" type="submit" title="Buscar">
                                        <i class="fas fa-search"></i>
                                    </button>

                                    @if (!string.IsNullOrWhiteSpace(busquedaActual))
                                    {
                                        if (modoAccesos)
                                        {
                                            <a asp-action="Accesos"
                                               class="btn btn-clear"
                                               title="Limpiar filtro">
                                                <i class="fas fa-times"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="Index"
                                               asp-route-activos="@activosQuery"
                                               class="btn btn-clear"
                                               title="Limpiar filtro">
                                                <i class="fas fa-times"></i>
                                            </a>
                                        }
                                    }
                                </div>
                            </form>
                        </div>

                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-icon">
                                    <i class="fas fa-users"></i>
                                </div>
                                <div>
                                    <p class="stat-value">@totalUsuarios</p>
                                    <p class="stat-label">Mostrados</p>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon success">
                                    <i class="fas fa-user-check"></i>
                                </div>
                                <div>
                                    <p class="stat-value">@totalActivos</p>
                                    <p class="stat-label">Activos</p>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon danger">
                                    <i class="fas fa-user-slash"></i>
                                </div>
                                <div>
                                    <p class="stat-value">@totalInactivos</p>
                                    <p class="stat-label">Inactivos</p>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon warning">
                                    <i class="fas fa-envelope-open-text"></i>
                                </div>
                                <div>
                                    <p class="stat-value">@totalSinCorreo</p>
                                    <p class="stat-label">Sin correo</p>
                                </div>
                            </div>
                        </div>
                    </main>
                </div>
            </section>
        </div>

        @if (modoAccesos)
        {
            @Html.AntiForgeryToken()
            <div id="alertaAccesos" class="alert d-none alerta-accesos" role="alert"></div>

            <div class="modal fade modal-accesos" id="modalConfirmarAccesos" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header modal-header-accesos">
                            <div class="d-flex align-items-center gap-3">
                                <div class="modal-icon-accesos">
                                    <i class="fas fa-paper-plane"></i>
                                </div>
                                <div>
                                    <h5 class="modal-title mb-0">Enviar accesos por correo</h5>
                                    <small>Confirma el envío de credenciales</small>
                                </div>
                            </div>

                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                        </div>

                        <div class="modal-body">
                            <p class="mb-3">
                                Se enviarán las credenciales de acceso al siguiente usuario:
                            </p>

                            <div class="modal-user-card">
                                <div class="modal-user-avatar">
                                    <i class="fas fa-user"></i>
                                </div>

                                <div>
                                    <div class="modal-user-name" id="modalAccesosNombre">Usuario</div>
                                    <div class="modal-user-email" id="modalAccesosCorreo">correo@empresa.com</div>
                                </div>
                            </div>

                            <div class="alert alert-warning mt-3 mb-0">
                                <i class="fas fa-exclamation-triangle me-1"></i>
                                Esta acción enviará el usuario y contraseña registrados en la base de datos.
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                <i class="fas fa-times me-1"></i> Cancelar
                            </button>

                            <button type="button" class="btn btn-warning" id="btnConfirmarEnviarAccesos">
                                <i class="fas fa-paper-plane me-1"></i> Enviar accesos
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="scrollable-content">
            <section class="usuarios-list-card">
                <div class="usuarios-list-header">
                    <h2 class="usuarios-list-title">
                        <i class="@(modoAccesos ? "fas fa-envelope-open-text" : "fas fa-address-book")"></i>
                        @(modoAccesos ? "Usuarios disponibles para envío" : "Listado de usuarios")
                    </h2>
                    <div class="usuarios-list-count">
                        @totalUsuarios registro@(totalUsuarios == 1 ? "" : "s") encontrado@(totalUsuarios == 1 ? "" : "s")
                    </div>
                </div>

                @if (usuarios.Any())
                {
                    <div class="table-responsive usuarios-table-wrap">
                        <table class="table table-hover usuarios-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Username</th>
                                    <th>Nombre completo</th>
                                    <th>Correo</th>
                                    <th>Rol</th>
                                    <th class="text-center">Estado</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in usuarios)
                                {
                                    var correo = Safe(item?.Correo);
                                    var nombreCompleto = NombreCompleto(item);
                                    var activo = item?.Activo == true;
                                    var usuarioId = item?.UsuarioID ?? 0;
                                    var username = Safe(item?.Username);
                                    var rol = Safe(item?.Rol);

                                    <tr>
                                        <td class="ps-4">
                                            <div class="user-cell">
                                                <span class="user-avatar">
                                                    @Iniciales(item?.Nombre, item?.ApellidoPaterno)
                                                </span>
                                                <div>
                                                    <div class="user-name-main">@username</div>
                                                    <div class="user-name-sub">ID @usuarioId</div>
                                                </div>
                                            </div>
                                        </td>

                                        <td>
                                            <strong>@nombreCompleto</strong>
                                        </td>

                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(correo))
                                            {
                                                <span class="correo-muted">@correo</span>
                                            }
                                            else
                                            {
                                                <span class="sin-correo">
                                                    <i class="fas fa-exclamation-circle"></i>
                                                    Sin correo
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <span class="role-pill" title="@rol">
                                                <i class="fas fa-user-tag"></i>
                                                @(string.IsNullOrWhiteSpace(rol) ? "Sin rol" : rol)
                                            </span>
                                        </td>

                                        <td class="text-center">
                                            @if (activo)
                                            {
                                                <span class="badge-estado activo">
                                                    <i class="fas fa-circle-check"></i>
                                                    Activo
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge-estado inactivo">
                                                    <i class="fas fa-circle-xmark"></i>
                                                    Inactivo
                                                </span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if (modoAccesos)
                                            {
                                                if (!activo)
                                                {
                                                    <button type="button"
                                                            class="btn btn-secondary btn-row-disabled btn-sm"
                                                            disabled
                                                            title="No se pueden enviar accesos a usuarios inactivos">
                                                        <i class="fas fa-ban me-1"></i> Inactivo
                                                    </button>
                                                }
                                                else if (string.IsNullOrWhiteSpace(correo))
                                                {
                                                    <button type="button"
                                                            class="btn btn-secondary btn-row-disabled btn-sm"
                                                            disabled
                                                            title="El usuario no tiene correo registrado">
                                                        <i class="fas fa-envelope-open-text me-1"></i> Sin correo
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button"
                                                            class="btn-row-action btn-send-access btn-sm btn-enviar-accesos"
                                                            data-id="@usuarioId"
                                                            data-nombre="@nombreCompleto"
                                                            data-correo="@correo">
                                                        <i class="fas fa-paper-plane me-1"></i> Enviar accesos
                                                    </button>
                                                }
                                            }
                                            else
                                            {
                                                <a class="btn-editar-usuario btn-row-action btn-edit-user btn-sm"
                                                   asp-action="Editar"
                                                   asp-controller="Usuarios"
                                                   asp-route-id="@usuarioId"
                                                   title="Editar">
                                                    <i class="fas fa-pencil-alt"></i> Editar
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="usuarios-mobile-list">
                        @foreach (var item in usuarios)
                        {
                            var correo = Safe(item?.Correo);
                            var nombreCompleto = NombreCompleto(item);
                            var activo = item?.Activo == true;
                            var usuarioId = item?.UsuarioID ?? 0;
                            var username = Safe(item?.Username);
                            var rol = Safe(item?.Rol);

                            <article class="usuario-mobile-card">
                                <div class="usuario-mobile-head">
                                    <div class="usuario-mobile-info">
                                        <span class="user-avatar">
                                            @Iniciales(item?.Nombre, item?.ApellidoPaterno)
                                        </span>
                                        <div>
                                            <div class="usuario-mobile-name">@nombreCompleto</div>
                                            <div class="usuario-mobile-user">@username</div>
                                        </div>
                                    </div>

                                    @if (activo)
                                    {
                                        <span class="badge-estado activo">
                                            <i class="fas fa-circle-check"></i>
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-estado inactivo">
                                            <i class="fas fa-circle-xmark"></i>
                                            Inactivo
                                        </span>
                                    }
                                </div>

                                <div class="usuario-mobile-detail">
                                    <div>
                                        <i class="fas fa-user"></i>
                                        <span>@username</span>
                                    </div>

                                    <div>
                                        <i class="fas fa-envelope"></i>
                                        @if (!string.IsNullOrWhiteSpace(correo))
                                        {
                                            <span>@correo</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-semibold">Sin correo</span>
                                        }
                                    </div>

                                    <div>
                                        <i class="fas fa-user-tag"></i>
                                        <span>@(string.IsNullOrWhiteSpace(rol) ? "Sin rol" : rol)</span>
                                    </div>
                                </div>

                                @if (modoAccesos)
                                {
                                    if (!activo)
                                    {
                                        <button type="button"
                                                class="btn btn-secondary btn-row-disabled w-100"
                                                disabled
                                                title="No se pueden enviar accesos a usuarios inactivos">
                                            <i class="fas fa-ban me-1"></i> Usuario inactivo
                                        </button>
                                    }
                                    else if (string.IsNullOrWhiteSpace(correo))
                                    {
                                        <button type="button"
                                                class="btn btn-secondary btn-row-disabled w-100"
                                                disabled
                                                title="El usuario no tiene correo registrado">
                                            <i class="fas fa-envelope-open-text me-1"></i> Sin correo registrado
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn-row-action btn-send-access w-100 btn-enviar-accesos"
                                                data-id="@usuarioId"
                                                data-nombre="@nombreCompleto"
                                                data-correo="@correo">
                                            <i class="fas fa-paper-plane me-1"></i> Enviar accesos
                                        </button>
                                    }
                                }
                                else
                                {
                                    <a class="btn-editar-usuario btn-row-action btn-edit-user w-100"
                                       asp-action="Editar"
                                       asp-controller="Usuarios"
                                       asp-route-id="@usuarioId"
                                       title="Editar">
                                        <i class="fas fa-pencil-alt"></i> Editar usuario
                                    </a>
                                }
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon">
                            <i class="fas fa-user-slash"></i>
                        </div>
                        <h3 class="empty-title">No hay usuarios para mostrar</h3>
                        <p class="empty-text">
                            Ajusta los filtros de búsqueda o registra un nuevo usuario para verlo en este listado.
                        </p>
                    </div>
                }
            </section>
        </div>
    </div>
</div>



