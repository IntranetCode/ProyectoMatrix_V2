@using System.Linq
@model IEnumerable<ProyectoMatrix.Models.V_InformacionUsuarioCompleta>

@{
    Layout = "_LayoutUsuarios";

    var actionActual = ViewContext.RouteData.Values["action"]?.ToString();
    var modoAccesos = ViewData["ModoAccesos"] as bool? ?? string.Equals(actionActual, "Accesos", StringComparison.OrdinalIgnoreCase);
    ViewData["Title"] = modoAccesos ? "Enviar accesos por correo" : "Administración de Usuarios";

    var usuarios = Model?.ToList() ?? new List<ProyectoMatrix.Models.V_InformacionUsuarioCompleta>();
    var busquedaActual = ViewData["BusquedaActual"] as string;
    var filtroCampoActual = ViewData["FiltroCampoActual"] as string;
    filtroCampoActual = string.IsNullOrWhiteSpace(filtroCampoActual) ? "Todos" : filtroCampoActual;
     
    var actionBusqueda = modoAccesos ? "Accesos" : "Index";
    var activosQuery = Context.Request.Query["activos"].ToString();

    var totalUsuarios = usuarios.Count;
    var totalActivos = usuarios.Count(x => x?.Activo == true);
    var totalInactivos = usuarios.Count(x => x?.Activo != true);
    var totalSinCorreo = usuarios.Count(x => string.IsNullOrWhiteSpace(x?.Correo));

    string Safe(string? s) => string.IsNullOrWhiteSpace(s) ? "" : s.Trim();

    string NombreCompleto(ProyectoMatrix.Models.V_InformacionUsuarioCompleta u)
    {
        var nombre = Safe(u?.Nombre);
        var apePat = Safe(u?.ApellidoPaterno);
        var apeMat = Safe(u?.ApellidoMaterno);

        var partes = new[] { nombre, apePat, apeMat }.Where(x => !string.IsNullOrWhiteSpace(x));
        var full = string.Join(" ", partes);
        return string.IsNullOrWhiteSpace(full) ? "(Sin nombre)" : full;
    }

    string Iniciales(string? nombre, string? apePat)
    {
        var n = Safe(nombre);
        var a = Safe(apePat);
        var i1 = n.Length > 0 ? n.Substring(0, 1).ToUpper() : "";
        var i2 = a.Length > 0 ? a.Substring(0, 1).ToUpper() : "";
        var ini = i1 + i2;
        return string.IsNullOrEmpty(ini) ? "NA" : ini;
    }

    string EstadoFiltroLabel()
    {
        if (modoAccesos) return "Reenvío de accesos";
        if (string.Equals(activosQuery, "true", StringComparison.OrdinalIgnoreCase)) return "Usuarios activos";
        if (string.Equals(activosQuery, "false", StringComparison.OrdinalIgnoreCase)) return "Usuarios inactivos";
        return "Todos los usuarios";
    }
}

