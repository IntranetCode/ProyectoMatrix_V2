@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/usuarios/usuarios-panel.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('submit', async function (event) {
            const form = event.target.closest('#ov-form');

            if (!form) return;

            event.preventDefault();
            event.stopPropagation();
            event.stopImmediatePropagation();

            if (form.dataset.enviandoPermisos === '1') return;
            form.dataset.enviandoPermisos = '1';

            const submitBtn = form.querySelector('#ov-save');
            const originalHtml = submitBtn ? submitBtn.innerHTML : '';

            function mostrarModalPermisos(mensaje) {
                let modalEl = document.getElementById('modalPermisosGuardados');

                if (!modalEl) {
                    modalEl = document.createElement('div');
                    modalEl.className = 'modal fade';
                    modalEl.id = 'modalPermisosGuardados';
                    modalEl.tabIndex = -1;
                    modalEl.setAttribute('aria-hidden', 'true');

                    modalEl.innerHTML = `
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 rounded-4 shadow">
                                <div class="modal-header text-white" style="background: linear-gradient(135deg,#1a237e 0%,#0d47a1 100%);">
                                    <h5 class="modal-title">
                                        <i class="fas fa-shield-alt me-2"></i>Permisos actualizados
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                                </div>

                                <div class="modal-body">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                            style="width:46px;height:46px;background:#e8f5e9;color:#16a34a;flex:0 0 46px;">
                                            <i class="fas fa-check-circle fa-lg"></i>
                                        </div>

                                        <div>
                                            <h6 class="fw-bold mb-1">Cambios guardados correctamente</h6>
                                            <p id="modalPermisosGuardadosMensaje" class="mb-0 text-muted">
                                                Los permisos del usuario fueron actualizados correctamente.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <div class="modal-footer">
                                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">
                                        <i class="fas fa-check me-1"></i>Aceptar
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;

                    document.body.appendChild(modalEl);
                }

                const msgEl = document.getElementById('modalPermisosGuardadosMensaje');
                if (msgEl) {
                    msgEl.textContent = mensaje || 'Los permisos del usuario fueron actualizados correctamente.';
                }

                if (window.bootstrap?.Modal) {
                    bootstrap.Modal.getOrCreateInstance(modalEl).show();
                } else {
                    alert(mensaje || 'Los permisos del usuario fueron actualizados correctamente.');
                }
            }

            function mostrarErrorPermisos(mensaje) {
                let alertEl = document.getElementById('alertPermisosError');

                if (!alertEl) {
                    alertEl = document.createElement('div');
                    alertEl.id = 'alertPermisosError';
                    alertEl.className = 'alert alert-danger mt-3';
                    alertEl.setAttribute('role', 'alert');

                    const permisosContainer = form.closest('.permissions-container') || form;
                    permisosContainer.prepend(alertEl);
                }

                alertEl.innerHTML = `<i class="fas fa-exclamation-circle me-1"></i>${mensaje || 'No fue posible guardar los permisos.'}`;
                alertEl.classList.remove('d-none');

                setTimeout(function () {
                    alertEl.classList.add('d-none');
                }, 7000);
            }

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';
            }

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: new FormData(form),
                    credentials: 'same-origin'
                });

                const data = await response.json().catch(function () {
                    return null;
                });

                if (!response.ok || !data?.ok) {
                    throw new Error(data?.message || 'No fue posible guardar los permisos.');
                }

                document.querySelectorAll('#ov-dirty-indicator, #ov-dirty-indicator-bottom').forEach(function (badge) {
                    badge.classList.add('d-none');
                });

                document.querySelectorAll('#ov-form tr[data-submenu]').forEach(function (tr) {
                    const checked = tr.querySelector('.ov-radio:checked');
                    if (checked) {
                        tr.setAttribute('data-estado-inicial', checked.value);
                    }
                });

                mostrarModalPermisos(data.message || 'Permisos actualizados correctamente.');
            } catch (error) {
                mostrarErrorPermisos(error.message || 'Error al guardar los permisos.');
            } finally {
                form.dataset.enviandoPermisos = '0';

                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                }
            }
        }, true);
    </script>
    <script>
        (function (window, document) {
            'use strict';

            function togglePasswordFromButton(button) {
                if (!button) button = document.querySelector('.js-toggle-password, #btnTogglePassword, .js-toggle-password-crear');
                const root = button?.closest('#user-form') || button?.closest('.tab-content-modern') || document;
                const selector = button?.getAttribute('data-password-target') || '#txtPassword';
                const input = root.querySelector?.(selector) || document.querySelector(selector) || document.querySelector('input[name="Password"]');
                const icon = button?.querySelector('i') || root.querySelector?.('#eyeIcon') || document.getElementById('eyeIcon');

                if (!input) return false;

                const show = input.type === 'password';
                input.type = show ? 'text' : 'password';

                if (icon) {
                    icon.classList.toggle('fa-eye', !show);
                    icon.classList.toggle('fa-eye-slash', show);
                }

                if (button) {
                    button.setAttribute('aria-label', show ? 'Ocultar contraseña' : 'Mostrar contraseña');
                    button.setAttribute('title', show ? 'Ocultar contraseña' : 'Mostrar contraseña');
                }

                return false;
            }

            window.togglePasswordVisibility = function () {
                return togglePasswordFromButton(document.querySelector('.js-toggle-password, #btnTogglePassword'));
            };

            document.addEventListener('click', function (event) {
                const btn = event.target.closest('.js-toggle-password, #btnTogglePassword, .js-toggle-password-crear');
                if (!btn) return;
                event.preventDefault();
                togglePasswordFromButton(btn);
            });

            function esModalRestablecerPassword(modalEl) {
                if (!modalEl || !modalEl.classList || !modalEl.classList.contains('modal')) return false;

                if (modalEl.querySelector('#form-restablecer-password')) return true;

                const id = (modalEl.id || '').toLowerCase();
                if (id.includes('restablecer') && (id.includes('password') || id.includes('contrasena') || id.includes('contraseña'))) return true;

                const titulo = (modalEl.querySelector('.modal-title')?.textContent || '').toLowerCase();
                return titulo.includes('restablecer') && (titulo.includes('contraseña') || titulo.includes('contrasena') || titulo.includes('password'));
            }

            function obtenerModalDesdeDisparador(disparador) {
                if (!disparador) return null;

                const selector = disparador.getAttribute('data-bs-target')
                    || disparador.getAttribute('data-target')
                    || disparador.getAttribute('href');

                if (!selector || !selector.startsWith('#')) return null;

                try {
                    return document.querySelector(selector);
                } catch {
                    return null;
                }
            }

            function ajustarBackdropsRestablecerPassword() {
                document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                    backdrop.classList.add('pm-reset-password-backdrop');
                    backdrop.style.setProperty('z-index', '2147482990', 'important');
                });
            }

            function prepararModalRestablecerPassword(modalEl) {
                if (!esModalRestablecerPassword(modalEl)) return;

                // Si el modal viene dentro del panel lateral/AJAX, queda debajo del backdrop.
                // Moverlo al body antes/durante la apertura evita que se vea gris y bloqueado.
                if (modalEl.parentElement !== document.body) {
                    document.body.appendChild(modalEl);
                }

                modalEl.classList.add('pm-reset-password-modal');
                modalEl.style.setProperty('z-index', '2147483000', 'important');
                document.body.classList.add('pm-reset-password-open');

                ajustarBackdropsRestablecerPassword();
                setTimeout(ajustarBackdropsRestablecerPassword, 0);
                setTimeout(ajustarBackdropsRestablecerPassword, 60);
            }

            // Captura antes de que Bootstrap abra el modal por data-bs-toggle.
            document.addEventListener('pointerdown', function (event) {
                const disparador = event.target.closest('[data-bs-toggle="modal"], [data-bs-target], [data-target], a[href^="#"]');
                const modalEl = obtenerModalDesdeDisparador(disparador);

                if (esModalRestablecerPassword(modalEl)) {
                    prepararModalRestablecerPassword(modalEl);
                }
            }, true);

            document.addEventListener('click', function (event) {
                const disparador = event.target.closest('[data-bs-toggle="modal"], [data-bs-target], [data-target], a[href^="#"]');
                const modalEl = obtenerModalDesdeDisparador(disparador);

                if (esModalRestablecerPassword(modalEl)) {
                    prepararModalRestablecerPassword(modalEl);
                }
            }, true);

            document.addEventListener('show.bs.modal', function (event) {
                if (esModalRestablecerPassword(event.target)) {
                    prepararModalRestablecerPassword(event.target);
                }
            }, true);

            document.addEventListener('shown.bs.modal', function (event) {
                if (esModalRestablecerPassword(event.target)) {
                    prepararModalRestablecerPassword(event.target);
                }
            }, true);

            document.addEventListener('hidden.bs.modal', function (event) {
                if (!esModalRestablecerPassword(event.target)) return;

                event.target.classList.remove('pm-reset-password-modal');
                event.target.style.removeProperty('z-index');
                document.body.classList.remove('pm-reset-password-open');

                setTimeout(function () {
                    limpiarBackdropsSiNoHayModales();
                }, 80);
            }, true);


            function limpiarBackdropsSiNoHayModales() {
                if (document.querySelector('.modal.show')) return;

                document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                    backdrop.remove();
                });

                document.body.classList.remove('modal-open');
                document.body.style.removeProperty('overflow');
                document.body.style.removeProperty('padding-right');
            }

            function mostrarModalOperacionUsuario(mensaje) {
                const modalEl = document.getElementById('modalOperacionUsuarioExitosa');
                const mensajeEl = document.getElementById('modalOperacionUsuarioMensaje');

                if (mensajeEl) {
                    mensajeEl.textContent = mensaje || 'La operación se realizó correctamente.';
                }

                if (!modalEl || !window.bootstrap?.Modal) {
                    alert(mensaje || 'La operación se realizó correctamente.');
                    return;
                }

                if (modalEl.parentElement !== document.body) {
                    document.body.appendChild(modalEl);
                }

                limpiarBackdropsSiNoHayModales();

                bootstrap.Modal.getOrCreateInstance(modalEl, {
                    backdrop: true,
                    keyboard: true,
                    focus: true
                }).show();
            }

            window.mostrarModalOperacionUsuario = mostrarModalOperacionUsuario;

            document.addEventListener('submit', async function (event) {
                const form = event.target.closest('#form-restablecer-password');
                if (!form) return;

                event.preventDefault();
                event.stopPropagation();
                event.stopImmediatePropagation();

                if (form.dataset.enviandoResetPassword === '1') return;
                form.dataset.enviandoResetPassword = '1';

                const nueva = form.querySelector('[name="nuevaPassword"]')?.value || '';
                const confirmar = form.querySelector('[name="confirmarPassword"]')?.value || '';
                const resultado = form.querySelector('#resetPasswordResultado');
                const submitBtn = form.querySelector('#btnRestablecerPasswordSubmit');

                function mostrarResultado(tipo, mensaje) {
                    if (!resultado) {
                        alert(mensaje);
                        return;
                    }

                    resultado.className = 'alert ' + (tipo === 'success' ? 'alert-success' : 'alert-danger');
                    resultado.textContent = mensaje;
                    resultado.classList.remove('d-none');
                }

                function limpiarResultado() {
                    if (!resultado) return;

                    resultado.className = 'alert d-none';
                    resultado.textContent = '';
                }

                limpiarResultado();

                if (nueva.length < 6) {
                    mostrarResultado('error', 'La contraseña debe tener al menos 6 caracteres.');
                    form.dataset.enviandoResetPassword = '0';
                    return;
                }

                if (nueva !== confirmar) {
                    mostrarResultado('error', 'La confirmación no coincide con la nueva contraseña.');
                    form.dataset.enviandoResetPassword = '0';
                    return;
                }

                const htmlOriginal = submitBtn?.innerHTML;

                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';
                }

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Accept': 'application/json'
                        },
                        body: new FormData(form),
                        credentials: 'same-origin'
                    });

                    const data = await response.json().catch(function () {
                        return null;
                    });

                    if (!response.ok || !data?.ok) {
                        throw new Error(data?.message || 'No fue posible restablecer la contraseña.');
                    }

                    const modalActual = form.closest('.modal');
                    const mensajeExito = data.message || 'Contraseña restablecida correctamente.';

                    if (modalActual && window.bootstrap?.Modal) {
                        modalActual.addEventListener('hidden.bs.modal', function handler() {
                            modalActual.removeEventListener('hidden.bs.modal', handler);
                            limpiarBackdropsSiNoHayModales();
                            mostrarModalOperacionUsuario(mensajeExito);
                        }, { once: true });

                        const modalInstance = bootstrap.Modal.getInstance(modalActual)
                            || bootstrap.Modal.getOrCreateInstance(modalActual);

                        modalInstance.hide();
                    } else {
                        mostrarModalOperacionUsuario(mensajeExito);
                    }

                    form.reset();
                } catch (error) {
                    mostrarResultado('error', error.message || 'Error al restablecer la contraseña.');
                } finally {
                    form.dataset.enviandoResetPassword = '0';

                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = htmlOriginal;
                    }
                }
            }, true);

            function ejecutarScriptsParciales(contenedor) {
                if (!contenedor || !contenedor.querySelectorAll) return;

                const scripts = [];
                if (contenedor.matches && contenedor.matches('script')) scripts.push(contenedor);
                contenedor.querySelectorAll('script').forEach(function (script) { scripts.push(script); });

                scripts.forEach(function (oldScript) {
                    if (oldScript.dataset.usuarioScriptEjecutado === '1') return;

                    const newScript = document.createElement('script');
                    Array.from(oldScript.attributes).forEach(function (attr) {
                        if (attr.name !== 'data-usuario-script-ejecutado') {
                            newScript.setAttribute(attr.name, attr.value);
                        }
                    });

                    newScript.dataset.usuarioScriptEjecutado = '1';
                    newScript.textContent = oldScript.textContent;
                    oldScript.replaceWith(newScript);
                });
            }

            function inicializarFormularioUsuario(contenedor) {
                if (!contenedor) return;

                ejecutarScriptsParciales(contenedor);

                const root = contenedor.querySelector?.('#user-form') ? contenedor : document;

                if (window.UsuarioFormPanel && typeof window.UsuarioFormPanel.init === 'function') {
                    window.UsuarioFormPanel.init(root);
                }
            }

            window.ejecutarScriptsParciales = ejecutarScriptsParciales;
            window.inicializarFormularioUsuario = inicializarFormularioUsuario;

            const observer = new MutationObserver(function (mutations) {
                mutations.forEach(function (mutation) {
                    mutation.addedNodes.forEach(function (node) {
                        if (!(node instanceof Element)) return;

                        if (node.matches('#user-form, .tab-content-modern') || node.querySelector?.('#user-form')) {
                            inicializarFormularioUsuario(node);
                        }
                    });
                });
            });

            if (document.body) {
                observer.observe(document.body, { childList: true, subtree: true });
            }
        })(window, document);

        function abrirModalAjuste(usuarioId) {
            $('#ajusteUsuarioID').val(usuarioId);
            $('#formAjusteVacaciones')[0].reset();
            $('#modalAjusteVacaciones').modal('show');
        }

        function guardarAjuste() {
            const formData = $('#formAjusteVacaciones').serialize();

            $.post('/AdminUsuarios/Usuarios/RegistrarAjusteVacaciones', formData, function (response) {
                if (response.success) {
                    Swal.fire('¡Éxito!', response.message, 'success');
                    $('#modalAjusteVacaciones').modal('hide');
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            });
        }
    </script>

    @if (modoAccesos)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const alerta = document.getElementById('alertaAccesos');
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const modalEl = document.getElementById('modalConfirmarAccesos');
                const modal = modalEl && window.bootstrap
                    ? bootstrap.Modal.getOrCreateInstance(modalEl)
                    : null;

                const modalNombre = document.getElementById('modalAccesosNombre');
                const modalCorreo = document.getElementById('modalAccesosCorreo');
                const btnConfirmar = document.getElementById('btnConfirmarEnviarAccesos');

                let usuarioSeleccionado = null;

                function mostrarAlerta(tipo, mensaje) {
                    if (!alerta) {
                        alert(mensaje);
                        return;
                    }

                    alerta.className = 'alert alert-' + tipo + ' alerta-accesos';
                    alerta.textContent = mensaje;
                    alerta.classList.remove('d-none');

                    setTimeout(function () {
                        alerta.classList.add('d-none');
                    }, 7000);
                }

                function abrirConfirmacion(datos) {
                    usuarioSeleccionado = datos;

                    if (modalNombre) {
                        modalNombre.textContent = datos.nombre || 'Usuario';
                    }

                    if (modalCorreo) {
                        modalCorreo.textContent = datos.correo || 'Sin correo';
                    }

                    if (modal) {
                        modal.show();
                    } else {
                        enviarAccesos();
                    }
                }

                async function enviarAccesos() {
                    if (!usuarioSeleccionado) return;

                    const botonFila = usuarioSeleccionado.boton;
                    const htmlOriginalFila = botonFila?.innerHTML;
                    const htmlOriginalConfirmar = btnConfirmar?.innerHTML;

                    let tipoAlerta = null;
                    let mensajeAlerta = null;

                    if (botonFila) {
                        botonFila.disabled = true;
                        botonFila.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Enviando...';
                    }

                    if (btnConfirmar) {
                        btnConfirmar.disabled = true;
                        btnConfirmar.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Enviando...';
                    }

                    try {
                        const formData = new FormData();
                        formData.append('id', usuarioSeleccionado.id);
                        formData.append('__RequestVerificationToken', token);

                        const response = await fetch('@Url.Action("EnviarAccesosPorCorreo", "Usuarios")', {
                            method: 'POST',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'Accept': 'application/json'
                            },
                            body: formData,
                            credentials: 'same-origin'
                        });

                        let data = null;

                        try {
                            data = await response.json();
                        } catch {
                            data = null;
                        }

                        if (!response.ok || !data?.ok) {
                            throw new Error(data?.message || 'No fue posible enviar los accesos.');
                        }

                        tipoAlerta = 'success';
                        mensajeAlerta = data.message || 'Accesos enviados correctamente.';
                    } catch (error) {
                        tipoAlerta = 'danger';
                        mensajeAlerta = error.message || 'Ocurrió un error al enviar los accesos.';
                    } finally {
                        if (modal) {
                            modal.hide();
                        }

                        if (botonFila) {
                            botonFila.disabled = false;
                            botonFila.innerHTML = htmlOriginalFila;
                        }

                        if (btnConfirmar) {
                            btnConfirmar.disabled = false;
                            btnConfirmar.innerHTML = htmlOriginalConfirmar;
                        }

                        usuarioSeleccionado = null;

                        if (tipoAlerta && mensajeAlerta) {
                            mostrarAlerta(tipoAlerta, mensajeAlerta);
                        }
                    }
                }

                document.querySelectorAll('.btn-enviar-accesos').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        abrirConfirmacion({
                            id: this.dataset.id,
                            nombre: this.dataset.nombre,
                            correo: this.dataset.correo,
                            boton: this
                        });
                    });
                });

                btnConfirmar?.addEventListener('click', function () {
                    enviarAccesos();
                });

                modalEl?.addEventListener('hidden.bs.modal', function () {
                    usuarioSeleccionado = null;
                });
            });
        </script>
    }
}
