@model IEnumerable<ProyectoMatrix.Models.Transporte>
@{
    Layout = null;

    var fechaGeneracion = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
    var transportes = Model?.OrderByDescending(x => x.FechaEmision).ToList() ?? new List<ProyectoMatrix.Models.Transporte>();

    int totalTransportes = transportes.Count;
    int pendientes = transportes.Count(x => !x.EstaBorrado && x.EstadoSolicitud == "Pendiente");
    int autorizadas = transportes.Count(x => !x.EstaBorrado && x.EstadoSolicitud == "Autorizada");
    int finalizadas = transportes.Count(x => !x.EstaBorrado && x.EstadoSolicitud == "Finalizada");
    int canceladas = transportes.Count(x => x.EstaBorrado);
    decimal totalCosto = transportes.Sum(x => x.CostoFlete ?? 0);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Auditoría de Transportes</title>

    <style>
        @@page {
            size: Letter landscape;
            margin: 8mm;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            color: #000;
            background: #fff;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 8px;
            line-height: 1.15;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            border: 1px solid #000;
        }

        th, td {
            border: 1px solid #000;
            padding: 4px 5px;
            vertical-align: middle;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        th {
            background: #e9e9e9;
            font-weight: 900;
            text-align: center;
        }

        .header-table {
            margin-bottom: 6px;
        }

        .logo-cell {
            width: 10%;
            text-align: center;
        }

        .logo-mark {
            display: inline-block;
            width: 42px;
            height: 42px;
            border: 2px solid #000;
            border-radius: 50%;
            line-height: 38px;
            font-weight: 900;
            font-size: 18px;
        }

        .logo-text {
            font-size: 5.8px;
            font-weight: 900;
            margin-top: 2px;
        }

        .title {
            font-size: 14px;
            font-weight: 900;
            text-align: center;
        }

        .subtitle {
            font-size: 8px;
            font-weight: 700;
            text-align: center;
        }

        .label {
            background: #eeeeee;
            font-weight: 900;
        }

        .value {
            text-align: center;
            font-weight: 700;
        }

        .kpi-table {
            margin-bottom: 6px;
        }

        .kpi-label {
            background: #f1f1f1;
            font-weight: 900;
            text-align: center;
        }

        .kpi-value {
            font-size: 11px;
            font-weight: 900;
            text-align: center;
        }

        .center { text-align: center; }
        .right { text-align: right; }
        .small { font-size: 7px; }

        tr {
            page-break-inside: avoid;
        }

        thead {
            display: table-header-group;
        }
    </style>
</head>
<body>
    <table class="header-table">
        <tr>
            <td rowspan="4" class="logo-cell">
                <div class="logo-mark">NS</div>
                <div class="logo-text">GROUP</div>
            </td>
            <td colspan="8" class="label">NS GROUP</td>
            <td colspan="3" class="value">@fechaGeneracion</td>
        </tr>
        <tr>
            <td colspan="11" class="label">PROCESOS Y MEJORA CONTINUA</td>
        </tr>
        <tr>
            <td colspan="11" class="title">Reporte de Auditoría de Transportes</td>
        </tr>
        <tr>
            <td colspan="11" class="subtitle">
                Reporte general para seguimiento de solicitudes, autorizaciones, cancelaciones, destinos y costos de flete.
            </td>
        </tr>
    </table>

    <table class="kpi-table">
        <tr>
            <td class="kpi-label">Total</td>
            <td class="kpi-label">Pendientes</td>
            <td class="kpi-label">Autorizadas</td>
            <td class="kpi-label">Finalizadas</td>
            <td class="kpi-label">Canceladas</td>
            <td class="kpi-label">Costo total</td>
        </tr>
        <tr>
            <td class="kpi-value">@totalTransportes</td>
            <td class="kpi-value">@pendientes</td>
            <td class="kpi-value">@autorizadas</td>
            <td class="kpi-value">@finalizadas</td>
            <td class="kpi-value">@canceladas</td>
            <td class="kpi-value">@totalCosto.ToString("C")</td>
        </tr>
    </table>

    <table>
        <thead>
            <tr>
                <th style="width: 6%;">Folio</th>
                <th style="width: 8%;">Estado</th>
                <th style="width: 8%;">Fecha carga</th>
                <th style="width: 10%;">Cliente</th>
                <th style="width: 10%;">Proyecto</th>
                <th style="width: 11%;">Solicitante</th>
                <th style="width: 10%;">Compañía</th>
                <th style="width: 8%;">Ruta</th>
                <th style="width: 9%;">Unidad</th>
                <th style="width: 10%;">Fletero</th>
                <th style="width: 8%;">Costo</th>
                <th style="width: 8%;">Destinos</th>
                <th style="width: 8%;">Items</th>
            </tr>
        </thead>
        <tbody>
            @if (transportes.Any())
            {
                foreach (var t in transportes)
                {
                    <tr>
                        <td class="center">@(t.Folio ?? $"TR-{t.IdTransporte}")</td>
                        <td class="center">@(t.EstaBorrado ? "Cancelada" : (t.EstadoSolicitud ?? ""))</td>
                        <td class="center">@(t.FechaCarga.HasValue ? t.FechaCarga.Value.ToString("dd/MM/yyyy") : "")</td>
                        <td>@(t.Cliente ?? "")</td>
                        <td>@(t.Proyecto ?? "")</td>
                        <td>@(t.NombreSolicitante ?? t.ElaboradoPor ?? "")</td>
                        <td>@(t.CompaniaSolicitante ?? "")</td>
                        <td class="center">@(t.TipoRuta ?? "")</td>
                        <td class="center">@(t.TipoUnidad ?? "")</td>
                        <td>@(t.Fletero ?? "")</td>
                        <td class="right">@(t.CostoFlete.HasValue ? t.CostoFlete.Value.ToString("C") : "")</td>
                        <td class="center">@(t.Destinos?.Count ?? 0)</td>
                        <td class="center">@(t.PlanEmbarque?.Count ?? 0)</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="13" class="center">No hay transportes para reportar.</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
