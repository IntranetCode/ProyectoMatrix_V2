                            <td class="fw-semibold">@(item.Cliente ?? "N/A")</td>
                            <td>@(item.Proyecto ?? "N/A")</td>
                            <td>@(item.FechaCarga.HasValue ? item.FechaCarga.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                            <td>@(item.TipoRuta ?? "N/A")</td>
                            <td>@(item.TipoUnidad ?? "N/A")</td>
                            <td>@(item.Fletero ?? "N/A")</td>
                            <td>@((item.CostoFlete ?? 0).ToString("C"))</td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm rounded-3">
                                    <button class="btn btn-sm btn-light border" onclick="abrirModalVer(@item.IdTransporte)" title="Ver"><i class="fas fa-eye text-primary"></i></button>
                                    <a class="btn btn-sm btn-light border" href="/Logistica/DescargarTransportePDF?id=@item.IdTransporte" target="_blank" title="PDF"><i class="fas fa-file-pdf text-danger"></i></a>
                                    <button class="btn btn-sm btn-light border" onclick="abrirModalEditar(@item.IdTransporte)" title="Editar"><i class="fas fa-pen text-secondary"></i></button>
                                    <button class="btn btn-sm btn-light border" onclick="finalizarTransporte(@item.IdTransporte)" title="Finalizar"><i class="fas fa-flag-checkered" style="color:#7c3aed;"></i></button>
                                    <button class="btn btn-sm btn-light border" onclick="abrirModalBorrar(@item.IdTransporte)" title="Cancelar"><i class="fas fa-trash text-danger"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (esLogistica)
    {
    <div id="seccionFinalizadas" data-section="seccionFinalizadas" class="dashboard-card p-4 mb-5 seccion-filtrable">
        <div class="section-toolbar">
        <h5 class="fw-bold section-title-line" style="color:#7c3aed;"><i class="fas fa-flag-checkered me-2"></i> Transportes Finalizados</h5>
        <div class="search-module-box">
            <i class="fas fa-search"></i>
            <input type="text" class="busqueda-seccion" data-target="#tablaFinalizadas" placeholder="Buscar folio, cliente, proyecto...">
        </div>
    </div>
    <div class="empty-search-message" data-empty-for="#tablaFinalizadas">
        <i class="fas fa-magnifying-glass me-1"></i> No se encontraron transportes finalizados con esa búsqueda.
    </div>
        <div class="table-responsive">
            <table class="table table-custom align-middle" id="tablaFinalizadas">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Cliente</th>
                        <th>Proyecto</th>
                        <th>Fecha carga</th>
                        <th>Tipo ruta</th>
                        <th>Fletero</th>
                        <th>Costo</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in finalizadas)
                    {
                        <tr>
                            <td><span class="badge" style="background:#7c3aed;color:white;">@(item.Folio ?? $"TR-{item.IdTransporte}")</span></td>
                            <td class="fw-semibold">@(item.Cliente ?? "N/A")</td>
                            <td>@(item.Proyecto ?? "N/A")</td>
                            <td>@(item.FechaCarga.HasValue ? item.FechaCarga.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                            <td>@(item.TipoRuta ?? "N/A")</td>
                            <td>@(item.Fletero ?? "N/A")</td>
                            <td>@((item.CostoFlete ?? 0).ToString("C"))</td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm rounded-3">
                                    <button class="btn btn-sm btn-light border" onclick="abrirModalVer(@item.IdTransporte)" title="Ver"><i class="fas fa-eye text-primary"></i></button>
                                    <a class="btn btn-sm btn-light border" href="/Logistica/DescargarTransportePDF?id=@item.IdTransporte" target="_blank" title="PDF"><i class="fas fa-file-pdf text-danger"></i></a>
                                    @if (esLogistica)
                                    {
                                        <button class="btn btn-sm btn-light border" onclick="eliminarTransporteFinalizado(@item.IdTransporte)" title="Eliminar finalizado"><i class="fas fa-trash-alt text-danger"></i></button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    }

    <div id="seccionEliminadas" data-section="seccionEliminadas" class="dashboard-card p-4 mb-5 seccion-filtrable">
            <div class="section-toolbar">
                <h5 class="fw-bold text-danger section-title-line"><i class="fas fa-trash-alt me-2"></i> Peticiones Canceladas / Eliminadas</h5>
                <div class="search-module-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="busqueda-seccion" data-target="#tablaBorrados" placeholder="Buscar folio, cliente, motivo...">
                </div>
            </div>
            <div class="empty-search-message" data-empty-for="#tablaBorrados">
                <i class="fas fa-magnifying-glass me-1"></i> No se encontraron registros cancelados con esa búsqueda.
            </div>
            <div class="table-responsive">
                <table class="table table-custom align-middle" id="tablaBorrados">
                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Cliente</th>
                            <th>Proyecto</th>
