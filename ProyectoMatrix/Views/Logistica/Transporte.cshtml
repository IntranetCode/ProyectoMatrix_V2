        function guardarTransporte() {
            reindexarDestinos();
            reindexarPartidas();

            const form = document.getElementById('formTransporte');
            if (!form.checkValidity()) {
                const invalido = form.querySelector(':invalid');
                const step = invalido.closest('.tab-pane');
                if (step) {
                    const tab = document.querySelector(`[data-bs-target="#${step.id}"]`);
                    if (tab) bootstrap.Tab.getOrCreateInstance(tab).show();
                    setTimeout(() => invalido.reportValidity(), 200);
                } else {
                    invalido.reportValidity();
                }
                return;
            }

            let btn = document.getElementById('btnGuardar');
            btn.disabled = true;
            document.getElementById('iconGuardar').className = 'fas fa-spinner fa-spin me-1';

            let datos = new URLSearchParams(new FormData(form));

            $.post('/Logistica/GuardarTransporteAjax', datos.toString(), function (res) {
                if (res.success) {
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modalTransporte')).hide();
                    location.reload();
                } else {
                    Swal.fire('Error', res.message || 'No se pudo guardar la solicitud.', 'error');
                    restaurarBotonGuardar();
                }
            }).fail(function () {
                Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
                restaurarBotonGuardar();
            });
        }

        function restaurarBotonGuardar() {
            let btn = document.getElementById('btnGuardar');
            if (btn) btn.disabled = false;
            let icon = document.getElementById('iconGuardar');
            if (icon) icon.className = 'fas fa-paper-plane me-1';
        }

        function abrirModalBorrar(id) {
            document.getElementById('idBorrar').value = id;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalBorrar')).show();
        }

        function resolverTransporte(id, resolucion) {
            const titulo = resolucion === 'Aceptada' ? 'Autorizar solicitud' : 'Rechazar solicitud';
            Swal.fire({
                title: titulo,
                input: resolucion === 'Rechazada' ? 'textarea' : null,
                inputLabel: resolucion === 'Rechazada' ? 'Motivo de rechazo' : null,
                showCancelButton: true,
                confirmButtonText: resolucion === 'Aceptada' ? 'Autorizar' : 'Rechazar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: resolucion === 'Aceptada' ? '#16a34a' : '#dc2626'
            }).then(r => {
                if (!r.isConfirmed) return;
                $.post('/Logistica/ResolverTransporte', { id: id, resolucion: resolucion, motivo: r.value || '' }, function(res) {
                    if (res.success) location.reload(); else Swal.fire('Error', res.message || 'No se pudo procesar.', 'error');
                });
            });
        }

        function finalizarTransporte(id) {
            Swal.fire({
                title: 'Finalizar transporte',
                text: 'La solicitud pasará al historial de transportes finalizados.',
                icon: 'question',
                input: 'textarea',
                inputLabel: 'Comentario opcional',
                inputPlaceholder: 'Ej. Entrega completada, documentación recibida...',
                showCancelButton: true,
                confirmButtonText: 'Finalizar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#7c3aed'
            }).then(r => {
                if (!r.isConfirmed) return;
                $.post('/Logistica/FinalizarTransporte', { id: id, comentario: r.value || '' }, function(res) {
                    if (res.success) location.reload(); else Swal.fire('Error', res.message || 'No se pudo finalizar.', 'error');
                }).fail(function () {
                    Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
                });
            });
        }

        function restaurarTransporte(id) {
            Swal.fire({ title: 'Restaurar solicitud', text: 'La solicitud volvera a pendientes para autorizacion.', icon: 'question', showCancelButton: true, confirmButtonText: 'Restaurar' })
                .then(r => {
                    if (!r.isConfirmed) return;
                    $.post('/Logistica/RestaurarBorradoAjax', { id: id, tipo: 'Transporte' }, function(res) {
                        if (res.success) location.reload(); else Swal.fire('Error', res.message || 'No se pudo restaurar.', 'error');
                    });
                });
        }


        function eliminarTransporteFinalizado(id) {
            Swal.fire({
                title: 'Eliminar transporte finalizado',
                html: 'Esta acción borrará definitivamente el transporte finalizado, incluyendo destinos, plan de embarque e historial relacionado.<br><strong>No se podrá recuperar después.</strong>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#64748b'
            }).then(r => {
                if (!r.isConfirmed) return;

                $.post('/Logistica/EliminarTransporteFinalizadoDefinitivo', { id: id }, function(res) {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
