                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="nuevoFormularioTipo">Tipo de formulario</label>
                        <select id="nuevoFormularioTipo" class="form-select">
                            <option value="Solicitud">Solicitud</option>
                            <option value="Autorización">Autorización</option>
