                                    ${contenidoPrincipal.innerHTML}
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                </div>`;
                        } else {
                            modalContent.innerHTML = `
                                <div class="modal-header text-white" style="background:#003B70;">
                                    <h5 class="modal-title fw-bold">
                                        <i class="fas fa-user-circle me-2"></i> Mi Perfil
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body text-center py-4">
                                    <i class="fas fa-user-circle text-primary mb-3" style="font-size:4rem;"></i>
                                    <h5 class="fw-bold">No se pudo cargar el perfil dentro del modal.</h5>
                                    <p class="text-muted mb-0">La vista de perfil respondió sin contenido visible.</p>
                                </div>
                                <div class="modal-footer">
                                    <a href="${urlPerfil}" class="btn btn-primary">Abrir perfil</a>
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                </div>`;
                        }
                    } catch (error) {
                        modalContent.innerHTML = `
                            <div class="modal-header text-white" style="background:#003B70;">
                                <h5 class="modal-title fw-bold">
                                    <i class="fas fa-user-circle me-2"></i> Mi Perfil
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body text-center py-4">
                                <i class="fas fa-triangle-exclamation text-warning mb-3" style="font-size:3rem;"></i>
                                <h5 class="fw-bold">No se pudo cargar el perfil.</h5>
                                <p class="text-muted mb-0">Intenta nuevamente.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                            </div>`;
                    }
                }, true);
            });
        }

        document.addEventListener('DOMContentLoaded', inicializarModalPerfilDesdeLayout);

    </script>
}
