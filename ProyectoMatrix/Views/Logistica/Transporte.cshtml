                    <div class="section-heading">
                        <span class="section-icon finished"><i class="fas fa-flag-checkered"></i></span>
                        <div class="section-heading-copy">
                            <div class="section-eyebrow">Flujo de transporte</div>
                            <div class="section-title-row">
                                <h2 class="section-title">Transportes finalizados</h2>
                                <span class="section-meta-badge">@finalizadas.Count registro@(finalizadas.Count == 1 ? "" : "s")</span>
                            </div>
                        </div>
                    </div>
                    <div class="search-module-box">
                        <i class="fas fa-search"></i>
                        <input type="text" class="busqueda-seccion" data-target="#tablaFinalizadas" placeholder="Buscar por folio o cliente...">
                    </div>
                </div>
                <div class="empty-search-message" data-empty-for="#tablaFinalizadas">
                    <i class="fas fa-magnifying-glass me-1"></i> No se encontraron transportes finalizados con esa búsqueda.
                </div>
                <div class="table-responsive section-table-wrap">
                    <table class="table transport-table align-middle" id="tablaFinalizadas">
