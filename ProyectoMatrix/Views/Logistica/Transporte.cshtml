@model IEnumerable<ProyectoMatrix.Models.Transporte>
@{
    ViewData["Title"] = "Logistica - Transporte";
    Layout = "_LayoutComunicados";

    bool esLogistica = ViewBag.EsLogistica ?? false;
    int usuarioActualId = ViewBag.UsuarioActualId ?? 0;
    string usuarioActualNombre = ViewBag.UsuarioActualNombre ?? "Usuario";
    string usuarioActualArea = ViewBag.UsuarioActualArea ?? "Sin departamento";
    var dicUsuarios = ViewBag.UsuariosIntranet as Dictionary<int, string>;
    var empresasTransporte = ViewBag.Empresas as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    var registrosBase = (Model ?? Enumerable.Empty<ProyectoMatrix.Models.Transporte>())
        .Where(x => x != null)
        .ToList();

    var registrosVisibles = esLogistica
        ? registrosBase
        : registrosBase.Where(x => x.UsuarioID == usuarioActualId).ToList();

    // Logística ve los cuatro estados.
    // Usuario final solo ve autorizadas y eliminadas/canceladas.
    var pendientes = esLogistica
        ? registrosVisibles.Where(x => !x.EstaBorrado && x.EstadoSolicitud == "Pendiente").ToList()
        : new List<ProyectoMatrix.Models.Transporte>();

    var autorizadas = registrosVisibles
        .Where(x => !x.EstaBorrado && x.EstadoSolicitud == "Autorizada")
        .ToList();

    var finalizadas = esLogistica
        ? registrosVisibles.Where(x => !x.EstaBorrado && x.EstadoSolicitud == "Finalizada").ToList()
        : new List<ProyectoMatrix.Models.Transporte>();

    var eliminadas = registrosVisibles
        .Where(x => x.EstaBorrado)
        .ToList();

    string seccionInicialTransporte = esLogistica ? "seccionPendientes" : "seccionAutorizadas";
    string menuLogisticaUrl = "/Menu/Grupo/5";
}

<input type="hidden" id="FirmaPanelTransporte" value="@(ViewBag.FirmaPanelTransporte ?? "")" />

