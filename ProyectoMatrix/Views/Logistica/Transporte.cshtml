                    </p>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <input class="form-control form-control-sm" value="Solicitante" readonly>
                        </div>
                        <div class="col-md-4">
                            <input class="form-control form-control-sm" value="Fecha de solicitud" readonly>
                        </div>
                        <div class="col-md-4">
                            <input class="form-control form-control-sm" value="Estado" readonly>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-white">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="agregarFormularioVista()">
                    <i class="fas fa-save me-1"></i> Guardar vista
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalTransporte" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content shadow-lg">
            <div class="modal-header text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-truck-moving me-2"></i> Solicitud de Transporte</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formTransporte">
                    <input type="hidden" id="IdTransporte" name="IdTransporte" value="0" />

                    <ul class="nav nav-pills transport-wizard" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" id="tab-general" data-bs-toggle="pill" data-bs-target="#step-general" type="button">
                                <span class="wizard-number">1</span><span class="wizard-label">General</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" id="tab-ruta" data-bs-toggle="pill" data-bs-target="#step-ruta" type="button">
                                <span class="wizard-number">2</span><span class="wizard-label">Ruta y Unidad</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" id="tab-destinos" data-bs-toggle="pill" data-bs-target="#step-destinos" type="button">
                                <span class="wizard-number">3</span><span class="wizard-label">Destinos</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" id="tab-embarque" data-bs-toggle="pill" data-bs-target="#step-embarque" type="button">
                                <span class="wizard-number">4</span><span class="wizard-label">Plan Embarque</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" id="tab-flete" data-bs-toggle="pill" data-bs-target="#step-flete" type="button">
                                <span class="wizard-number">5</span><span class="wizard-label">Flete</span>
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content transport-wizard-body wizard-scroll">
                        <div class="tab-pane fade show active" id="step-general">
                            <h6 class="form-section-title">Datos Principales</h6>
                            <div class="row g-4 mb-5">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-user me-1"></i> Solicitante</label>
                                    <div class="readonly-field">@usuarioActualNombre</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-building me-1"></i> Departamento</label>
                                    <div class="readonly-field">@usuarioActualArea</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-file-invoice me-1"></i> # Factura <span class="text-muted small">(Opcional)</span></label>
                                    <input type="text" class="form-control" id="NumeroFactura" name="NumeroFactura" placeholder="Ej. F001-12345">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required"><i class="fas fa-building me-1"></i> Compañía Solicitante</label>
                                    <select class="form-select" id="CompaniaSolicitante" name="CompaniaSolicitante" required>
                                        <option value="">Seleccione compañía</option>
                                        @if (empresasTransporte.Any())
                                        {
                                            foreach (var empresa in empresasTransporte)
                                            {
                                                <option value="@empresa.Value">@empresa.Text</option>
                                            }
                                        }
                                        else
                                        {
                                            <option value="NS Equipo">NS Equipo</option>
                                            <option value="NS Multiservicios">NS Multiservicios</option>
                                            <option value="NS Corporativo">NS Corporativo</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <h6 class="form-section-title">Programación</h6>
                            <div class="row g-4 mb-5">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required"><i class="fas fa-calendar-day me-1"></i> Fecha de Carga</label>
                                    <input type="date" class="form-control" id="FechaCarga" name="FechaCarga" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-clock me-1"></i> Horario de Carga</label>
                                    <input type="text" class="form-control" id="HorarioCarga" name="HorarioCarga" placeholder="Ej. 08:00 - 12:00" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-clock me-1"></i> Horario Llegada</label>
                                    <input type="text" class="form-control" id="HorarioLlegadaDestino" name="HorarioLlegadaDestino" placeholder="--:-- --">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-stopwatch me-1"></i> Duración Flete Estimada</label>
                                    <input type="text" class="form-control" id="DuracionAproxFlete" name="DuracionAproxFlete" placeholder="0 Horas">
                                </div>
                            </div>

                            <h6 class="form-section-title">Asignación Financiera</h6>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required"><i class="fas fa-landmark me-1"></i> Centro de Costo</label>
                                    <input type="text" class="form-control" id="CentroCosto" name="CentroCosto" placeholder="Seleccione CC">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-briefcase me-1"></i> Proyecto</label>
                                    <input type="text" class="form-control" id="Proyecto" name="Proyecto" placeholder="Nombre o código de proyecto" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required"><i class="fas fa-gem me-1"></i> Cliente</label>
                                    <input type="text" class="form-control" id="Cliente" name="Cliente" placeholder="Razón social del cliente" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold"><i class="fas fa-shield-alt me-1"></i> Autorizado Presupuesto por</label>
                                    <input type="text" class="form-control" id="AutorizadoPresupuesto" name="AutorizadoPresupuesto" placeholder="Nombre de jefatura">
                                </div>
                                <div class="col-12 d-flex justify-content-end wizard-actions">
                                    <button type="button" class="btn btn-wizard-next px-4" onclick="validarYMostrarPaso('step-general', 'tab-ruta')">
                                        Siguiente Paso <i class="fas fa-arrow-right ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-ruta">
                            <h6 class="form-section-title">Ruta y Unidad</h6>
                            <p class="form-section-subtitle">Captura la ruta de origen, la volumetría y el tipo de unidad sugerida para el flete.</p>
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold required">Tipo de ruta</label>
                                    <select class="form-select" id="TipoRuta" name="TipoRuta" required>
                                        <option value="">Seleccione...</option>
                                        <option value="Local">Local</option>
                                        <option value="Foranea">Foranea</option>
                                        <option value="Especial">Especial</option>
                                    </select>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label fw-semibold required">Dirección de origen / carga</label>
                                    <input type="text" class="form-control" id="DireccionRecoleccion" name="DireccionRecoleccion" placeholder="Planta, bodega o punto de recolección" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold required">Volumetría / dimensiones</label>
                                    <input type="text" class="form-control" id="Volumetria" name="Volumetria" placeholder="Ej. 2.5m x 6.0m" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold required">Tipo de unidad sugerida</label>
                                    <input type="text" class="form-control" id="TipoUnidad" name="TipoUnidad" placeholder="Ej. Torton, Rabón, Camioneta" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Comentarios de unidad</label>
                                    <input type="text" class="form-control" id="ComentariosUnidad" name="ComentariosUnidad" placeholder="Observaciones adicionales">
                                </div>
                                <div class="col-12 d-flex justify-content-between wizard-actions">
                                    <button type="button" class="btn btn-outline-secondary px-4" onclick="mostrarPaso('tab-general')">Atrás</button>
                                    <button type="button" class="btn btn-wizard-next px-4" onclick="validarYMostrarPaso('step-ruta', 'tab-destinos')">
                                        Siguiente <i class="fas fa-arrow-right ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-destinos">
                            <h6 class="form-section-title">Información de Destinos</h6>
                            <p class="form-section-subtitle">Puede agregar múltiples destinos para esta ruta. Los campos marcados con * son obligatorios.</p>
                            <div id="contenedorDestinos"></div>
                            <button type="button" class="btn btn-soft-primary mt-2" onclick="agregarDestino()"><i class="fas fa-plus-circle me-1"></i> Agregar destino</button>
                            <div class="col-12 d-flex justify-content-between wizard-actions">
                                <button type="button" class="btn btn-outline-secondary px-4" onclick="mostrarPaso('tab-ruta')">Atrás</button>
                                <button type="button" class="btn btn-wizard-next px-4" onclick="validarYMostrarPaso('step-destinos', 'tab-embarque')">
                                    Siguiente <i class="fas fa-arrow-right ms-1"></i>
                                </button>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-embarque">
                            <h6 class="form-section-title">Plan de Embarque</h6>
                            <p class="form-section-subtitle">Agrega las partidas de material o equipo que viajarán en la solicitud.</p>
                            <div id="contenedorPlanEmbarque"></div>
                            <button type="button" class="btn btn-soft-primary mt-2" onclick="agregarPartida()"><i class="fas fa-plus-circle me-1"></i> Agregar partida</button>
                            <div class="col-12 d-flex justify-content-between wizard-actions">
                                <button type="button" class="btn btn-outline-secondary px-4" onclick="mostrarPaso('tab-destinos')">Atrás</button>
                                <button type="button" class="btn btn-wizard-next px-4" onclick="validarYMostrarPaso('step-embarque', 'tab-flete')">
                                    Siguiente <i class="fas fa-arrow-right ms-1"></i>
                                </button>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-flete">
                            <h6 class="form-section-title">Flete</h6>
                            <p class="form-section-subtitle">Estos campos pueden quedar vacíos si Logística los completará al revisar o autorizar la solicitud.</p>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Línea transportista / Fletero asignado</label>
                                    <input type="text" class="form-control" id="Fletero" name="Fletero" placeholder="Lo puede completar Logística">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Tarifa estimada autorizada</label>
                                    <input type="number" step="0.01" class="form-control" id="CostoFlete" name="CostoFlete" placeholder="Lo puede completar Logística">
                                </div>
                                <div class="col-12 d-flex justify-content-between wizard-actions">
                                    <button type="button" class="btn btn-outline-secondary px-4" onclick="mostrarPaso('tab-embarque')">Atrás</button>
                                    <button type="button" class="btn btn-wizard-save px-5" id="btnGuardar" onclick="guardarTransporte()">
                                        <i class="fas fa-paper-plane me-1" id="iconGuardar"></i> Guardar Solicitud
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalVerDetalles" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header text-white" style="background-color: var(--navy-principal);">
                <h5 class="modal-title fw-bold"><i class="fas fa-eye me-2"></i> Vista previa de solicitud</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="contenidoDetalles"></div>
