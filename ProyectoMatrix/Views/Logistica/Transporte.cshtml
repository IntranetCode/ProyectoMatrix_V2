        function inicializarModalPerfilDesdeLayout() {
            document.querySelectorAll('a[href*="/Perfil/Index"], a[href$="/Perfil"]').forEach(function (linkPerfil) {
                if (linkPerfil.dataset.perfilModalLogistica === "1") return;

                linkPerfil.dataset.perfilModalLogistica = "1";

                linkPerfil.addEventListener('click', async function (event) {
                    event.preventDefault();
                    event.stopPropagation();

                    const dropdownToggle = linkPerfil.closest('.dropdown')?.querySelector('[data-bs-toggle="dropdown"]');
                    if (dropdownToggle && window.bootstrap) {
                        const dropdown = bootstrap.Dropdown.getInstance(dropdownToggle);
                        if (dropdown) dropdown.hide();
                    }

                    let modalPerfil = document.getElementById('modalPerfilLogistica');

                    if (!modalPerfil) {
                        const modalHtml = `
                            <div class="modal fade" id="modalPerfilLogistica" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content shadow-lg border-0" id="modalPerfilLogisticaContent">
                                        <div class="modal-header text-white" style="background:#003B70;">
                                            <h5 class="modal-title fw-bold">
                                                <i class="fas fa-user-circle me-2"></i> Mi Perfil
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body text-center py-5">
                                            <div class="spinner-border text-primary" role="status"></div>
                                            <p class="mt-3 mb-0 text-muted">Cargando perfil...</p>
                                        </div>
                                    </div>
                                </div>
                            </div>`;

                        document.body.insertAdjacentHTML('beforeend', modalHtml);
                        modalPerfil = document.getElementById('modalPerfilLogistica');
                    }

                    const modalContent = document.getElementById('modalPerfilLogisticaContent');

                    modalContent.innerHTML = `
                        <div class="modal-header text-white" style="background:#003B70;">
                            <h5 class="modal-title fw-bold">
                                <i class="fas fa-user-circle me-2"></i> Mi Perfil
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3 mb-0 text-muted">Cargando perfil...</p>
                        </div>`;

                    const instanciaModal = bootstrap.Modal.getOrCreateInstance(modalPerfil);
                    instanciaModal.show();

                    try {
                        const urlPerfil = linkPerfil.getAttribute('href') || '/Perfil/Index';

                        const response = await fetch(urlPerfil, {
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                        const html = await response.text();
                        const documento = new DOMParser().parseFromString(html, 'text/html');

                        const modalRecibido = documento.querySelector('.modal .modal-content');
                        const modalContentRecibido = documento.querySelector('.modal-content');
                        const cuerpoModalRecibido = documento.querySelector('.modal-body');
                        const contenidoPrincipal = documento.querySelector('main') || documento.body;

                        if (modalRecibido) {
                            modalContent.innerHTML = modalRecibido.innerHTML;
                        } else if (modalContentRecibido) {
                            modalContent.innerHTML = modalContentRecibido.innerHTML;
                        } else if (cuerpoModalRecibido) {
                            modalContent.innerHTML = `
                                <div class="modal-header text-white" style="background:#003B70;">
                                    <h5 class="modal-title fw-bold">
                                        <i class="fas fa-user-circle me-2"></i> Mi Perfil
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    ${cuerpoModalRecibido.innerHTML}
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                </div>`;
                        } else if (contenidoPrincipal && contenidoPrincipal.innerHTML.trim().length > 20) {
                            modalContent.innerHTML = `
                                <div class="modal-header text-white" style="background:#003B70;">
                                    <h5 class="modal-title fw-bold">
                                        <i class="fas fa-user-circle me-2"></i> Mi Perfil
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    ${contenidoPrincipal.innerHTML}
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                </div>`;
                        } else {
                            modalContent.innerHTML = `
                                <div class="modal-header text-white" style="background:#003B70;">
                                    <h5 class="modal-title fw-bold">
                                        <i class="fas fa-user-circle me-2"></i> Mi Perfil
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body text-center py-4">
                                    <i class="fas fa-user-circle text-primary mb-3" style="font-size:4rem;"></i>
                                    <h5 class="fw-bold">No se pudo cargar el perfil dentro del modal.</h5>
                                    <p class="text-muted mb-0">La vista de perfil respondió sin contenido visible.</p>
                                </div>
                                <div class="modal-footer">
                                    <a href="${urlPerfil}" class="btn btn-primary">Abrir perfil</a>
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                </div>`;
                        }
                    } catch (error) {
                        modalContent.innerHTML = `
                            <div class="modal-header text-white" style="background:#003B70;">
                                <h5 class="modal-title fw-bold">
                                    <i class="fas fa-user-circle me-2"></i> Mi Perfil
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body text-center py-4">
                                <i class="fas fa-triangle-exclamation text-warning mb-3" style="font-size:3rem;"></i>
                                <h5 class="fw-bold">No se pudo cargar el perfil.</h5>
                                <p class="text-muted mb-0">Intenta nuevamente.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                            </div>`;
                    }
                }, true);
            });
        }

        document.addEventListener('DOMContentLoaded', inicializarModalPerfilDesdeLayout);

    </script>
}
