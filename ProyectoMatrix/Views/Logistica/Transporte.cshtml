</button>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        let miGrafica = null;
        const esLogisticaJS = @esLogistica.ToString().ToLower();
        let firmaPanelActual = document.getElementById('FirmaPanelTransporte')?.value || '';
        const NotificacionBurbuja = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 5500, timerProgressBar: true });

        $(document).ready(function () {
            if ($('#tablaTransporte').length) $('#tablaTransporte').DataTable({ language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-MX.json' }, order: [[0, 'desc']] });
            if ($('#tablaFinalizadas').length) $('#tablaFinalizadas').DataTable({ language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-MX.json' }, order: [[0, 'desc']] });
            if ($('#tablaBorrados').length) $('#tablaBorrados').DataTable({ language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-MX.json' }, order: [[0, 'desc']] });
            if (esLogisticaJS) iniciarRadarLogistico();
            inicializarSignalROpcional();
        });

        function iniciarRadarLogistico() {
            setInterval(function () {
                $.get('/Logistica/EstadoPanelTransporte', function (res) {
                    if (!res || !res.firma) return;
                    if (firmaPanelActual && res.firma !== firmaPanelActual) {
                        firmaPanelActual = res.firma;
                        NotificacionBurbuja.fire({ icon: 'info', title: 'Movimiento en Transporte', text: 'Hay cambios en pendientes, autorizadas o canceladas. Actualizando...' });
                        setTimeout(() => location.reload(), 2500);
                    }
                });
            }, 12000);
        }

        function inicializarSignalROpcional() {
            if (!window.signalR) return;
            try {
                const conexion = new signalR.HubConnectionBuilder().withUrl('/logisticaHub').withAutomaticReconnect().build();
                conexion.on('ActualizacionLogistica', function () {
                    if (esLogisticaJS) {
                        NotificacionBurbuja.fire({ icon: 'info', title: 'Actualización logística recibida', text: 'Refrescando panel de transporte...' });
                        setTimeout(() => location.reload(), 1800);
                    }
                });
                conexion.start().catch(() => {});
            } catch (e) { }
        }


        document.addEventListener('input', function (e) {
            const input = e.target.closest('.busqueda-seccion');
            if (!input) return;
            filtrarTablaModulo(input.dataset.target, input.value);
        });

        function normalizarTextoBusqueda(valor) {
            return String(valor || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .trim();
        }

        function filtrarTablaModulo(selectorTabla, texto) {
            const tabla = document.querySelector(selectorTabla);
            if (!tabla) return;

            const filtro = normalizarTextoBusqueda(texto);
            const filas = Array.from(tabla.querySelectorAll('tbody tr'));
            let visibles = 0;

            filas.forEach(fila => {
                const coincide = normalizarTextoBusqueda(fila.innerText).includes(filtro);
                fila.classList.toggle('fila-oculta-busqueda', !coincide);
                if (coincide) visibles++;
            });

            const mensaje = document.querySelector(`[data-empty-for="${selectorTabla}"]`);
            if (mensaje) mensaje.style.display = visibles === 0 ? 'block' : 'none';
        }

        document.addEventListener('click', function(e) {
            const link = e.target.closest('#tabsFlujoTransporte a');
            if (!link) return;
            e.preventDefault();
            mostrarSeccionTransporte(link.dataset.target || link.getAttribute('href').replace('#', ''));
        });

        document.addEventListener('click', function(e) {
            const card = e.target.closest('.kpi-filter');
            if (!card) return;
            mostrarSeccionTransporte(card.dataset.target);
        });

        function mostrarSeccionTransporte(targetId) {
            if (!targetId) return;

            const esPanelFormularios = targetId === 'seccionFormularios';

            document.querySelectorAll('.seccion-filtrable').forEach(sec => {
                sec.classList.toggle('seccion-activa', sec.id === targetId);
            });

            document.querySelectorAll('#tabsFlujoTransporte .nav-link').forEach(tab => {
                tab.classList.toggle('active', tab.dataset.target === targetId);
            });

            document.querySelectorAll('.kpi-filter').forEach(card => {
                card.classList.toggle('active', card.dataset.target === targetId);
            });

            document.querySelectorAll('.transport-flow-link').forEach(link => {
                link.classList.toggle('active', !esPanelFormularios && link.dataset.target === targetId);
            });

            document.querySelectorAll('.transport-module-main').forEach(link => {
                link.classList.toggle('active', !esPanelFormularios);
            });

            document.querySelectorAll('.transport-form-menu').forEach(link => {
                link.classList.toggle('active', esPanelFormularios);
            });

            const destino = document.getElementById(targetId);
            if (destino) destino.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function abrirModalCrearFormulario() {
            const modal = document.getElementById('modalCrearFormulario');
            if (!modal) return;
            bootstrap.Modal.getOrCreateInstance(modal).show();
        }

        function agregarFormularioVista() {
            const nombre = (document.getElementById('nuevoFormularioNombre')?.value || '').trim();
            const modulo = document.getElementById('nuevoFormularioModulo')?.value || 'General';
            const descripcion = (document.getElementById('nuevoFormularioDescripcion')?.value || '').trim();
            const estado = document.getElementById('nuevoFormularioEstado')?.value || 'Borrador';

            if (!nombre) {
                document.getElementById('nuevoFormularioNombre')?.focus();
                return;
            }

            const grid = document.getElementById('formulariosGrid');
            if (grid) {
                const card = document.createElement('article');
                card.className = 'form-template-card';
                card.innerHTML = `
                    <span class="form-template-icon"><i class="fas fa-file-alt"></i></span>
                    <h4 class="form-template-title">${nombre}</h4>
                    <p class="form-template-subtitle">${descripcion || 'Formulario agregado desde la vista. Pendiente de conexión a base de datos.'}</p>
                    <div class="form-template-meta">
                        <span>${modulo}</span>
                        <span class="form-status-pill">${estado}</span>
                    </div>
                `;

                const addCard = grid.querySelector('.add-card');
                grid.insertBefore(card, addCard || null);
            }

            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalCrearFormulario')).hide();
            mostrarSeccionTransporte('seccionFormularios');

            document.getElementById('nuevoFormularioNombre').value = '';
            document.getElementById('nuevoFormularioDescripcion').value = '';
        }

        function mostrarPaso(tabId) {
            bootstrap.Tab.getOrCreateInstance(document.getElementById(tabId)).show();
        }

        function validarYMostrarPaso(stepId, tabDestinoId) {
            const step = document.getElementById(stepId);
            const invalido = step.querySelector(':invalid');
            if (invalido) {
                invalido.reportValidity();
                return;
            }
            mostrarPaso(tabDestinoId);
        }

        function crearFilaDestino(index, data) {
            return `
                <div class="detalle-card mb-3 destino-row">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Destino <span class="numero-destino">${index + 1}</span></strong>
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" onclick="eliminarFila(this, 'destino')"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4"><label class="form-label fw-semibold required">Nombre de quien recibe</label><input type="text" class="form-control campo-destino" data-campo="NombreRecibe" value="${data?.nombreRecibe || data?.NombreRecibe || ''}" required></div>
                        <div class="col-md-3"><label class="form-label fw-semibold required">Contacto</label><input type="text" class="form-control campo-destino" data-campo="ContactoRecibe" value="${data?.contactoRecibe || data?.ContactoRecibe || ''}" required></div>
                        <div class="col-md-5"><label class="form-label fw-semibold required">Direccion destino</label><input type="text" class="form-control campo-destino" data-campo="DireccionDestino" value="${data?.direccionDestino || data?.DireccionDestino || ''}" required></div>
                    </div>
                </div>`;
        }

        function crearFilaPartida(index, data) {
            return `
                <div class="detalle-card mb-3 partida-row">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Partida <span class="numero-partida">${index + 1}</span></strong>
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill" onclick="eliminarFila(this, 'partida')"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-2"><label class="form-label fw-semibold">Clave SAT</label><input type="text" class="form-control campo-partida" data-campo="ClaveSAT" value="${data?.claveSAT || data?.ClaveSAT || ''}"></div>
                        <div class="col-md-4"><label class="form-label fw-semibold required">Descripcion</label><input type="text" class="form-control campo-partida" data-campo="Descripcion" value="${data?.descripcion || data?.Descripcion || ''}" required></div>
                        <div class="col-md-2"><label class="form-label fw-semibold required">Cantidad</label><input type="number" step="0.01" class="form-control campo-partida" data-campo="Cantidad" value="${data?.cantidad || data?.Cantidad || ''}" required></div>
                        <div class="col-md-2"><label class="form-label fw-semibold required">UM</label><input type="text" class="form-control campo-partida" data-campo="UnidadMedida" value="${data?.unidadMedida || data?.UnidadMedida || ''}" required></div>
                        <div class="col-md-2"><label class="form-label fw-semibold">Peso</label><input type="number" step="0.01" class="form-control campo-partida" data-campo="Peso" value="${data?.peso || data?.Peso || ''}"></div>
                        <div class="col-md-3"><label class="form-label fw-semibold">Valor</label><input type="number" step="0.01" class="form-control campo-partida" data-campo="Valor" value="${data?.valor || data?.Valor || ''}"></div>
                        <div class="col-md-9"><label class="form-label fw-semibold">Vale de salida / factura</label><input type="text" class="form-control campo-partida" data-campo="ValeSalidaFactura" value="${data?.valeSalidaFactura || data?.ValeSalidaFactura || ''}"></div>
                    </div>
                </div>`;
        }

        function agregarDestino(data) {
            const contenedor = document.getElementById('contenedorDestinos');
            contenedor.insertAdjacentHTML('beforeend', crearFilaDestino(contenedor.querySelectorAll('.destino-row').length, data));
            reindexarDestinos();
        }

        function agregarPartida(data) {
            const contenedor = document.getElementById('contenedorPlanEmbarque');
            contenedor.insertAdjacentHTML('beforeend', crearFilaPartida(contenedor.querySelectorAll('.partida-row').length, data));
            reindexarPartidas();
        }

        function eliminarFila(btn, tipo) {
            btn.closest('.detalle-card').remove();
            if (tipo === 'destino') reindexarDestinos(); else reindexarPartidas();
        }

        function reindexarDestinos() {
            document.querySelectorAll('.destino-row').forEach((row, index) => {
                row.querySelector('.numero-destino').textContent = index + 1;
                row.querySelectorAll('.campo-destino').forEach(input => input.name = `Destinos[${index}].${input.dataset.campo}`);
            });
        }

        function reindexarPartidas() {
            document.querySelectorAll('.partida-row').forEach((row, index) => {
                row.querySelector('.numero-partida').textContent = index + 1;
                row.querySelectorAll('.campo-partida').forEach(input => input.name = `PlanEmbarque[${index}].${input.dataset.campo}`);
            });
        }

        function abrirModalCrear() {
            document.getElementById('formTransporte').reset();
            document.getElementById('IdTransporte').value = '0';
            document.getElementById('contenedorDestinos').innerHTML = '';
            document.getElementById('contenedorPlanEmbarque').innerHTML = '';
            agregarDestino();
            agregarPartida();
            restaurarBotonGuardar();
            mostrarPaso('tab-general');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalTransporte')).show();
        }

        function abrirModalEditar(id) {
            $.get('/Logistica/ObtenerTransporte/' + id, function (data) {
                document.getElementById('formTransporte').reset();
                document.getElementById('IdTransporte').value = data.idTransporte;
                $('#FechaCarga').val(data.fechaCarga ? data.fechaCarga.substring(0, 10) : '');
                $('#NumeroFactura').val(data.numeroFactura || '');
                $('#HorarioCarga').val(data.horarioCarga || '');
                $('#HorarioLlegadaDestino').val(data.horarioLlegadaDestino || '');
                $('#DuracionAproxFlete').val(data.duracionAproxFlete || '');
                $('#Cliente').val(data.cliente || '');
                $('#Proyecto').val(data.proyecto || '');
                $('#CompaniaSolicitante').val(data.companiaSolicitante || '');
                $('#CentroCosto').val(data.centroCosto || '');
                $('#AutorizadoPresupuesto').val(data.autorizadoPresupuesto || '');
                $('#TipoRuta').val(data.tipoRuta || '');
                $('#DireccionRecoleccion').val(data.direccionRecoleccion || '');
                $('#Volumetria').val(data.volumetria || '');
                $('#TipoUnidad').val(data.tipoUnidad || '');
                $('#ComentariosUnidad').val(data.comentariosUnidad || '');
                $('#Fletero').val(data.fletero || '');
                $('#CostoFlete').val(data.costoFlete || '');

                document.getElementById('contenedorDestinos').innerHTML = '';
                (data.destinos && data.destinos.length ? data.destinos : [{}]).forEach(d => agregarDestino(d));

                document.getElementById('contenedorPlanEmbarque').innerHTML = '';
                (data.planEmbarque && data.planEmbarque.length ? data.planEmbarque : [{}]).forEach(p => agregarPartida(p));

                restaurarBotonGuardar();
                mostrarPaso('tab-general');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalTransporte')).show();
            });
        }

        function escaparHtml(valor) {
            return String(valor ?? '').replace(/[&<>"']/g, function (m) {
                return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[m];
            });
        }

        function abrirModalVer(id) {
