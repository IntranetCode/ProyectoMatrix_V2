                                        <button class="transport-icon-btn" onclick="abrirModalEditar(@item.IdTransporte)" title="Editar"><i class="fas fa-pen"></i></button>
                                        <button class="transport-icon-btn" onclick="finalizarTransporte(@item.IdTransporte)" title="Finalizar"><i class="fas fa-flag-checkered"></i></button>
                                        <button class="transport-icon-btn text-danger" onclick="abrirModalBorrar(@item.IdTransporte)" title="Cancelar"><i class="fas fa-trash-alt"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer-line">
                <span>Mostrando 1 a @autorizadas.Count de @autorizadas.Count registros</span>
                <span class="table-pager"><i class="fas fa-angle-left"></i><i class="fas fa-angle-right"></i></span>
            </div>
        </div>

        @if (esLogistica)
        {
            <div id="seccionFinalizadas" data-section="seccionFinalizadas" class="seccion-filtrable">
