        </div>
        <div class="table-responsive">
            <table class="table table-custom align-middle" id="tablaTransporte">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Cliente</th>
                        <th>Proyecto</th>
                        <th>Fecha carga</th>
                        <th>Tipo ruta</th>
                        <th>Unidad</th>
