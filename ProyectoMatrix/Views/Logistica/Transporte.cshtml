                                        <button class="btn btn-sm btn-success rounded-circle me-1" onclick="resolverTransporte(@item.IdTransporte, 'Aceptada')" title="Autorizar"><i class="fas fa-check"></i></button>
                                        <button class="btn btn-sm btn-danger rounded-circle" onclick="resolverTransporte(@item.IdTransporte, 'Rechazada')" title="Rechazar"><i class="fas fa-times"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <div id="seccionAutorizadas" data-section="seccionAutorizadas" class="dashboard-card p-4 mb-5 seccion-filtrable @(esLogistica ? "" : "seccion-activa")">
