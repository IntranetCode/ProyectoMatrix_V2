        }

        function generarGraficaFinanciera(rango) {
            $.get('/Logistica/ObtenerDatosFinancieros', { rango: rango }, function (res) {
                const ctx = document.getElementById('chartFinanciero').getContext('2d');

                const etiquetas = res.etiquetas || [];
                const datos = res.ingresos || [];

                const total = datos.reduce((acc, val) => acc + Number(val || 0), 0);
                const operaciones = datos.filter(x => Number(x || 0) > 0).length;
                const promedio = operaciones > 0 ? total / operaciones : 0;

                document.getElementById('kpiTotalCostos').innerText = total.toLocaleString('es-MX', {
                    style: 'currency',
                    currency: 'MXN'
                });

                document.getElementById('kpiTotalOperaciones').innerText = operaciones;

                document.getElementById('kpiPromedioCostos').innerText = promedio.toLocaleString('es-MX', {
                    style: 'currency',
                    currency: 'MXN'
                });

                if (miGrafica) {
                    miGrafica.destroy();
                }

                const gradient = ctx.createLinearGradient(0, 0, 0, 360);
                gradient.addColorStop(0, 'rgba(37, 99, 235, .95)');
                gradient.addColorStop(0.55, 'rgba(14, 165, 233, .75)');
                gradient.addColorStop(1, 'rgba(249, 115, 22, .55)');

                miGrafica = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: etiquetas,
                        datasets: [{
                            label: 'Costo de fletes',
                            data: datos,
                            backgroundColor: gradient,
                            borderColor: 'rgba(15, 23, 42, .85)',
                            borderWidth: 1,
                            borderRadius: 14,
                            borderSkipped: false,
                            maxBarThickness: 58
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 900,
                            easing: 'easeOutQuart'
                        },
                        plugins: {
                            legend: {
                                display: true,
                                labels: {
                                    color: '#334155',
                                    font: { weight: 'bold' },
                                    usePointStyle: true,
                                    pointStyle: 'rectRounded'
                                }
                            },
                            tooltip: {
                                backgroundColor: '#0f172a',
                                titleColor: '#ffffff',
                                bodyColor: '#e2e8f0',
                                padding: 12,
                                cornerRadius: 12,
                                callbacks: {
                                    label: function (context) {
                                        const value = Number(context.raw || 0);
                                        return ' ' + value.toLocaleString('es-MX', {
                                            style: 'currency',
                                            currency: 'MXN'
                                        });
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: {
                                    color: '#64748b',
                                    font: { weight: 'bold' }
                                }
                            },
                            y: {
                                beginAtZero: true,
                                grid: {
                                    color: 'rgba(148,163,184,.22)',
                                    drawBorder: false
                                },
                                ticks: {
                                    color: '#64748b',
                                    callback: function (value) {
                                        return '$' + Number(value).toLocaleString('es-MX');
                                    }
                                }
                            }
                        }
                    }
                });
            });
        }

