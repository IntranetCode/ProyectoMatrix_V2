            <div class="modal-header border-0">
                <div>
                    <h5 class="modal-title fw-bold" id="modalCrearFormularioLabel">
                        <i class="fas fa-clipboard-list me-2"></i> Crear nuevo formulario
                    </h5>
                    <small class="text-white-50">Vista inicial para preparar los formularios que se irán agregando al módulo.</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
