<div class="transport-layout-shell fade-in-up" id="inicioPagina">
    <aside class="transport-side-menu" aria-label="Menu lateral de Logistica">
        <div class="side-brand">
            <div class="side-brand-mark">NS</div>
            <div>
                <div class="side-brand-name">NS EQUIPO</div>
                <div class="side-brand-subtitle">Intranet Corporativa</div>
            </div>
        </div>

        <button type="button" class="side-new-request" onclick="abrirModalCrear()">
            <i class="fas fa-plus"></i> Nueva Solicitud
        </button>

        <button type="button" class="side-create-form" onclick="abrirModalCrearFormulario()">
            <i class="fas fa-file-alt"></i> Crear Formulario
        </button>

        <nav class="side-nav">
            <div class="side-nav-title">Menu principal</div>
            <a href="@menuLogisticaUrl" class="side-link">
                <i class="fas fa-th-large"></i><span>Menu</span>
            </a>
            <a href="/Logistica/Guias" class="side-link">
                <i class="fas fa-map"></i><span>Logistica Guias</span>
            </a>
            <button type="button" class="side-link active transport-module-main" onclick="mostrarSeccionTransporte('@seccionInicialTransporte')">
                <i class="fas fa-truck"></i><span>Logistica Transporte</span>
            </button>
            @if (esLogistica)
            {
                <button type="button" class="side-link" onclick="abrirModalDashboard()">
                    <i class="fas fa-chart-bar"></i><span>Reportes</span>
                </button>
            }
            <button type="button" id="btnFormulariosMenu" class="side-link transport-form-menu" onclick="mostrarSeccionTransporte('seccionFormularios')">
                <i class="fas fa-clipboard-list"></i><span>Formularios</span>
            </button>

            <div class="side-nav-title mt-3">Flujo de transporte</div>
            @if (esLogistica)
            {
                <button type="button" class="side-link side-subitem transport-flow-link active" data-target="seccionPendientes" onclick="mostrarSeccionTransporte('seccionPendientes')">
                    <i class="fas fa-clock"></i><span>Pendientes</span><span class="side-count">@pendientes.Count</span>
                </button>
            }
            <button type="button" class="side-link side-subitem transport-flow-link @(esLogistica ? "" : "active")" data-target="seccionAutorizadas" onclick="mostrarSeccionTransporte('seccionAutorizadas')">
                <i class="fas fa-check-circle"></i><span>Autorizadas</span><span class="side-count">@autorizadas.Count</span>
            </button>
            @if (esLogistica)
            {
                <button type="button" class="side-link side-subitem transport-flow-link" data-target="seccionFinalizadas" onclick="mostrarSeccionTransporte('seccionFinalizadas')">
                    <i class="fas fa-flag-checkered"></i><span>Finalizadas</span><span class="side-count">@finalizadas.Count</span>
                </button>
            }
            <button type="button" class="side-link side-subitem transport-flow-link" data-target="seccionEliminadas" onclick="mostrarSeccionTransporte('seccionEliminadas')">
                <i class="fas fa-times-circle"></i><span>Canceladas</span><span class="side-count">@eliminadas.Count</span>
            </button>
        </nav>

    </aside>

    <main class="transport-page-shell">

    <div class="transport-top-row">
        <div class="page-back-zone">
            <a href="@menuLogisticaUrl" class="page-back-btn logistica-back-btn">
                <i class="fas fa-arrow-left"></i> Regresar
            </a>
        </div>

        @if (esLogistica)
        {
            <div class="transport-top-actions">
                <a href="/Logistica/DescargarReporteTransportesPDF" target="_blank" class="hero-action-btn hero-action-pdf" title="Descargar PDF">
                    <i class="fas fa-file-pdf"></i> PDF
                </a>
                <a href="/Logistica/DescargarReporteTransportesExcel" target="_blank" class="hero-action-btn hero-action-excel" title="Descargar Excel">
                    <i class="fas fa-file-excel"></i> Excel
                </a>
                <button type="button" class="hero-action-btn hero-action-costs" onclick="abrirModalDashboard()" title="Dashboard de costos">
                    <i class="fas fa-chart-line"></i> Costos
                </button>
            </div>
        }
    </div>

    <section class="transport-hero mb-4">
        <h1 class="transport-hero-title">Solicitudes de Transporte</h1>
        <p class="transport-hero-subtitle">Gestión y seguimiento de requerimientos logísticos.</p>
    </section>

    <div class="transport-board transport-board-clean">
        @if (esLogistica)
        {
            <div id="seccionPendientes" data-section="seccionPendientes" class="seccion-filtrable seccion-activa">
                <div class="section-toolbar">
                    <div class="section-heading">
                        <span class="section-icon pending"><i class="fas fa-clock"></i></span>
                        <div class="section-heading-copy">
                            <div class="section-eyebrow">Flujo de transporte</div>
                            <div class="section-title-row">
                                <h2 class="section-title">Solicitudes pendientes de autorización</h2>
                                <span class="section-meta-badge">@pendientes.Count registro@(pendientes.Count == 1 ? "" : "s")</span>
                            </div>
                        </div>
                    </div>
                    <div class="search-module-box">
                        <i class="fas fa-search"></i>
                        <input type="text" class="busqueda-seccion" data-target="#tablaPendientes" placeholder="Buscar por folio o cliente...">
                    </div>
                </div>
                <div class="empty-search-message" data-empty-for="#tablaPendientes">
                    <i class="fas fa-magnifying-glass me-1"></i> No se encontraron solicitudes pendientes con esa búsqueda.
                </div>
                <div class="table-responsive section-table-wrap">
                    <table class="table transport-table align-middle" id="tablaPendientes">
                        <thead>
                            <tr>
                                <th>Folio</th>
                                <th>Fecha solicitud</th>
                                <th>Cliente / Proyecto</th>
                                <th>Ruta - Unidad</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in pendientes)
                            {
                                <tr>
                                    <td><span class="folio-pill">@(item.Folio ?? $"TR-{item.IdTransporte}")</span></td>
                                    <td>@(item.FechaCarga.HasValue ? item.FechaCarga.Value.ToString("dd MMM yyyy") : "N/A")</td>
                                    <td>
                                        <div class="transport-client-main">@(item.Cliente ?? "N/A")</div>
                                        <div class="transport-client-sub">@(item.Proyecto ?? "N/A")</div>
                                    </td>
                                    <td>@(item.TipoRuta ?? "N/A") <span class="text-muted mx-1">→</span> @(item.TipoUnidad ?? "N/A")</td>
                                    <td><span class="status-pill">Por autorizar</span></td>
                                    <td class="text-center">
                                        <div class="transport-actions-row">
                                            <button class="transport-icon-btn" onclick="abrirModalVer(@item.IdTransporte)" title="Ver"><i class="fas fa-eye"></i></button>
                                            <button class="transport-icon-btn" onclick="abrirModalEditar(@item.IdTransporte)" title="Revisar"><i class="fas fa-pen"></i></button>
                                            <button class="transport-icon-btn text-success" onclick="resolverTransporte(@item.IdTransporte, 'Aceptada')" title="Autorizar"><i class="fas fa-check"></i></button>
                                            <button class="transport-icon-btn text-danger" onclick="resolverTransporte(@item.IdTransporte, 'Rechazada')" title="Rechazar"><i class="fas fa-times"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer-line">
                    <span>Mostrando 1 a @pendientes.Count de @pendientes.Count registros</span>
                    <span class="table-pager"><i class="fas fa-angle-left"></i><i class="fas fa-angle-right"></i></span>
                </div>
            </div>
        }

        <div id="seccionAutorizadas" data-section="seccionAutorizadas" class="seccion-filtrable @(esLogistica ? "" : "seccion-activa")">
            <div class="section-toolbar">
                <div class="section-heading">
                    <span class="section-icon authorized"><i class="fas fa-check-circle"></i></span>
                    <div class="section-heading-copy">
                        <div class="section-eyebrow">Flujo de transporte</div>
                        <div class="section-title-row">
                            <h2 class="section-title">Solicitudes autorizadas</h2>
                            <span class="section-meta-badge">@autorizadas.Count registro@(autorizadas.Count == 1 ? "" : "s")</span>
                        </div>
                    </div>
                </div>
                <div class="search-module-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="busqueda-seccion" data-target="#tablaTransporte" placeholder="Buscar por folio o cliente...">
                </div>
            </div>
            <div class="empty-search-message" data-empty-for="#tablaTransporte">
                <i class="fas fa-magnifying-glass me-1"></i> No se encontraron solicitudes autorizadas con esa búsqueda.
            </div>
            <div class="table-responsive section-table-wrap">
                <table class="table transport-table align-middle" id="tablaTransporte">
                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Fecha solicitud</th>
                            <th>Cliente / Proyecto</th>
                            <th>Ruta - Unidad</th>
                            <th>Fletero</th>
                            <th>Costo</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in autorizadas)
                        {
                            <tr>
                                <td><span class="folio-pill">@(item.Folio ?? $"TR-{item.IdTransporte}")</span></td>
                                <td>@(item.FechaCarga.HasValue ? item.FechaCarga.Value.ToString("dd MMM yyyy") : "N/A")</td>
                                <td>
                                    <div class="transport-client-main">@(item.Cliente ?? "N/A")</div>
                                    <div class="transport-client-sub">@(item.Proyecto ?? "N/A")</div>
                                </td>
                                <td>@(item.TipoRuta ?? "N/A") <span class="text-muted mx-1">→</span> @(item.TipoUnidad ?? "N/A")</td>
                                <td>@(item.Fletero ?? "N/A")</td>
                                <td>@((item.CostoFlete ?? 0).ToString("C"))</td>
                                <td><span class="status-pill authorized">Autorizada</span></td>
                                <td class="text-center">
                                    <div class="transport-actions-row">
                                        <a class="transport-icon-btn" href="/Logistica/DescargarTransportePDF?id=@item.IdTransporte" target="_blank" title="PDF"><i class="fas fa-file-pdf"></i></a>
