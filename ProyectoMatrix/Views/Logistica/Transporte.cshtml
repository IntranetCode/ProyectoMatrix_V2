        function inicializarModalPerfilDesdeLayout() {
            document.querySelectorAll('a[href*="/Perfil/Index"], a[href$="/Perfil"]').forEach(function (linkPerfil) {
                if (linkPerfil.dataset.perfilModalLogistica === "1") return;

                linkPerfil.dataset.perfilModalLogistica = "1";

                linkPerfil.addEventListener('click', async function (event) {
                    event.preventDefault();
                    event.stopPropagation();

                    const dropdownToggle = linkPerfil.closest('.dropdown')?.querySelector('[data-bs-toggle="dropdown"]');
                    if (dropdownToggle && window.bootstrap) {
                        const dropdown = bootstrap.Dropdown.getInstance(dropdownToggle);
                        if (dropdown) dropdown.hide();
