</div>

<button class="btn-flotante" onclick="abrirModalCrear()"><i class="fas fa-plus me-2"></i> Nueva Solicitud</button>

<div class="modal fade" id="modalTransporte" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content shadow-lg">
            <div class="modal-header text-white" style="background-color: var(--navy-principal);">
                <h5 class="modal-title fw-bold"><i class="fas fa-edit me-2"></i> Solicitud de Transporte</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <form id="formTransporte">
                    <input type="hidden" id="IdTransporte" name="IdTransporte" value="0" />

                    <ul class="nav nav-pills flex-wrap justify-content-center gap-2 mb-4" role="tablist">
                        <li class="nav-item"><button class="nav-link active" id="tab-general" data-bs-toggle="pill" data-bs-target="#step-general" type="button">1. General</button></li>
                        <li class="nav-item"><button class="nav-link" id="tab-ruta" data-bs-toggle="pill" data-bs-target="#step-ruta" type="button">2. Ruta y Unidad</button></li>
                        <li class="nav-item"><button class="nav-link" id="tab-destinos" data-bs-toggle="pill" data-bs-target="#step-destinos" type="button">3. Destinos</button></li>
                        <li class="nav-item"><button class="nav-link" id="tab-embarque" data-bs-toggle="pill" data-bs-target="#step-embarque" type="button">4. Plan de Embarque</button></li>
                        <li class="nav-item"><button class="nav-link" id="tab-flete" data-bs-toggle="pill" data-bs-target="#step-flete" type="button">5. Flete</button></li>
                    </ul>

                    <div class="tab-content bg-white p-4 rounded-3 border shadow-sm wizard-scroll">
                        <div class="tab-pane fade show active" id="step-general">
                            <h6 class="form-section-title">Datos generales para facturacion</h6>
                            <div class="row g-3">
                                <div class="col-md-3"><label class="form-label fw-semibold"># Factura</label><input type="text" class="form-control" id="NumeroFactura" name="NumeroFactura" placeholder="Si aplica"></div>
                                <div class="col-md-3"><label class="form-label fw-semibold required">Fecha de carga</label><input type="date" class="form-control" id="FechaCarga" name="FechaCarga" required></div>
                                <div class="col-md-3"><label class="form-label fw-semibold required">Horario de carga</label><input type="text" class="form-control" id="HorarioCarga" name="HorarioCarga" placeholder="Ej. 08:00 - 12:00" required></div>
                                <div class="col-md-3"><label class="form-label fw-semibold">Horario llegada destino</label><input type="text" class="form-control" id="HorarioLlegadaDestino" name="HorarioLlegadaDestino" placeholder="Ej. 16:00"></div>
                                <div class="col-md-4"><label class="form-label fw-semibold">Duración aprox. de flete</label><input type="text" class="form-control" id="DuracionAproxFlete" name="DuracionAproxFlete" placeholder="Ej. 4 hrs / 2 días"></div>
                                <div class="col-md-4"><label class="form-label fw-semibold required">Compania solicitante</label>
                                    <select class="form-select" id="CompaniaSolicitante" name="CompaniaSolicitante" required>
                                        <option value="">Seleccione...</option>
                                        @if (empresasTransporte.Any())
                                        {
                                            foreach (var empresa in empresasTransporte)
                                            {
                                                <option value="@empresa.Value">@empresa.Text</option>
                                            }
                                        }
                                        else
                                        {
                                            <option value="NS Equipo">NS Equipo</option>
                                            <option value="NS Multiservicios">NS Multiservicios</option>
                                            <option value="NS Corporativo">NS Corporativo</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4"><label class="form-label fw-semibold">Centro de costo</label><input type="text" class="form-control" id="CentroCosto" name="CentroCosto" placeholder="Ej. Directo / área / cuenta"></div>
                                <div class="col-md-6"><label class="form-label fw-semibold required">Cliente</label><input type="text" class="form-control" id="Cliente" name="Cliente" required></div>
                                <div class="col-md-6"><label class="form-label fw-semibold required">Proyecto</label><input type="text" class="form-control" id="Proyecto" name="Proyecto" required></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">Autorizado presupuesto</label><input type="text" class="form-control" id="AutorizadoPresupuesto" name="AutorizadoPresupuesto" placeholder="Nombre o autorización"></div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Solicitante</label>
                                    <div class="detalle-card bg-light">
                                        <i class="fas fa-user me-1 text-primary"></i> @usuarioActualNombre
                                        <div class="small text-muted">Se toma automaticamente del usuario que inicio sesion.</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Departamento / area</label>
                                    <div class="detalle-card bg-light">
                                        <i class="fas fa-building me-1 text-primary"></i> @usuarioActualArea
                                        <div class="small text-muted">Se toma automaticamente de la base de datos.</div>
                                    </div>
                                </div>
                                <div class="col-12 d-flex justify-content-end wizard-actions">
                                    <button type="button" class="btn btn-wizard-next px-4 rounded-pill" onclick="validarYMostrarPaso('step-general', 'tab-ruta')">
                                        Siguiente <i class="fas fa-arrow-right ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-ruta">
                            <h6 class="form-section-title">Ruta, recoleccion y unidad</h6>
                            <div class="row g-3">
                                <div class="col-md-4"><label class="form-label fw-semibold required">Tipo de ruta</label><select class="form-select" id="TipoRuta" name="TipoRuta" required><option value="">Seleccione...</option><option value="Local">Local</option><option value="Foranea">Foranea</option><option value="Especial">Especial</option></select></div>
                                <div class="col-md-8"><label class="form-label fw-semibold required">Direccion de recoleccion</label><input type="text" class="form-control" id="DireccionRecoleccion" name="DireccionRecoleccion" required></div>
                                <div class="col-md-4"><label class="form-label fw-semibold required">Volumetria</label><input type="text" class="form-control" id="Volumetria" name="Volumetria" placeholder="Ej. 2.5 x 6 mts" required></div>
                                <div class="col-md-4"><label class="form-label fw-semibold required">Tipo de unidad</label><input type="text" class="form-control" id="TipoUnidad" name="TipoUnidad" placeholder="Ej. Torton, Rabon, Camioneta" required></div>
                                <div class="col-md-4"><label class="form-label fw-semibold">Comentarios de unidad</label><input type="text" class="form-control" id="ComentariosUnidad" name="ComentariosUnidad"></div>
                                <div class="col-12 d-flex justify-content-between wizard-actions">
                                    <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-general')">Atras</button>
                                    <button type="button" class="btn btn-wizard-next px-4 rounded-pill" onclick="validarYMostrarPaso('step-ruta', 'tab-destinos')">
                                        Siguiente <i class="fas fa-arrow-right ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-destinos">
                            <h6 class="form-section-title">Destinos y personas que reciben carga</h6>
                            <div id="contenedorDestinos"></div>
                            <button type="button" class="btn btn-soft-primary rounded-pill mt-2" onclick="agregarDestino()"><i class="fas fa-plus me-1"></i> Agregar destino</button>
                            <div class="col-12 d-flex justify-content-between wizard-actions">
                                <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-ruta')">Atras</button>
                                <button type="button" class="btn btn-wizard-next px-4 rounded-pill" onclick="validarYMostrarPaso('step-destinos', 'tab-embarque')">
                                    Siguiente <i class="fas fa-arrow-right ms-1"></i>
                                </button>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-embarque">
                            <h6 class="form-section-title">Plan de embarque</h6>
                            <div id="contenedorPlanEmbarque"></div>
                            <button type="button" class="btn btn-soft-primary rounded-pill mt-2" onclick="agregarPartida()"><i class="fas fa-plus me-1"></i> Agregar partida</button>
                            <div class="col-12 d-flex justify-content-between wizard-actions">
                                <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-destinos')">Atras</button>
                                <button type="button" class="btn btn-wizard-next px-4 rounded-pill" onclick="validarYMostrarPaso('step-embarque', 'tab-flete')">
                                    Siguiente <i class="fas fa-arrow-right ms-1"></i>
                                </button>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-flete">
                            <h6 class="form-section-title">Fletero y costo</h6>
                            <div class="alert alert-info py-2 small"><i class="fas fa-circle-info me-1"></i> Estos campos pueden quedar vacios si Logistica los completara al revisar o autorizar la solicitud.</div>
                            <div class="row g-3">
                                <div class="col-md-6"><label class="form-label fw-semibold">Fletero</label><input type="text" class="form-control" id="Fletero" name="Fletero" placeholder="Lo puede completar Logistica"></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">Costo del flete</label><input type="number" step="0.01" class="form-control" id="CostoFlete" name="CostoFlete" placeholder="Lo puede completar Logistica"></div>
                                <div class="col-12 d-flex justify-content-between wizard-actions">
                                    <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-embarque')">Atras</button>
                                    <button type="button" class="btn btn-wizard-save px-5 rounded-pill" id="btnGuardar" onclick="guardarTransporte()">
                                        <i class="fas fa-paper-plane me-1" id="iconGuardar"></i> Guardar Solicitud
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalVerDetalles" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header text-white" style="background-color: var(--navy-principal);">
                <h5 class="modal-title fw-bold"><i class="fas fa-eye me-2"></i> Vista previa de solicitud</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
