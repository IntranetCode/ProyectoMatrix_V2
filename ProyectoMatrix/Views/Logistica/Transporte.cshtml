                            <tr>
                                <th>Folio</th>
                                <th>Fecha solicitud</th>
                                <th>Cliente / Proyecto</th>
                                <th>Ruta - Unidad</th>
                                <th>Fletero</th>
                                <th>Costo</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in finalizadas)
                            {
                                <tr>
                                    <td><span class="folio-pill">@(item.Folio ?? $"TR-{item.IdTransporte}")</span></td>
                                    <td>@(item.FechaCarga.HasValue ? item.FechaCarga.Value.ToString("dd MMM yyyy") : "N/A")</td>
                                    <td>
                                        <div class="transport-client-main">@(item.Cliente ?? "N/A")</div>
                                        <div class="transport-client-sub">@(item.Proyecto ?? "N/A")</div>
                                    </td>
                                    <td>@(item.TipoRuta ?? "N/A") <span class="text-muted mx-1">→</span> @(item.TipoUnidad ?? "N/A")</td>
                                    <td>@(item.Fletero ?? "N/A")</td>
                                    <td>@((item.CostoFlete ?? 0).ToString("C"))</td>
                                    <td><span class="status-pill finished">Finalizada</span></td>
                                    <td class="text-center">
                                        <a class="transport-icon-btn" href="/Logistica/DescargarTransportePDF?id=@item.IdTransporte" target="_blank" title="PDF"><i class="fas fa-file-pdf"></i></a>
                                        <button class="transport-icon-btn" onclick="abrirModalVer(@item.IdTransporte)" title="Ver"><i class="fas fa-eye"></i></button>
                                        @if (esLogistica)
                                        {
                                            <button class="transport-icon-btn text-danger" onclick="eliminarTransporteFinalizado(@item.IdTransporte)" title="Eliminar finalizado"><i class="fas fa-trash-alt"></i></button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer-line">
                    <span>Mostrando 1 a @finalizadas.Count de @finalizadas.Count registros</span>
                    <span class="table-pager"><i class="fas fa-angle-left"></i><i class="fas fa-angle-right"></i></span>
                </div>
            </div>
        }

        <div id="seccionEliminadas" data-section="seccionEliminadas" class="seccion-filtrable">
            <div class="section-toolbar">
                <div class="section-heading">
                    <span class="section-icon cancelled"><i class="fas fa-times-circle"></i></span>
                    <div class="section-heading-copy">
                        <div class="section-eyebrow">Flujo de transporte</div>
                        <div class="section-title-row">
                            <h2 class="section-title">Solicitudes canceladas</h2>
                            <span class="section-meta-badge">@eliminadas.Count registro@(eliminadas.Count == 1 ? "" : "s")</span>
                        </div>
                    </div>
                </div>
                <div class="search-module-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="busqueda-seccion" data-target="#tablaBorrados" placeholder="Buscar por folio o cliente...">
                </div>
            </div>
            <div class="empty-search-message" data-empty-for="#tablaBorrados">
                <i class="fas fa-magnifying-glass me-1"></i> No se encontraron registros cancelados con esa búsqueda.
            </div>
            <div class="table-responsive section-table-wrap">
                <table class="table transport-table align-middle" id="tablaBorrados">
                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Fecha</th>
                            <th>Cliente / Proyecto</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in eliminadas)
                        {
                            <tr>
                                <td><span class="folio-pill">@(item.Folio ?? $"TR-{item.IdTransporte}")</span></td>
                                <td>@(item.FechaBorrado.HasValue ? item.FechaBorrado.Value.ToString("dd MMM yyyy") : "N/A")</td>
                                <td>
                                    <div class="transport-client-main">@(item.Cliente ?? "N/A")</div>
                                    <div class="transport-client-sub">@(item.Proyecto ?? "N/A")</div>
                                </td>
                                <td>@(item.MotivoBorrado ?? "N/A")</td>
                                <td><span class="status-pill cancelled">Cancelada</span></td>
                                <td class="text-center">
                                    @if (esLogistica)
                                    {
                                        <button class="transport-icon-btn text-success" onclick="restaurarTransporte(@item.IdTransporte)" title="Restaurar"><i class="fas fa-undo"></i></button>
                                        <button class="transport-icon-btn text-danger" onclick="eliminarTransporteDefinitivo(@item.IdTransporte)" title="Eliminar definitivo"><i class="fas fa-trash-alt"></i></button>
                                    }
                                    else
                                    {
                                        <button class="transport-icon-btn" onclick="abrirModalVer(@item.IdTransporte)" title="Ver"><i class="fas fa-eye"></i></button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer-line">
                <span>Mostrando 1 a @eliminadas.Count de @eliminadas.Count registros</span>
                <span class="table-pager"><i class="fas fa-angle-left"></i><i class="fas fa-angle-right"></i></span>
            </div>
        </div>

        <div id="seccionFormularios" data-section="seccionFormularios" class="seccion-filtrable">
            <div class="section-toolbar">
                <div class="section-heading">
                    <span class="section-icon finished"><i class="fas fa-clipboard-list"></i></span>
                    <div class="section-heading-copy">
                        <div class="section-eyebrow">Administración interna</div>
                        <div class="section-title-row">
                            <h2 class="section-title">Formularios</h2>
                            <span class="section-meta-badge">Repositorio de formularios</span>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-form-ghost" onclick="abrirModalCrearFormulario()">
                    <i class="fas fa-plus me-1"></i> Crear formulario
                </button>
            </div>

            <div class="forms-workspace">
                <div class="forms-intro-card">
                    <h3 class="forms-intro-title">Formularios del módulo de logística</h3>
                    <p class="forms-intro-text">
                        Este apartado queda reservado para cargar y administrar los formularios nuevos que se vayan creando para Transportes,
                        Guías y futuros procesos internos.
                    </p>

                    <div class="forms-grid" id="formulariosGrid">
                        <article class="form-template-card">
                            <span class="form-template-icon"><i class="fas fa-truck"></i></span>
                            <h4 class="form-template-title">Solicitud de Transporte</h4>
                            <p class="form-template-subtitle">Formulario principal para registrar nuevas solicitudes de transporte.</p>
                            <div class="form-template-meta">
                                <span>Transportes</span>
                                <span class="form-status-pill">Activo</span>
                            </div>
                        </article>

                        <article class="form-template-card">
                            <span class="form-template-icon"><i class="fas fa-map-marked-alt"></i></span>
                            <h4 class="form-template-title">Guías de envío</h4>
                            <p class="form-template-subtitle">Acceso al módulo de guías. Después podemos darle el mismo estilo visual.</p>
                            <div class="form-template-meta">
                                <span>Guías</span>
                                <a href="/Logistica/Guias" class="text-decoration-none fw-bold">Abrir</a>
                            </div>
                        </article>

                        <article class="form-template-card add-card">
                            <span class="form-template-icon"><i class="fas fa-plus"></i></span>
                            <h4 class="form-template-title">Nuevo formulario</h4>
                            <p class="form-template-subtitle">Crea la vista base para un nuevo formulario del flujo logístico.</p>
                            <button type="button" class="btn-form-ghost mt-1" onclick="abrirModalCrearFormulario()">Crear formulario</button>
                        </article>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
</div>

<button class="btn-flotante" onclick="abrirModalCrear()"><i class="fas fa-plus me-2"></i> Nueva Solicitud</button>

<div class="modal fade form-builder-modal" id="modalCrearFormulario" tabindex="-1" aria-labelledby="modalCrearFormularioLabel" aria-hidden="true">
