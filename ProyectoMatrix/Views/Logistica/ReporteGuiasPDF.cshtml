@model IEnumerable<ProyectoMatrix.Models.Guia>
@{
    Layout = null;

    var fechaGeneracion = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
    var guias = Model?.OrderByDescending(x => x.FechaSolicitud).ToList() ?? new List<ProyectoMatrix.Models.Guia>();

    decimal totalCosto = guias.Sum(x => x.Costo);
    int totalGuias = guias.Count;
    int totalFrio = guias.Count(x => x.RequiereCadenaFrio == true);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Auditoría de Guías</title>

    <style>
        @@page {
            size: Letter landscape;
            margin: 8mm;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            color: #000;
            background: #fff;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 8px;
            line-height: 1.15;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            border: 1px solid #000;
        }

        th, td {
            border: 1px solid #000;
            padding: 4px 5px;
            vertical-align: middle;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        th {
            background: #e9e9e9;
            font-weight: 900;
            text-align: center;
        }

        .header-table {
            margin-bottom: 6px;
        }

        .logo-cell {
            width: 10%;
            text-align: center;
        }

        .logo-mark {
            display: inline-block;
            width: 42px;
            height: 42px;
            border: 2px solid #000;
            border-radius: 50%;
            line-height: 38px;
            font-weight: 900;
            font-size: 18px;
        }

        .logo-text {
            font-size: 5.8px;
            font-weight: 900;
            margin-top: 2px;
        }

        .title {
            font-size: 14px;
            font-weight: 900;
            text-align: center;
        }

        .subtitle {
            font-size: 8px;
            font-weight: 700;
            text-align: center;
        }

        .label {
            background: #eeeeee;
            font-weight: 900;
        }

        .value {
            text-align: center;
            font-weight: 700;
        }

        .center {
            text-align: center;
        }

        .right {
            text-align: right;
        }

        .kpi-table {
            margin-bottom: 6px;
        }

        .kpi-label {
            background: #f1f1f1;
            font-weight: 900;
            text-align: center;
        }

        .kpi-value {
            font-size: 11px;
            font-weight: 900;
            text-align: center;
        }

        .small {
            font-size: 7px;
        }

        tr {
            page-break-inside: avoid;
        }

        thead {
            display: table-header-group;
        }
    </style>
</head>
<body>
    <table class="header-table">
        <tr>
            <td rowspan="4" class="logo-cell">
                <div class="logo-mark">NS</div>
                <div class="logo-text">GROUP</div>
            </td>
            <td colspan="8" class="label">NS GROUP</td>
            <td colspan="3" class="value">@fechaGeneracion</td>
        </tr>
        <tr>
            <td colspan="11" class="label">PROCESOS Y MEJORA CONTINUA</td>
        </tr>
        <tr>
            <td colspan="11" class="title">Reporte de Auditoría de Guías y Paquetería</td>
        </tr>
        <tr>
            <td colspan="11" class="subtitle">
                Reporte generado desde el módulo de Logística para control de solicitudes, costos, cadena de frío y cancelaciones.
            </td>
        </tr>
    </table>

    <table class="kpi-table">
        <tr>
            <td class="kpi-label">Total de guías</td>
            <td class="kpi-label">Cadena de frío</td>
            <td class="kpi-label">Costo total</td>
            <td class="kpi-label">Fecha de generación</td>
        </tr>
        <tr>
            <td class="kpi-value">@totalGuias</td>
            <td class="kpi-value">@totalFrio</td>
            <td class="kpi-value">@totalCosto.ToString("C")</td>
            <td class="kpi-value">@fechaGeneracion</td>
        </tr>
    </table>

    <table>
        <thead>
            <tr>
                <th style="width: 6%;">Folio</th>
                <th style="width: 9%;">Fecha solicitud</th>
                <th style="width: 10%;">Empresa</th>
                <th style="width: 10%;">Cliente / Proyecto</th>
                <th style="width: 9%;">Gestión</th>
                <th style="width: 9%;">Requerimiento</th>
                <th style="width: 8%;">Entrega</th>
                <th style="width: 12%;">Remitente</th>
                <th style="width: 12%;">Destinatario</th>
                <th style="width: 8%;">Tipo envío</th>
                <th style="width: 7%;">Peso</th>
                <th style="width: 8%;">Frío</th>
                <th style="width: 8%;">Costo</th>
            </tr>
        </thead>
        <tbody>
            @if (guias.Any())
            {
                foreach (var g in guias)
                {
                    <tr>
                        <td class="center">GU-@g.IdGuia</td>
                        <td class="center">@(g.FechaSolicitud.HasValue ? g.FechaSolicitud.Value.ToString("dd/MM/yyyy") : "")</td>
                        <td>@(g.Empresa ?? "")</td>
                        <td>@(g.ClienteProyecto ?? "")</td>
                        <td class="center">@(g.QuienGestiona ?? "")</td>
                        <td class="center">@(g.TipoRequerimiento ?? "")</td>
                        <td class="center">@(g.TipoEntrega ?? "")</td>
                        <td>
                            <strong>@(g.RemitenteNombre ?? "")</strong><br />
                            <span class="small">Tel: @(g.RemitenteTelefono ?? "")</span><br />
                            <span class="small">Origen: @(g.Origen ?? "")</span>
                        </td>
                        <td>
                            <strong>@(g.DestinatarioNombre ?? "")</strong><br />
                            <span class="small">Tel: @(g.DestinatarioTelefono ?? "")</span><br />
                            <span class="small">CP: @(g.CodigoPostalDestino ?? "")</span>
                        </td>
                        <td class="center">@(g.TipoEnvio ?? "")</td>
                        <td class="center">@(g.PesoKg.HasValue ? g.PesoKg.Value.ToString("N2") + " kg" : "")</td>
                        <td class="center">@(g.RequiereCadenaFrio == true ? "Sí" : "No")</td>
                        <td class="right">@g.Costo.ToString("C")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="13" class="center">No hay guías activas para reportar.</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
