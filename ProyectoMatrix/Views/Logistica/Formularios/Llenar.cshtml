@model ProyectoMatrix.ViewModels.Formularios.FormularioLlenadoViewModel

@{
    Layout = null;
    ViewData["Title"] = "Llenar formulario";
    var origenModuloSeguro = (ViewData["OrigenModulo"]?.ToString() ?? Model.OrigenTipo ?? Model.Categoria ?? "Transporte");
    var esModal = string.Equals(ViewData["EsModal"]?.ToString(), "True", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Context.Request.Query["modal"].ToString(), "1", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Context.Request.Query["modal"].ToString(), "true", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Llenar formulario</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            color: #111827;
        }

        .page {
            padding: 28px;
        }

        .panel {
            background: white;
            padding: 22px;
            border-radius: 16px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 8px 18px rgba(0,0,0,.06);
        }

        h1 {
            margin: 0 0 6px 0;
        }

        .subtitle {
            color: #6b7280;
            margin-bottom: 18px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 14px;
        }

        .full {
            grid-column: 1 / -1;
        }

        .group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        label {
            font-size: 13px;
            font-weight: 700;
        }

        input, textarea, select {
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 10px;
            font-size: 14px;
        }

        .btn {
            padding: 10px 14px;
            border-radius: 10px;
            border: none;
            text-decoration: none;
            cursor: pointer;
            font-weight: 700;
        }

        .btn-primary {
            background: #2563eb;
            color: white;
        }

        .btn-secondary {
            background: #e5e7eb;
            color: #111827;
        }

        .btn-danger {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-small {
            padding: 7px 10px;
            font-size: 12px;
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 20px;
        }

        .dynamic-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            overflow: hidden;
            background: #ffffff;
        }

        .dynamic-table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            background: #f9fafb;
            border-bottom: 1px solid #e5e7eb;
        }

        .dynamic-table-title {
            font-weight: 800;
            color: #111827;
        }

        .dynamic-table {
            width: 100%;
            border-collapse: collapse;
        }

        .dynamic-table th {
            text-align: left;
            font-size: 12px;
            color: #6b7280;
            text-transform: uppercase;
            padding: 10px;
            background: #f9fafb;
            border-bottom: 1px solid #e5e7eb;
        }

        .dynamic-table td {
            padding: 8px;
            border-bottom: 1px solid #f3f4f6;
            vertical-align: top;
        }

        .dynamic-table input {
            width: 100%;
            box-sizing: border-box;
        }

        @@media(max-width: 900px) {
            .grid {
                grid-template-columns: 1fr;
            }

            .dynamic-table-wrap {
                overflow-x: auto;
            }

            .dynamic-table {
                min-width: 850px;
            }
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="panel">
            <h1>@Model.NombreFormulario</h1>
            <div class="subtitle">
                @(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Completa los campos del formulario." : Model.Descripcion)
            </div>

            <form action="@Url.Action("GuardarRespuesta", "Formularios", new { origenModulo = origenModuloSeguro, modal = esModal })" method="post" id="formLlenarFormulario">
                @Html.AntiForgeryToken()

                <input type="hidden" name="IdFormulario" value="@Model.IdFormulario" />
                <input type="hidden" name="RespuestaOrigenID" value="@Model.RespuestaOrigenID" />
                <input type="hidden" name="OrigenTipo" value="@origenModuloSeguro" />
                <input type="hidden" name="OrigenID" value="@Model.OrigenID" />
                <input type="hidden" name="Estado" value="Registrado" />

                <div class="grid">
                    @foreach (var campo in Model.Campos)
                    {
                        var valor = Model.Valores.ContainsKey(campo.Clave) ? Model.Valores[campo.Clave] : "";
                        var full = campo.Tipo == "textarea"
                            || campo.Tipo == "tabla_destinos"
                            || campo.Tipo == "tabla_plan_embarque";

                        <div class="group @(full ? "full" : "")">
                            <label>
                                @campo.Etiqueta
                                @if (campo.Obligatorio)
                                {
                                    <span style="color:red;">*</span>
                                }
                            </label>

                            @if (campo.Tipo == "tabla_destinos")
                            {
                                <input type="hidden"
                                       class="json-destinos"
                                       name="Valores[@campo.Clave]"
                                       value="@valor" />

                                <div class="dynamic-table-wrap destinos-wrap">
                                    <div class="dynamic-table-header">
                                        <div class="dynamic-table-title">Destinos</div>
                                        <button type="button" class="btn btn-secondary btn-small" onclick="agregarDestino(this)">
                                            + Agregar destino
                                        </button>
                                    </div>

                                    <table class="dynamic-table">
                                        <thead>
                                            <tr>
                                                <th style="width:60px;">#</th>
                                                <th>Nombre quien recibe</th>
                                                <th>Contacto</th>
                                                <th>Dirección destino</th>
                                                <th style="width:90px;">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody class="destinos-body"></tbody>
                                    </table>
                                </div>
                            }
                            else if (campo.Tipo == "tabla_plan_embarque")
                            {
                                <input type="hidden"
                                       class="json-plan"
                                       name="Valores[@campo.Clave]"
                                       value="@valor" />

                                <div class="dynamic-table-wrap plan-wrap">
                                    <div class="dynamic-table-header">
                                        <div class="dynamic-table-title">Plan de embarque</div>
                                        <button type="button" class="btn btn-secondary btn-small" onclick="agregarPlanItem(this)">
                                            + Agregar producto
                                        </button>
                                    </div>

                                    <table class="dynamic-table">
                                        <thead>
                                            <tr>
                                                <th>Clave SAT</th>
                                                <th>Descripción</th>
                                                <th>Cantidad</th>
                                                <th>UM</th>
                                                <th>Peso</th>
                                                <th>Valor</th>
                                                <th>Vale / Factura</th>
                                                <th style="width:90px;">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody class="plan-body"></tbody>
                                    </table>
                                </div>
                            }
                            else if (campo.Tipo == "textarea")
                            {
                                <textarea name="Valores[@campo.Clave]" rows="4" required="@campo.Obligatorio">@valor</textarea>
                            }
                            else if (campo.Tipo == "numero")
                            {
                                <input type="number" step="any" name="Valores[@campo.Clave]" value="@valor" required="@campo.Obligatorio" />
                            }
                            else if (campo.Tipo == "fecha")
                            {
                                <input type="date" name="Valores[@campo.Clave]" value="@valor" required="@campo.Obligatorio" />
                            }
                            else if (campo.Tipo == "select")
                            {
                                <select name="Valores[@campo.Clave]" required="@campo.Obligatorio">
                                    <option value="">Seleccionar</option>
                                    @foreach (var opcion in campo.Opciones)
                                    {
                                        <option value="@opcion" selected="@(valor == opcion)">@opcion</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" name="Valores[@campo.Clave]" value="@valor" required="@campo.Obligatorio" />
                            }
                        </div>
                    }
                </div>

                <div class="actions">
                    @if (esModal)
                    {
                        <button class="btn btn-secondary" type="button" onclick="cerrarModalFormularioPeticion()">Cancelar</button>
                    }
                    else
                    {
                        <a class="btn btn-secondary" href="@Url.Action("Index", "Formularios", new { origenModulo = origenModuloSeguro })">Cancelar</a>
                    }
                    <button class="btn btn-primary" type="submit" id="btnGuardarPeticion">Guardar petición</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            inicializarTablasDestinos();
            inicializarTablasPlan();
        });

        document.getElementById('formLlenarFormulario').addEventListener('submit', async function (event) {
            event.preventDefault();
            sincronizarTodasLasTablas();

            const form = event.currentTarget;

            if (form.dataset.enviando === 'true') {
                return;
            }

            form.dataset.enviando = 'true';

            const boton = document.getElementById('btnGuardarPeticion');
            const textoOriginal = boton ? boton.textContent : '';

            if (boton) {
                boton.disabled = true;
                boton.textContent = 'Guardando petición...';
            }

            try {
                const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    credentials: 'same-origin',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                        ...(tokenInput ? { 'RequestVerificationToken': tokenInput.value } : {})
                    }
                });

                const contentType = response.headers.get('content-type') || '';
                let data = null;

                if (contentType.toLowerCase().includes('application/json')) {
                    data = await response.json();
                } else {
                    const html = await response.text();
                    console.error('El servidor devolvió HTML en vez de JSON al guardar la petición:', html);
                    throw new Error('El servidor devolvió una página de error en vez de confirmar el guardado. Revisa la consola/Network para ver el error real del servidor.');
                }

                if (!response.ok || !data || !data.success) {
                    throw new Error((data && data.message) || 'No se pudo guardar la petición.');
                }

                if (window.parent && typeof window.parent.formularioPeticionGuardada === 'function') {
                    window.parent.formularioPeticionGuardada(data.message, data.redirectUrl);
                } else if (data.redirectUrl) {
                    window.location.href = data.redirectUrl;
                }
            } catch (error) {
                if (window.parent && typeof window.parent.formularioPeticionError === 'function') {
                    window.parent.formularioPeticionError(error.message);
                } else {
                    alert(error.message || 'No se pudo guardar la petición.');
                }

                form.dataset.enviando = 'false';

                if (boton) {
                    boton.disabled = false;
                    boton.textContent = textoOriginal || 'Guardar petición';
                }
            }
        });

        function cerrarModalFormularioPeticion() {
            if (window.parent && typeof window.parent.cerrarModalUsarFormulario === 'function') {
                window.parent.cerrarModalUsarFormulario(false);
            } else {
                window.history.back();
            }
        }

        function inicializarTablasDestinos() {
            document.querySelectorAll('.destinos-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-destinos');
                let data = parseJsonArray(hidden.value);

                if (data.length === 0) {
                    data = [{ nombre_recibe: '', contacto: '', direccion: '' }];
                }

                const body = wrap.querySelector('.destinos-body');
                body.innerHTML = '';

                data.forEach(item => crearFilaDestino(body, item));
                reindexarDestinos(body);
            });
        }

        function inicializarTablasPlan() {
            document.querySelectorAll('.plan-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-plan');
                let data = parseJsonArray(hidden.value);

                if (data.length === 0) {
                    data = [{
                        clave_sat: '',
                        descripcion: '',
                        cantidad: '',
                        um: '',
                        peso: '',
                        valor: '',
                        vale_salida_factura: ''
                    }];
                }

                const body = wrap.querySelector('.plan-body');
                body.innerHTML = '';

                data.forEach(item => crearFilaPlan(body, item));
            });
        }

        function agregarDestino(button) {
            const wrap = button.closest('.destinos-wrap');
            const body = wrap.querySelector('.destinos-body');

            crearFilaDestino(body, { nombre_recibe: '', contacto: '', direccion: '' });
            reindexarDestinos(body);
        }

        function crearFilaDestino(body, item) {
            const tr = document.createElement('tr');

            tr.innerHTML = `
                <td class="destino-numero"></td>
                <td><input type="text" class="destino-nombre" value="${escapeHtml(item.nombre_recibe || '')}" /></td>
                <td><input type="text" class="destino-contacto" value="${escapeHtml(item.contacto || '')}" /></td>
                <td><input type="text" class="destino-direccion" value="${escapeHtml(item.direccion || '')}" /></td>
                <td><button type="button" class="btn btn-danger btn-small" onclick="quitarDestino(this)">Quitar</button></td>
            `;

            body.appendChild(tr);
        }

        function quitarDestino(button) {
            const body = button.closest('tbody');
            button.closest('tr').remove();

            if (body.querySelectorAll('tr').length === 0) {
                crearFilaDestino(body, { nombre_recibe: '', contacto: '', direccion: '' });
            }

            reindexarDestinos(body);
        }

        function reindexarDestinos(body) {
            body.querySelectorAll('tr').forEach((row, index) => {
                row.querySelector('.destino-numero').textContent = index + 1;
            });
        }

        function agregarPlanItem(button) {
            const wrap = button.closest('.plan-wrap');
            const body = wrap.querySelector('.plan-body');

            crearFilaPlan(body, {
                clave_sat: '',
                descripcion: '',
                cantidad: '',
                um: '',
                peso: '',
                valor: '',
                vale_salida_factura: ''
            });
        }

        function crearFilaPlan(body, item) {
            const tr = document.createElement('tr');

            tr.innerHTML = `
                <td><input type="text" class="plan-clave-sat" value="${escapeHtml(item.clave_sat || '')}" /></td>
                <td><input type="text" class="plan-descripcion" value="${escapeHtml(item.descripcion || '')}" /></td>
                <td><input type="text" class="plan-cantidad" value="${escapeHtml(item.cantidad || '')}" /></td>
                <td><input type="text" class="plan-um" value="${escapeHtml(item.um || '')}" /></td>
                <td><input type="text" class="plan-peso" value="${escapeHtml(item.peso || '')}" /></td>
                <td><input type="text" class="plan-valor" value="${escapeHtml(item.valor || '')}" /></td>
                <td><input type="text" class="plan-vale" value="${escapeHtml(item.vale_salida_factura || '')}" /></td>
                <td><button type="button" class="btn btn-danger btn-small" onclick="quitarPlanItem(this)">Quitar</button></td>
            `;

            body.appendChild(tr);
        }

        function quitarPlanItem(button) {
            const body = button.closest('tbody');
            button.closest('tr').remove();

            if (body.querySelectorAll('tr').length === 0) {
                crearFilaPlan(body, {
                    clave_sat: '',
                    descripcion: '',
                    cantidad: '',
                    um: '',
                    peso: '',
                    valor: '',
                    vale_salida_factura: ''
                });
            }
        }

        function sincronizarTodasLasTablas() {
            document.querySelectorAll('.destinos-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-destinos');
                const body = wrap.querySelector('.destinos-body');

                const destinos = [];

                body.querySelectorAll('tr').forEach(row => {
                    const item = {
                        nombre_recibe: row.querySelector('.destino-nombre')?.value || '',
                        contacto: row.querySelector('.destino-contacto')?.value || '',
                        direccion: row.querySelector('.destino-direccion')?.value || ''
                    };

                    if (item.nombre_recibe || item.contacto || item.direccion) {
                        destinos.push(item);
                    }
                });

                hidden.value = JSON.stringify(destinos);
            });

            document.querySelectorAll('.plan-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-plan');
                const body = wrap.querySelector('.plan-body');

                const plan = [];

                body.querySelectorAll('tr').forEach(row => {
                    const item = {
                        clave_sat: row.querySelector('.plan-clave-sat')?.value || '',
                        descripcion: row.querySelector('.plan-descripcion')?.value || '',
                        cantidad: row.querySelector('.plan-cantidad')?.value || '',
                        um: row.querySelector('.plan-um')?.value || '',
                        peso: row.querySelector('.plan-peso')?.value || '',
                        valor: row.querySelector('.plan-valor')?.value || '',
                        vale_salida_factura: row.querySelector('.plan-vale')?.value || ''
                    };

                    if (
                        item.clave_sat ||
                        item.descripcion ||
                        item.cantidad ||
                        item.um ||
                        item.peso ||
                        item.valor ||
                        item.vale_salida_factura
                    ) {
                        plan.push(item);
                    }
                });

                hidden.value = JSON.stringify(plan);
            });
        }

        function parseJsonArray(value) {
            if (!value) return [];

            try {
                const parsed = JSON.parse(value);
                return Array.isArray(parsed) ? parsed : [];
            } catch {
                return [];
            }
        }

        function escapeHtml(value) {
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }
    </script>
</body>
</html>