@model ProyectoMatrix.ViewModels.Formularios.FormularioLlenadoViewModel

@{
    Layout = null;
    ViewData["Title"] = "Usar formulario";

    var origenModulo = (ViewData["OrigenModulo"]?.ToString() ?? Context.Request.Query["origenModulo"].ToString()).Trim();

    if (string.IsNullOrWhiteSpace(origenModulo))
    {
        origenModulo = Model.Categoria ?? string.Empty;
    }

    var cancelarUrl = string.IsNullOrWhiteSpace(origenModulo)
        ? "/Logistica/Formularios"
        : $"/Logistica/Formularios?origenModulo={Uri.EscapeDataString(origenModulo)}";

    var guardarUrl = string.IsNullOrWhiteSpace(origenModulo)
        ? "/Logistica/Formularios/GuardarRespuesta"
        : $"/Logistica/Formularios/GuardarRespuesta?origenModulo={Uri.EscapeDataString(origenModulo)}";

    var esModal = string.Equals(Context.Request.Query["modal"].ToString(), "1", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Context.Request.Query["modal"].ToString(), "true", StringComparison.OrdinalIgnoreCase);

    if (esModal)
    {
        guardarUrl += guardarUrl.Contains("?") ? "&modal=true" : "?modal=true";
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Usar formulario</title>
    <style>
        :root {
            --navy: #062b57;
            --orange: #e85d04;
            --muted: #64748b;
            --line: #e2e8f0;
            --bg: #f3f6fb;
            --blue: #2563eb;
            --danger: #dc2626;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: var(--bg);
            color: #0f172a;
        }

        .page {
            padding: 28px;
        }

        .hero {
            background: linear-gradient(135deg, #062b57, #073b78);
            color: white;
            border-radius: 18px;
            padding: 30px 32px;
            margin-bottom: 20px;
        }

        .hero h1 {
            margin: 0;
            font-size: 30px;
            font-weight: 900;
            letter-spacing: -.03em;
        }

        .hero p {
            margin: 9px 0 0;
            opacity: .88;
            font-size: 14px;
        }

        .panel {
            background: white;
            border-radius: 18px;
            border: 1px solid var(--line);
            box-shadow: 0 10px 24px rgba(15, 23, 42, .05);
            padding: 22px;
            margin-bottom: 18px;
        }

        .panel h2 {
            margin: 0 0 6px;
            font-size: 20px;
            font-weight: 900;
        }

        .panel-subtitle {
            color: var(--muted);
            font-size: 13px;
            margin-bottom: 18px;
        }

        .official-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 10px;
        }

        .official-item {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 10px;
            background: #f8fafc;
        }

        .official-label {
            color: var(--muted);
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .official-value {
            color: #0f172a;
            font-size: 13px;
            font-weight: 800;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }

        .full {
            grid-column: 1 / -1;
        }

        .group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        label {
            font-size: 12px;
            font-weight: 900;
            color: #1f2937;
        }

        input,
        textarea,
        select {
            width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 11px;
            padding: 11px 12px;
            font-size: 14px;
            background: white;
        }

        textarea {
            min-height: 96px;
            resize: vertical;
        }

        input:focus,
        textarea:focus,
        select:focus {
            outline: none;
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, .14);
        }

        .required {
            color: var(--danger);
        }

        .dynamic-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            overflow: hidden;
            background: #fff;
            margin-top: 4px;
        }

        .dynamic-table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-bottom: 1px solid #e5e7eb;
            background: #f8fafc;
        }

        .dynamic-table-title {
            font-weight: 900;
            color: #111827;
        }

        .dynamic-table {
            width: 100%;
            border-collapse: collapse;
        }

        .dynamic-table th {
            text-align: left;
            font-size: 11px;
            color: #64748b;
            text-transform: uppercase;
            padding: 10px;
            background: #f9fafb;
            border-bottom: 1px solid #e5e7eb;
        }

        .dynamic-table td {
            padding: 8px;
            border-bottom: 1px solid #f3f4f6;
            vertical-align: top;
        }

        .dynamic-table input {
            width: 100%;
            box-sizing: border-box;
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            border-top: 1px solid var(--line);
            padding-top: 18px;
            margin-top: 18px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 10px 14px;
            border-radius: 11px;
            text-decoration: none;
            font-weight: 900;
            font-size: 13px;
            border: 1px solid transparent;
            cursor: pointer;
        }

        .btn-primary {
            background: var(--orange);
            color: white;
            border-color: var(--orange);
        }

        .btn-secondary {
            background: #e5e7eb;
            color: #111827;
        }

        .btn-danger {
            background: #fee2e2;
            color: #991b1b;
            border-color: #fecaca;
        }

        .btn-small {
            padding: 6px 9px;
            font-size: 12px;
            border-radius: 9px;
        }

        @@media(max-width: 900px) {
            .grid,
            .official-grid {
                grid-template-columns: 1fr;
            }

            .dynamic-table-wrap {
                overflow-x: auto;
            }

            .dynamic-table {
                min-width: 850px;
            }
        }


        body.modal-mode .page {
            padding: 18px;
        }

        body.modal-mode .hero {
            display: none;
        }

        body.modal-mode .panel {
            box-shadow: none;
            border-radius: 14px;
        }

    </style>
</head>
<body class="@(esModal ? "modal-mode" : string.Empty)">
    <div class="page">
        <section class="hero">
            <h1>@Model.NombreFormulario</h1>
            <p>@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Completa los campos para crear tu petición." : Model.Descripcion)</p>
        </section>

        @if (Model.DatosOficiales != null && Model.DatosOficiales.TieneDatos())
        {
            <section class="panel">
                <h2>Datos oficiales del formato</h2>
                <div class="panel-subtitle">Información fija de la plantilla seleccionada.</div>

                <div class="official-grid">
                    <div class="official-item">
                        <div class="official-label">Área</div>
                        <div class="official-value">@(string.IsNullOrWhiteSpace(Model.DatosOficiales.Area) ? "N/A" : Model.DatosOficiales.Area)</div>
                    </div>

                    <div class="official-item">
                        <div class="official-label">Elaborado por</div>
                        <div class="official-value">@(string.IsNullOrWhiteSpace(Model.DatosOficiales.ElaboradoPor) ? "N/A" : Model.DatosOficiales.ElaboradoPor)</div>
                    </div>

                    <div class="official-item">
                        <div class="official-label">Liberado por</div>
                        <div class="official-value">@(string.IsNullOrWhiteSpace(Model.DatosOficiales.LiberadoPor) ? "N/A" : Model.DatosOficiales.LiberadoPor)</div>
                    </div>

                    <div class="official-item">
                        <div class="official-label">Versión</div>
                        <div class="official-value">@(string.IsNullOrWhiteSpace(Model.DatosOficiales.Version) ? "N/A" : Model.DatosOficiales.Version)</div>
                    </div>

                    <div class="official-item">
                        <div class="official-label">Fecha de emisión</div>
                        <div class="official-value">@(string.IsNullOrWhiteSpace(Model.DatosOficiales.FechaEmision) ? "N/A" : Model.DatosOficiales.FechaEmision)</div>
                    </div>

                    <div class="official-item">
                        <div class="official-label">Página</div>
                        <div class="official-value">@(string.IsNullOrWhiteSpace(Model.DatosOficiales.Pagina) ? "N/A" : Model.DatosOficiales.Pagina)</div>
                    </div>

                    <div class="official-item">
                        <div class="official-label">Código</div>
                        <div class="official-value">@(string.IsNullOrWhiteSpace(Model.DatosOficiales.Codigo) ? "N/A" : Model.DatosOficiales.Codigo)</div>
                    </div>
                </div>
            </section>
        }

        <section class="panel">
            <h2>Captura de petición</h2>
            <div class="panel-subtitle">Llena la información solicitada y guarda la petición.</div>

            <form action="@guardarUrl" method="post" id="formLlenarFormulario">
                @Html.AntiForgeryToken()

                <input type="hidden" name="ModalFormulario" value="@(esModal ? "1" : "0")" />
                <input type="hidden" name="IdFormulario" value="@Model.IdFormulario" />
                <input type="hidden" name="RespuestaOrigenID" value="@Model.RespuestaOrigenID" />
                <input type="hidden" name="OrigenTipo" value="@Model.OrigenTipo" />
                <input type="hidden" name="OrigenID" value="@Model.OrigenID" />
                <input type="hidden" name="Estado" value="Registrado" />

                <div class="grid">
                    @foreach (var campo in Model.Campos)
                    {
                        var valor = Model.Valores.ContainsKey(campo.Clave) ? Model.Valores[campo.Clave] : "";
                        var full = campo.Tipo == "textarea"
                            || campo.Tipo == "tabla_destinos"
                            || campo.Tipo == "tabla_plan_embarque";

                        var requerido = campo.Obligatorio ? "required" : "";

                        <div class="group @(full ? "full" : "")">
                            <label>
                                @campo.Etiqueta
                                @if (campo.Obligatorio)
                                {
                                    <span class="required">*</span>
                                }
                            </label>

                            @if (campo.Tipo == "tabla_destinos")
                            {
                                <input type="hidden" name="Valores[@campo.Clave]" value="@valor" class="json-destinos" />

                                <div class="dynamic-table-wrap destinos-wrap">
                                    <div class="dynamic-table-header">
                                        <div class="dynamic-table-title">Destinos</div>
                                        <button type="button" class="btn btn-secondary btn-small" onclick="agregarDestino(this)">
                                            + Agregar destino
                                        </button>
                                    </div>

                                    <table class="dynamic-table">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>Nombre de quien recibe</th>
                                                <th>Contacto</th>
                                                <th>Dirección destino</th>
                                                <th style="width:90px;">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody class="destinos-body"></tbody>
                                    </table>
                                </div>
                            }
                            else if (campo.Tipo == "tabla_plan_embarque")
                            {
                                <input type="hidden" name="Valores[@campo.Clave]" value="@valor" class="json-plan" />

                                <div class="dynamic-table-wrap plan-wrap">
                                    <div class="dynamic-table-header">
                                        <div class="dynamic-table-title">Plan de embarque</div>
                                        <button type="button" class="btn btn-secondary btn-small" onclick="agregarPlanItem(this)">
                                            + Agregar producto
                                        </button>
                                    </div>

                                    <table class="dynamic-table">
                                        <thead>
                                            <tr>
                                                <th>Clave SAT</th>
                                                <th>Descripción</th>
                                                <th>Cantidad</th>
                                                <th>UM</th>
                                                <th>Peso</th>
                                                <th>Valor</th>
                                                <th>Vale / Factura</th>
                                                <th style="width:90px;">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody class="plan-body"></tbody>
                                    </table>
                                </div>
                            }
                            else if (campo.Tipo == "textarea")
                            {
                                <textarea name="Valores[@campo.Clave]" rows="4" placeholder="@campo.Placeholder" @requerido>@valor</textarea>
                            }
                            else if (campo.Tipo == "numero")
                            {
                                <input type="number" step="any" name="Valores[@campo.Clave]" value="@valor" placeholder="@campo.Placeholder" @requerido />
                            }
                            else if (campo.Tipo == "fecha")
                            {
                                <input type="date" name="Valores[@campo.Clave]" value="@valor" @requerido />
                            }
                            else if (campo.Tipo == "select")
                            {
                                <select name="Valores[@campo.Clave]" @requerido>
                                    <option value="">Seleccionar</option>
                                    @foreach (var opcion in campo.Opciones)
                                    {
                                        <option value="@opcion" selected="@(valor == opcion)">@opcion</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" name="Valores[@campo.Clave]" value="@valor" placeholder="@campo.Placeholder" @requerido />
                            }
                        </div>
                    }
                </div>

                <div class="actions">
                    @if (esModal)
                    {
                        <button class="btn btn-secondary" type="button" onclick="window.parent && window.parent.cerrarModalUsarFormulario ? window.parent.cerrarModalUsarFormulario(false) : window.location.href='@cancelarUrl'">Cancelar</button>
                    }
                    else
                    {
                        <a class="btn btn-secondary" href="@cancelarUrl">Cancelar</a>
                    }
                    <button class="btn btn-primary" type="submit">Guardar petición</button>
                </div>
            </form>
        </section>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            inicializarTablasDestinos();
            inicializarTablasPlan();
        });

        document.getElementById('formLlenarFormulario').addEventListener('submit', function () {
            sincronizarTodasLasTablas();
        });

        function inicializarTablasDestinos() {
            document.querySelectorAll('.destinos-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-destinos');
                let data = parseJsonArray(hidden.value);

                if (data.length === 0) {
                    data = [{ nombre_recibe: '', contacto: '', direccion: '' }];
                }

                const body = wrap.querySelector('.destinos-body');
                body.innerHTML = '';

                data.forEach(item => crearFilaDestino(body, item));
                reindexarDestinos(body);
            });
        }

        function agregarDestino(button) {
            const wrap = button.closest('.destinos-wrap');
            const body = wrap.querySelector('.destinos-body');

            crearFilaDestino(body, { nombre_recibe: '', contacto: '', direccion: '' });
            reindexarDestinos(body);
        }

        function crearFilaDestino(body, item) {
            const tr = document.createElement('tr');

            tr.innerHTML = `
                <td class="destino-numero"></td>
                <td><input type="text" class="destino-nombre" value="${escapeHtml(item.nombre_recibe || '')}" /></td>
                <td><input type="text" class="destino-contacto" value="${escapeHtml(item.contacto || '')}" /></td>
                <td><input type="text" class="destino-direccion" value="${escapeHtml(item.direccion || '')}" /></td>
                <td><button type="button" class="btn btn-danger btn-small" onclick="quitarDestino(this)">Quitar</button></td>
            `;

            body.appendChild(tr);
        }

        function quitarDestino(button) {
            const body = button.closest('tbody');
            button.closest('tr').remove();

            if (body.querySelectorAll('tr').length === 0) {
                crearFilaDestino(body, { nombre_recibe: '', contacto: '', direccion: '' });
            }

            reindexarDestinos(body);
        }

        function reindexarDestinos(body) {
            body.querySelectorAll('tr').forEach((row, index) => {
                row.querySelector('.destino-numero').textContent = index + 1;
            });
        }

        function agregarPlanItem(button) {
            const wrap = button.closest('.plan-wrap');
            const body = wrap.querySelector('.plan-body');

            crearFilaPlan(body, {
                clave_sat: '',
                descripcion: '',
                cantidad: '',
                um: '',
                peso: '',
                valor: '',
                vale_salida_factura: ''
            });
        }

        function crearFilaPlan(body, item) {
            const tr = document.createElement('tr');

            tr.innerHTML = `
                <td><input type="text" class="plan-clave-sat" value="${escapeHtml(item.clave_sat || '')}" /></td>
                <td><input type="text" class="plan-descripcion" value="${escapeHtml(item.descripcion || '')}" /></td>
                <td><input type="text" class="plan-cantidad" value="${escapeHtml(item.cantidad || '')}" /></td>
                <td><input type="text" class="plan-um" value="${escapeHtml(item.um || '')}" /></td>
                <td><input type="text" class="plan-peso" value="${escapeHtml(item.peso || '')}" /></td>
                <td><input type="text" class="plan-valor" value="${escapeHtml(item.valor || '')}" /></td>
                <td><input type="text" class="plan-vale" value="${escapeHtml(item.vale_salida_factura || '')}" /></td>
                <td><button type="button" class="btn btn-danger btn-small" onclick="quitarPlanItem(this)">Quitar</button></td>
            `;

            body.appendChild(tr);
        }

        function quitarPlanItem(button) {
            const body = button.closest('tbody');
            button.closest('tr').remove();

            if (body.querySelectorAll('tr').length === 0) {
                crearFilaPlan(body, {
                    clave_sat: '',
                    descripcion: '',
                    cantidad: '',
                    um: '',
                    peso: '',
                    valor: '',
                    vale_salida_factura: ''
                });
            }
        }

        function sincronizarTodasLasTablas() {
            document.querySelectorAll('.destinos-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-destinos');
                const data = [];

                wrap.querySelectorAll('tbody tr').forEach(row => {
                    data.push({
                        nombre_recibe: row.querySelector('.destino-nombre')?.value || '',
                        contacto: row.querySelector('.destino-contacto')?.value || '',
                        direccion: row.querySelector('.destino-direccion')?.value || ''
                    });
                });

                hidden.value = JSON.stringify(data);
            });

            document.querySelectorAll('.plan-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-plan');
                const data = [];

                wrap.querySelectorAll('tbody tr').forEach(row => {
                    data.push({
                        clave_sat: row.querySelector('.plan-clave-sat')?.value || '',
                        descripcion: row.querySelector('.plan-descripcion')?.value || '',
                        cantidad: row.querySelector('.plan-cantidad')?.value || '',
                        um: row.querySelector('.plan-um')?.value || '',
                        peso: row.querySelector('.plan-peso')?.value || '',
                        valor: row.querySelector('.plan-valor')?.value || '',
                        vale_salida_factura: row.querySelector('.plan-vale')?.value || ''
                    });
                });

                hidden.value = JSON.stringify(data);
            });
        }

        function inicializarTablasPlan() {
            document.querySelectorAll('.plan-wrap').forEach(wrap => {
                const hidden = wrap.parentElement.querySelector('.json-plan');
                let data = parseJsonArray(hidden.value);

                if (data.length === 0) {
                    data = [{
                        clave_sat: '',
                        descripcion: '',
                        cantidad: '',
                        um: '',
                        peso: '',
                        valor: '',
                        vale_salida_factura: ''
                    }];
                }

                const body = wrap.querySelector('.plan-body');
                body.innerHTML = '';

                data.forEach(item => crearFilaPlan(body, item));
            });
        }

        function parseJsonArray(value) {
            if (!value) return [];

            try {
                const parsed = JSON.parse(value);
                return Array.isArray(parsed) ? parsed : [];
            } catch {
                return [];
            }
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }
    </script>
</body>
</html>
