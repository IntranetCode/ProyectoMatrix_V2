@using Microsoft.AspNetCore.Http
@model List<ProyectoMatrix.ViewModels.Formularios.FormularioPlantillaViewModel>

@{
    Layout = "_LayoutComunicados";
    ViewData["Title"] = "Formularios Logística";

    var origenModulo = (ViewData["OrigenModulo"]?.ToString() ?? Context.Request.Query["origenModulo"].ToString()).Trim();
    var origenModuloSeguro = string.IsNullOrWhiteSpace(origenModulo) ? "Transporte" : origenModulo;

    var esLogistica = ViewData["EsLogistica"] as bool? ?? false;
    var estadoPlantillas = (ViewData["EstadoPlantillas"]?.ToString() ?? Context.Request.Query["estado"].ToString()).Trim();
    var viendoDesactivadas = esLogistica && string.Equals(estadoPlantillas, "desactivadas", StringComparison.OrdinalIgnoreCase);

    var esGuias = string.Equals(origenModuloSeguro, "Guias", StringComparison.OrdinalIgnoreCase)
        || string.Equals(origenModuloSeguro, "Guías", StringComparison.OrdinalIgnoreCase);

    var volverUrl = $"/Logistica/Formularios/CentroFormularios?origenModulo={Uri.EscapeDataString(origenModuloSeguro)}";
    var urlActivas = $"/Logistica/Formularios?origenModulo={Uri.EscapeDataString(origenModuloSeguro)}";
    var urlDesactivadas = $"/Logistica/Formularios?origenModulo={Uri.EscapeDataString(origenModuloSeguro)}&estado=desactivadas";

    var claseTabActivas = viendoDesactivadas ? "plantilla-tab" : "plantilla-tab active";
    var claseTabDesactivadas = viendoDesactivadas ? "plantilla-tab warning active" : "plantilla-tab warning";

    var titulo = esLogistica
        ? (viendoDesactivadas ? "Plantillas desactivadas" : "Plantillas de formularios")
        : "Peticiones disponibles";

    var subtitulo = esLogistica
        ? (viendoDesactivadas
            ? "Consulta plantillas fuera de uso y reactívalas cuando vuelvan a estar disponibles."
            : "Administra plantillas activas, crea peticiones y controla los formularios disponibles.")
        : "Selecciona una plantilla y presiona Usar para crear tu petición.";
}

@section Estilos {
    <style>
        :root {
            --logistica-navy: #062b57;
            --logistica-navy-2: #073b78;
            --logistica-orange: #e85d04;
            --logistica-blue: #2563eb;
            --logistica-danger: #dc2626;
            --logistica-success: #16a34a;
            --logistica-muted: #64748b;
            --logistica-line: #e2e8f0;
            --logistica-bg: #f3f6fb;
            --logistica-card: #ffffff;
        }

        body {
            background:
                radial-gradient(circle at top left, rgba(37, 99, 235, .08), transparent 25rem),
                radial-gradient(circle at bottom right, rgba(249, 115, 22, .10), transparent 28rem),
                linear-gradient(180deg, #f8fafc 0%, #f3f6fb 100%);
        }

        .formularios-page {
            width: 100%;
            padding: 10px 0 34px;
            color: #0f172a;
        }

        .formularios-hero {
            position: relative;
            background: linear-gradient(135deg, var(--logistica-navy), var(--logistica-navy-2));
            color: #ffffff;
            border-radius: 18px;
            padding: 34px 32px;
            margin-bottom: 24px;
            overflow: hidden;
            box-shadow: 0 18px 44px rgba(15, 23, 42, .10);
        }

        .formularios-hero h1 {
            margin: 0;
            font-size: clamp(1.7rem, 2.7vw, 2.2rem);
            font-weight: 900;
            letter-spacing: -.035em;
        }

        .formularios-hero p {
            margin: 10px 0 0;
            color: rgba(255, 255, 255, .88);
            font-size: .95rem;
        }

        .formularios-page-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 16px;
        }

        .formularios-page-head h2 {
            margin: 0;
            font-size: 1.55rem;
            font-weight: 900;
            letter-spacing: -.03em;
            color: #0f172a;
        }

        .formularios-page-head p {
            margin: 6px 0 0;
            color: var(--logistica-muted);
            font-size: .90rem;
        }

        .head-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-formulario {
            border: 0;
            border-radius: 12px;
            padding: 10px 14px;
            min-height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: .86rem;
            font-weight: 900;
            text-decoration: none !important;
            cursor: pointer;
            transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
            line-height: 1;
        }

        .btn-formulario:hover {
            transform: translateY(-1px);
        }

        .btn-secondary-soft {
            background: #e5e7eb;
            color: #0f172a !important;
        }

        .btn-primary-soft {
            background: #2563eb;
            color: #ffffff !important;
            box-shadow: 0 12px 22px rgba(37, 99, 235, .20);
        }

        .btn-use {
            background: var(--logistica-orange);
            color: #ffffff !important;
            box-shadow: 0 12px 22px rgba(232, 93, 4, .22);
        }

        .btn-outline-soft {
            background: #ffffff;
            color: #2563eb !important;
            border: 1px solid rgba(37, 99, 235, .28);
        }

        .btn-danger-soft {
            background: #fee2e2;
            color: #991b1b !important;
        }

        .btn-success-soft {
            background: #dcfce7;
            color: #166534 !important;
        }

        .notice {
            border: 1px solid rgba(37, 99, 235, .20);
            border-left: 4px solid #2563eb;
            background: rgba(255, 255, 255, .92);
            color: #0f3b83;
            border-radius: 12px;
            padding: 13px 16px;
            font-size: .86rem;
            font-weight: 800;
            margin-bottom: 16px;
        }

        .plantilla-tabs {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }

        .plantilla-tab {
            border-radius: 999px;
            padding: 10px 16px;
            border: 1px solid rgba(37, 99, 235, .25);
            color: #0f3b83 !important;
            background: #ffffff;
            text-decoration: none !important;
            font-weight: 900;
            font-size: .84rem;
        }

        .plantilla-tab.active {
            color: #ffffff !important;
            background: #062b57;
            border-color: #062b57;
        }

        .plantilla-tab.warning {
            color: #9a3412 !important;
            border-color: rgba(249, 115, 22, .40);
        }

        .plantilla-tab.warning.active {
            color: #ffffff !important;
            background: #c2410c;
            border-color: #c2410c;
        }

        .alert-form-success,
        .alert-form-error {
            border-radius: 14px;
            padding: 13px 16px;
            margin: 0 0 16px;
            font-weight: 800;
            font-size: .88rem;
        }

        .alert-form-success {
            background: #dcfce7;
            color: #166534;
        }

        .alert-form-error {
            background: #fee2e2;
            color: #991b1b;
        }

        .formularios-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(255px, 1fr));
            gap: 18px;
        }

        .form-card {
            background: var(--logistica-card);
            border: 1px solid rgba(148, 163, 184, .22);
            border-radius: 17px;
            padding: 20px;
            min-height: 222px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            box-shadow: 0 14px 34px rgba(15, 23, 42, .07);
        }

        .form-card h3 {
            margin: 0 0 8px;
            font-size: 1.05rem;
            font-weight: 900;
            color: #0f172a;
            line-height: 1.16;
        }

        .form-card p {
            color: var(--logistica-muted);
            font-size: .86rem;
            line-height: 1.35;
            margin: 0 0 14px;
            min-height: 38px;
        }

        .badge-form {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            padding: 5px 9px;
            margin: 0 5px 8px 0;
            background: #eef2ff;
            color: #3730a3;
            font-size: .75rem;
            font-weight: 900;
        }

        .badge-base {
            background: #fff7ed;
            color: #9a3412;
        }

        .badge-inactive {
            background: #f1f5f9;
            color: #475569;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 16px;
        }

        .empty-state {
            background: #ffffff;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
            padding: 48px 24px;
            text-align: center;
            color: var(--logistica-muted);
        }

        .empty-state h3 {
            color: #0f172a;
            font-weight: 900;
            margin-bottom: 6px;
        }

        .modal-backdrop-custom,
        .confirm-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, .62);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            padding: 22px;
            backdrop-filter: blur(3px);
        }

        .modal-backdrop-custom.show,
        .confirm-modal-backdrop.show {
            display: flex;
        }

        .save-success-card {
            width: min(420px, 92vw);
            background: #ffffff;
            border-radius: 22px;
            padding: 34px 28px;
            text-align: center;
            box-shadow: 0 26px 70px rgba(15, 23, 42, .34);
            transform: translateY(8px) scale(.96);
            opacity: 0;
            animation: saveSuccessEnter .28s ease forwards;
        }

        .save-success-icon {
            width: 74px;
            height: 74px;
            margin: 0 auto 18px;
            border-radius: 999px;
            background: #dcfce7;
            color: #16a34a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 900;
            box-shadow: 0 12px 28px rgba(22, 163, 74, .18);
            animation: saveCheckPop .42s ease .12s both;
        }

        .save-success-card h3 {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 900;
            color: #0f172a;
            letter-spacing: -.025em;
        }

        .save-success-card p {
            margin: 8px 0 0;
            color: #64748b;
            font-size: .92rem;
            line-height: 1.45;
        }

        @@keyframes saveSuccessEnter {
            to {
                transform: translateY(0) scale(1);
                opacity: 1;
            }
        }

        @@keyframes saveCheckPop {
            0% { transform: scale(.55); opacity: 0; }
            70% { transform: scale(1.08); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }

        .modal-card {
            width: min(1120px, 96vw);
            max-height: 90vh;
            background: #ffffff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 26px 70px rgba(15, 23, 42, .34);
        }

        .use-modal-card {
            width: min(1180px, 96vw);
        }

        .modal-head {
            background: linear-gradient(135deg, #062b57, #073b78);
            color: #ffffff;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .modal-head h3 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 900;
        }

        .modal-close {
            border: 0;
            background: transparent;
            color: #ffffff;
            font-size: 1.8rem;
            line-height: 1;
            cursor: pointer;
        }

        .modal-body {
            padding: 20px;
            max-height: calc(90vh - 64px);
            overflow: auto;
        }

        .use-modal-body {
            height: calc(90vh - 64px);
            padding: 0;
            position: relative;
        }

        .use-modal-frame {
            width: 100%;
            height: 100%;
            border: 0;
            background: #f8fafc;
        }

        .use-modal-loading {
            padding: 40px;
            color: var(--logistica-muted);
            font-weight: 900;
            text-align: center;
        }

        .detail-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
            font-size: .86rem;
        }

        .detail-table th,
        .detail-table td {
            border: 1px solid #e2e8f0;
            padding: 9px 10px;
            text-align: left;
        }

        .detail-table th {
            background: #f8fafc;
            color: #334155;
        }

        .confirm-modal-card {
            width: min(440px, 94vw);
            background: #ffffff;
            border-radius: 22px;
            padding: 28px;
            text-align: center;
            box-shadow: 0 26px 70px rgba(15, 23, 42, .30);
        }

        .confirm-modal-icon {
            width: 58px;
            height: 58px;
            border-radius: 18px;
            background: #fff7ed;
            color: #ea580c;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 1.4rem;
            margin-bottom: 14px;
        }

        .confirm-modal-icon.success {
            background: #dcfce7;
            color: #16a34a;
        }

        .confirm-modal-card h3 {
            font-weight: 900;
            margin-bottom: 8px;
        }

        .confirm-modal-card p {
            color: var(--logistica-muted);
            font-size: .88rem;
            margin: 0;
        }

        .confirm-modal-name {
            margin: 14px 0;
            padding: 12px;
            border-radius: 14px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            font-weight: 900;
        }

        .confirm-modal-actions {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 22px;
        }

        .confirm-cancel,
        .confirm-danger,
        .confirm-success {
            border: 0;
            border-radius: 12px;
            padding: 11px 16px;
            font-weight: 900;
            cursor: pointer;
        }

        .confirm-cancel {
            background: #e5e7eb;
            color: #334155;
        }

        .confirm-danger {
            background: #dc2626;
            color: #ffffff;
        }

        .confirm-success {
            background: #16a34a;
            color: #ffffff;
        }

        @@media (max-width: 768px) {
            .formularios-page-head {
                flex-direction: column;
            }

            .head-actions {
                width: 100%;
            }

            .head-actions .btn-formulario {
                flex: 1;
            }
        }
    </style>
}

<div class="formularios-page" id="inicioPagina">
    <section class="formularios-hero">
        <h1>Formularios de logística</h1>
        <p>Administra cuestionarios adicionales para Guías y Transporte.</p>
    </section>

    <div class="formularios-page-head">
        <div>
            <h2>@titulo</h2>
            <p>@subtitulo</p>
        </div>

        <div class="head-actions">
            <a class="btn-formulario btn-secondary-soft" href="@volverUrl">
                Volver
            </a>

            @if (esLogistica)
            {
                <a class="btn-formulario btn-primary-soft" href="/Logistica/Formularios/Crear?origenModulo=@Uri.EscapeDataString(origenModuloSeguro)">
                    Crear plantilla
                </a>
            }
        </div>
    </div>

    @if (esLogistica)
    {
        <div class="notice">
            @(viendoDesactivadas
                ? "Modo logística: estás consultando plantillas desactivadas. Desde aquí puedes reactivarlas cuando vuelvan a estar disponibles."
                : "Modo logística: puedes crear, editar, visualizar, usar o desactivar plantillas activas.")
        </div>

        <div class="plantilla-tabs">
            <a class="@claseTabActivas" href="@urlActivas">Plantillas activas</a>
            <a class="@claseTabDesactivadas" href="@urlDesactivadas">Plantillas desactivadas</a>
        </div>
    }
    else
    {
        <div class="notice">
            Selecciona una opción y presiona <strong>Usar</strong> para crear tu petición.
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert-form-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert-form-error">@TempData["Error"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>@(viendoDesactivadas ? "No hay plantillas desactivadas" : "No hay formularios disponibles")</h3>
            <p>@(viendoDesactivadas ? "Cuando desactives una plantilla, aparecerá aquí para poder reactivarla." : "Cuando logística cree plantillas activas, aparecerán aquí.")</p>
        </div>
    }
    else
    {
        <div class="formularios-grid">
            @foreach (var formulario in Model)
            {
                <div class="form-card">
                    <div>
                        <h3>@formulario.Nombre</h3>
                        <p>@(string.IsNullOrWhiteSpace(formulario.Descripcion) ? "Sin descripción." : formulario.Descripcion)</p>

                        <div>
                            <span class="badge-form">@(string.IsNullOrWhiteSpace(formulario.Categoria) ? "Sin categoría" : formulario.Categoria)</span>
                            <span class="badge-form">@formulario.Campos.Count campos</span>

                            @if (formulario.EsPlantillaBase)
                            {
                                <span class="badge-form badge-base">Plantilla base</span>
                            }

                            @if (!formulario.Activo)
                            {
                                <span class="badge-form badge-inactive">Inactiva</span>
                            }
                        </div>
                    </div>

                    <div class="actions">
                        @if (!viendoDesactivadas)
                        {
                            var usarUrl = $"/Logistica/Formularios/Usar/{formulario.IdFormulario}?origenModulo={Uri.EscapeDataString(origenModuloSeguro)}&modal=1";

                            <button type="button"
                                    class="btn-formulario btn-use"
                                    data-use-url="@usarUrl"
                                    data-use-title="@formulario.Nombre"
                                    onclick="abrirModalUsarFormularioDesdeBoton(this)">
                                Usar
                            </button>
                        }

                        @if (esLogistica)
                        {
                            <button type="button"
                                    class="btn-formulario btn-outline-soft"
                                    onclick="abrirContenido(@formulario.IdFormulario)">
                                Ver contenido
                            </button>

                            <a class="btn-formulario btn-primary-soft"
                               href="/Logistica/Formularios/Editar/@formulario.IdFormulario?origenModulo=@Uri.EscapeDataString(origenModuloSeguro)">
                                Editar
                            </a>

                            @if (viendoDesactivadas)
                            {
                                <form id="formReactivar-@formulario.IdFormulario"
                                      method="post"
                                      action="/Logistica/Formularios/Reactivar/@formulario.IdFormulario?origenModulo=@Uri.EscapeDataString(origenModuloSeguro)"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="button"
                                            class="btn-formulario btn-success-soft"
                                            data-formulario-id="@formulario.IdFormulario"
                                            data-formulario-nombre="@formulario.Nombre"
                                            onclick="abrirModalReactivarDesdeBoton(this)">
                                        Reactivar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form id="formDesactivar-@formulario.IdFormulario"
                                      method="post"
                                      action="/Logistica/Formularios/Eliminar/@formulario.IdFormulario?origenModulo=@Uri.EscapeDataString(origenModuloSeguro)"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="button"
                                            class="btn-formulario btn-danger-soft"
                                            data-formulario-id="@formulario.IdFormulario"
                                            data-formulario-nombre="@formulario.Nombre"
                                            onclick="abrirModalDesactivarDesdeBoton(this)">
                                        Desactivar
                                    </button>
                                </form>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<div id="modalUsarFormulario" class="modal-backdrop-custom" role="dialog" aria-modal="true" aria-labelledby="modalUsarTitulo">
    <div class="modal-card use-modal-card">
        <div class="modal-head">
            <h3 id="modalUsarTitulo">Usar plantilla</h3>
            <button type="button" class="modal-close" onclick="cerrarModalUsarFormulario(false)">×</button>
        </div>
        <div class="modal-body use-modal-body">
            <div id="modalUsarLoading" class="use-modal-loading">Cargando formulario...</div>
            <iframe id="modalUsarFrame" class="use-modal-frame" title="Llenar formulario" src="about:blank" style="display:none;"></iframe>
        </div>
    </div>
</div>

<div id="modalGuardadoExitoso" class="confirm-modal-backdrop" role="dialog" aria-modal="true">
    <div class="save-success-card">
        <div class="save-success-icon">✓</div>
        <h3>Petición enviada</h3>
        <p id="mensajeGuardadoExitoso">La solicitud se guardó correctamente y fue enviada a Logística.</p>
    </div>
</div>

@if (esLogistica)
{
    <div id="modalContenido" class="modal-backdrop-custom" role="dialog" aria-modal="true">
        <div class="modal-card">
            <div class="modal-head">
                <h3 id="modalTitulo">Contenido de la plantilla</h3>
                <button type="button" class="modal-close" onclick="cerrarContenido()">×</button>
            </div>
            <div class="modal-body">
                <div id="modalDescripcion"></div>

                <h4>Datos oficiales del formato</h4>
                <table class="detail-table">
                    <tbody id="tablaDatosOficiales"></tbody>
                </table>

                <h4 style="margin-top:20px;">Campos de captura</h4>
                <table class="detail-table">
                    <thead>
                        <tr>
                            <th>Campo</th>
                            <th>Clave</th>
                            <th>Tipo</th>
                            <th>Obligatorio</th>
                        </tr>
                    </thead>
                    <tbody id="tablaCampos"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="modalDesactivarPlantilla" class="confirm-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="tituloDesactivarPlantilla">
        <div class="confirm-modal-card">
            <div class="confirm-modal-icon">!</div>
            <h3 id="tituloDesactivarPlantilla">Desactivar plantilla</h3>
            <p>Estás por desactivar la plantilla:</p>
            <div class="confirm-modal-name" id="nombrePlantillaDesactivar">Plantilla seleccionada</div>
            <p>La plantilla ya no aparecerá para nuevas peticiones, pero no se eliminará el historial.</p>
            <div class="confirm-modal-actions">
                <button type="button" class="confirm-cancel" onclick="cerrarModalDesactivar()">Cancelar</button>
                <button type="button" class="confirm-danger" onclick="confirmarDesactivarPlantilla()">Sí, desactivar</button>
            </div>
        </div>
    </div>

    <div id="modalReactivarPlantilla" class="confirm-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="tituloReactivarPlantilla">
        <div class="confirm-modal-card">
            <div class="confirm-modal-icon success">✓</div>
            <h3 id="tituloReactivarPlantilla">Reactivar plantilla</h3>
            <p>Estás por volver a activar la plantilla:</p>
            <div class="confirm-modal-name" id="nombrePlantillaReactivar">Plantilla seleccionada</div>
            <p>La plantilla volverá a aparecer para nuevas peticiones.</p>
            <div class="confirm-modal-actions">
                <button type="button" class="confirm-cancel" onclick="cerrarModalReactivar()">Cancelar</button>
                <button type="button" class="confirm-success" onclick="confirmarReactivarPlantilla()">Sí, reactivar</button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function abrirModalUsarFormularioDesdeBoton(boton) {
            if (!boton) return;

            const url = boton.getAttribute('data-use-url');
            const titulo = boton.getAttribute('data-use-title') || 'Usar plantilla';

            if (!url) return;

            const modal = document.getElementById('modalUsarFormulario');
            const frame = document.getElementById('modalUsarFrame');
            const loading = document.getElementById('modalUsarLoading');
            const tituloModal = document.getElementById('modalUsarTitulo');

            if (tituloModal) tituloModal.textContent = `Usar: ${titulo}`;
            if (loading) loading.style.display = 'block';
            if (frame) {
                frame.style.display = 'none';
                frame.src = url;
                frame.onload = function () {
                    if (loading) loading.style.display = 'none';
                    frame.style.display = 'block';
                };
            }
            if (modal) modal.classList.add('show');
        }

        function cerrarModalUsarFormulario(recargar) {
            const modal = document.getElementById('modalUsarFormulario');
            const frame = document.getElementById('modalUsarFrame');
            const loading = document.getElementById('modalUsarLoading');

            if (modal) modal.classList.remove('show');
            if (frame) {
                frame.onload = null;
                frame.src = 'about:blank';
                frame.style.display = 'none';
            }
            if (loading) loading.style.display = 'block';

            if (recargar) {
                window.location.reload();
            }
        }

        function formularioPeticionGuardada(mensaje, redirectUrl) {
            const frame = document.getElementById('modalUsarFrame');
            const loading = document.getElementById('modalUsarLoading');
            const modalExito = document.getElementById('modalGuardadoExitoso');
            const mensajeExito = document.getElementById('mensajeGuardadoExitoso');

            if (frame) {
                frame.onload = null;
                frame.style.display = 'none';
                frame.src = 'about:blank';
            }

            if (loading) loading.style.display = 'none';
            if (mensajeExito) mensajeExito.textContent = mensaje || 'La solicitud se guardó correctamente y fue enviada a Logística.';
            if (modalExito) modalExito.classList.add('show');

            setTimeout(function () {
                const destino = redirectUrl || '@(esGuias ? "/Logistica/Guias" : "/Logistica/Transporte")';
                window.location.href = destino;
            }, 1150);
        }

        function formularioPeticionError(mensaje) {
            alert(mensaje || 'No se pudo guardar la petición.');
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                cerrarModalUsarFormulario(false);
                cerrarModalDesactivar();
                cerrarModalReactivar();
                cerrarContenido();
            }
        });

        document.addEventListener('click', function (event) {
            const modalUsar = document.getElementById('modalUsarFormulario');
            const modalDesactivar = document.getElementById('modalDesactivarPlantilla');
            const modalReactivar = document.getElementById('modalReactivarPlantilla');
            const modalContenido = document.getElementById('modalContenido');

            if (modalUsar && event.target === modalUsar) cerrarModalUsarFormulario(false);
            if (modalDesactivar && event.target === modalDesactivar) cerrarModalDesactivar();
            if (modalReactivar && event.target === modalReactivar) cerrarModalReactivar();
            if (modalContenido && event.target === modalContenido) cerrarContenido();
        });

        function abrirModalDesactivarDesdeBoton(boton) {
            if (!boton) return;

            window.formularioDesactivarId = boton.getAttribute('data-formulario-id');
            const nombreFormulario = boton.getAttribute('data-formulario-nombre') || 'Plantilla seleccionada';
            const modal = document.getElementById('modalDesactivarPlantilla');
            const nombre = document.getElementById('nombrePlantillaDesactivar');

            if (nombre) nombre.textContent = nombreFormulario;
            if (modal) modal.classList.add('show');
        }

        function cerrarModalDesactivar() {
            window.formularioDesactivarId = null;
            const modal = document.getElementById('modalDesactivarPlantilla');
            if (modal) modal.classList.remove('show');
        }

        function confirmarDesactivarPlantilla() {
            if (!window.formularioDesactivarId) return;
            const form = document.getElementById(`formDesactivar-${window.formularioDesactivarId}`);
            if (form) form.submit();
        }

        function abrirModalReactivarDesdeBoton(boton) {
            if (!boton) return;

            window.formularioReactivarId = boton.getAttribute('data-formulario-id');
            const nombreFormulario = boton.getAttribute('data-formulario-nombre') || 'Plantilla seleccionada';
            const modal = document.getElementById('modalReactivarPlantilla');
            const nombre = document.getElementById('nombrePlantillaReactivar');

            if (nombre) nombre.textContent = nombreFormulario;
            if (modal) modal.classList.add('show');
        }

        function cerrarModalReactivar() {
            window.formularioReactivarId = null;
            const modal = document.getElementById('modalReactivarPlantilla');
            if (modal) modal.classList.remove('show');
        }

        function confirmarReactivarPlantilla() {
            if (!window.formularioReactivarId) return;
            const form = document.getElementById(`formReactivar-${window.formularioReactivarId}`);
            if (form) form.submit();
        }

        async function abrirContenido(idFormulario) {
            try {
                const response = await fetch(`/Logistica/Formularios/ContenidoJson/${idFormulario}`);

                if (!response.ok) {
                    alert('No se pudo cargar el contenido.');
                    return;
                }

                const data = await response.json();

                document.getElementById('modalTitulo').textContent = data.nombre || 'Contenido de la plantilla';
                document.getElementById('modalDescripcion').textContent = data.descripcion || 'Sin descripción.';

                const datos = data.datosOficiales || {};
                const filasOficiales = [
                    ['Área', datos.area],
                    ['Elaborado por', datos.elaboradoPor],
                    ['Liberado por', datos.liberadoPor],
                    ['Versión', datos.version],
                    ['Fecha de emisión', datos.fechaEmision],
                    ['Página', datos.pagina],
                    ['Código', datos.codigo]
                ];

                document.getElementById('tablaDatosOficiales').innerHTML = filasOficiales.map(f => `
                    <tr>
                        <th>${escapeHtml(f[0])}</th>
                        <td>${escapeHtml(f[1] || 'N/A')}</td>
                    </tr>
                `).join('');

                const campos = data.campos || [];

                document.getElementById('tablaCampos').innerHTML = campos.length === 0
                    ? '<tr><td colspan="4">Sin campos configurados.</td></tr>'
                    : campos.map(c => `
                        <tr>
                            <td>${escapeHtml(c.etiqueta || '')}</td>
                            <td>${escapeHtml(c.clave || '')}</td>
                            <td>${escapeHtml(c.tipo || '')}</td>
                            <td>${c.obligatorio ? 'Sí' : 'No'}</td>
                        </tr>
                    `).join('');

                document.getElementById('modalContenido').classList.add('show');
            } catch (error) {
                alert('No se pudo cargar el contenido.');
            }
        }

        function cerrarContenido() {
            const modal = document.getElementById('modalContenido');
            if (modal) modal.classList.remove('show');
        }
    </script>
}
