@using Microsoft.AspNetCore.Http
@model List<ProyectoMatrix.ViewModels.Formularios.FormularioPlantillaViewModel>

@functions {
    private static bool ContieneLogistica(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
        {
            return false;
        }

        var texto = valor.Trim().ToLowerInvariant()
            .Replace("á", "a")
            .Replace("é", "e")
            .Replace("í", "i")
            .Replace("ó", "o")
            .Replace("ú", "u");

        return texto.Contains("logistica");
    }
}

@{
    Layout = null;
    ViewData["Title"] = "Formularios Logística";

    var origenModulo = Context.Request.Query["origenModulo"].ToString();

    if (string.IsNullOrWhiteSpace(origenModulo))
    {
        var referer = Context.Request.Headers["Referer"].ToString();

        if (!string.IsNullOrWhiteSpace(referer) &&
            referer.Contains("/Logistica/Guias", StringComparison.OrdinalIgnoreCase))
        {
            origenModulo = "Guias";
        }
        else if (!string.IsNullOrWhiteSpace(referer) &&
                 referer.Contains("/Logistica/Transporte", StringComparison.OrdinalIgnoreCase))
        {
            origenModulo = "Transporte";
        }
    }

    var volverUrl = "/Logistica/Transporte";

    if (string.Equals(origenModulo, "Guias", StringComparison.OrdinalIgnoreCase))
    {
        volverUrl = "/Logistica/Guias";
    }
    else if (string.Equals(origenModulo, "Transporte", StringComparison.OrdinalIgnoreCase))
    {
        volverUrl = "/Logistica/Transporte";
    }

    var origenQuery = string.IsNullOrWhiteSpace(origenModulo)
        ? string.Empty
        : "?origenModulo=" + Uri.EscapeDataString(origenModulo);

    var crearFormularioUrl = "/Logistica/Formularios/Crear" + origenQuery;

    var esUsuarioLogistica = false;
    var valorDesdeController = ViewBag.EsUsuarioLogistica?.ToString();

    if (!string.IsNullOrWhiteSpace(valorDesdeController))
    {
        esUsuarioLogistica = valorDesdeController.Equals("true", StringComparison.OrdinalIgnoreCase);
    }
    else
    {
        esUsuarioLogistica =
            User.IsInRole("Logistica") ||
            User.IsInRole("Logística") ||
            User.IsInRole("Administrador") ||
            ContieneLogistica(Context.Session.GetString("Rol")) ||
            ContieneLogistica(Context.Session.GetString("RolUsuario")) ||
            ContieneLogistica(Context.Session.GetString("TipoUsuario")) ||
            ContieneLogistica(Context.Session.GetString("Area")) ||
            ContieneLogistica(Context.Session.GetString("AreaNombre")) ||
            ContieneLogistica(Context.Session.GetString("Departamento")) ||
            ContieneLogistica(Context.Session.GetString("DepartamentoNombre"));
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Formularios Logística</title>

    <style>
        :root {
            --ns-primary: #062b55;
            --ns-primary-dark: #041f3f;
            --ns-accent: #e85d04;
            --ns-accent-dark: #c94f03;
            --ns-bg: #f3f6fb;
            --ns-card: #ffffff;
            --ns-border: #e2e8f0;
            --ns-muted: #64748b;
            --ns-text: #0f172a;
            --ns-soft-blue: #eff6ff;
            --ns-danger-bg: #fee2e2;
            --ns-danger-text: #991b1b;
            --ns-success-bg: #dcfce7;
            --ns-success-text: #166534;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Segoe UI", Arial, sans-serif;
            background: var(--ns-bg);
            color: var(--ns-text);
        }

        .page {
            min-height: 100vh;
            padding: 26px;
            background: radial-gradient(circle at top right, rgba(6, 43, 85, .08), transparent 30%), var(--ns-bg);
        }

        .formularios-hero {
            background: linear-gradient(135deg, var(--ns-primary), var(--ns-primary-dark));
            color: white;
            border-radius: 18px;
            padding: 28px 32px;
            margin-bottom: 22px;
            box-shadow: 0 16px 35px rgba(15, 23, 42, .14);
            position: relative;
            overflow: hidden;
        }

        .formularios-hero::after {
            content: "";
            position: absolute;
            right: 36px;
            top: 50%;
            transform: translateY(-50%);
            width: 92px;
            height: 92px;
            border-radius: 24px;
            background: rgba(255,255,255,.10);
        }

        .formularios-hero h1 {
            margin: 0;
            font-size: 32px;
            font-weight: 900;
            letter-spacing: -.5px;
        }

        .formularios-hero p {
            margin: 8px 0 0;
            color: rgba(255,255,255,.78);
            font-size: 15px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
        }

        .page-title {
            margin: 0;
            font-size: 24px;
            font-weight: 900;
            color: var(--ns-text);
        }

        .page-subtitle {
            color: var(--ns-muted);
            font-size: 14px;
            margin-top: 5px;
        }

        .header-actions {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn {
            border: 0;
            border-radius: 12px;
            padding: 10px 15px;
            font-weight: 800;
            font-size: 13px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            transition: all .18s ease;
            white-space: nowrap;
            line-height: 1;
        }

        .btn-primary {
            background: var(--ns-accent);
            color: white;
            box-shadow: 0 8px 18px rgba(232, 93, 4, .22);
        }

        .btn-primary:hover {
            background: var(--ns-accent-dark);
            color: white;
            transform: translateY(-1px);
        }

        .btn-secondary {
            background: #e5e7eb;
            color: #111827;
        }

        .btn-secondary:hover {
            background: #d1d5db;
            color: #111827;
        }

        .btn-outline {
            background: white;
            color: var(--ns-primary);
            border: 1px solid #bfdbfe;
        }

        .btn-outline:hover {
            background: var(--ns-soft-blue);
        }

        .alert-info-custom {
            background: white;
            border: 1px solid var(--ns-border);
            border-left: 4px solid #2563eb;
            color: #334155;
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 16px;
            box-shadow: 0 8px 18px rgba(15, 23, 42, .04);
        }

        .alert-success,
        .alert-success-custom {
            background: var(--ns-success-bg);
            color: var(--ns-success-text);
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 16px;
            font-weight: 800;
        }

        .alert-error,
        .alert-error-custom {
            background: var(--ns-danger-bg);
            color: var(--ns-danger-text);
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 16px;
            font-weight: 800;
        }

        .formularios-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(255px, 1fr));
            gap: 16px;
        }

        .form-card {
            background: white;
            border: 1px solid var(--ns-border);
            border-radius: 18px;
            padding: 18px;
            box-shadow: 0 12px 24px rgba(15, 23, 42, .06);
            transition: all .18s ease;
        }

        .form-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 30px rgba(15, 23, 42, .10);
        }

        .form-card-title {
            font-size: 17px;
            font-weight: 900;
            color: var(--ns-text);
            margin: 0 0 8px;
        }

        .form-card-desc {
            color: var(--ns-muted);
            font-size: 13px;
            min-height: 42px;
            margin: 0 0 12px;
            line-height: 1.35;
        }

        .form-badges {
            display: flex;
            gap: 7px;
            flex-wrap: wrap;
            margin: 12px 0 16px;
        }

        .badge {
            background: #eef2ff;
            color: #3730a3;
            padding: 5px 9px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 800;
        }

        .badge-muted {
            background: #f1f5f9;
            color: #475569;
        }

        .form-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .empty-state {
            background: white;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
            padding: 42px;
            text-align: center;
            color: var(--ns-muted);
        }

        .empty-state h3 {
            color: var(--ns-text);
            margin-top: 0;
        }

        .modal-view-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, .55);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 20px;
        }

        .modal-view-overlay.active { display: flex; }

        .modal-view-card {
            background: white;
            width: min(820px, 96vw);
            max-height: 86vh;
            overflow: auto;
            border-radius: 18px;
            box-shadow: 0 24px 60px rgba(0,0,0,.25);
        }

        .modal-view-header {
            background: linear-gradient(135deg, var(--ns-primary), var(--ns-primary-dark));
            color: white;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 14px;
        }

        .modal-view-header h3 {
            margin: 0;
            font-size: 18px;
            font-weight: 900;
        }

        .modal-view-header p {
            margin: 6px 0 0;
            color: rgba(255,255,255,.78);
            font-size: 13px;
        }

        .modal-view-close {
            background: rgba(255,255,255,.12);
            border: 0;
            color: white;
            border-radius: 10px;
            padding: 8px 10px;
            cursor: pointer;
            font-weight: 900;
        }

        .modal-view-body { padding: 20px; }

        .fields-table {
            width: 100%;
            border-collapse: collapse;
        }

        .fields-table th {
            text-align: left;
            font-size: 11px;
            color: var(--ns-muted);
            text-transform: uppercase;
            padding: 10px;
            background: #f8fafc;
            border-bottom: 1px solid var(--ns-border);
        }

        .fields-table td {
            padding: 11px 10px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 13px;
            color: #334155;
        }

        .required-text {
            color: #b91c1c;
            font-weight: 900;
        }

        @@media(max-width: 900px) {
            .page { padding: 16px; }
            .formularios-hero { padding: 24px; }
            .formularios-hero::after { display: none; }
            .page-header { flex-direction: column; }
            .header-actions { justify-content: stretch; width: 100%; }
            .btn { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="formularios-hero">
            <h1>Formularios de logística</h1>
            <p>Administra cuestionarios adicionales para Guías y Transporte.</p>
        </div>

        <div class="page-header">
            <div>
                <h2 class="page-title">Cuestionarios disponibles</h2>
                <div class="page-subtitle">
                    Estos formularios se agregan como complemento al crear una Guía o Solicitud de Transporte.
                </div>
            </div>

            <div class="header-actions">
                <a class="btn btn-secondary" href="@volverUrl">Volver</a>

                @if (esUsuarioLogistica)
                {
                    <a class="btn btn-primary" href="@crearFormularioUrl">Crear formulario</a>
                }
            </div>
        </div>

        @if (!esUsuarioLogistica)
        {
            <div class="alert-info-custom">
                Estás en modo consulta. Puedes revisar el contenido de los formularios, pero solo logística puede crear o editar plantillas.
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert-error">@TempData["Error"]</div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <h3>No hay cuestionarios disponibles</h3>
                @if (esUsuarioLogistica)
                {
                    <p>Crea el primer formulario adicional para poder seleccionarlo desde Guías o Transporte.</p>
                }
                else
                {
                    <p>Por el momento no hay formularios publicados para consulta.</p>
                }
            </div>
        }
        else
        {
            <div class="formularios-grid">
                @foreach (var formulario in Model)
                {
                    var modalId = $"modal-formulario-{formulario.IdFormulario}";
                    var categoria = string.IsNullOrWhiteSpace(formulario.Categoria) ? "General" : formulario.Categoria;
                    var descripcion = string.IsNullOrWhiteSpace(formulario.Descripcion) ? "Sin descripción registrada." : formulario.Descripcion;
                    var editarUrl = $"/Logistica/Formularios/Editar/{formulario.IdFormulario}{origenQuery}";

                    <div class="form-card">
                        <h3 class="form-card-title">@formulario.Nombre</h3>
                        <p class="form-card-desc">@descripcion</p>

                        <div class="form-badges">
                            <span class="badge">@categoria</span>
                            <span class="badge">@formulario.Campos.Count campos</span>
                            @if (!esUsuarioLogistica)
                            {
                                <span class="badge badge-muted">Solo consulta</span>
                            }
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn btn-outline" onclick="abrirModalFormulario('@modalId')">
                                Ver contenido
                            </button>

                            @if (esUsuarioLogistica)
                            {
                                <a class="btn btn-primary" href="@editarUrl">Editar</a>
                            }
                        </div>
                    </div>

                    <div class="modal-view-overlay" id="@modalId" aria-hidden="true">
                        <div class="modal-view-card" role="dialog" aria-modal="true" aria-labelledby="@($"{modalId}-title")">
                            <div class="modal-view-header">
                                <div>
                                    <h3 id="@($"{modalId}-title")">@formulario.Nombre</h3>
                                    <p>@descripcion</p>
                                </div>
                                <button type="button" class="modal-view-close" onclick="cerrarModalFormulario('@modalId')">Cerrar</button>
                            </div>

                            <div class="modal-view-body">
                                @if (formulario.Campos == null || !formulario.Campos.Any())
                                {
                                    <div class="empty-state" style="padding:24px;">
                                        Este formulario todavía no tiene campos configurados.
                                    </div>
                                }
                                else
                                {
                                    <table class="fields-table">
                                        <thead>
                                            <tr>
                                                <th>Etiqueta</th>
                                                <th>Clave interna</th>
                                                <th>Tipo</th>
                                                <th>Obligatorio</th>
                                                <th>Copiable</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var campo in formulario.Campos)
                                            {
                                                <tr>
                                                    <td>@campo.Etiqueta</td>
                                                    <td>@campo.Clave</td>
                                                    <td>@campo.Tipo</td>
                                                    <td>
                                                        @if (campo.Obligatorio)
                                                        {
                                                            <span class="required-text">Sí</span>
                                                        }
                                                        else
                                                        {
                                                            <span>No</span>
                                                        }
                                                    </td>
                                                    <td>@(campo.Copiable ? "Sí" : "No")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <script>
        function abrirModalFormulario(id) {
            const modal = document.getElementById(id);
            if (!modal) return;

            modal.classList.add('active');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function cerrarModalFormulario(id) {
            const modal = document.getElementById(id);
            if (!modal) return;

            modal.classList.remove('active');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        document.addEventListener('click', function (event) {
            if (event.target.classList && event.target.classList.contains('modal-view-overlay')) {
                cerrarModalFormulario(event.target.id);
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                document.querySelectorAll('.modal-view-overlay.active').forEach(modal => cerrarModalFormulario(modal.id));
            }
        });
    </script>
</body>
</html>
