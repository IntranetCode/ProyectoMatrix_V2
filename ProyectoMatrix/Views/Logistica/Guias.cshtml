@model IEnumerable<ProyectoMatrix.Models.Guia>
@{
    ViewData["Title"] = "Gestión de Guías y Paquetería";
    Layout = "_LayoutComunicados";

    bool esLogistica = ViewBag.EsLogistica ?? false;
    var dicUsuarios = ViewBag.UsuariosIntranet as Dictionary<int, string>;
    var empresasGuias = ViewBag.EmpresasGuias as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    string? currentUserIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    int currentUserId = string.IsNullOrEmpty(currentUserIdStr) ? 1 : int.Parse(currentUserIdStr);

    var activas = Model?.Where(x => x != null && !x.EstaBorrado && x.EstadoEdicion != "Pendiente").ToList() ?? new List<ProyectoMatrix.Models.Guia>();
    var pendientes = Model?.Where(x => x != null && !x.EstaBorrado && x.EstadoEdicion == "Pendiente").ToList() ?? new List<ProyectoMatrix.Models.Guia>();
    var canceladas = Model?.Where(x => x != null && x.EstaBorrado).ToList() ?? new List<ProyectoMatrix.Models.Guia>();

    decimal gastoTotal = activas.Sum(x => x.Costo);
    int frias = activas.Count(x => x.RequiereCadenaFrio == true);
}

<style>
