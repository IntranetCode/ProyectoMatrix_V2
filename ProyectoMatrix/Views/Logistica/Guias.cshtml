<div class="guias-layout-shell fade-in-up" id="inicioPagina">
    <aside class="guias-side-menu" aria-label="Menu lateral de guías">
        <div class="side-brand">
            <div class="side-brand-mark">NS</div>
            <div>
                <div class="side-brand-name">NS EQUIPO</div>
                <div class="side-brand-subtitle">Intranet Corporativa</div>
            </div>
        </div>

        <button type="button" class="side-new-guide" onclick="abrirModalCrear()">
            <i class="fas fa-paper-plane"></i> Nueva Guía
        </button>

        <nav class="side-nav">
            <div class="side-nav-title">Menu principal</div>
            <a href="/Menu/Grupo/5" class="side-link">
                <i class="fas fa-th-large"></i><span>Menu</span>
            </a>
            <button type="button" class="side-link active" onclick="document.getElementById('inicioPagina').scrollIntoView({ behavior: 'smooth' });">
                <i class="fas fa-map"></i><span>Logística Guías</span>
            </button>
            <a href="/Logistica/Transporte" class="side-link">
                <i class="fas fa-truck"></i><span>Logística Transporte</span>
            </a>
            @if (esLogistica)
            {
                <button type="button" class="side-link" onclick="abrirModalDashboard()">
                    <i class="fas fa-chart-bar"></i><span>Reportes</span>
                </button>
            }
            <button type="button" class="side-link" disabled title="Repositorio para los formularios que se integren al módulo">
                <i class="fas fa-clipboard-list"></i><span>Formularios</span>
            </button>

            <div class="side-nav-title mt-3">Flujo de guías</div>
            <button type="button" class="side-link side-subitem guias-flow-link active" data-target="seccionActivas" onclick="mostrarSeccionGuias('seccionActivas')">
                <i class="fas fa-barcode"></i><span>Activas</span><span class="side-count">@activas.Count</span>
            </button>
            @if (esLogistica)
            {
                <button type="button" class="side-link side-subitem guias-flow-link" data-target="seccionPendientes" onclick="mostrarSeccionGuias('seccionPendientes')">
                    <i class="fas fa-clock"></i><span>Validación</span><span class="side-count">@pendientes.Count</span>
                </button>
            }
            <button type="button" class="side-link side-subitem guias-flow-link" data-target="seccionCadenaFrio" onclick="mostrarSeccionGuias('seccionCadenaFrio')">
                <i class="fas fa-snowflake"></i><span>Cadena frío</span><span class="side-count">@frias</span>
            </button>
            @if (esLogistica)
            {
                <button type="button" class="side-link side-subitem guias-flow-link" data-target="seccionCanceladas" onclick="mostrarSeccionGuias('seccionCanceladas')">
                    <i class="fas fa-ban"></i><span>Canceladas</span><span class="side-count">@canceladas.Count</span>
                </button>
            }
        </nav>
    </aside>

    <main class="guias-page-shell">
        <div class="guias-top-row">
            <div class="page-back-zone">
                <a href="/Menu/Grupo/5" class="page-back-btn logistica-back-btn">
                    <i class="fas fa-arrow-left"></i> Regresar
                </a>
            </div>

            @if (esLogistica)
            {
                <div class="guias-top-actions">
                    <a href="/Logistica/DescargarReporteGuiasPDF" target="_blank" class="hero-action-btn hero-action-pdf" title="Descargar PDF">
                        <i class="fas fa-file-pdf"></i> PDF
                    </a>
                    <a href="/Logistica/DescargarReporteGuiasExcel" target="_blank" class="hero-action-btn hero-action-excel" title="Descargar Excel">
                        <i class="fas fa-file-excel"></i> Excel
                    </a>
                    <button class="hero-action-btn hero-action-stats" onclick="abrirModalDashboard()" title="Dashboard de gastos">
                        <i class="fas fa-chart-line"></i> Gastos
                    </button>
                </div>
            }
        </div>

        <section class="guias-hero mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg-8">
                    <div class="d-flex align-items-center gap-3">
                        <div class="metric-icon fs-4"><i class="fas fa-box-open"></i></div>
                        <div>
                            <div class="small text-uppercase opacity-75 fw-bold" style="letter-spacing:.14em;">Paquetería externa</div>
                            <h2 class="fw-bold mb-1">Guías y Envíos</h2>
                            <p class="mb-0 opacity-75">Bandeja de guías, validación de cambios, cadena de frío y auditoría de cancelaciones.</p>
                            <div class="mt-3 d-flex flex-wrap gap-2">
                                <span class="hero-chip"><i class="fas fa-barcode"></i> Tracking interno</span>
                                <span class="hero-chip"><i class="fas fa-snowflake"></i> Cadena de frío</span>
                                <span class="hero-chip"><i class="fas fa-chart-column"></i> Gastos logísticos</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    <div id="seccionActivas" data-section="seccionActivas" class="section-shell mb-5 seccion-filtrable seccion-activa">
        <div class="section-toolbar">
            <h5 class="section-title-line" style="color:#0e7490;"><i class="fas fa-barcode me-2"></i> Guías activas</h5>
            <div class="search-module-box">
                <i class="fas fa-search"></i>
                <input type="text" class="busqueda-guias" data-target="#seccionActivas" placeholder="Buscar guía, origen, destino, usuario...">
            </div>
        </div>
        <div class="empty-search-message" data-empty-for="#seccionActivas">
            <i class="fas fa-magnifying-glass me-1"></i> No se encontraron guías activas con esa búsqueda.
        </div>

        @if (activas.Any())
        {
            <div class="guia-grid">
                @foreach (var item in activas)
                {
                    string nombreCreador = dicUsuarios != null && dicUsuarios.ContainsKey(item.UsuarioID) ? dicUsuarios[item.UsuarioID] : "N/A";
                    <article class="guia-card">
                        <div class="guia-card-body">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                <span class="tracking-badge"><i class="fas fa-barcode"></i> GU-@item.IdGuia</span>
                                <span class="status-chip chip-active"><i class="fas fa-check-circle"></i> Activa</span>
                            </div>

                            <div class="route-line">
                                <div class="route-box">
                                    <div class="route-label">Origen</div>
                                    <div class="route-value">@(item.Empresa ?? "N/A")</div>
                                    <div class="small text-muted">CP @(item.CodigoPostalOrigen ?? "N/A")</div>
                                </div>
                                <div class="route-arrow"><i class="fas fa-arrow-right-long"></i></div>
                                <div class="route-box">
                                    <div class="route-label">Destino</div>
                                    <div class="route-value">@(item.DestinatarioNombre ?? "N/A")</div>
                                    <div class="small text-muted">CP @(item.CodigoPostalDestino ?? "N/A")</div>
                                </div>
                            </div>

                            <div class="quick-tags">
                                <span class="quick-tag"><i class="fas fa-truck text-info"></i> @(item.TipoEnvio ?? "Sin servicio")</span>
                                <span class="quick-tag"><i class="fas fa-user text-secondary"></i> @nombreCreador</span>
                                @if (item.RequiereCadenaFrio == true)
                                {
                                    <span class="quick-tag"><i class="fas fa-snowflake text-primary"></i> Cadena frío</span>
                                }
                                @if (esLogistica)
                                {
                                    <span class="quick-tag"><i class="fas fa-dollar-sign text-danger"></i> @item.Costo.ToString("C")</span>
                                }
                            </div>
                            @if(esLogistica){
                            <div class="actions-panel">
                                <button class="btn btn-sm btn-soft-primary rounded-pill" onclick="abrirModalVer(@item.IdGuia)"><i class="fas fa-eye me-1"></i> Ver</button>
                                <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="abrirModalEditar(@item.IdGuia)"><i class="fas fa-pen me-1"></i> Editar</button>
                                <button class="btn btn-sm btn-soft-danger rounded-pill" onclick="abrirModalBorrar(@item.IdGuia)"><i class="fas fa-trash me-1"></i> Cancelar</button>
                            </div>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="section-empty"><i class="fas fa-box-open fa-2x mb-3 text-info"></i><div class="fw-bold mb-1">No hay guías activas</div><div>Cuando se creen solicitudes de guía, aparecerán aquí.</div></div>
        }
    </div>


    <div id="seccionCadenaFrio" data-section="seccionCadenaFrio" class="section-shell mb-5 seccion-filtrable">
        <div class="section-toolbar">
            <h5 class="section-title-line" style="color:#2563eb;"><i class="fas fa-snowflake me-2"></i> Guías con cadena de frío</h5>
            <div class="search-module-box">
                <i class="fas fa-search"></i>
                <input type="text" class="busqueda-guias" data-target="#seccionCadenaFrio" placeholder="Buscar guía, origen, destino, servicio...">
            </div>
        </div>
        <div class="empty-search-message" data-empty-for="#seccionCadenaFrio">
            <i class="fas fa-magnifying-glass me-1"></i> No se encontraron guías con cadena de frío.
        </div>

        @{
            var guiasCadenaFrio = activas.Where(x => x.RequiereCadenaFrio == true).ToList();
        }

        @if (guiasCadenaFrio.Any())
        {
            <div class="guia-grid">
                @foreach (var item in guiasCadenaFrio)
                {
                    string nombreCreador = dicUsuarios != null && dicUsuarios.ContainsKey(item.UsuarioID) ? dicUsuarios[item.UsuarioID] : "N/A";
                    <article class="guia-card">
                        <div class="guia-card-body">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                <span class="tracking-badge"><i class="fas fa-snowflake"></i> GU-@item.IdGuia</span>
                                <span class="status-chip chip-active"><i class="fas fa-temperature-low"></i> Cadena frío</span>
                            </div>

                            <div class="route-line">
                                <div class="route-box">
                                    <div class="route-label">Origen</div>
                                    <div class="route-value">@(item.Empresa ?? "N/A")</div>
                                    <div class="small text-muted">CP @(item.CodigoPostalOrigen ?? "N/A")</div>
                                </div>
                                <div class="route-arrow"><i class="fas fa-arrow-right-long"></i></div>
                                <div class="route-box">
                                    <div class="route-label">Destino</div>
                                    <div class="route-value">@(item.DestinatarioNombre ?? "N/A")</div>
                                    <div class="small text-muted">CP @(item.CodigoPostalDestino ?? "N/A")</div>
                                </div>
                            </div>

                            <div class="quick-tags">
                                <span class="quick-tag"><i class="fas fa-truck text-info"></i> @(item.TipoEnvio ?? "Sin servicio")</span>
                                <span class="quick-tag"><i class="fas fa-user text-secondary"></i> @nombreCreador</span>
                                <span class="quick-tag"><i class="fas fa-snowflake text-primary"></i> Cadena frío</span>
                                @if (esLogistica)
                                {
                                    <span class="quick-tag"><i class="fas fa-dollar-sign text-danger"></i> @item.Costo.ToString("C")</span>
                                }
                            </div>

                            <div class="actions-panel">
                                <button class="btn btn-sm btn-soft-primary rounded-pill" onclick="abrirModalVer(@item.IdGuia)"><i class="fas fa-eye me-1"></i> Ver</button>
                                <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="abrirModalEditar(@item.IdGuia)"><i class="fas fa-pen me-1"></i> Editar</button>
                                <button class="btn btn-sm btn-soft-danger rounded-pill" onclick="abrirModalBorrar(@item.IdGuia)"><i class="fas fa-trash me-1"></i> Cancelar</button>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="section-empty"><i class="fas fa-snowflake fa-2x mb-3 text-primary"></i><div class="fw-bold mb-1">No hay guías con cadena de frío</div><div>Cuando una guía requiera temperatura controlada, aparecerá aquí.</div></div>
        }
    </div>

    @if (esLogistica)
    {
        <div id="seccionPendientes" data-section="seccionPendientes" class="section-shell mb-5 seccion-filtrable">
            <div class="section-toolbar">
                <h5 class="section-title-line" style="color:#b45309;"><i class="fas fa-clipboard-check me-2"></i> Cambios pendientes de validación</h5>
                <div class="search-module-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="busqueda-guias" data-target="#seccionPendientes" placeholder="Buscar guía, empresa, destino, usuario...">
                </div>
            </div>
            <div class="empty-search-message" data-empty-for="#seccionPendientes">
                <i class="fas fa-magnifying-glass me-1"></i> No se encontraron cambios pendientes con esa búsqueda.
            </div>

            @if (pendientes.Any())
            {
                <div class="guia-grid">
                    @foreach (var item in pendientes)
                    {
                        string nombreCreador = dicUsuarios != null && dicUsuarios.ContainsKey(item.UsuarioID) ? dicUsuarios[item.UsuarioID] : "N/A";
                        <article class="guia-card pending">
                            <div class="guia-card-body">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                    <span class="tracking-badge"><i class="fas fa-barcode"></i> GU-@item.IdGuia</span>
                                    <span class="status-chip chip-pending"><i class="fas fa-hourglass-half"></i> Pendiente</span>
                                </div>

                                <div class="route-line">
                                    <div class="route-box">
                                        <div class="route-label">Empresa</div>
                                        <div class="route-value">@(item.Empresa ?? "N/A")</div>
                                    </div>
                                    <div class="route-arrow"><i class="fas fa-arrow-right-long"></i></div>
                                    <div class="route-box">
                                        <div class="route-label">Destino actual</div>
                                        <div class="route-value">@(item.DestinatarioNombre ?? "N/A")</div>
                                    </div>
                                </div>

                                <div class="quick-tags">
                                    <span class="quick-tag"><i class="fas fa-user text-secondary"></i> @nombreCreador</span>
                                    <span class="quick-tag"><i class="fas fa-truck text-warning"></i> @(item.TipoEnvio ?? "Sin servicio")</span>
                                </div>

                                <div class="actions-panel">
                                    <button class="btn btn-sm btn-soft-primary rounded-pill" onclick="verCambiosEdicionGuia(@item.IdGuia)"><i class="fas fa-code-compare me-1"></i> Comparar</button>
                                    <button class="btn btn-sm btn-success rounded-pill" onclick="resolverEdicionGuia(@item.IdGuia, 'Aceptada')"><i class="fas fa-check me-1"></i> Aceptar</button>
                                    <button class="btn btn-sm btn-soft-danger rounded-pill" onclick="resolverEdicionGuia(@item.IdGuia, 'Rechazada')"><i class="fas fa-times me-1"></i> Rechazar</button>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="section-empty"><i class="fas fa-circle-check fa-2x mb-3 text-warning"></i><div class="fw-bold mb-1">No hay cambios pendientes</div><div>Las ediciones por validar aparecerán en esta sección.</div></div>
            }
        </div>

        <div id="seccionCanceladas" data-section="seccionCanceladas" class="section-shell mb-5 seccion-filtrable">
            <div class="section-toolbar">
                <h5 class="section-title-line text-danger"><i class="fas fa-user-shield me-2"></i> Auditoría: guías canceladas</h5>
                <div class="search-module-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="busqueda-guias" data-target="#seccionCanceladas" placeholder="Buscar guía, motivo, usuario...">
                </div>
            </div>
            <div class="empty-search-message" data-empty-for="#seccionCanceladas">
                <i class="fas fa-magnifying-glass me-1"></i> No se encontraron guías canceladas con esa búsqueda.
            </div>

            @if (canceladas.Any())
            {
                <div class="guia-grid">
                    @foreach (var item in canceladas)
                    {
                        string nombreElimino = item.BorradoPor.HasValue && dicUsuarios != null && dicUsuarios.ContainsKey(item.BorradoPor.Value) ? dicUsuarios[item.BorradoPor.Value] : "N/A";
                        <article class="guia-card deleted">
                            <div class="guia-card-body">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                    <span class="tracking-badge"><i class="fas fa-archive"></i> GU-@item.IdGuia</span>
                                    <span class="status-chip chip-deleted"><i class="fas fa-ban"></i> Cancelada</span>
                                </div>

                                <div class="route-box mb-3">
                                    <div class="route-label">Motivo</div>
                                    <div class="route-value">@(item.MotivoBorrado ?? "Sin motivo registrado")</div>
                                    <div class="small text-muted mt-1">@(item.FechaBorrado.HasValue ? item.FechaBorrado.Value.ToString("dd/MM/yyyy HH:mm") : "Sin fecha")</div>
                                </div>

                                <div class="quick-tags">
                                    <span class="quick-tag"><i class="fas fa-user text-secondary"></i> Eliminó: @nombreElimino</span>
                                    <span class="quick-tag"><i class="fas fa-building text-secondary"></i> @(item.Empresa ?? "N/A")</span>
                                </div>

                                <div class="actions-panel">
                                    <button class="btn btn-sm btn-soft-success rounded-pill" onclick="restaurarRegistroAjax(@item.IdGuia, 'Guia')"><i class="fas fa-undo me-1"></i> Restaurar</button>
                                    <button class="btn btn-sm btn-soft-danger rounded-pill" onclick="eliminarGuiaDefinitivo(@item.IdGuia)"><i class="fas fa-trash-alt me-1"></i> Eliminar definitivo</button>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="section-empty"><i class="fas fa-box-open fa-2x mb-3 text-danger"></i><div class="fw-bold mb-1">No hay guías canceladas</div><div>Las cancelaciones aparecerán aquí para auditoría.</div></div>
            }
        </div>
    }
</main>
</div>

<button class="btn-flotante" onclick="abrirModalCrear()"><i class="fas fa-paper-plane me-2"></i> Solicitar Guía</button>

<div class="modal fade" id="modalGuia" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content shadow-lg">
            <div class="modal-header text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-shipping-fast me-2"></i> Solicitud de guía</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <ul class="nav nav-pills flex-wrap justify-content-center gap-2 mb-4" id="pills-tab" role="tablist">
                    <li class="nav-item"><button class="nav-link active" id="tab-general-guia" data-bs-toggle="pill" data-bs-target="#step-general-guia" type="button"><i class="fas fa-sitemap me-1"></i> 1. General</button></li>
                    <li class="nav-item"><button class="nav-link" id="tab-remitente" data-bs-toggle="pill" data-bs-target="#step-remitente" type="button"><i class="fas fa-building me-1"></i> 2. Remitente</button></li>
                    <li class="nav-item"><button class="nav-link" id="tab-destinatario" data-bs-toggle="pill" data-bs-target="#step-destinatario" type="button"><i class="fas fa-user-tag me-1"></i> 3. Destinatario</button></li>
                    <li class="nav-item"><button class="nav-link" id="tab-paquete" data-bs-toggle="pill" data-bs-target="#step-paquete" type="button"><i class="fas fa-box me-1"></i> 4. Envío</button></li>
                    <li class="nav-item"><button class="nav-link" id="tab-servicio" data-bs-toggle="pill" data-bs-target="#step-servicio" type="button"><i class="fas fa-check-circle me-1"></i> 5. Confirmación</button></li>
                </ul>

                <form id="formGuia">
                    <input type="hidden" id="IdGuia" name="IdGuia" value="0" />
                    <input type="hidden" id="Departamento" name="Departamento" value="" />

                    <div class="tab-content bg-white p-4 rounded-3 border shadow-sm wizard-content">
                        <div class="tab-pane fade show active" id="step-general-guia">
                            <h6 class="form-section-title">Datos generales</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required">Empresa solicitante</label>
                                    <select class="form-select" id="Empresa" name="Empresa" required>
                                        <option value="">Seleccione...</option>
                                        @if (empresasGuias.Any())
                                        {
                                            foreach (var empresa in empresasGuias)
                                            {
                                                <option value="@empresa.Value">@empresa.Text</option>
                                            }
                                        }
                                        else
                                        {
                                            <option value="NS Equipo">NS Equipo</option>
                                            <option value="NS Multiservicios">NS Multiservicios</option>
                                            <option value="NS Corporativo">NS Corporativo</option>
                                        }
                                    </select>
                                    <div class="form-text">Se carga directamente desde la tabla Empresas.</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required">Nombre del cliente / proyecto</label>
                                    <input type="text" class="form-control" id="ClienteProyecto" name="ClienteProyecto" required>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required">¿Quién gestiona la recolección / entrega?</label>
                                    <div class="d-flex gap-3 flex-wrap mt-2">
                                        <div class="form-check">
                                            <input class="form-check-input flujo-guia" type="radio" name="QuienGestiona" id="QuienGestionaLogistica" value="Logistica" required>
                                            <label class="form-check-label fw-semibold" for="QuienGestionaLogistica">Logística</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input flujo-guia" type="radio" name="QuienGestiona" id="QuienGestionaUsuario" value="Usuario" required>
                                            <label class="form-check-label fw-semibold" for="QuienGestionaUsuario">Usuario</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold required">Tipo de requerimiento</label>
                                    <select class="form-select flujo-guia" id="TipoRequerimiento" name="TipoRequerimiento" required>
                                        <option value="">Seleccione...</option>
                                        <option value="Envio de paquete" data-gestor="Logistica">Envío de paquete</option>
                                        <option value="Recoleccion" data-gestor="Logistica">Recolección</option>
                                        <option value="Solicitud de guia" data-gestor="Usuario">Solicitud de guía</option>
                                    </select>
                                    <div class="form-text">Si gestiona Usuario, se toma como Solicitud de guía.</div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold required">Fecha de envío</label>
                                    <input type="date" class="form-control" id="FechaEnvio" name="FechaEnvio" required>
                                </div>

                                <div class="col-12 text-end mt-4">
                                    <button type="button" class="btn text-white px-4 rounded-pill shadow" style="background:linear-gradient(135deg,var(--g-cyan),var(--g-blue));" onclick="validarPestana('step-general-guia', 'tab-remitente')">Siguiente <i class="fas fa-arrow-right ms-1"></i></button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-remitente">
                            <h6 class="form-section-title">Remitente y tipo de entrega</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold required">Tipo de entrega</label>
                                    <select class="form-select flujo-guia" id="TipoEntrega" name="TipoEntrega" required>
                                        <option value="">Seleccione...</option>
                                        <option value="Domicilio">Domicilio</option>
                                        <option value="Ocurre">Ocurre</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold required">Nombre del remitente</label>
                                    <input type="text" class="form-control" id="RemitenteNombre" name="RemitenteNombre" required>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Teléfono contacto</label>
                                    <input type="text" class="form-control" id="RemitenteTelefono" name="RemitenteTelefono">
                                </div>

                                <div class="col-md-4 bloque-domicilio">
                                    <label class="form-label fw-semibold required">Dirección del remitente</label>
                                    <select class="form-select flujo-guia" id="DireccionRemitenteTipo" name="DireccionRemitenteTipo">
                                        <option value="">Seleccione...</option>
                                        <option value="Antiguo camino">Antiguo camino</option>
                                        <option value="Lateral via">Lateral vía</option>
                                        <option value="Otro">Otro</option>
                                    </select>
                                </div>

                                <div class="col-md-6 bloque-direccion-otro">
                                    <label class="form-label fw-semibold required">Otra dirección de remitente</label>
                                    <input type="text" class="form-control" id="Origen" name="Origen">
                                </div>

                                <div class="col-md-2 bloque-direccion-otro">
                                    <label class="form-label fw-semibold required">Código postal</label>
                                    <input type="text" class="form-control" id="CodigoPostalOrigen" name="CodigoPostalOrigen">
                                </div>

                                <div class="col-12 alerta-ocurre d-none">
                                    <div class="alert alert-info mb-0">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Para entrega <strong>Ocurre</strong> no se pide dirección de remitente. Solo se registrará el nombre de quien entrega o manda el paquete.
                                    </div>
                                </div>

                                <div class="col-12 d-flex justify-content-between mt-4">
                                    <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-general-guia')"><i class="fas fa-arrow-left me-1"></i> Atrás</button>
                                    <button type="button" class="btn text-white px-4 rounded-pill shadow" style="background:linear-gradient(135deg,var(--g-cyan),var(--g-blue));" onclick="validarPestana('step-remitente', 'tab-destinatario')">Siguiente <i class="fas fa-arrow-right ms-1"></i></button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-destinatario">
                            <h6 class="form-section-title">Destino</h6>
                            <div class="row g-3">
                                <div class="col-md-6"><label class="form-label fw-semibold required">Nombre destinatario</label><input type="text" class="form-control" id="DestinatarioNombre" name="DestinatarioNombre" required></div>
                                <div class="col-md-6"><label class="form-label fw-semibold required">Contacto del destinatario</label><input type="text" class="form-control" id="DestinatarioTelefono" name="DestinatarioTelefono" required></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">Correo electrónico del destinatario</label><input type="email" class="form-control" id="DestinatarioCorreo" name="DestinatarioCorreo"></div>
                                <div class="col-md-6"><label class="form-label fw-semibold required">Código postal destino</label><input type="text" class="form-control" id="CodigoPostalDestino" name="CodigoPostalDestino" required></div>
                                <div class="col-md-12"><label class="form-label fw-semibold required">Dirección del destino</label><input type="text" class="form-control" id="Destino" name="Destino" required></div>
                                <div class="col-12 d-flex justify-content-between mt-4">
                                    <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-remitente')"><i class="fas fa-arrow-left me-1"></i> Atrás</button>
                                    <button type="button" class="btn text-white px-4 rounded-pill shadow" style="background:linear-gradient(135deg,var(--g-cyan),var(--g-blue));" onclick="validarPestana('step-destinatario', 'tab-paquete')">Siguiente <i class="fas fa-arrow-right ms-1"></i></button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-paquete">
                            <h6 class="form-section-title">Tipo de envío y paquete</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold required">Tipo de envío</label>
                                    <select class="form-select flujo-guia" id="TipoEnvio" name="TipoEnvio" required>
                                        <option value="">Seleccione...</option>
                                        <option value="Sobre">Sobre</option>
                                        <option value="Paquete">Paquete</option>
                                        <option value="Tarima">Tarima</option>
                                    </select>
                                </div>

                                <div class="col-md-8">
                                    <label class="form-label fw-semibold required">Contenido del paquete</label>
                                    <input type="text" class="form-control" id="ContenidoDeclarado" name="ContenidoDeclarado" required>
                                </div>

                                <div class="col-md-4 bloque-dimensiones">
                                    <label class="form-label fw-semibold required">Información de dimensiones y peso</label>
                                    <select class="form-select flujo-guia" id="InformacionDimensionesPeso" name="InformacionDimensionesPeso">
                                        <option value="">Seleccione...</option>
                                        <option value="Aproximado">Aproximado</option>
                                        <option value="Real">Real</option>
                                    </select>
                                </div>

                                <div class="col-md-2 bloque-peso">
                                    <label class="form-label fw-semibold required">Peso del paquete (kg)</label>
                                    <input type="number" step="0.01" class="form-control" id="PesoKg" name="PesoKg">
                                </div>

                                <div class="col-md-2 bloque-medidas-real">
                                    <label class="form-label fw-semibold required">Largo (cm)</label>
                                    <input type="number" step="0.01" class="form-control" id="LargoCm" name="LargoCm">
                                </div>

                                <div class="col-md-2 bloque-medidas-real">
                                    <label class="form-label fw-semibold required">Alto (cm)</label>
                                    <input type="number" step="0.01" class="form-control" id="AltoCm" name="AltoCm">
                                </div>

                                <div class="col-md-2 bloque-medidas-real">
                                    <label class="form-label fw-semibold required">Ancho (cm)</label>
                                    <input type="number" step="0.01" class="form-control" id="AnchoCm" name="AnchoCm">
                                </div>

                                <div class="col-12 alerta-sobre d-none">
                                    <div class="alert alert-secondary mb-0">
                                        <i class="fas fa-envelope me-1"></i>
                                        Para <strong>Sobre</strong> solo se solicita el contenido del envío.
                                    </div>
                                </div>

                                <div class="col-12 d-flex justify-content-between mt-4">
                                    <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-destinatario')"><i class="fas fa-arrow-left me-1"></i> Atrás</button>
                                    <button type="button" class="btn text-white px-4 rounded-pill shadow" style="background:linear-gradient(135deg,var(--g-cyan),var(--g-blue));" onclick="validarPestana('step-paquete', 'tab-servicio')">Siguiente <i class="fas fa-arrow-right ms-1"></i></button>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="step-servicio">
                            <h6 class="form-section-title">Confirmación logística</h6>
                            <div class="row g-3">
                                <div class="col-md-6 d-flex align-items-center">
                                    <div class="form-check form-switch mt-3 fs-5">
                                        <input class="form-check-input" type="checkbox" id="RequiereCadenaFrio" name="RequiereCadenaFrio" value="true">
                                        <label class="form-check-label fw-bold text-info" for="RequiereCadenaFrio">Requiere cadena de frío</label>
                                    </div>
                                </div>

                                @if (esLogistica)
                                {
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">Costo logístico</label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" step="0.01" class="form-control" id="Costo" name="Costo" value="0">
                                        </div>
                                    </div>
                                }

                                <div class="col-md-12">
                                    <label class="form-label fw-semibold">Observaciones</label>
                                    <textarea class="form-control" id="Observaciones" name="Observaciones" rows="2"></textarea>
                                </div>

                                <div class="col-12 d-flex justify-content-between mt-5">
                                    <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" onclick="mostrarPaso('tab-paquete')"><i class="fas fa-arrow-left me-1"></i> Atrás</button>
                                    <button type="button" class="btn text-white px-5 shadow rounded-pill" style="background:linear-gradient(135deg,var(--g-orange),#ea580c);" id="btnGuardar" onclick="guardarGuia()">
                                        <i class="fas fa-check-circle me-1" id="iconGuardar"></i>
                                        <span id="txtGuardar">Guardar solicitud</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalVerDetalles" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-receipt me-2"></i> Detalle de guía</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="contenidoDetalles"></div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalBorrar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form action="/Logistica/SolicitarBorrado" method="post">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Cancelar guía</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-secondary fw-semibold">Motivo de la cancelación:</p>
                    <input type="hidden" name="tipo" value="Guia" />
                    <input type="hidden" id="idBorrar" name="id" value="" />
                    <textarea class="form-control" name="motivo" required rows="3"></textarea>
                </div>
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalDashboard" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header text-white modal-costos-header">
                <div>
                    <h5 class="modal-title fw-bold mb-1"><i class="fas fa-chart-line me-2 text-warning"></i> Centro de Gastos de Guías</h5>
                    <div class="small opacity-75">Resumen visual de costos de paquetería externa</div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="cost-kpi">
                            <div class="cost-kpi-label">Gasto total</div>
                            <div class="cost-kpi-value" id="kpiTotalGuias">$0.00</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="cost-kpi">
                            <div class="cost-kpi-label">Guías con costo</div>
                            <div class="cost-kpi-value" id="kpiTotalGuiasOperaciones">0</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="cost-kpi">
                            <div class="cost-kpi-label">Promedio</div>
                            <div class="cost-kpi-value" id="kpiPromedioGuias">$0.00</div>
                        </div>
                    </div>
                </div>

                <div class="chart-shell">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <div>
                            <h6 class="fw-bold mb-0">Gastos de guías</h6>
                            <div class="small text-muted">Comparativo por periodo</div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="generarGraficaFinancieraGuias('Semana')">Semana</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="generarGraficaFinancieraGuias('Mes')">Mes</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="generarGraficaFinancieraGuias('Anio')">Año</button>
                        </div>
                    </div>
                    <div class="chart-container-custom">
                        <canvas id="chartFinanciero"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<button type="button" class="scroll-top-btn" id="btnSubirInicio" title="Subir al inicio">
    <i class="fas fa-arrow-up"></i>
</button>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let miGrafica = null;
        const esLogisticaJS = @esLogistica.ToString().ToLower();

        const NotificacionBurbuja = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 5200,
            timerProgressBar: true
        });

        $(document).ready(function () {
            iniciarRadarGuias();

            @if (!esLogistica && Model != null)
            {
                var notificaciones = Model.Where(x => x.UsuarioID == currentUserId && !x.NotificacionLeida && (x.EstadoEdicion == "Aceptada" || x.EstadoEdicion == "Rechazada")).ToList();
                foreach (var alerta in notificaciones)
                {
                    @:Swal.fire({
                    @:    title: 'Estatus de tu Guía',
                    @:    html: @(System.Text.Json.JsonSerializer.Serialize($"Tu solicitud para la guía <b>GU-{alerta.IdGuia}</b> fue <b>{alerta.EstadoEdicion}</b>.<br><br><i>Dictamen: '{(alerta.MensajeEdicion ?? "Sin comentarios.")}'</i>")),
                    @:    icon: '@(alerta.EstadoEdicion == "Aceptada" ? "success" : "error")',
                    @:    confirmButtonColor: '#164e63'
                    @:}).then(function () { $.post('/Logistica/MarcarAvisoGuiaLeido', { id: @alerta.IdGuia }); });
                }
            }
        });

        function iniciarRadarGuias() {
            if (!esLogisticaJS) return;

            let firmaActual = '@(activas.Count)-@(pendientes.Count)-@(canceladas.Count)';
            setInterval(function () {
                $.get(window.location.href, function (htmlRecibido) {
                    let doc = $(htmlRecibido);
                    let nuevasActivas = doc.find('#seccionActivas .guia-card').length;
                    let nuevasPendientes = doc.find('#seccionPendientes .guia-card').length;
                    let nuevasCanceladas = doc.find('#seccionCanceladas .guia-card').length;
                    let nuevaFirma = `${nuevasActivas}-${nuevasPendientes}-${nuevasCanceladas}`;

                    if (nuevaFirma !== firmaActual) {
                        firmaActual = nuevaFirma;
                        if ($('.modal.show').length > 0) {
                            NotificacionBurbuja.fire({ icon: 'warning', title: 'Radar de guías', text: 'Hay movimientos nuevos en paquetería.' });
                        } else {
                            NotificacionBurbuja.fire({ icon: 'info', title: 'Actualización en guías', text: 'Refrescando panel...' });
                            setTimeout(() => location.reload(), 3000);
                        }
                    }
                });
            }, 15000);
        }

        document.addEventListener('click', function (e) {
            const link = e.target.closest('#tabsFlujoGuias a');
            if (!link) return;
            e.preventDefault();
            mostrarSeccionGuias(link.dataset.target || link.getAttribute('href').replace('#', ''));
        });

        document.addEventListener('click', function (e) {
            const card = e.target.closest('.metric-filter');
            if (!card) return;
            mostrarSeccionGuias(card.dataset.target);
        });

        document.addEventListener('input', function (e) {
            const input = e.target.closest('.busqueda-guias');
            if (!input) return;
            filtrarGuias(input.dataset.target, input.value);
        });

        function mostrarSeccionGuias(targetId) {
            if (!targetId) return;

            document.querySelectorAll('.seccion-filtrable').forEach(sec => {
                sec.classList.toggle('seccion-activa', sec.id === targetId);
            });

            document.querySelectorAll('#tabsFlujoGuias .nav-link').forEach(tab => {
                tab.classList.toggle('active', tab.dataset.target === targetId);
            });

            document.querySelectorAll('.metric-filter').forEach(card => {
                card.classList.toggle('active', card.dataset.target === targetId);
            });

            document.querySelectorAll('.guias-flow-link').forEach(link => {
                link.classList.toggle('active', link.dataset.target === targetId);
            });

            const destino = document.getElementById(targetId);
            if (destino) destino.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function normalizarTextoGuias(valor) {
            return String(valor || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .trim();
        }

        function filtrarGuias(selectorSeccion, texto) {
            const seccion = document.querySelector(selectorSeccion);
            if (!seccion) return;

            const filtro = normalizarTextoGuias(texto);
            const cards = Array.from(seccion.querySelectorAll('.guia-card'));
            let visibles = 0;

            cards.forEach(card => {
                const coincide = normalizarTextoGuias(card.innerText).includes(filtro);
                card.classList.toggle('guia-oculta-busqueda', !coincide);
                if (coincide) visibles++;
            });

            const mensaje = document.querySelector(`[data-empty-for="${selectorSeccion}"]`);
            if (mensaje) mensaje.style.display = visibles === 0 ? 'block' : 'none';
        }


        function setRequiredGuia(selector, requerido) {
            document.querySelectorAll(selector).forEach(el => {
                if (requerido) {
                    el.setAttribute('required', 'required');
                } else {
                    el.removeAttribute('required');
                }
            });
        }

        function mostrarBloqueGuia(selector, mostrar) {
            document.querySelectorAll(selector).forEach(el => {
                el.classList.toggle('d-none', !mostrar);
                el.querySelectorAll('input, select, textarea').forEach(ctrl => {
                    if (!mostrar) {
                        ctrl.removeAttribute('required');
                    }
                });
            });
        }

        function aplicarCondicionesGuia() {
            const gestor = document.querySelector('input[name="QuienGestiona"]:checked')?.value || '';
            const tipoReq = document.getElementById('TipoRequerimiento');
            const tipoEntrega = document.getElementById('TipoEntrega')?.value || '';
            const tipoDireccion = document.getElementById('DireccionRemitenteTipo')?.value || '';
            const tipoEnvio = document.getElementById('TipoEnvio')?.value || '';
            const infoDim = document.getElementById('InformacionDimensionesPeso')?.value || '';

            if (tipoReq) {
                Array.from(tipoReq.options).forEach(op => {
                    if (!op.value) {
                        op.hidden = false;
                        return;
                    }
                    const permitido = !gestor || op.dataset.gestor === gestor;
                    op.hidden = !permitido;
                });

                if (gestor === 'Usuario') {
                    tipoReq.value = 'Solicitud de guia';
                }

                if (gestor === 'Logistica' && tipoReq.value === 'Solicitud de guia') {
                    tipoReq.value = '';
                }
            }

            const esDomicilio = tipoEntrega === 'Domicilio';
            const esOcurre = tipoEntrega === 'Ocurre';
            const esOtro = tipoDireccion === 'Otro';

            mostrarBloqueGuia('.bloque-domicilio', esDomicilio);
            mostrarBloqueGuia('.bloque-direccion-otro', esDomicilio && esOtro);
            document.querySelector('.alerta-ocurre')?.classList.toggle('d-none', !esOcurre);

            setRequiredGuia('#DireccionRemitenteTipo', esDomicilio);
            setRequiredGuia('#Origen, #CodigoPostalOrigen', esDomicilio && esOtro);

            if (esDomicilio && !esOtro && tipoDireccion) {
                document.getElementById('Origen').value = tipoDireccion;
                document.getElementById('CodigoPostalOrigen').value = '';
            }

            if (esOcurre) {
                document.getElementById('DireccionRemitenteTipo').value = '';
                document.getElementById('Origen').value = '';
                document.getElementById('CodigoPostalOrigen').value = '';
            }

            const esSobre = tipoEnvio === 'Sobre';
            const pideDimensiones = tipoEnvio === 'Paquete' || tipoEnvio === 'Tarima';
            const esReal = infoDim === 'Real';
            const esAproximado = infoDim === 'Aproximado';

            document.querySelector('.alerta-sobre')?.classList.toggle('d-none', !esSobre);
            mostrarBloqueGuia('.bloque-dimensiones', pideDimensiones);
            mostrarBloqueGuia('.bloque-peso', pideDimensiones && (esReal || esAproximado));
            mostrarBloqueGuia('.bloque-medidas-real', pideDimensiones && esReal);

            setRequiredGuia('#InformacionDimensionesPeso', pideDimensiones);
            setRequiredGuia('#PesoKg', pideDimensiones && (esReal || esAproximado));
            setRequiredGuia('#LargoCm, #AltoCm, #AnchoCm', pideDimensiones && esReal);

            if (esSobre) {
                document.getElementById('InformacionDimensionesPeso').value = '';
                document.getElementById('PesoKg').value = '';
                document.getElementById('LargoCm').value = '';
                document.getElementById('AltoCm').value = '';
                document.getElementById('AnchoCm').value = '';
            }

            if (pideDimensiones && esAproximado) {
                document.getElementById('LargoCm').value = '';
                document.getElementById('AltoCm').value = '';
                document.getElementById('AnchoCm').value = '';
            }
        }

        document.addEventListener('change', function (e) {
            if (e.target.classList.contains('flujo-guia')) {
                aplicarCondicionesGuia();
            }
        });

        function mostrarPaso(tabId) {
            bootstrap.Tab.getOrCreateInstance(document.getElementById(tabId)).show();
        }

        function validarPestana(idContenedorActual, idSiguientePestana) {
            let contenedor = document.getElementById(idContenedorActual);
            let invalido = contenedor.querySelector(':invalid');
            if (invalido) {
                invalido.reportValidity();
                return;
            }
            mostrarPaso(idSiguientePestana);
        }

        function abrirModalCrear() {
            document.getElementById('formGuia').reset();
            document.getElementById('IdGuia').value = '0';
            restaurarBotonGuardar();
            aplicarCondicionesGuia();
            mostrarPaso('tab-general-guia');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalGuia')).show();
        }

        function abrirModalEditar(id) {
            $.get('/Logistica/ObtenerGuia/' + id, function (data) {
                document.getElementById('formGuia').reset();
                document.getElementById('IdGuia').value = data.idGuia;

                $('#Empresa').val(data.empresa || '');
                $('#ClienteProyecto').val(data.clienteProyecto || '');
                $(`input[name="QuienGestiona"][value="${data.quienGestiona || ''}"]`).prop('checked', true);
                $('#TipoRequerimiento').val(data.tipoRequerimiento || '');
                $('#FechaEnvio').val(data.fechaEnvio ? data.fechaEnvio.substring(0, 10) : '');

                $('#TipoEntrega').val(data.tipoEntrega || '');
                $('#RemitenteNombre').val(data.remitenteNombre || '');
                $('#RemitenteTelefono').val(data.remitenteTelefono || '');
                $('#DireccionRemitenteTipo').val(data.direccionRemitenteTipo || '');
                $('#Origen').val(data.origen || '');
                $('#CodigoPostalOrigen').val(data.codigoPostalOrigen || '');

                $('#DestinatarioNombre').val(data.destinatarioNombre || '');
                $('#DestinatarioTelefono').val(data.destinatarioTelefono || '');
                $('#DestinatarioCorreo').val(data.destinatarioCorreo || '');
                $('#Destino').val(data.destino || '');
                $('#CodigoPostalDestino').val(data.codigoPostalDestino || '');

                $('#TipoEnvio').val(data.tipoEnvio || '');
                $('#InformacionDimensionesPeso').val(data.informacionDimensionesPeso || '');
                $('#PesoKg').val(data.pesoKg || '');
                $('#LargoCm').val(data.largoCm || '');
                $('#AnchoCm').val(data.anchoCm || '');
                $('#AltoCm').val(data.altoCm || '');
                $('#ContenidoDeclarado').val(data.contenidoDeclarado || '');

                document.getElementById('RequiereCadenaFrio').checked = data.requiereCadenaFrio === true;
                $('#Observaciones').val(data.observaciones || '');
                if ($('#Costo').length) $('#Costo').val(data.costo || 0);

                restaurarBotonGuardar();
                aplicarCondicionesGuia();
                mostrarPaso('tab-general-guia');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalGuia')).show();
            });
        }

        function escaparHtml(valor) {
            return String(valor ?? '').replace(/[&<>"']/g, function (m) {
                return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[m];
            });
        }

        function abrirModalVer(id) {
            $.get('/Logistica/ObtenerGuia/' + id, function (d) {
                let frio = d.requiereCadenaFrio ? '<span class="badge bg-info">Sí</span>' : '<span class="badge bg-secondary">No</span>';

                document.getElementById('contenidoDetalles').innerHTML = `
                    <div class="shipping-label mb-3">
                        <div class="row g-3">
                            <div class="col-md-6 border-end">
                                <small class="text-muted fw-bold">REMITENTE</small><br>
                                <strong>${escaparHtml(d.empresa || '')} - ${escaparHtml(d.remitenteNombre || 'N/A')}</strong><br>
                                <strong>Cliente/Proyecto:</strong> ${escaparHtml(d.clienteProyecto || 'N/A')}<br>
                                <strong>Gestión:</strong> ${escaparHtml(d.quienGestiona || 'N/A')} / ${escaparHtml(d.tipoRequerimiento || 'N/A')}<br>
                                <strong>Entrega:</strong> ${escaparHtml(d.tipoEntrega || 'N/A')}<br>
                                ${escaparHtml(d.origen || 'N/A')}<br>
                                CP: ${escaparHtml(d.codigoPostalOrigen || 'N/A')}<br>
                                Tel: ${escaparHtml(d.remitenteTelefono || 'N/A')}
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted fw-bold">DESTINATARIO</small><br>
                                <strong>${escaparHtml(d.destinatarioNombre || 'N/A')}</strong><br>
                                ${escaparHtml(d.destino || 'N/A')}<br>
                                CP: ${escaparHtml(d.codigoPostalDestino || 'N/A')}<br>
                                Tel: ${escaparHtml(d.destinatarioTelefono || 'N/A')}<br>
                                Correo: ${escaparHtml(d.destinatarioCorreo || 'N/A')}
                            </div>
                        </div>
                    </div>
                    <div class="row text-secondary g-3">
                        <div class="col-md-6">
                            <p><strong>Tipo de envío:</strong> ${escaparHtml(d.tipoEnvio || 'N/A')}</p>
                            <p><strong>Dimensiones:</strong> ${escaparHtml(d.informacionDimensionesPeso || 'N/A')} | ${d.pesoKg || 0}kg | ${d.largoCm || 0}x${d.anchoCm || 0}x${d.altoCm || 0}cm</p>
                            <p><strong>Contenido:</strong> ${escaparHtml(d.contenidoDeclarado || 'N/A')}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Fecha envío:</strong> ${d.fechaEnvio ? d.fechaEnvio.substring(0, 10) : 'N/A'}</p>
                            <p><strong>Cadena frío:</strong> ${frio}</p>
                            <p><strong>Observaciones:</strong> ${escaparHtml(d.observaciones || 'N/A')}</p>
                        </div>
                    </div>`;

                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalVerDetalles')).show();
            });
        }

        function guardarGuia() {
            const form = document.getElementById('formGuia');

            if (!form.checkValidity()) {
                const invalido = form.querySelector(':invalid');
                const step = invalido.closest('.tab-pane');
                if (step) {
                    const tab = document.querySelector(`[data-bs-target="#${step.id}"]`);
                    if (tab) bootstrap.Tab.getOrCreateInstance(tab).show();
                    setTimeout(() => invalido.reportValidity(), 200);
                } else {
                    invalido.reportValidity();
                }
                return;
            }

            let btn = document.getElementById('btnGuardar');
            btn.disabled = true;
            document.getElementById('iconGuardar').className = "fas fa-spinner fa-spin me-1";
            document.getElementById('txtGuardar').innerText = "Guardando...";

            document.getElementById('Departamento').value = document.getElementById('Empresa').value || '';
            let datos = new URLSearchParams(new FormData(form));
            datos.set('RequiereCadenaFrio', document.getElementById('RequiereCadenaFrio').checked);

            $.post('/Logistica/GuardarGuiaAjax', datos.toString(), function (res) {
                if (res.success) {
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modalGuia')).hide();
                    location.reload();
                } else {
                    Swal.fire('Error', res.message || 'No se pudo guardar la guía.', 'error');
                    restaurarBotonGuardar();
                }
            }).fail(function () {
                Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
                restaurarBotonGuardar();
            });
        }

        function restaurarBotonGuardar() {
            let btn = document.getElementById('btnGuardar');
            if (btn) btn.disabled = false;

            let icon = document.getElementById('iconGuardar');
            if (icon) icon.className = "fas fa-check-circle me-1";

            let txt = document.getElementById('txtGuardar');
            if (txt) txt.innerText = "Generar Guía";
        }

        function abrirModalBorrar(id) {
            document.getElementById('idBorrar').value = id;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalBorrar')).show();
        }

        function restaurarRegistroAjax(id, tipo) {
            Swal.fire({
                title: 'Restaurar guía',
                text: 'La guía volverá al listado activo.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Restaurar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#16a34a'
            }).then(r => {
                if (!r.isConfirmed) return;
                $.post('/Logistica/RestaurarBorradoAjax', { id: id, tipo: tipo }, function (res) {
                    if (res.success) location.reload();
                    else Swal.fire('Error', res.message || 'No se pudo restaurar.', 'error');
                });
            });
        }

        function eliminarGuiaDefinitivo(id) {
            Swal.fire({
                title: 'Eliminar guía definitivamente',
                text: 'Esta acción eliminará la guía de forma permanente y no podrá restaurarse.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#dc2626'
            }).then(r => {
                if (!r.isConfirmed) return;

                $.post('/Logistica/EliminarGuiaDefinitivo', { id: id }, function (res) {
                    if (res.success) location.reload();
                    else Swal.fire('Error', res.message || 'No se pudo eliminar definitivamente.', 'error');
                }).fail(function () {
                    Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
                });
            });
        }

        function abrirModalDashboard() {
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalDashboard')).show();
            setTimeout(() => generarGraficaFinancieraGuias('Semana'), 300);
        }

        function generarGraficaFinancieraGuias(rango) {
            $.get('/Logistica/ObtenerDatosFinancieros', { rango: rango }, function (data) {
                const ctx = document.getElementById('chartFinanciero').getContext('2d');
                const etiquetas = data.etiquetas || [];
                const datos = data.gastos || data.ingresos || [];

                const total = datos.reduce((acc, val) => acc + Number(val || 0), 0);
                const operaciones = datos.filter(x => Number(x || 0) > 0).length;
                const promedio = operaciones > 0 ? total / operaciones : 0;

                document.getElementById('kpiTotalGuias').innerText = total.toLocaleString('es-MX', { style: 'currency', currency: 'MXN' });
                document.getElementById('kpiTotalGuiasOperaciones').innerText = operaciones;
                document.getElementById('kpiPromedioGuias').innerText = promedio.toLocaleString('es-MX', { style: 'currency', currency: 'MXN' });

                if (miGrafica) miGrafica.destroy();

                const gradient = ctx.createLinearGradient(0, 0, 0, 360);
                gradient.addColorStop(0, 'rgba(6, 182, 212, .95)');
                gradient.addColorStop(.55, 'rgba(37, 99, 235, .75)');
                gradient.addColorStop(1, 'rgba(249, 115, 22, .55)');

                miGrafica = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: etiquetas,
                        datasets: [{
                            label: 'Gasto en guías',
                            data: datos,
                            backgroundColor: gradient,
                            borderColor: 'rgba(15, 23, 42, .85)',
                            borderWidth: 1,
                            borderRadius: 14,
                            borderSkipped: false,
                            maxBarThickness: 58
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: { duration: 900, easing: 'easeOutQuart' },
                        plugins: {
                            legend: {
                                labels: {
                                    color: '#334155',
                                    font: { weight: 'bold' },
                                    usePointStyle: true,
                                    pointStyle: 'rectRounded'
                                }
                            },
                            tooltip: {
                                backgroundColor: '#0f172a',
                                titleColor: '#ffffff',
                                bodyColor: '#e2e8f0',
                                padding: 12,
                                cornerRadius: 12,
                                callbacks: {
                                    label: function (context) {
                                        const value = Number(context.raw || 0);
                                        return ' ' + value.toLocaleString('es-MX', { style: 'currency', currency: 'MXN' });
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: { color: '#64748b', font: { weight: 'bold' } }
                            },
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(148,163,184,.22)' },
                                ticks: {
                                    color: '#64748b',
                                    callback: function (value) {
                                        return '$' + Number(value).toLocaleString('es-MX');
                                    }
                                }
                            }
                        }
                    }
                });
            });
        }

        function verCambiosEdicionGuia(id) {
            $.get('/Logistica/ObtenerDiferenciasGuia?id=' + id, function (res) {
                if (!res.success) {
                    Swal.fire('Error', res.message || 'No se pudieron obtener diferencias.', 'error');
                    return;
                }

                let html = `<div class="table-responsive text-start"><table class="table table-bordered table-sm align-middle"><thead class="table-light"><tr class="text-center"><th>Campo</th><th class="table-danger text-danger">Original</th><th class="table-success text-success">Propuesto</th></tr></thead><tbody>`;

                for (let campo in res.nuevo) {
                    if (['estadoedicion', 'mensajeedicion', 'datosantiguos', 'notificacionleida', 'fecharegistro', 'fechasolicitud'].includes(campo.toLowerCase())) continue;

                    let original = res.viejo[campo];
                    let propuesto = res.nuevo[campo];

                    if (original !== propuesto && !(original == null && propuesto === "")) {
                        html += `<tr><td class="fw-bold text-secondary text-capitalize">${escaparHtml(campo)}</td><td class="text-danger text-decoration-line-through bg-light">${escaparHtml(original || 'Vacío')}</td><td class="text-success fw-bold">${escaparHtml(propuesto || 'Vacío')}</td></tr>`;
                    }
                }

                html += `</tbody></table></div>`;
                Swal.fire({ title: 'Análisis de cambios de guía', html: html, width: '760px', confirmButtonColor: '#164e63' });
            });
        }

        function resolverEdicionGuia(id, resolucion) {
            Swal.fire({
                title: resolucion === 'Aceptada' ? 'Aceptar cambios' : 'Rechazar cambios',
                text: 'Agrega un comentario para el usuario:',
                input: 'textarea',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: resolucion === 'Aceptada' ? 'Aceptar' : 'Rechazar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: resolucion === 'Aceptada' ? '#16a34a' : '#dc2626'
            }).then((result) => {
                if (!result.isConfirmed) return;

                $.post('/Logistica/ResolverEdicionGuia', {
                    id: id,
                    resolucion: resolucion,
                    motivo: result.value || 'Validado.'
                }, function (r) {
                    if (r.success) location.reload();
                    else Swal.fire('Error', r.message || 'No se pudo procesar.', 'error');
                });
            });
        }

        const btnSubirInicio = document.getElementById('btnSubirInicio');

        if (btnSubirInicio) {
            window.addEventListener('scroll', function () {
                btnSubirInicio.classList.toggle('visible', window.scrollY > 520);
            });

            btnSubirInicio.addEventListener('click', function () {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }

    </script>
}
