<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - NS Streaming Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-page">
    <aside class="admin-sidebar" aria-label="Panel de administración">
        <a class="admin-brand" asp-controller="Admin" asp-action="Index">
            <span class="brand-mark">NS</span>
            <span>NS Streaming</span>
        </a>
        <nav class="admin-menu">
            <a asp-controller="StreamingAdmin" asp-action="Index">Transmisiones</a>
            <a asp-controller="StreamingAdmin" asp-action="Create">Agregar</a>
            <a asp-controller="Streaming" asp-action="Index">Vista pública</a>
        </nav>
        <p class="admin-help">El panel es solo para administrar. Los usuarios solo ven el reproductor y el catálogo.</p>
    </aside>

    <main class="admin-main">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
